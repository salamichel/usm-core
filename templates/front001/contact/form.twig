{% extends "base.twig" %}

{% block title %}Nous contacter — USM Volley{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto px-4 py-10">

  <h1 class="text-4xl font-black mb-8 border-b-4 border-black pb-3">Nous contacter</h1>

  {% if flash %}
    {% if flash.type == 'success' %}
      <div class="border-2 border-black p-4 mb-6 shadow-[4px_4px_0_#000] bg-green-100 text-green-800 font-semibold">
        {{ flash.message }}
      </div>
    {% elseif flash.type == 'error' %}
      <div class="border-2 border-black p-4 mb-6 shadow-[4px_4px_0_#000] bg-red-100 text-red-800 font-semibold">
        {{ flash.message }}
      </div>
    {% endif %}
  {% endif %}

  {% if error %}
    <div class="border-2 border-black p-4 mb-6 shadow-[4px_4px_0_#000] bg-red-100 text-red-800 font-semibold">
      {{ error }}
    </div>
  {% endif %}

  <form method="POST" action="{{ url('contact') }}"
        class="bg-white border-4 border-black shadow-[8px_8px_0_#000] p-8 space-y-6">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

    <div>
      <label for="name" class="block font-black mb-2 uppercase text-sm tracking-wide">Nom *</label>
      <input
        type="text"
        id="name"
        name="name"
        value="{{ form_data.name ?? '' }}"
        required
        class="w-full px-4 py-3 border-2 border-black focus:outline-none focus:border-usm-brown bg-amber-50"
      >
    </div>

    <div>
      <label for="phone" class="block font-black mb-2 uppercase text-sm tracking-wide">Téléphone *</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        value="{{ form_data.phone ?? '' }}"
        required
        placeholder="06 00 00 00 00"
        class="w-full px-4 py-3 border-2 border-black focus:outline-none focus:border-usm-brown bg-amber-50"
      >
    </div>

    <div>
      <label for="subject" class="block font-black mb-2 uppercase text-sm tracking-wide">Sujet *</label>
      <select
        id="subject"
        name="subject"
        required
        class="w-full px-4 py-3 border-2 border-black focus:outline-none focus:border-usm-brown bg-amber-50 appearance-none"
      >
        <option value="" disabled {% if not form_data.subject %}selected{% endif %}>— Choisissez un sujet —</option>
        {% set subjects = [
          'Adhésion / Inscription',
          'Tarifs et licences',
          'Informations sur les entraînements',
          'Matchs et compétitions',
          'Partenariat / Sponsor',
          'Bénévolat',
          'Question générale',
          'Autre'
        ] %}
        {% for s in subjects %}
          <option value="{{ s }}" {% if form_data.subject == s %}selected{% endif %}>{{ s }}</option>
        {% endfor %}
      </select>
    </div>

    <div>
      <label for="message" class="block font-black mb-2 uppercase text-sm tracking-wide">Message *</label>
      <textarea
        id="message"
        name="message"
        rows="7"
        required
        class="w-full px-4 py-3 border-2 border-black focus:outline-none focus:border-usm-brown bg-amber-50 resize-none"
      >{{ form_data.message ?? '' }}</textarea>
    </div>

    <div class="pt-2">
      <button
        type="submit"
        class="inline-block border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[6px_6px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all uppercase tracking-wide"
      >
        Envoyer →
      </button>
    </div>
  </form>
</div>
{% endblock %}
