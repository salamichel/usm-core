{% extends 'base.twig' %}
{% block title %}Nos équipes{% if saison %} — {{ saison.libelle }}{% endif %} — USM Volley{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto px-4 py-10">
  <h1 class="text-5xl font-black mb-2">Nos équipes</h1>
  {% if saison %}
    <p class="text-gray-500 font-semibold mb-10">Saison {{ saison.libelle }}</p>
  {% endif %}

  {% if grouped|length %}
    {% for cat, equipes in grouped %}
    <section class="mb-16">
      <h2 class="text-3xl font-black mb-4 border-b-4 border-black pb-3">{{ cat }}</h2>
      {% if categorie_descriptions[cat] is defined and categorie_descriptions[cat].description %}
        <div class="prose mb-8 text-gray-700">
          {{ categorie_descriptions[cat].description|raw }}
        </div>
      {% endif %}

      {% if categorie_descriptions[cat] is defined and (categorie_descriptions[cat].type or categorie_descriptions[cat].hauteur_filet or categorie_descriptions[cat].description_courte) %}
        <div class="mb-8 border-l-4 border-black pl-4 py-2 bg-gray-50 p-4">
          {% if categorie_descriptions[cat].type %}
            <p class="text-sm font-bold text-gray-600 uppercase tracking-wider mb-1">Type</p>
            <p class="text-lg font-black text-gray-900 mb-3">{{ categorie_descriptions[cat].type }}</p>
          {% endif %}
          {% if categorie_descriptions[cat].hauteur_filet %}
            <p class="text-sm font-bold text-gray-600 uppercase tracking-wider mb-1">Hauteur du filet</p>
            <p class="text-lg font-black text-gray-900 mb-3">{{ categorie_descriptions[cat].hauteur_filet }}</p>
          {% endif %}
        </div>
      {% endif %}
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        {% for eq in equipes %}
        <a href="{{ url('equipes/' ~ eq.slug) }}"
           class="border-4 border-black bg-white shadow-[6px_6px_0_#000]
                  hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1
                  transition-all flex flex-col overflow-hidden group">

          {# Photo #}
          {% if eq.cover %}
            <img src="{{ asset('uploads/' ~ eq.cover.filename) }}"
                 alt="{{ eq.libelle }}"
                 class="w-full {{ eq.description_courte ? 'h-48' : 'h-72' }} object-cover transition-transform duration-300 group-hover:scale-105">
          {% else %}
            <div class="w-full {{ eq.description_courte ? 'h-48' : 'h-72' }} bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center text-gray-400 text-5xl">🏐</div>
          {% endif %}

          {% if eq.description_courte %}
          {# Carte enrichie avec description courte #}
          <div class="flex flex-col flex-1 p-5">
            <h3 class="font-black text-lg leading-tight mb-4 border-l-4 border-black pl-3 group-hover:text-amber-700 transition-colors">
              {{ eq.libelle }}
            </h3>
            <div class="border-t-2 border-gray-200 pt-4 mt-auto">
              <p class="text-gray-700 text-sm leading-relaxed italic line-clamp-3">
                {{ eq.description_courte }}
              </p>
            </div>
          </div>
          {% else %}
          {# Carte simple #}
          <div class="p-5">
            <h3 class="font-black text-lg leading-tight group-hover:text-amber-700 transition-colors">{{ eq.libelle }}</h3>
          </div>
          {% endif %}

        </a>
        {% endfor %}
      </div>
    </section>
    {% endfor %}
  {% else %}
    <div class="border-4 border-black bg-white p-8 text-center shadow-[4px_4px_0_#000]">
      <p class="text-gray-500 text-lg">Aucune équipe disponible pour cette saison.</p>
      <p class="text-gray-400 text-sm mt-2">Les équipes apparaissent après le flashage d'une saison active.</p>
    </div>
  {% endif %}
</div>
{% endblock %}
