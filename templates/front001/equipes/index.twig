{% extends 'base.twig' %}
{% block title %}Nos équipes{% if saison %} — {{ saison.libelle }}{% endif %} — USM Volley{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto px-4 py-10">
  <h1 class="text-4xl font-black mb-2">Nos équipes</h1>
  {% if saison %}
    <p class="text-gray-500 font-semibold mb-8">Saison {{ saison.libelle }}</p>
  {% endif %}

  {% if grouped|length %}
    {% for cat, equipes in grouped %}
    <section class="mb-12">
      <h2 class="text-2xl font-black mb-6 border-b-4 border-black pb-2">{{ cat }}</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-5">
        {% for eq in equipes %}
        <a href="{{ url('equipes/' ~ eq.slug) }}"
           class="border-4 border-black bg-white shadow-[4px_4px_0_#000]
                  hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1
                  transition-all block overflow-hidden">
          {% if eq.cover %}
            <img src="{{ asset('uploads/' ~ eq.cover.filename) }}"
                 alt="{{ eq.libelle }}"
                 class="w-full h-40 object-cover">
          {% else %}
            <div class="w-full h-40 bg-gray-100 flex items-center justify-center text-gray-400 text-3xl">🏐</div>
          {% endif %}
          <div class="p-3">
            <h3 class="font-black text-base leading-tight">{{ eq.libelle }}</h3>
          </div>
        </a>
        {% endfor %}
      </div>
    </section>
    {% endfor %}
  {% else %}
    <div class="border-4 border-black bg-white p-8 text-center shadow-[4px_4px_0_#000]">
      <p class="text-gray-500 text-lg">Aucune équipe disponible pour cette saison.</p>
      <p class="text-gray-400 text-sm mt-2">Les équipes apparaissent après le flashage d'une saison active.</p>
    </div>
  {% endif %}
</div>
{% endblock %}
