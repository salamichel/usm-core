{% extends 'base.twig' %}
{% block title %}{{ equipe.libelle }}{% if saison %} — {{ saison.libelle }}{% endif %} — USM Volley{% endblock %}

{% import '_gallery.twig' as components %}
{% import 'agenda/_macros.twig' as agendaMacros %}

{% block content %}
<div class="max-w-5xl mx-auto px-4 py-10">

  {# Breadcrumb #}
  <nav class="text-sm text-gray-500 mb-6">
    <a href="{{ url('/') }}" class="hover:underline">Accueil</a>
    <span class="mx-2">›</span>
    <a href="{{ url('equipes') }}" class="hover:underline">Équipes</a>
    <span class="mx-2">›</span>
    <span class="font-semibold text-gray-800">{{ equipe.libelle }}</span>
  </nav>

  {# Hero section avec photo et infos côte à côte #}
  <section class="mb-12 grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
    {% if cover %}
    <a href="{{ asset('uploads/' ~ cover.filename) }}"
       class="glightbox block border-4 border-black shadow-[6px_6px_0_#000] overflow-hidden
              hover:shadow-[3px_3px_0_#000] transition-all group order-2 md:order-1"
       {% if cover.caption %}data-glightbox="description: {{ cover.caption }}"{% endif %}
       data-gallery="gallery-equipe_saison-cover">
      <img src="{{ asset('uploads/' ~ cover.filename) }}"
           alt="{{ cover.caption ? cover.caption|truncate(125) : 'Photo de couverture' }}"
           loading="eager"
           decoding="async"
           class="w-full h-80 md:h-96 object-cover transition-transform duration-300 group-hover:scale-105">
    </a>
    {% endif %}

    <div class="order-1 md:order-2">
      <h1 class="text-5xl font-black mb-4">{{ equipe.libelle }}</h1>
      <div class="flex flex-wrap gap-3 items-center mb-6">
        <span class="border-4 border-black px-3 py-1.5 text-base font-black bg-amber-100">{{ equipe.categorie }}</span>
        {% if saison %}
          <span class="text-lg font-bold text-gray-600">{{ saison.libelle }}</span>
        {% endif %}
      </div>
      {% if joueurs|length %}
      <p class="text-gray-700 font-semibold text-lg">
        <span class="font-black">{{ joueurs|length }}</span> joueur{{ joueurs|length > 1 ? 's' : '' }}
      </p>
      {% endif %}
    </div>
  </section>

  {% if equipe.description %}
  <section class="mb-10">
    <div class="border-4 border-black bg-white p-6 shadow-[4px_4px_0_#000] prose max-w-none text-gray-800">
      {{ equipe.description|raw }}
    </div>
  </section>
  {% endif %}

  {# Upcoming events for this team — featured section #}
  {% if mini_agenda_events|length %}
  <section class="mt-12 mb-12 bg-gradient-to-br from-amber-50 to-orange-50 border-4 border-black p-6 sm:p-8 shadow-[8px_8px_0_#000]">
    <h2 class="text-3xl font-black mb-2">🗓️ Prochains matchs</h2>
    <p class="text-gray-600 font-semibold mb-6">Calendrier {{ equipe.libelle }}</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {% for event in mini_agenda_events %}
      <div class="bg-white border-4 border-black p-4 hover:shadow-[6px_6px_0_#000] hover:translate-x-0.5 hover:translate-y-0.5 transition-all group">
        <div class="flex justify-between items-start gap-3">
          <div class="flex-1">
            <h3 class="font-black text-base sm:text-lg mb-2 group-hover:text-amber-700 transition-colors">{{ event.titre }}</h3>
            <div class="space-y-1 text-xs sm:text-sm text-gray-600 font-semibold">
              <p>📅 {{ event.date_display }}</p>
              {% if event.time_range %}<p>🕐 {{ event.time_range }}</p>{% endif %}
              <p>📍 {{ event.lieu }}</p>
            </div>
          </div>
          <div class="flex-shrink-0 text-center">
            {{ agendaMacros.render_participation_badge(event.nb_present, event.nb_disponible, event.nb_indisponible) }}
          </div>
        </div>
      </div>
      {% endfor %}
    </div>

    <div class="mt-6 flex gap-4">
      {% if agenda_filter_url %}
      <a href="{{ agenda_filter_url }}" class="flex-1 sm:flex-none inline-block px-5 py-3 bg-black hover:bg-gray-800 text-white font-black rounded transition-colors text-center">
        📋 Agenda complet
      </a>
      {% endif %}
    </div>
  </section>
  {% endif %}

  {# Galerie des autres photos #}
  {{ components.gallery(photos) }}

  {# Liste des joueurs #}
  {% if joueurs|length %}
  <section class="mt-10">
    <h2 class="text-2xl font-black mb-6 border-b-4 border-black pb-2">👥 Effectif ({{ joueurs|length }})</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
      {% for j in joueurs %}
      {%- set isFemale = j.data.Sexe|default('F') == 'F' -%}
      {%- set borderColor = isFemale ? 'border-pink-500' : 'border-blue-500' -%}
      <div class="border-4 {{ borderColor }} bg-white p-4 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-0.5 hover:translate-y-0.5 transition-all">
        <p class="font-black text-base leading-tight">{{ j.prenom }} {{ j.nom }}</p>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# Autres équipes de la même catégorie #}
  {% if otherEquipes|length %}
  <section class="mt-12 mb-12">
    <h2 class="text-2xl font-black mb-6 border-b-4 border-black pb-2">Autres équipes — {{ equipe.categorie }}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for eq in otherEquipes %}
      <a href="{{ url('equipes/' ~ eq.slug) }}" class="group">
        <div class="relative overflow-hidden border-4 border-black shadow-[4px_4px_0_#000]
                    hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
          {% if eq.cover %}
          <div class="relative h-48 overflow-hidden">
            <img src="{{ asset('uploads/' ~ eq.cover.filename) }}"
                 alt="{{ eq.libelle }}"
                 loading="lazy"
                 decoding="async"
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
          </div>
          {% else %}
          <div class="h-48 bg-gray-100 flex items-center justify-center">
            <span class="text-gray-400 text-center px-4">Pas de photo</span>
          </div>
          {% endif %}
          <div class="p-4">
            <h3 class="font-black text-lg leading-tight">{{ eq.libelle }}</h3>
          </div>
        </div>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

</div>
{% endblock %}

{% block head %}
{% if photos|length %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
{% endif %}
{% endblock %}

{% block scripts %}
{% if photos|length or cover %}
<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script>GLightbox({ selector: '.glightbox' });</script>
{% endif %}
{% endblock %}
