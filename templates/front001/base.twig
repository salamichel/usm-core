<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=yes, maximum-scale=5">

  {# Title #}
  {% set page_title = block('title')|trim %}
  <title>{{ page_title ?: 'USM Volley' }}</title>

  {# SEO: Meta description & robots #}
  {% if meta %}
    <meta name="description" content="{{ meta.description|truncate(160) }}">
    <meta name="robots" content="{{ meta.robots }}">
    {% if meta.canonical %}
      <link rel="canonical" href="{{ meta.canonical }}">
    {% else %}
      <link rel="canonical" href="{{ base_url ~ current_path }}">
    {% endif %}
  {% else %}
    <meta name="description" content="{{ 'Union Sportive Miosienne Volley-Ball — actualités, agenda et équipes.'|truncate(160) }}">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ base_url ~ current_path }}">
  {% endif %}

  {# Open Graph #}
  {% if meta %}
    <meta property="og:title" content="{{ meta.title }}">
    <meta property="og:description" content="{{ meta.description|truncate(160) }}">
    <meta property="og:type" content="{{ meta.ogType|default('website') }}">
    <meta property="og:url" content="{{ meta.canonical|default(base_url ~ current_path) }}">
    {% if meta.ogImage %}
      <meta property="og:image" content="{{ meta.ogImage }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="630">
      <meta property="og:image:type" content="image/jpeg">
    {% endif %}
    {% if meta.articlePublishedAt %}
      <meta property="article:published_time" content="{{ meta.articlePublishedAt }}">
    {% endif %}
    {% if meta.articleModifiedAt %}
      <meta property="article:modified_time" content="{{ meta.articleModifiedAt }}">
    {% endif %}
  {% else %}
    <meta property="og:title" content="{{ page_title ?: 'USM Volley' }}">
    <meta property="og:description" content="{{ 'Union Sportive Miosienne Volley-Ball — actualités, agenda et équipes.'|truncate(160) }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ base_url ~ current_path }}">
  {% endif %}

  {# Twitter Card #}
  <meta name="twitter:card" content="summary_large_image">
  {% if meta %}
    <meta name="twitter:title" content="{{ meta.title }}">
    <meta name="twitter:description" content="{{ meta.description|truncate(160) }}">
    {% if meta.ogImage %}
      <meta name="twitter:image" content="{{ meta.ogImage }}">
    {% endif %}
  {% else %}
    <meta name="twitter:title" content="{{ page_title ?: 'USM Volley' }}">
    <meta name="twitter:description" content="{{ 'Union Sportive Miosienne Volley-Ball — actualités, agenda et équipes.'|truncate(160) }}">
  {% endif %}

  {# JSON-LD Structured Data #}
  {% if meta and meta.jsonLd %}
    {% for schema in meta.jsonLd %}
    <script type="application/ld+json">
      {{ json_encode_pretty(schema) }}
    </script>
    {% endfor %}
  {% endif %}


  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: { 'usm-brown': '#94674d' }
        }
      }
    }
  </script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const toggle = document.getElementById('mobile-menu-toggle');
      const menu = document.getElementById('mobile-menu');

      toggle.addEventListener('click', function() {
        menu.classList.toggle('hidden');
      });

      // Close menu when clicking on a link
      const menuLinks = menu.querySelectorAll('a');
      menuLinks.forEach(link => {
        link.addEventListener('click', function() {
          menu.classList.add('hidden');
        });
      });
    });
  </script>
  <style>
    /* Fix list styles: replace bullet points with volleyball emoji */
    ul, ol {
      margin-left: 0 !important;
      padding-left: 0 !important;
      margin-top: 0.5rem !important;
      margin-bottom: 0.5rem !important;
    }
    ul {
      counter-reset: none !important;
    }
    ul li {
      margin-left: 2rem !important;
      margin-top: 0 !important;
      margin-bottom: 0 !important;
      padding-left: 0.5rem !important;
      padding-top: 0 !important;
      padding-bottom: 0 !important;
      list-style: none !important;
      position: relative;
    }
    ul li::before {
      content: '🏐';
      position: absolute;
      left: -1.5rem;
      width: 1.5rem;
      text-align: center;
    }
    ol {
      counter-reset: custom-counter;
      margin-left: 0 !important;
      padding-left: 0 !important;
      margin-top: 0.5rem !important;
      margin-bottom: 0.5rem !important;
    }
    ol li {
      counter-increment: custom-counter;
      margin-left: 2rem !important;
      margin-top: 0 !important;
      margin-bottom: 0 !important;
      padding-left: 0.5rem !important;
      padding-top: 0 !important;
      padding-bottom: 0 !important;
      list-style: none !important;
      position: relative;
    }
    ol li::before {
      content: counter(custom-counter) '.';
      position: absolute;
      left: -2rem;
      width: 1.5rem;
      text-align: right;
    }

    /* Show mobile menu burger on landscape smartphone mode */
    @media (max-height: 500px) and (min-width: 480px) and (max-width: 900px) and (orientation: landscape) {
      /* Hide desktop menu */
      nav.sm\:flex {
        display: none !important;
      }

      #mobile-menu-toggle {
        display: block !important;
      }

      /* Allow menu to toggle normally */
      #mobile-menu {
        display: none;
      }

      #mobile-menu:not(.hidden) {
        display: block !important;
      }
    }
  </style>
  {% block head %}{% endblock %}
</head>
<body class="bg-amber-50 text-gray-900 min-h-screen flex flex-col">

  {# ── Header ── #}
  <header class="sticky top-0 z-50 border-b-4 border-black bg-usm-brown text-white">
    <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between gap-4">
      <a href="{{ url('/') }}" class="text-2xl font-black tracking-tight hover:opacity-80">USM VOLLEY</a>

      {# Desktop menu #}
      <nav class="hidden sm:flex items-center gap-2 flex-wrap text-sm font-semibold">
        {% for item in menu_items %}
          {% if item.children|length %}
            <div class="relative group">
              <button class="px-3 py-1 border-2 border-white/40 hover:border-white rounded transition flex items-center gap-1">
                {{ item.label }} <span class="text-xs">▾</span>
              </button>
              <div class="hidden group-hover:block absolute top-full left-0 z-50 bg-usm-brown border-2 border-black shadow-[4px_4px_0_#000] min-w-[160px]">
                {% for child in item.children %}
                  <a href="{{ item_url(child) }}" class="block px-4 py-2 hover:bg-black/20 border-b border-white/20 last:border-b-0">
                    {{ child.label }}
                  </a>
                {% endfor %}
              </div>
            </div>
          {% else %}
            <a href="{{ item_url(item) }}" class="px-3 py-1 border-2 border-white/40 hover:border-white rounded transition">
              {{ item.label }}
            </a>
          {% endif %}
        {% endfor %}
        {% if admin_logged_in %}
          <a href="{{ url('admin') }}" class="px-3 py-1 bg-black text-white border-2 border-black hover:bg-gray-800 rounded transition">⚙ Admin</a>
        {% endif %}
      </nav>

      {# Mobile burger button #}
      <button id="mobile-menu-toggle" class="sm:hidden border-2 border-white px-3 py-2 rounded hover:bg-black/20 transition" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    {# Mobile menu dropdown #}
    <nav id="mobile-menu" class="hidden sm:hidden bg-usm-brown border-t-2 border-white/20">
      <div class="px-4 py-3 space-y-2">
        {% for item in menu_items %}
          {% if item.children|length %}
            <div x-data="{ open: false }">
              <button @click="open = !open" class="w-full text-left px-3 py-2 border-2 border-white/40 hover:border-white rounded transition flex items-center justify-between font-semibold text-sm">
                {{ item.label }}
                <span class="text-xs" :class="{ 'rotate-180': open }">▾</span>
              </button>
              <div x-show="open" class="ml-4 mt-1 space-y-1 border-l-2 border-white/20">
                {% for child in item.children %}
                  <a href="{{ item_url(child) }}" class="block px-3 py-2 hover:bg-black/20 rounded transition text-sm">
                    {{ child.label }}
                  </a>
                {% endfor %}
              </div>
            </div>
          {% else %}
            <a href="{{ item_url(item) }}" class="block px-3 py-2 border-2 border-white/40 hover:border-white rounded transition font-semibold text-sm">
              {{ item.label }}
            </a>
          {% endif %}
        {% endfor %}
        {% if admin_logged_in %}
          <a href="{{ url('admin') }}" class="block px-3 py-2 bg-black text-white border-2 border-black hover:bg-gray-800 rounded transition font-semibold text-sm">⚙ Admin</a>
        {% endif %}
      </div>
    </nav>
  </header>

  {# ── Flash message ── #}
  {% if flash %}
    <div class="max-w-5xl mx-auto w-full px-4 pt-4">
      <div class="border-2 border-black p-3 shadow-[4px_4px_0_#000] font-semibold
        {% if flash.type == 'success' %}bg-green-100 text-green-800{% else %}bg-red-100 text-red-800{% endif %}">
        {{ flash.message }}
      </div>
    </div>
  {% endif %}

  {# ── Content ── #}
  <main class="flex-1">
    {% block content %}{% endblock %}
  </main>

  {# ── Footer ── #}
  <footer class="border-t-4 border-black bg-usm-brown text-white mt-12">
    <div class="max-w-5xl mx-auto px-4 py-8 sm:py-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">

        {# Section 1 — Club Identity #}
        <div>
          <h3 class="text-lg font-black mb-3 pb-2 border-b-2 border-white/40">
            🏐 {{ site_config.club_name|default('USM Volley') }}
          </h3>
          {% if site_config.club_tagline %}
            <p class="text-sm text-white/90 mb-3 leading-relaxed">{{ site_config.club_tagline }}</p>
          {% endif %}
          {% if site_config.address %}
            <address class="not-italic text-xs text-white/75 whitespace-pre-line leading-relaxed">{{ site_config.address }}</address>
          {% endif %}
        </div>

        {# Section 2 — Main Navigation #}
        <div>
          <h4 class="text-base font-black mb-4 pb-2 border-b-2 border-white/40">Navigation</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="{{ url('/') }}" class="hover:text-amber-300 transition">🏠 Accueil</a></li>
            <li><a href="{{ url('agenda') }}" class="hover:text-amber-300 transition">📅 Agenda</a></li>
            <li><a href="{{ url('equipes') }}" class="hover:text-amber-300 transition">👥 Équipes</a></li>
            <li><a href="{{ url('blog') }}" class="hover:text-amber-300 transition">📰 Actualités</a></li>
            {% for item in menu_items %}
              <li><a href="{{ item_url(item) }}" class="hover:text-amber-300 transition">→ {{ item.label }}</a></li>
            {% endfor %}
          </ul>
        </div>

        {# Section 3 — Info & Contact #}
        <div>
          <h4 class="text-base font-black mb-4 pb-2 border-b-2 border-white/40">Infos</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="{{ url('contact') }}" class="hover:text-amber-300 transition">💬 Nous contacter</a></li>
            {% if site_config.phone %}
              <li class="text-white/85">📞 <span class="font-semibold">{{ site_config.phone }}</span></li>
            {% endif %}
            {% if site_config.email %}
              <li><a href="mailto:{{ site_config.email }}" class="hover:text-amber-300 transition">📧 {{ site_config.email }}</a></li>
            {% endif %}
            <li><a href="{{ url('documents') }}" class="hover:text-amber-300 transition">📄 Documents</a></li>
          </ul>
        </div>

        {# Section 4 — Social & Actions #}
        <div>
          <h4 class="text-base font-black mb-4 pb-2 border-b-2 border-white/40">Nous suivre</h4>
          <div class="flex gap-3 mb-6">
            {% if site_config.facebook_url %}
              <a href="{{ site_config.facebook_url }}" target="_blank" rel="noopener"
                 aria-label="Facebook"
                 class="w-10 h-10 border-3 border-black bg-white text-usm-brown flex items-center justify-center shadow-[2px_2px_0_#000] hover:shadow-none hover:translate-x-0.5 hover:translate-y-0.5 transition-all">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M22 12.07C22 6.48 17.52 2 11.93 2 6.36 2 1.88 6.48 1.88 12.07c0 5.02 3.66 9.18 8.46 9.93v-7.03H7.83v-2.9h2.51V9.83c0-2.48 1.48-3.85 3.74-3.85 1.08 0 2.21.19 2.21.19v2.43h-1.25c-1.23 0-1.61.77-1.61 1.55v1.86h2.74l-.44 2.9h-2.3V22c4.8-.75 8.46-4.91 8.46-9.93z"/>
                </svg>
              </a>
            {% endif %}
            {% if site_config.instagram_url %}
              <a href="{{ site_config.instagram_url }}" target="_blank" rel="noopener"
                 aria-label="Instagram"
                 class="w-10 h-10 border-3 border-black bg-white text-usm-brown flex items-center justify-center shadow-[2px_2px_0_#000] hover:shadow-none hover:translate-x-0.5 hover:translate-y-0.5 transition-all">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.07.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.07.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.43-.36-1.07-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.07-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zm0 1.8c-3.15 0-3.5.01-4.74.07-1.07.05-1.65.23-2.04.38-.51.2-.88.44-1.26.83-.39.38-.63.75-.83 1.26-.15.39-.33.97-.38 2.04-.06 1.24-.07 1.59-.07 4.74s.01 3.5.07 4.74c.05 1.07.23 1.65.38 2.04.2.51.44.88.83 1.26.38.39.75.63 1.26.83.39.15.97.33 2.04.38 1.24.06 1.59.07 4.74.07s3.5-.01 4.74-.07c1.07-.05 1.65-.23 2.04-.38.51-.2.88-.44 1.26-.83.39-.38.63-.75.83-1.26.15-.39.33-.97.38-2.04.06-1.24.07-1.59.07-4.74s-.01-3.5-.07-4.74c-.05-1.07-.23-1.65-.38-2.04a3.4 3.4 0 0 0-.83-1.26 3.4 3.4 0 0 0-1.26-.83c-.39-.15-.97-.33-2.04-.38-1.24-.06-1.59-.07-4.74-.07zm0 3.06A4.97 4.97 0 1 1 12 17a4.97 4.97 0 0 1 0-9.97zm0 1.8a3.17 3.17 0 1 0 0 6.34 3.17 3.17 0 0 0 0-6.34zm5.18-2.16a1.16 1.16 0 1 1 0 2.32 1.16 1.16 0 0 1 0-2.32z"/>
                </svg>
              </a>
            {% endif %}
            {% if not site_config.facebook_url and not site_config.instagram_url %}
              <p class="text-xs text-white/60 italic">Réseaux à configurer</p>
            {% endif %}
          </div>
          {% if admin_logged_in %}
            <a href="{{ url('admin') }}" class="inline-block px-3 py-2 bg-black text-white border-2 border-black hover:bg-gray-800 rounded text-xs font-semibold transition">⚙️ Admin</a>
          {% endif %}
        </div>
      </div>

      {# ── Bottom bar ── #}
      <div class="border-t-2 border-white/30 pt-6 text-center text-xs text-white/75">
        <p>© {{ "now"|date("Y") }} {{ site_config.club_name|default('USM Volley') }}. {% if site_config.legal_text %}{{ site_config.legal_text }}{% endif %}</p>
        <p class="mt-2 text-white/60">Construit avec passion 🏐</p>
      </div>
    </div>
  </footer>

  {% block scripts %}{% endblock %}
</body>
</html>
