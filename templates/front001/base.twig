<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=yes, maximum-scale=5">

  {# Title #}
  {% set page_title = block('title')|trim %}
  <title>{{ page_title ?: 'USM Volley' }}</title>

  {# SEO: Meta description & robots #}
  {% if meta %}
    <meta name="description" content="{{ meta.description|truncate(160) }}">
    <meta name="robots" content="{{ meta.robots }}">
    {% if meta.canonical %}
      <link rel="canonical" href="{{ meta.canonical }}">
    {% else %}
      <link rel="canonical" href="{{ base_url ~ current_path }}">
    {% endif %}
  {% else %}
    <meta name="description" content="{{ 'Union Sportive Miosienne Volley-Ball — actualités, agenda et équipes.'|truncate(160) }}">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ base_url ~ current_path }}">
  {% endif %}

  {# Open Graph #}
  {% if meta %}
    <meta property="og:title" content="{{ meta.title }}">
    <meta property="og:description" content="{{ meta.description|truncate(160) }}">
    <meta property="og:type" content="{{ meta.ogType|default('website') }}">
    <meta property="og:url" content="{{ meta.canonical|default(base_url ~ current_path) }}">
    {% if meta.ogImage %}
      <meta property="og:image" content="{{ meta.ogImage }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="630">
      <meta property="og:image:type" content="image/jpeg">
    {% endif %}
    {% if meta.articlePublishedAt %}
      <meta property="article:published_time" content="{{ meta.articlePublishedAt }}">
    {% endif %}
    {% if meta.articleModifiedAt %}
      <meta property="article:modified_time" content="{{ meta.articleModifiedAt }}">
    {% endif %}
  {% else %}
    <meta property="og:title" content="{{ page_title ?: 'USM Volley' }}">
    <meta property="og:description" content="{{ 'Union Sportive Miosienne Volley-Ball — actualités, agenda et équipes.'|truncate(160) }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ base_url ~ current_path }}">
  {% endif %}

  {# Twitter Card #}
  <meta name="twitter:card" content="summary_large_image">
  {% if meta %}
    <meta name="twitter:title" content="{{ meta.title }}">
    <meta name="twitter:description" content="{{ meta.description|truncate(160) }}">
    {% if meta.ogImage %}
      <meta name="twitter:image" content="{{ meta.ogImage }}">
    {% endif %}
  {% else %}
    <meta name="twitter:title" content="{{ page_title ?: 'USM Volley' }}">
    <meta name="twitter:description" content="{{ 'Union Sportive Miosienne Volley-Ball — actualités, agenda et équipes.'|truncate(160) }}">
  {% endif %}

  {# JSON-LD Structured Data #}
  {% if meta and meta.jsonLd %}
    {% for schema in meta.jsonLd %}
    <script type="application/ld+json">
      {{ json_encode_pretty(schema) }}
    </script>
    {% endfor %}
  {% endif %}


  {% if site_config.font_family %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family={{ site_config.font_family|replace({' ': '+'}) }}:wght@400;500;600;700;800;900&display=swap">
  {% endif %}
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'usm-brown':  '{{ site_config.primary_color|default('#94674d') }}',
            'brutal-dark': '#1a2d4c',
            'brutal-gold': '{{ site_config.primary_color|default('#94674d') }}'
          }
          {% if site_config.font_family %}
          , fontFamily: { sans: ['{{ site_config.font_family }}', 'ui-sans-serif', 'system-ui', 'sans-serif'] }
          {% endif %}
        }
      }
    }
  </script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const toggle = document.getElementById('mobile-menu-toggle');
      const menu = document.getElementById('mobile-menu');

      toggle.addEventListener('click', function() {
        menu.classList.toggle('hidden');
      });

      // Close menu when clicking on a link
      const menuLinks = menu.querySelectorAll('a');
      menuLinks.forEach(link => {
        link.addEventListener('click', function() {
          menu.classList.add('hidden');
        });
      });

      // Initialize Lucide icons
      if (typeof lucide !== 'undefined') {
        lucide.createIcons();
      }
    });
  </script>
  <link rel="stylesheet" href="{{ asset('content-styles.css') }}">
  <style>
    :root {
      --primary: {{ site_config.primary_color|default('#94674d') }};
      --header-text: {{ site_config.header_text_color|default('#000000') }};
      --brutal-dark: #1a2d4c;
      --brutal-gold: var(--primary);
      --brutal-shadow: 5px 5px 0px #000000;
      --brutal-shadow-hover: 2px 2px 0px #000000;
      --transition: all 0.2s ease;
    }

    /* Neobrutalism Header */
    .header-brutal {
      background-color: #ffffff;
      height: 90px;
      display: flex;
      align-items: center;
      padding: 0 5%;
      position: sticky;
      top: 0;
      z-index: 1000;
      border-bottom: 4px solid #000000;
    }

    .logo-brutal {
      color: var(--header-text);
      font-size: 24px;
      font-weight: 900;
      letter-spacing: -1px;
      text-transform: uppercase;
      cursor: pointer;
      margin-right: 40px;
      border: 3px solid #000000;
      padding: 8px 16px;
      background: var(--brutal-gold);
      box-shadow: var(--brutal-shadow);
      text-decoration: none;
      display: inline-block;
    }

    .nav-container-brutal {
      flex-grow: 1;
      height: 100%;
    }

    .nav-list-brutal {
      display: flex;
      list-style: none;
      height: 100%;
      align-items: center;
      justify-content: flex-end;
      gap: 10px;
      margin: 0;
      padding: 0;
    }

    .nav-item-brutal {
      height: 100%;
      display: flex;
      align-items: center;
    }

    .nav-link-brutal {
      color: var(--header-text);
      text-decoration: none;
      padding: 8px 15px;
      font-weight: 900;
      font-size: 12px;
      text-transform: uppercase;
      transition: var(--transition);
      border: 3px solid transparent;
      display: flex;
      align-items: center;
      gap: 5px;
      height: 100%;
    }

    .nav-link-brutal:hover {
      background-color: var(--brutal-gold);
      border: 3px solid #000000;
      box-shadow: 3px 3px 0px #000000;
      transform: translate(-2px, -2px);
    }

    .has-mega {
      position: static;
    }

    .mega-menu {
      position: absolute;
      top: 90px;
      left: 0;
      width: 100%;
      background-color: #ffffff;
      border: 4px solid #000000;
      box-shadow: var(--brutal-shadow);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      padding: 40px;
      gap: 30px;
      opacity: 0;
      visibility: hidden;
      transform: translateY(15px);
      transition: var(--transition);
    }

    .has-mega:hover .mega-menu {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .mega-column h3 {
      color: var(--header-text);
      font-size: 14px;
      margin-bottom: 20px;
      text-transform: uppercase;
      background: var(--brutal-gold);
      border: 3px solid #000000;
      padding: 8px 10px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      box-shadow: 3px 3px 0px #000000;
      font-weight: 900;
    }

    .mega-links {
      list-style: none;
      margin-top: 15px;
      padding: 0;
    }

    .mega-links li {
      margin-bottom: 10px;
    }

    .mega-links a {
      color: var(--header-text);
      text-decoration: none;
      font-size: 13px;
      font-weight: bold;
      transition: var(--transition);
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px;
    }

    .mega-links a:hover {
      background: #eee;
      transform: translateX(5px);
      border-left: 3px solid var(--header-text);
      padding-left: 5px;
    }

    .mega-links svg {
      color: var(--header-text);
      width: 18px;
      height: 18px;
      flex-shrink: 0;
    }

    /* Show mobile menu burger on landscape smartphone mode */
    @media (max-height: 500px) and (min-width: 480px) and (max-width: 900px) and (orientation: landscape) {
      nav.sm\:flex {
        display: none !important;
      }

      #mobile-menu-toggle {
        display: block !important;
      }

      #mobile-menu {
        display: none;
      }

      #mobile-menu:not(.hidden) {
        display: block !important;
      }
    }

    @media (max-width: 768px) {
      .mega-menu {
        grid-template-columns: 1fr 1fr;
        padding: 20px;
        gap: 20px;
      }

      .nav-link-brutal {
        font-size: 11px;
        padding: 6px 10px;
      }
    }
  </style>
  {% block head %}{% endblock %}
</head>
<body class="bg-amber-50 text-gray-900 min-h-screen flex flex-col">

  {# ── Header Neobrutalism ── #}
  <header class="header-brutal">
    <a href="{{ url('/') }}" class="logo-brutal">{{ site_config.club_name|default('USM VOLLEY') }}</a>

    <nav class="nav-container-brutal hidden sm:block">
      <ul class="nav-list-brutal">
        {% for item in menu_items %}
          {% if item.children|length %}
            <li class="nav-item-brutal has-mega">
              <a href="#" class="nav-link-brutal">
                {{ item.label }}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </a>
              <div class="mega-menu">
                {# Check if children have their own sub-children (3-level: col headers) #}
                {% set has_columns = false %}
                {% for child in item.children %}
                  {% if child.children|length %}{% set has_columns = true %}{% endif %}
                {% endfor %}

                {% if has_columns %}
                  {# 3-level mode: level-2 items = columns, level-3 items = links #}
                  {% for col in item.children %}
                    <div class="mega-column">
                      <h3>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect>
                          <rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect>
                        </svg>
                        {{ col.label }}
                      </h3>
                      <ul class="mega-links">
                        {% if col.children|length %}
                          {% for sub in col.children %}
                            <li>
                              <a href="{{ item_url(sub) }}">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                  <polyline points="9 18 15 12 9 6"></polyline>
                                </svg>
                                {{ sub.label }}
                              </a>
                            </li>
                          {% endfor %}
                        {% else %}
                          <li>
                            <a href="{{ item_url(col) }}">
                              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <polyline points="9 18 15 12 9 6"></polyline>
                              </svg>
                              {{ col.label }}
                            </a>
                          </li>
                        {% endif %}
                      </ul>
                    </div>
                  {% endfor %}
                {% else %}
                  {# 2-level fallback: all children in a single column #}
                  <div class="mega-column" style="grid-column: 1 / -1;">
                    <ul class="mega-links" style="columns: 2; column-gap: 30px;">
                      {% for child in item.children %}
                        <li style="break-inside: avoid;">
                          <a href="{{ item_url(child) }}">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                              <polyline points="9 18 15 12 9 6"></polyline>
                            </svg>
                            {{ child.label }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              </div>
            </li>
          {% else %}
            <li class="nav-item-brutal">
              <a href="{{ item_url(item) }}" class="nav-link-brutal">{{ item.label }}</a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </nav>

    {# Mobile burger button #}
    <button id="mobile-menu-toggle" class="sm:hidden border-4 border-black px-3 py-2 bg-white hover:bg-brutal-gold transition font-bold" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </header>

  {# Mobile menu dropdown #}
  <nav id="mobile-menu" class="hidden sm:hidden bg-white border-b-4 border-black">
    <div class="px-4 py-3 space-y-2">
      {% for item in menu_items %}
        {% if item.children|length %}
          <div x-data="{ open: false }">
            <button @click="open = !open" class="w-full text-left px-3 py-2 border-2 border-black hover:bg-brutal-gold transition flex items-center justify-between font-black text-sm uppercase bg-white shadow-[3px_3px_0_#000]">
              {{ item.label }}
              <svg :class="{ 'rotate-180': open }" class="w-4 h-4 transition-transform flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            <div x-show="open" class="mt-1 border-l-4 border-black ml-2 pl-3 space-y-1">
              {% for child in item.children %}
                {% if child.children|length %}
                  {# Level 2 = section header (column title in mega menu) #}
                  <div class="pt-2">
                    <p class="text-xs font-black uppercase text-gray-500 tracking-widest py-1">{{ child.label }}</p>
                    <div class="space-y-1 border-l-2 border-brutal-gold ml-1 pl-2">
                      {% for sub in child.children %}
                        <a href="{{ item_url(sub) }}" class="block px-2 py-1.5 hover:bg-gray-100 transition text-sm font-semibold uppercase">
                          {{ sub.label }}
                        </a>
                      {% endfor %}
                    </div>
                  </div>
                {% else %}
                  <a href="{{ item_url(child) }}" class="block px-2 py-2 hover:bg-gray-100 transition text-sm font-semibold uppercase">
                    {{ child.label }}
                  </a>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% else %}
          <a href="{{ item_url(item) }}" class="block px-3 py-2 border-2 border-black hover:bg-brutal-gold transition font-black text-sm uppercase bg-white shadow-[3px_3px_0_#000]">
            {{ item.label }}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </nav>

  {# ── Flash message ── #}
  {% if flash %}
    <div class="max-w-5xl mx-auto w-full px-4 pt-4">
      <div class="border-2 border-black p-3 shadow-[4px_4px_0_#000] font-semibold
        {% if flash.type == 'success' %}bg-green-100 text-green-800{% else %}bg-red-100 text-red-800{% endif %}">
        {{ flash.message }}
      </div>
    </div>
  {% endif %}

  {# ── Content ── #}
  <main class="flex-1">
    {% block content %}{% endblock %}
  </main>

  {# ── Footer ── #}
  <footer class="border-t-4 border-black bg-usm-brown text-white mt-12">
    <div class="max-w-5xl mx-auto px-4 py-8 sm:py-12">

      {# Main footer content: 2 columns with vertical separator #}
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 mb-8 pb-6 border-b-2 border-white/30 sm:gap-12">

        {# Left: Logo + Contact Info + Social #}
        <div class="flex flex-col justify-between sm:border-r-2 sm:border-white/20 sm:pr-8">
          <div>
            <h3 class="text-lg font-black mb-2 uppercase">{{ site_config.club_name|default('USM Volley') }}</h3>

            {# Tagline #}
            {% if site_config.club_tagline %}
              <p class="text-sm text-white/80 mb-4 leading-relaxed">{{ site_config.club_tagline }}</p>
            {% endif %}

            {# Address #}
            {% if site_config.address %}
              <address class="not-italic text-xs text-white/75 whitespace-pre-line leading-relaxed mb-3">{{ site_config.address }}</address>
            {% endif %}

            {# Phone #}
            {% if site_config.phone %}
              <div class="text-xs text-white/75 mb-4">
                <a href="tel:{{ site_config.phone|replace({' ': ''}) }}" class="hover:text-amber-300 transition">
                  {{ site_config.phone }}
                </a>
              </div>
            {% endif %}
          </div>

          {# Social icons #}
          <div class="flex gap-3 mt-4">
            {% if site_config.facebook_url %}
              <a href="{{ site_config.facebook_url }}" target="_blank" rel="noopener"
                 aria-label="Facebook"
                 class="w-8 h-8 border border-white/40 hover:border-white flex items-center justify-center transition-all hover:bg-white/10">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M22 12.07C22 6.48 17.52 2 11.93 2 6.36 2 1.88 6.48 1.88 12.07c0 5.02 3.66 9.18 8.46 9.93v-7.03H7.83v-2.9h2.51V9.83c0-2.48 1.48-3.85 3.74-3.85 1.08 0 2.21.19 2.21.19v2.43h-1.25c-1.23 0-1.61.77-1.61 1.55v1.86h2.74l-.44 2.9h-2.3V22c4.8-.75 8.46-4.91 8.46-9.93z"/>
                </svg>
              </a>
            {% endif %}
            {% if site_config.instagram_url %}
              <a href="{{ site_config.instagram_url }}" target="_blank" rel="noopener"
                 aria-label="Instagram"
                 class="w-8 h-8 border border-white/40 hover:border-white flex items-center justify-center transition-all hover:bg-white/10">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.07.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.07.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.43-.36-1.07-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.07-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zm0 1.8c-3.15 0-3.5.01-4.74.07-1.07.05-1.65.23-2.04.38-.51.2-.88.44-1.26.83-.39.38-.63.75-.83 1.26-.15.39-.33.97-.38 2.04-.06 1.24-.07 1.59-.07 4.74s.01 3.5.07 4.74c.05 1.07.23 1.65.38 2.04.2.51.44.88.83 1.26.38.39.75.63 1.26.83.39.15.97.33 2.04.38 1.24.06 1.59.07 4.74.07s3.5-.01 4.74-.07c1.07-.05 1.65-.23 2.04-.38.51-.2.88-.44 1.26-.83.39-.38.63-.75.83-1.26.15-.39.33-.97.38-2.04.06-1.24.07-1.59.07-4.74s-.01-3.5-.07-4.74c-.05-1.07-.23-1.65-.38-2.04a3.4 3.4 0 0 0-.83-1.26 3.4 3.4 0 0 0-1.26-.83c-.39-.15-.97-.33-2.04-.38-1.24-.06-1.59-.07-4.74-.07zm0 3.06A4.97 4.97 0 1 1 12 17a4.97 4.97 0 0 1 0-9.97zm0 1.8a3.17 3.17 0 1 0 0 6.34 3.17 3.17 0 0 0 0-6.34zm5.18-2.16a1.16 1.16 0 1 1 0 2.32 1.16 1.16 0 0 1 0-2.32z"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>

        {# Right: Legal links (no bullets) #}
        <div class="sm:pl-8">
          <ul class="space-y-2 text-sm font-semibold list-none">
            <li><a href="{{ url('/p/mentions-legales') }}" class="uppercase hover:text-amber-300 transition tracking-wide">Mentions légales</a></li>
            <li><a href="{{ url('/p/politique-de-confidentialite') }}" class="uppercase hover:text-amber-300 transition tracking-wide">Politique de confidentialité</a></li>
            <li><a href="{{ url('/p/politique-d-utilisation-des-cookies') }}" class="uppercase hover:text-amber-300 transition tracking-wide">Gestion des cookies</a></li>
          </ul>
        </div>
      </div>

      {# Bottom bar — Copyright #}
      <div class="text-center text-xs text-white/75 py-4">
        <p>© {{ "now"|date("Y") }} {{ site_config.club_name|default('USM Volley') }}. {% if site_config.legal_text %}{{ site_config.legal_text }}{% endif %}</p>
      </div>
    </div>
  </footer>

  {% block scripts %}{% endblock %}
</body>
</html>
