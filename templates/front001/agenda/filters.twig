{# Agenda filter panel - all filters above table #}

<div class="bg-white border-2 border-black shadow-[4px_4px_0_#000] p-6 mb-6">
  <div class="flex justify-between items-center mb-6">
    <h2 class="text-lg font-bold">Filtres</h2>
    {% if filters is not empty %}
      <a href="/agenda" class="text-sm text-usm-brown hover:underline font-semibold">Réinitialiser ↺</a>
    {% endif %}
  </div>

  {# Mobile filter toggle button #}
  <button id="filters-toggle" class="md:hidden w-full mb-4 px-4 py-2 bg-usm-brown text-white border-2 border-black rounded font-semibold flex items-center justify-between hover:bg-amber-900 transition">
    <span>🔍 Filtres</span>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </button>

  {# Filters content - visible on desktop, hidden on mobile by default #}
  <div id="filters-content" class="hidden md:block space-y-6">

    {# Type filter - segmented control #}
    <div>
      <p class="text-xs font-semibold text-gray-600 mb-3 uppercase tracking-wider">Type d'évènement</p>
      <div class="flex flex-wrap gap-2">
        {% set _no_type = [] %}
        {% for k, v in filters %}
          {% set _enc = v is same as(true) ? '1' : v|url_encode %}
          {% if k != 'type' %}{% set _no_type = _no_type|merge([k ~ '=' ~ _enc]) %}{% endif %}
        {% endfor %}
        {% set _base_type = '/agenda' ~ (_no_type is not empty ? '?' ~ _no_type|join('&') : '') %}
        {% set _sep_type = _no_type is not empty ? '&' : '?' %}

        <a href="{{ _base_type }}" class="px-4 py-2 text-sm rounded-lg border-2 font-semibold transition {% if not filters.type %}bg-white text-usm-brown border-usm-brown{% else %}border-gray-300 bg-gray-50 text-gray-600 hover:bg-white{% endif %}">
          Tous
        </a>
        <a href="{{ _base_type ~ _sep_type ~ 'type=Match' }}" class="px-4 py-2 text-sm rounded-lg border-2 font-semibold transition {% if filters.type == 'Match' %}bg-white text-usm-brown border-usm-brown{% else %}border-gray-300 bg-gray-50 text-gray-600 hover:bg-white{% endif %}">
          ⚽ Matchs
        </a>
        <a href="{{ _base_type ~ _sep_type ~ 'type=Pr%C3%A9sences%20-%20Entrainement' }}" class="px-4 py-2 text-sm rounded-lg border-2 font-semibold transition {% if filters.type == 'Présences - Entrainement' %}bg-white text-usm-brown border-usm-brown{% else %}border-gray-300 bg-gray-50 text-gray-600 hover:bg-white{% endif %}">
          🏋️ Entraînement
        </a>
      </div>
    </div>

    {# Dropdown filters grid #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {# Manifestation dropdown #}
      {% if filterOptions.manifestationNames %}
        <div>
          <p class="text-xs font-semibold text-gray-600 mb-3 uppercase tracking-wider">Manifestation</p>
          <div>
            {% set _no_manif = [] %}
            {% for k, v in filters %}
              {% set _enc = v is same as(true) ? '1' : v|url_encode %}
              {% if k != 'manifestation' %}{% set _no_manif = _no_manif|merge([k ~ '=' ~ _enc]) %}{% endif %}
            {% endfor %}
            {% set _base_manif = '/agenda' ~ (_no_manif is not empty ? '?' ~ _no_manif|join('&') : '') %}
            {% set _sep_manif = _no_manif is not empty ? '&' : '?' %}

            <select onchange="if(this.value) window.location.href = '{{ _base_manif }}' + (this.value ? '{{ _sep_manif }}manifestation=' + encodeURIComponent(this.value) : ''); else window.location.href = '{{ _base_manif }}';" class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg bg-white text-gray-800 font-medium focus:outline-none focus:border-usm-brown">
              <option value="">Tous les événements</option>
              {% for name in filterOptions.manifestationNames %}
                <option value="{{ name }}" {% if filters.manifestation == name %}selected{% endif %}>{{ name }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
      {% endif %}

      {# Équipe dropdown #}
      {% if filterOptions.teams %}
        <div>
          <p class="text-xs font-semibold text-gray-600 mb-3 uppercase tracking-wider">Équipe</p>
          <div>
            {% set _no_team = [] %}
            {% for k, v in filters %}
              {% set _enc = v is same as(true) ? '1' : v|url_encode %}
              {% if k != 'team' %}{% set _no_team = _no_team|merge([k ~ '=' ~ _enc]) %}{% endif %}
            {% endfor %}
            {% set _base_team = '/agenda' ~ (_no_team is not empty ? '?' ~ _no_team|join('&') : '') %}
            {% set _sep_team = _no_team is not empty ? '&' : '?' %}

            <select onchange="if(this.value) window.location.href = '{{ _base_team }}' + (this.value ? '{{ _sep_team }}team=' + encodeURIComponent(this.value) : ''); else window.location.href = '{{ _base_team }}';" class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg bg-white text-gray-800 font-medium focus:outline-none focus:border-usm-brown">
              <option value="">Toutes les équipes</option>
              {% for team in filterOptions.teams %}
                <option value="{{ team }}" {% if filters.team == team %}selected{% endif %}>{{ team }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
      {% endif %}

      {# Lieu dropdown #}
      {% if filterOptions.locations %}
        <div>
          <p class="text-xs font-semibold text-gray-600 mb-3 uppercase tracking-wider">Lieu</p>
          <div>
            {% set _no_location = [] %}
            {% for k, v in filters %}
              {% set _enc = v is same as(true) ? '1' : v|url_encode %}
              {% if k != 'location' %}{% set _no_location = _no_location|merge([k ~ '=' ~ _enc]) %}{% endif %}
            {% endfor %}
            {% set _base_location = '/agenda' ~ (_no_location is not empty ? '?' ~ _no_location|join('&') : '') %}
            {% set _sep_location = _no_location is not empty ? '&' : '?' %}

            <select onchange="if(this.value) window.location.href = '{{ _base_location }}' + (this.value ? '{{ _sep_location }}location=' + encodeURIComponent(this.value) : ''); else window.location.href = '{{ _base_location }}';" class="w-full px-4 py-2.5 border-2 border-gray-300 rounded-lg bg-white text-gray-800 font-medium focus:outline-none focus:border-usm-brown">
              <option value="">Tous les lieux</option>
              {% for location in filterOptions.locations %}
                <option value="{{ location }}" {% if filters.location == location %}selected{% endif %}>{{ location }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
      {% endif %}
    </div>

    {# Display section - segmented control #}
    <div class="pt-6 border-t-2 border-gray-200">
      <p class="text-xs font-semibold text-gray-600 mb-3 uppercase tracking-wider">Affichage</p>
      <div class="flex flex-wrap gap-2">
        {% set _no_empty = [] %}
        {% for k, v in filters %}
          {% set _enc = v is same as(true) ? '1' : v|url_encode %}
          {% if k != 'hide_empty_players' %}{% set _no_empty = _no_empty|merge([k ~ '=' ~ _enc]) %}{% endif %}
        {% endfor %}
        {% set _base_empty = '/agenda' ~ (_no_empty is not empty ? '?' ~ _no_empty|join('&') : '') %}
        {% set _sep_empty = _no_empty is not empty ? '&' : '?' %}

        <a href="{{ _base_empty }}" class="px-4 py-2 text-sm rounded-lg border-2 font-semibold transition {% if not filters.hide_empty_players %}bg-white text-usm-brown border-usm-brown{% else %}border-gray-300 bg-gray-50 text-gray-600 hover:bg-white{% endif %}">
          Liste complète
        </a>
        <a href="{{ _base_empty ~ _sep_empty ~ 'hide_empty_players=1' }}" class="px-4 py-2 text-sm rounded-lg border-2 font-semibold transition {% if filters.hide_empty_players %}bg-white text-usm-brown border-usm-brown{% else %}border-gray-300 bg-gray-50 text-gray-600 hover:bg-white{% endif %}">
          Mes réponses
        </a>
      </div>
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const toggle = document.getElementById('filters-toggle');
    const content = document.getElementById('filters-content');
    const svg = toggle ? toggle.querySelector('svg') : null;

    if (toggle) {
      toggle.addEventListener('click', function() {
        const isHidden = content.classList.toggle('hidden');
        if (svg) svg.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
      });
    }
  });
</script>
