{# Agenda filter form #}
{% import '_macros.twig' as macros %}

<div class="bg-gray-100 p-4 rounded-lg mb-6">
  <form method="GET" action="/agenda" class="space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-4">
      {{ macros.render_filter_dropdown('team', 'Équipe', filterOptions.teams, filters.team) }}
      {{ macros.render_filter_dropdown('type', 'Type', filterOptions.types, filters.type) }}
      {{ macros.render_filter_dropdown('manifestation', 'Manifestation', filterOptions.manifestationNames, filters.manifestation) }}
      {{ macros.render_filter_dropdown('location', 'Lieu', filterOptions.locations, filters.location) }}
      {{ macros.render_filter_checkbox('this_week', 'Semaine en cours', filters.this_week) }}
      {{ macros.render_filter_checkbox('hide_empty_players', 'Sans réponse', filters.hide_empty_players) }}
    </div>

    {# Reset button #}
    {% if filters is not empty %}
      <div class="flex gap-2">
        <a href="/agenda" class="px-4 py-2 bg-gray-400 hover:bg-gray-500 text-white rounded-md text-sm font-medium">
          Réinitialiser filtres
        </a>
      </div>
    {% endif %}
  </form>
</div>
