{# Agenda filter form #}
{% import 'agenda/_macros.twig' as macros %}

<div class="bg-gray-100 p-4 rounded-lg mb-6">
  {# Mobile filter toggle button #}
  <button id="filters-toggle" class="md:hidden w-full mb-4 px-4 py-2 bg-usm-brown text-white border-2 border-black rounded font-semibold flex items-center justify-between hover:bg-amber-900 transition">
    <span>🔍 Filtres</span>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </button>

  {# Filters content #}
  <form method="GET" action="/agenda" id="filters-content" class="hidden md:block space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-4">
      {{ macros.render_filter_dropdown('team', 'Équipe', filterOptions.teams, filters.team) }}
      {{ macros.render_filter_dropdown('type', 'Type', filterOptions.types, filters.type) }}
      {{ macros.render_filter_dropdown('manifestation', 'Manifestation', filterOptions.manifestationNames, filters.manifestation) }}
      {{ macros.render_filter_dropdown('location', 'Lieu', filterOptions.locations, filters.location) }}
      {{ macros.render_filter_checkbox('this_week', 'Semaine en cours', filters.this_week) }}
      {{ macros.render_filter_checkbox('hide_empty_players', 'Sans réponse', filters.hide_empty_players) }}
    </div>

    {# Reset button #}
    {% if filters is not empty %}
      <div class="flex gap-2">
        <a href="/agenda" class="px-4 py-2 bg-gray-400 hover:bg-gray-500 text-white rounded-md text-sm font-medium">
          Réinitialiser filtres
        </a>
      </div>
    {% endif %}
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const toggle = document.getElementById('filters-toggle');
    const content = document.getElementById('filters-content');
    const svg = toggle.querySelector('svg');

    toggle.addEventListener('click', function() {
      const isHidden = content.classList.toggle('hidden');
      svg.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(180deg)';
    });
  });
</script>
