{# Agenda filter form #}
<div class="bg-gray-100 p-4 rounded-lg mb-6">
  <form method="GET" action="/agenda" class="space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {# Type filter #}
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-2">Type de manifestation</label>
        <select name="type" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm" onchange="this.form.submit()">
          <option value="Tous">[Tous]</option>
          {% for type in filterOptions.types %}
            <option value="{{ type }}" {% if filters.type == type %}selected{% endif %}>{{ type }}</option>
          {% endfor %}
        </select>
      </div>

      {# Location filter #}
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-2">Lieu</label>
        <select name="location" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm" onchange="this.form.submit()">
          <option value="Tous">[Tous]</option>
          {% for location in filterOptions.locations %}
            <option value="{{ location }}" {% if filters.location == location %}selected{% endif %}>{{ location }}</option>
          {% endfor %}
        </select>
      </div>

      {# Week filter #}
      <div class="flex items-end">
        <label class="flex items-center text-sm">
          <input type="checkbox" name="this_week" value="1" {% if filters.this_week %}checked{% endif %} onchange="this.form.submit()" class="w-4 h-4 text-amber-600 border-gray-300 rounded">
          <span class="ml-2 text-gray-700">Semaine en cours</span>
        </label>
      </div>

      {# Hide empty players filter #}
      <div class="flex items-end">
        <label class="flex items-center text-sm">
          <input type="checkbox" name="hide_empty_players" value="1" {% if filters.hide_empty_players %}checked{% endif %} onchange="this.form.submit()" class="w-4 h-4 text-amber-600 border-gray-300 rounded">
          <span class="ml-2 text-gray-700">Sans réponse</span>
        </label>
      </div>
    </div>

    {# Reset button #}
    {% if filters is not empty %}
      <div class="flex gap-2">
        <a href="/agenda" class="px-4 py-2 bg-gray-400 hover:bg-gray-500 text-white rounded-md text-sm font-medium">
          Réinitialiser filtres
        </a>
      </div>
    {% endif %}
  </form>
</div>
