{% extends "base.twig" %}

{% block title %}Agenda{% endblock %}

{% block content %}
<div class="px-4 py-6">
  <h1 class="text-3xl font-bold mb-6">Agenda — événements à venir</h1>

  {% include 'agenda/filters.twig' %}

  {# Toolbar: Zoom + Quick filters #}
  <div class="bg-white border-b-2 border-gray-300 p-3 mb-4 rounded-lg flex flex-wrap items-center gap-4">
    {# Zoom controls #}
    <div class="flex items-center gap-2">
      <span class="text-sm font-semibold text-gray-700 whitespace-nowrap">Zoom :</span>
      <div class="flex gap-1">
        <button type="button" data-zoom="1"    class="zoom-btn px-2 py-1 text-xs rounded border border-gray-400 bg-white hover:bg-amber-50 font-semibold">100%</button>
        <button type="button" data-zoom="0.8"  class="zoom-btn px-2 py-1 text-xs rounded border border-gray-400 bg-white hover:bg-amber-50 font-semibold">80%</button>
        <button type="button" data-zoom="0.65" class="zoom-btn px-2 py-1 text-xs rounded border border-gray-400 bg-white hover:bg-amber-50 font-semibold">65%</button>
        <button type="button" data-zoom="0.5"  class="zoom-btn px-2 py-1 text-xs rounded border border-gray-400 bg-white hover:bg-amber-50 font-semibold">50%</button>
      </div>
    </div>

    {# Divider #}
    <div class="hidden sm:block w-px h-6 bg-gray-300"></div>

    {# Build base query strings preserving other active filters #}
    {% set _no_type = [] %}
    {% set _no_manif = [] %}
    {% for k, v in filters %}
      {% set _enc = v is same as(true) ? '1' : v|url_encode %}
      {% if k != 'type' %}{% set _no_type = _no_type|merge([k ~ '=' ~ _enc]) %}{% endif %}
      {% if k != 'manifestation' %}{% set _no_manif = _no_manif|merge([k ~ '=' ~ _enc]) %}{% endif %}
    {% endfor %}
    {% set _base_type = '/agenda' ~ (_no_type is not empty ? '?' ~ _no_type|join('&') : '') %}
    {% set _base_manif = '/agenda' ~ (_no_manif is not empty ? '?' ~ _no_manif|join('&') : '') %}
    {% set _sep_type = _no_type is not empty ? '&' : '?' %}
    {% set _sep_manif = _no_manif is not empty ? '&' : '?' %}

    {# Quick type filters #}
    <div class="flex items-center gap-2">
      <span class="text-sm font-semibold text-gray-700 whitespace-nowrap">Type :</span>
      <div class="flex gap-1 flex-wrap">
        <a href="{{ _base_type }}" class="px-3 py-1 text-xs rounded border-2 {% if not filters.type %}bg-amber-600 text-white border-amber-800{% else %}border-gray-400 bg-white hover:bg-amber-50{% endif %} font-semibold transition">
          Tous
        </a>
        <a href="{{ _base_type ~ _sep_type ~ 'type=Match' }}" class="px-3 py-1 text-xs rounded border-2 {% if filters.type == 'Match' %}bg-amber-600 text-white border-amber-800{% else %}border-gray-400 bg-white hover:bg-amber-50{% endif %} font-semibold transition">
          ⚽ Matchs
        </a>
        <a href="{{ _base_type ~ _sep_type ~ 'type=Pr%C3%A9sences%20-%20Entrainement' }}" class="px-3 py-1 text-xs rounded border-2 {% if filters.type == 'Présences - Entrainement' %}bg-blue-600 text-white border-blue-800{% else %}border-gray-400 bg-white hover:bg-blue-50{% endif %} font-semibold transition">
          🏋️ Entr.
        </a>
      </div>
    </div>

    {% if filterOptions.manifestationNames %}
      {# Divider #}
      <div class="hidden sm:block w-px h-6 bg-gray-300"></div>

      {# Quick manifestation filters #}
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-sm font-semibold text-gray-700 whitespace-nowrap">Manifestation :</span>
        <div class="flex gap-1 flex-wrap">
          <a href="{{ _base_manif }}" class="px-3 py-1 text-xs rounded border-2 {% if not filters.manifestation %}bg-green-600 text-white border-green-800{% else %}border-gray-400 bg-white hover:bg-green-50{% endif %} font-semibold transition">
            Tous
          </a>
          {% for name in filterOptions.manifestationNames %}
            <a href="{{ _base_manif ~ _sep_manif ~ 'manifestation=' ~ name|url_encode }}" class="px-3 py-1 text-xs rounded border-2 {% if filters.manifestation == name %}bg-green-600 text-white border-green-800{% else %}border-gray-400 bg-white hover:bg-green-50{% endif %} font-semibold transition">
              {{ name }}
            </a>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>

  {# Login CTA for players #}
  <div class="mb-4 p-3 bg-amber-50 border-2 border-amber-400 rounded flex items-center gap-3">
    <span class="text-amber-700 text-lg">🔒</span>
    <a href="https://unionsallesmiosvolley.free.nf/login.php"
       target="_blank" rel="noopener"
       class="text-usm-brown font-semibold underline hover:text-amber-800 transition">
      S'identifier pour mettre à jour sa participation
    </a>
  </div>

  {% if manifestations is empty %}
    <p class="text-gray-600">Aucun événement à venir.</p>
  {% else %}

  {# Tableau croisé avec scroll horizontal + zoom #}
  <div class="border border-gray-400 rounded agenda-table-container" style="max-height:80vh; overflow-y:auto; overflow-x:auto;">
    <table class="border-collapse text-sm whitespace-nowrap agenda-table">

      {# ── EN-TÊTE : une colonne par manifestation ── #}
      <thead class="sticky top-0 z-20 bg-white">
        <tr>
          {# Cellule coin haut-gauche #}
          <th class="sticky-left z-30 bg-gradient-to-b from-gray-300 to-gray-200 border-2 border-gray-500 px-3 py-2 text-left font-bold min-w-[160px]">
            <div class="text-center">👥</div>
            <div>Joueurs</div>
          </th>

          {% for mid, m in manifestations %}
            {% if m.annule %}
              {% set col_top = 'border-t-4 border-t-red-500' %}
              {% set col_bg  = 'bg-red-50' %}
            {% elseif m.provisoire %}
              {% set col_top = 'border-t-4 border-t-orange-400' %}
              {% set col_bg  = 'bg-orange-50' %}
            {% else %}
              {% set col_top = 'border-t-4 border-t-blue-500' %}
              {% set col_bg  = loop.index is odd ? 'bg-blue-100' : 'bg-cyan-100' %}
            {% endif %}

            {% set ok = (m.nb_present + m.nb_disponible + m.nb_selection) >= 6 %}
            {% set terrain_alert = (m.nb_terrains != 0) and (m.nb_terrains != 1) and (m.nb_terrains != '.') %}

            <th class="border border-gray-300 {{ col_top }} {{ col_bg }} px-3 py-2 text-left font-normal min-w-[170px] align-top">

              {# Type + badge statut #}
              <div class="flex items-center justify-between gap-1 mb-1">
                <span class="text-[10px] font-extrabold uppercase tracking-widest text-gray-400">{{ m.type }}</span>
                {% if m.annule %}
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-full bg-red-100 text-red-700 border border-red-300">Annulé</span>
                {% elseif m.provisoire %}
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-full bg-orange-100 text-orange-700 border border-orange-300">Provisoire</span>
                {% else %}
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-full bg-green-100 text-green-700 border border-green-300">Confirmé</span>
                {% endif %}
              </div>

              {# Titre #}
              <div class="font-bold text-sm text-gray-900 leading-tight mb-2">{{ m.titre }}</div>

              {# Infos avec icônes SVG #}
              <div class="space-y-1 text-xs text-gray-600 mb-2">
                <div class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <span>{{ m.date_display }}</span>
                </div>
                {% if m.time_range %}
                <div class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  <span>{{ m.time_range }}</span>
                </div>
                {% endif %}
                <div class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  <span>{{ m.lieu }}</span>
                </div>
                {% if terrain_alert %}
                <div class="flex items-center gap-1.5 text-red-600 font-semibold">
                  <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
                  <span>🏐 {{ m.nb_terrains }} terrains</span>
                </div>
                {% endif %}
                {% if m.commentaire %}
                <div class="flex items-start gap-1.5 italic text-gray-500">
                  <svg class="w-3.5 h-3.5 shrink-0 mt-0.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                  <span>{{ m.commentaire|slice(0,40) }}</span>
                </div>
                {% endif %}
              </div>

              {# Stats compactes #}
              <div class="border-t border-gray-200 pt-1.5 space-y-1 text-[11px]">
                {% if 'Match' in m.type %}
                  <div class="px-1 py-1 rounded font-bold text-xs text-center {% if ok %}text-green-700 bg-green-100 border border-green-300{% else %}text-red-700 bg-red-100 border border-red-300{% endif %}">
                    {% if ok %}✓ Équipe OK{% else %}⚠️ Sous-effectif{% endif %}
                  </div>
                  <div class="flex flex-wrap gap-x-2 gap-y-0.5">
                    {% if m.nb_selection > 0 %}<span class="text-amber-700 font-semibold">Sélection: <strong>{{ m.nb_selection }}</strong></span>{% endif %}
                    {% if m.nb_present > 0 %}<span class="text-green-700 font-semibold">Présents: <strong>{{ m.nb_present }}</strong></span>{% endif %}
                  </div>
                  <div class="flex flex-wrap gap-x-2 gap-y-0.5">
                    {% if m.nb_disponible > 0 %}<span class="text-blue-700">Dispos: <strong>{{ m.nb_disponible }}</strong></span>{% endif %}
                    {% if m.nb_indisponible > 0 %}<span class="text-red-700">Indispos: <strong>{{ m.nb_indisponible }}</strong></span>{% endif %}
                  </div>
                  <div class="flex flex-wrap gap-x-2 gap-y-0.5">
                    {% if m.nb_absent > 0 %}<span class="text-red-800 font-semibold">Absents: <strong>{{ m.nb_absent }}</strong></span>{% endif %}
                    {% if m.nb_ne_sait_pas > 0 %}<span class="text-orange-600">Ne sait pas: <strong>{{ m.nb_ne_sait_pas }}</strong></span>{% endif %}
                  </div>
                {% else %}
                  <div class="flex flex-wrap gap-x-2 gap-y-0.5">
                    <span class="text-green-700 font-semibold">Présents: <strong>{{ m.nb_present }}</strong></span>
                    <span class="text-red-700">Absents: <strong>{{ m.nb_absent }}</strong></span>
                  </div>
                  <div class="flex flex-wrap gap-x-2 gap-y-0.5">
                    {% if m.nb_disponible > 0 %}<span class="text-blue-700">Dispos: <strong>{{ m.nb_disponible }}</strong></span>{% endif %}
                    {% if m.nb_indisponible > 0 %}<span class="text-red-700">Indispos: <strong>{{ m.nb_indisponible }}</strong></span>{% endif %}
                  </div>
                  {% if m.nb_ne_sait_pas > 0 %}<div><span class="text-orange-600">Ne sait pas: <strong>{{ m.nb_ne_sait_pas }}</strong></span></div>{% endif %}
                {% endif %}
              </div>

            </th>
          {% endfor %}
        </tr>
      </thead>

      {# ── LIGNES : un joueur par ligne ── #}
      <tbody>
        {% for jid, nom in joueurs %}
          {% set row = cross[jid] %}

          {# Alerte joueur : pas tout rempli ou "ne sait pas encore" proche #}
          {% set nb_manif = manifestations|length %}
          {% set alerte = (row.nb_participation < nb_manif) or (row.nb_ne_sait_pas_proche > 0) or (row.nb_ne_sait_pas > 3) %}

          <tr class="{{ loop.index is odd ? 'bg-white' : 'bg-gray-50' }} hover:bg-yellow-50">

            {# Nom joueur — sticky gauche #}
            <td class="sticky-left z-10 border-2 border-gray-400 px-2 py-1 font-semibold bg-gradient-to-r from-gray-200 to-gray-100 min-w-[160px]">
              {# Smiley avec 3 niveaux selon l'alerte #}
              {% if row.nb_participation < nb_manif %}
                <img src="{{ asset('icons/pas_content_violet.png') }}" alt="Participation incomplète" title="Participation incomplète" class="inline w-6 h-6">
              {% elseif row.nb_ne_sait_pas > 3 %}
                <span class="text-xl" title="Trop d'hésitations">😕</span>
              {% elseif row.nb_ne_sait_pas_proche > 0 %}
                <span class="text-xl" title="Réponse attendue bientôt">🤔</span>
              {% else %}
                <img src="{{ asset('icons/content.png') }}" alt="Participation complète" title="Participation complète" class="inline w-6 h-6">
              {% endif %}
              {% set parts = nom|split(' ') %}
              {% set nom_famille = parts[0] %}
              {% set prenom = parts|last %}
              <span class="ml-1 text-xs">{{ nom_famille|slice(0, 3)|upper }}... {{ prenom }}</span>
            </td>

            {# Cellule par manifestation #}
            {% for mid, m in manifestations %}
              {% set part = row[mid] ?? '' %}

              {# Parser le statut de participation #}
              {% set is_selected = part matches '/Sélectionné/' %}
              {% set is_present = part matches '/(Présent|Oui)/' %}
              {% set is_available_if_needed = part matches '/Disponible si n/' %}
              {% set is_available = part matches '/(Disponible|Joker)/' and not is_available_if_needed %}
              {% set is_unavailable = part matches '/Indisponible/' %}
              {% set is_absent = part matches '/(Absent|Non)/' %}
              {% set is_unknown = part matches '/(Ne sait pas|\\?)/' %}

              {# Couleur de fond et bordure de la cellule #}
              {% if is_selected %}
                {% set cell_bg = 'bg-amber-300 border-l-4 border-amber-600' %}
                {% set text_color = 'text-amber-900' %}
              {% elseif is_present %}
                {% set cell_bg = 'bg-green-200 border-l-4 border-green-600' %}
                {% set text_color = 'text-green-900' %}
              {% elseif is_available %}
                {% set cell_bg = 'bg-blue-200 border-l-4 border-blue-500' %}
                {% set text_color = 'text-blue-900' %}
              {% elseif is_available_if_needed %}
                {% set cell_bg = 'bg-cyan-200 border-l-4 border-cyan-500' %}
                {% set text_color = 'text-cyan-900' %}
              {% elseif is_unavailable %}
                {% set cell_bg = 'bg-red-200 border-l-4 border-red-600' %}
                {% set text_color = 'text-red-900' %}
              {% elseif is_absent %}
                {% set cell_bg = 'bg-red-300 border-l-4 border-red-700' %}
                {% set text_color = 'text-red-950 font-bold' %}
              {% elseif is_unknown %}
                {% set cell_bg = 'bg-orange-200 border-l-4 border-orange-500' %}
                {% set text_color = 'text-orange-900' %}
              {% else %}
                {% set cell_bg = 'bg-gray-200 border-l-4 border-gray-400' %}
                {% set text_color = 'text-gray-600' %}
              {% endif %}

              {# Appliquer la couleur de fond du type de manifestation par-dessus #}
              {% if m.annule %}
                {% set cell_bg = 'bg-red-400 border-l-4 border-red-700' %}
                {% set text_color = 'text-red-900 font-bold' %}
              {% elseif m.provisoire %}
                {% set cell_bg = 'bg-amber-300 border-l-4 border-amber-600' %}
                {% set text_color = 'text-amber-900 font-semibold' %}
              {% endif %}

              {# Icône + libellé selon statut #}
              {% set is_no_response = not is_selected and not is_present and not is_available_if_needed and not is_available and not is_unavailable and not is_absent and not is_unknown %}

              {% if is_selected %}
                {% set icone = '⭐' %}
                {% set libelle = 'Sél.' %}
                {% set special_style = '' %}
              {% elseif is_present %}
                {% set icone = '✅' %}
                {% set libelle = 'Prés.' %}
                {% set special_style = '' %}
              {% elseif is_available_if_needed %}
                {% set icone = '👋' %}
                {% set libelle = 'Si néc.' %}
                {% set special_style = '' %}
              {% elseif is_available %}
                {% set icone = '👍' %}
                {% set libelle = 'Dispo' %}
                {% set special_style = '' %}
              {% elseif is_unavailable %}
                {% set icone = '👎' %}
                {% set libelle = 'Indispo' %}
                {% set special_style = '' %}
              {% elseif is_absent %}
                {% set icone = '❌' %}
                {% set libelle = 'Absent' %}
                {% set special_style = '' %}
              {% elseif is_unknown %}
                {% set icone = '❓' %}
                {% set libelle = '?' %}
                {% set special_style = '' %}
              {% else %}
                {# Sans réponse - pas de couleur spéciale #}
                {% set icone = '😞' %}
                {% set libelle = 'S.R.' %}
                {% set special_style = '' %}
              {% endif %}

              <td class="border border-gray-300 px-2 py-1 text-center font-semibold {% if special_style %}{{ special_style }}{% else %}{{ cell_bg }}{% endif %}" title="{{ part }}">
                <span class="text-sm">{{ icone }}</span> <span class="text-xs {% if special_style %}font-bold{% else %}{{ text_color }}{% endif %}">{{ libelle }}</span>
              </td>
            {% endfor %}

          </tr>
        {% endfor %}
      </tbody>

    </table>
  </div>

  {# Légende #}
  <div class="mt-8 space-y-4">
    <h2 class="text-lg font-bold text-gray-800">Légende</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      <div class="flex items-center gap-2 bg-green-200 px-3 py-2 rounded border-l-4 border-green-600">
        <span class="text-xl">✅</span>
        <div>
          <div class="text-xs font-bold text-green-900">Présent</div>
          <div class="text-xs text-green-700">Confirmé</div>
        </div>
      </div>

      <div class="flex items-center gap-2 bg-amber-300 px-3 py-2 rounded border-l-4 border-amber-600">
        <span class="text-xl">⭐</span>
        <div>
          <div class="text-xs font-bold text-amber-900">Sélectionné</div>
          <div class="text-xs text-amber-700">Important</div>
        </div>
      </div>

      <div class="flex items-center gap-2 bg-blue-200 px-3 py-2 rounded border-l-4 border-blue-500">
        <span class="text-xl">👍</span>
        <div>
          <div class="text-xs font-bold text-blue-900">Disponible</div>
          <div class="text-xs text-blue-700">En réserve</div>
        </div>
      </div>

      <div class="flex items-center gap-2 bg-cyan-200 px-3 py-2 rounded border-l-4 border-cyan-500">
        <span class="text-xl">👋</span>
        <div>
          <div class="text-xs font-bold text-cyan-900">Si nécessaire</div>
          <div class="text-xs text-cyan-700">En dernier recours</div>
        </div>
      </div>

      <div class="flex items-center gap-2 bg-red-200 px-3 py-2 rounded border-l-4 border-red-600">
        <span class="text-xl">👎</span>
        <div>
          <div class="text-xs font-bold text-red-900">Indisponible</div>
          <div class="text-xs text-red-700">Empêchement</div>
        </div>
      </div>

      <div class="flex items-center gap-2 bg-red-300 px-3 py-2 rounded border-l-4 border-red-700">
        <span class="text-xl">❌</span>
        <div>
          <div class="text-xs font-bold text-red-950">Absent</div>
          <div class="text-xs text-red-800">Confirmé</div>
        </div>
      </div>

      <div class="flex items-center gap-2 bg-orange-200 px-3 py-2 rounded border-l-4 border-orange-500">
        <span class="text-xl">❓</span>
        <div>
          <div class="text-xs font-bold text-orange-900">Ne sait pas</div>
          <div class="text-xs text-orange-700">À confirmer</div>
        </div>
      </div>

      <div class="flex items-center gap-2 bg-gray-200 px-3 py-2 rounded border-l-4 border-gray-400">
        <span class="text-xl">😞</span>
        <div>
          <div class="text-xs font-bold text-gray-700">Sans réponse</div>
          <div class="text-xs text-gray-600">À remplir</div>
        </div>
      </div>
    </div>

    <div class="mt-6 pt-4 border-t-2 border-gray-300">
      <h3 class="font-bold text-gray-800 mb-3">État des joueurs (smileys)</h3>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-2 mb-4">
        <div class="text-center">
          <div class="text-2xl">😊</div>
          <div class="text-xs text-gray-700">Complet</div>
          <div class="text-xs text-gray-500">Tout rempli</div>
        </div>
        <div class="text-center">
          <div class="text-2xl">🤔</div>
          <div class="text-xs text-gray-700">En attente</div>
          <div class="text-xs text-gray-500">Réponse < 3j</div>
        </div>
        <div class="text-center">
          <div class="text-2xl">😕</div>
          <div class="text-xs text-gray-700">Hésitant</div>
          <div class="text-xs text-gray-500">> 3 "?"</div>
        </div>
        <div class="text-center">
          <div class="text-2xl">😒</div>
          <div class="text-xs text-gray-700">Incomplet</div>
          <div class="text-xs text-gray-500">Manque réponse</div>
        </div>
      </div>
    </div>

    <div class="mt-4 pt-4 border-t-2 border-gray-300 space-y-2">
      <div class="flex items-center gap-2">
        <span class="text-lg">✓</span>
        <span class="text-xs text-gray-700"><strong>En-tête vert :</strong> Au moins 6 joueurs dans Présents OU Disponibles OU Sélectionnés</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-lg">⚠️</span>
        <span class="text-xs text-gray-700"><strong>En-tête rouge :</strong> Moins de 6 joueurs dans toutes les catégories (sous-effectif)</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-lg">⚠️</span>
        <span class="text-xs text-gray-700"><strong>Alerte terrains :</strong> Nombre de terrains anormal (pas 0, 1 ou ".")</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-lg" style="background: rgb(244 63 94); color: white; padding: 0 4px; border-radius: 2px;">😞</span>
        <span class="text-xs text-gray-700"><strong>Cellule rouge :</strong> Pas de réponse du joueur pour cet événement</span>
      </div>
    </div>
  </div>

  {% endif %}

  <div class="mt-8">
    <a href="/" class="text-amber-600 hover:underline">← Retour à l'accueil</a>
  </div>
</div>

<style>
  .agenda-table-container {
    position: relative;
    /* Enable scrolling and zoom on mobile */
    touch-action: manipulation;
    /* Scrollbar styling */
    scrollbar-width: thin;
    scrollbar-color: #d1d5db #f3f4f6;
  }

  /* Gradient indicating scrollable content on right */
  .agenda-table-container::after {
    content: '';
    position: sticky;
    right: 0;
    top: 0;
    width: 40px;
    height: 100%;
    background: linear-gradient(to right, transparent, rgba(0,0,0,0.05));
    pointer-events: none;
    z-index: 5;
  }

  .agenda-table thead {
    position: sticky;
    top: 0;
    z-index: 20;
    background: white;
  }

  .agenda-table th.sticky-left {
    position: sticky;
    left: 0;
    z-index: 30;
  }

  .agenda-table td.sticky-left {
    position: sticky;
    left: 0;
    z-index: 10;
  }

  @media (max-width: 640px) {
    .agenda-table-container {
      font-size: 0.75rem;
    }
    .agenda-table th, .agenda-table td {
      padding: 4px 6px;
    }
  }

  .zoom-btn.active {
    background-color: #d97706;
    color: white;
    border-color: #92400e;
  }
</style>

<script>
(function() {
  var table = document.querySelector('.agenda-table');
  var buttons = document.querySelectorAll('.zoom-btn');
  if (!table || !buttons.length) return;

  function applyZoom(z) {
    table.style.zoom = z;
    buttons.forEach(function(b) {
      b.classList.toggle('active', parseFloat(b.dataset.zoom) === z);
    });
    try { localStorage.setItem('agendaZoom', String(z)); } catch (e) {}
  }

  var stored = null;
  try { stored = localStorage.getItem('agendaZoom'); } catch (e) {}
  var initial = stored ? parseFloat(stored) : (window.innerWidth < 768 ? 0.65 : 1);

  applyZoom(initial);

  buttons.forEach(function(b) {
    b.addEventListener('click', function() {
      applyZoom(parseFloat(b.dataset.zoom));
    });
  });
})();
</script>

{% endblock %}
