{% extends "base.twig" %}

{% block title %}Agenda{% endblock %}

{% block content %}
<div class="px-4 py-6">
  <h1 class="text-3xl font-bold mb-6">Agenda — événements à venir</h1>

  {% if manifestations is empty %}
    <p class="text-gray-600">Aucun événement à venir.</p>
  {% else %}

  {# Tableau croisé avec sticky première colonne #}
  <div class="overflow-x-auto border border-gray-400 rounded" style="max-height:80vh; overflow-y:auto;">
    <table class="border-collapse text-sm whitespace-nowrap">

      {# ── EN-TÊTE : une colonne par manifestation ── #}
      <thead class="sticky top-0 z-20 bg-white">
        <tr>
          {# Cellule coin haut-gauche #}
          <th class="sticky left-0 z-30 bg-gray-200 border border-gray-400 px-3 py-2 text-left font-semibold min-w-[160px]">
            Joueurs
          </th>

          {% for mid, m in manifestations %}
            {% if m.annule %}
              {% set col_bg = 'bg-red-100' %}
            {% elseif m.provisoire %}
              {% set col_bg = 'bg-orange-100' %}
            {% else %}
              {% set col_bg = loop.index is odd ? 'bg-blue-50' : 'bg-slate-50' %}
            {% endif %}

            {# Seuil 6 joueurs : vert si ok, rouge sinon #}
            {% set ok = (m.nb_present + m.nb_disponible + m.nb_disponible_si_necessaire + m.nb_selection) >= 6 %}
            {% set stats_color = ok ? 'text-green-700' : 'text-red-700' %}

            <th class="border border-gray-400 px-2 py-1 text-center font-normal {{ col_bg }} min-w-[130px] align-top">
              <div class="font-bold text-xs">{{ m.type }}</div>
              <div class="font-semibold text-xs">{{ m.titre }}</div>
              <div class="text-xs">{{ m.date_display }}</div>
              <div class="text-xs">{{ m.time_range }}</div>
              <div class="text-xs text-gray-600">Nb terrain(s) : {{ m.nb_terrains }}</div>
              <div class="text-xs font-medium" title="{{ m.lieu }}">{{ m.lieu|slice(0,18) }}</div>
              {% if m.annule %}
                <div class="text-xs font-bold text-red-700">Annulé</div>
              {% elseif m.provisoire %}
                <div class="text-xs font-bold text-orange-600">Provisoire</div>
              {% else %}
                <div class="text-xs text-gray-500">Confirmé</div>
              {% endif %}

              {# Stats participation #}
              <div class="mt-1 text-xs {{ stats_color }} leading-tight">
                {% if m.nb_selection > 0 %}<div class="font-bold">{{ m.nb_selection }} sélectionné(s)</div>{% endif %}
                {% if m.nb_present > 0 %}<div>{{ m.nb_present }} présent(s)</div>{% endif %}
                {% if m.nb_absent > 0 %}<div>{{ m.nb_absent }} absent(s)</div>{% endif %}
                {% if m.nb_disponible > 0 %}<div>{{ m.nb_disponible }} disponible(s)</div>{% endif %}
                {% if m.nb_disponible_si_necessaire > 0 %}<div>{{ m.nb_disponible_si_necessaire }} dispo si néc.</div>{% endif %}
                {% if m.nb_indisponible > 0 %}<div>{{ m.nb_indisponible }} indisponible(s)</div>{% endif %}
                {% if m.nb_ne_sait_pas > 0 %}<div>Ne sait pas : {{ m.nb_ne_sait_pas }}</div>{% endif %}
                {% if m.nb_pas_de_reponse > 0 %}<div class="text-purple-700">Sans réponse : {{ m.nb_pas_de_reponse }}</div>{% endif %}
              </div>

              {% if m.commentaire %}
                <div class="text-xs italic text-gray-500 mt-1" title="{{ m.commentaire }}">ℹ {{ m.commentaire|slice(0,25) }}</div>
              {% endif %}
            </th>
          {% endfor %}
        </tr>
      </thead>

      {# ── LIGNES : un joueur par ligne ── #}
      <tbody>
        {% for jid, nom in joueurs %}
          {% set row = cross[jid] %}

          {# Alerte joueur : pas tout rempli ou "ne sait pas encore" proche #}
          {% set nb_manif = manifestations|length %}
          {% set alerte = (row.nb_participation < nb_manif) or (row.nb_ne_sait_pas_proche > 0) or (row.nb_ne_sait_pas > 3) %}

          <tr class="{{ loop.index is odd ? 'bg-white' : 'bg-gray-50' }} hover:bg-yellow-50">

            {# Nom joueur — sticky gauche #}
            <td class="sticky left-0 z-10 border border-gray-400 px-2 py-1 font-medium bg-gray-100 min-w-[160px]">
              {% if alerte %}
                <span class="text-purple-700">⚠</span>
              {% endif %}
              {{ nom }}
            </td>

            {# Cellule par manifestation #}
            {% for mid, m in manifestations %}
              {% set part = row[mid] ?? '' %}

              {# Couleur de fond de la cellule #}
              {% if part contains 'Sélectionné' %}
                {% set cell_bg = 'bg-green-200' %}
              {% elseif m.annule %}
                {% set cell_bg = 'bg-red-100' %}
              {% elseif m.provisoire %}
                {% set cell_bg = 'bg-orange-100' %}
              {% elseif loop.index is odd %}
                {% set cell_bg = 'bg-blue-50' %}
              {% else %}
                {% set cell_bg = 'bg-slate-50' %}
              {% endif %}

              {# Icône + libellé selon statut #}
              {% if part contains 'Présent' or part contains 'Oui' %}
                {% set icone = '✅' %}
                {% set libelle = part %}
              {% elseif part contains 'Sélectionné' %}
                {% set icone = '⭐' %}
                {% set libelle = 'Sélectionné(e)' %}
              {% elseif part contains 'Disponible si n' %}
                {% set icone = '👍' %}
                {% set libelle = 'Disponible si ...' %}
              {% elseif part contains 'Disponible' or part contains 'Joker' %}
                {% set icone = '👍' %}
                {% set libelle = part %}
              {% elseif part contains 'Indisponible' %}
                {% set icone = '👎' %}
                {% set libelle = part %}
              {% elseif part contains 'Absent' or part contains 'Non' %}
                {% set icone = '❌' %}
                {% set libelle = part %}
              {% elseif part contains 'Ne sait pas' or part contains '?' %}
                {% set icone = '❓' %}
                {% set libelle = part %}
              {% else %}
                {% set icone = '😞' %}
                {% set libelle = '' %}
              {% endif %}

              <td class="border border-gray-400 px-2 py-1 text-center {{ cell_bg }}" title="{{ part }}">
                <span class="text-base">{{ icone }}</span>
                {% if libelle %}<span class="text-xs block">{{ libelle }}</span>{% endif %}
              </td>
            {% endfor %}

          </tr>
        {% endfor %}
      </tbody>

    </table>
  </div>

  {# Légende #}
  <div class="mt-6 text-xs text-gray-600 grid grid-cols-2 md:grid-cols-4 gap-2">
    <div>✅ Présent</div>
    <div>⭐ Sélectionné(e)</div>
    <div>👍 Disponible</div>
    <div>👎 Indisponible</div>
    <div>❌ Absent</div>
    <div>❓ Ne sait pas encore</div>
    <div>😞 Sans réponse</div>
    <div class="text-green-700 font-bold">Vert = seuil 6 joueurs atteint</div>
  </div>

  {% endif %}

  <div class="mt-8">
    <a href="/" class="text-amber-600 hover:underline">← Retour à l'accueil</a>
  </div>
</div>
{% endblock %}
