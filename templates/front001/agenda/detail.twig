{% extends"base.twig" %}

{% block title %}{{ event.title }} - Agenda - USM Volley{% endblock %}

{% block content %}
<div class="mx-auto max-w-4xl px-4 py-12">
  <a href="/agenda" class="text-amber-600 hover:underline mb-6 inline-block">
    ← Retour à l'agenda
  </a>

  <article class="bg-white rounded-lg shadow-lg overflow-hidden">
    {# Header #}
    <div class="bg-amber-900 text-white p-8">
      <h1 class="mb-4">{{ event.title }}</h1>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div>
          <div class="text-sm opacity-75">Date</div>
          <div class="font-bold">{{ event.date_display }}</div>
        </div>

        {% if event.time_display %}
          <div>
            <div class="text-sm opacity-75">Heure</div>
            <div class="font-bold">{{ event.time_display }}</div>
          </div>
        {% endif %}

        {% if event.duration %}
          <div>
            <div class="text-sm opacity-75">Durée</div>
            <div class="font-bold">{{ event.duration }}</div>
          </div>
        {% endif %}

        {% if event.nb_courts %}
          <div>
            <div class="text-sm opacity-75">Terrains</div>
            <div class="font-bold">{{ event.nb_courts }}</div>
          </div>
        {% endif %}
      </div>
    </div>

    {# Content #}
    <div class="p-8 space-y-6">
      {# Status #}
      {% if event.status == 'Annulé' %}
        <div class="bg-red-100 border-2 border-red-600 text-red-800 px-4 py-3 rounded-lg">
          ⚠️ Cet événement a été ANNULÉ
        </div>
      {% elseif event.status == 'Provisoire' %}
        <div class="bg-yellow-100 border-2 border-yellow-600 text-yellow-800 px-4 py-3 rounded-lg">
          ⚠️ Cet événement est PROVISOIRE
        </div>
      {% else %}
        <div class="bg-green-100 border-2 border-green-600 text-green-800 px-4 py-3 rounded-lg">
          ✓ Cet événement est confirmé
        </div>
      {% endif %}

      {# Location #}
      {% if event.location %}
        <div class="border-b pb-4">
          <h2 class="mb-2">📍 Lieu</h2>
          <p class="text-lg text-gray-700">{{ event.location }}</p>
        </div>
      {% endif %}

      {# Type #}
      {% if event.type %}
        <div class="border-b pb-4">
          <h2 class="mb-2">🏐 Type</h2>
          <p class="text-lg text-gray-700">{{ event.type }}</p>
        </div>
      {% endif %}

      {# Comment #}
      {% if event.comment %}
        <div class="border-b pb-4">
          <h2 class="mb-2">📝 Informations</h2>
          <p class="text-gray-700 whitespace-pre-wrap">{{ event.comment }}</p>
        </div>
      {% endif %}

      {# Event status badge #}
      <div class="flex gap-2 flex-wrap">
        {% if event.is_soon %}
          <span class="bg-amber-500 text-white px-4 py-2 rounded-full">
            Événement imminent
          </span>
        {% endif %}
        <span class="bg-gray-300 text-gray-800 px-4 py-2 rounded-full">
          Statut: {{ event.status }}
        </span>
      </div>

      {# Participation stats #}
      {% set part = event.participation %}
      <div class="border-t pt-6 mt-6">
        <h2 class="mb-4">Disponibilités des joueurs</h2>

        {# Summary stats #}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
          <div class="bg-green-50 border border-green-200 p-4 rounded">
            <div class="text-3xl text-green-700">{{ part.present }}</div>
            <div class="text-sm text-green-600">Présents</div>
          </div>
          <div class="bg-blue-50 border border-blue-200 p-4 rounded">
            <div class="text-3xl text-blue-700">{{ part.available }}</div>
            <div class="text-sm text-blue-600">Disponibles</div>
          </div>
          <div class="bg-amber-50 border border-amber-200 p-4 rounded">
            <div class="text-3xl text-amber-700">{{ part.selected }}</div>
            <div class="text-sm text-amber-600">Sélectionnés</div>
          </div>
          <div class="bg-red-50 border border-red-200 p-4 rounded">
            <div class="text-3xl text-red-700">{{ part.unavailable }}</div>
            <div class="text-sm text-red-600">Indisponibles</div>
          </div>
        </div>

        {# Feasibility indicator #}
        {% set total_committed = part.present + part.available + part.selected %}
        {% if part.enough_players %}
          <div class="bg-green-100 border-2 border-green-600 text-green-800 px-4 py-3 rounded-lg mb-4">
            ✓ Équipe complète: {{ total_committed }} joueurs engagés (≥6 requis)
          </div>
        {% else %}
          <div class="bg-red-100 border-2 border-red-600 text-red-800 px-4 py-3 rounded-lg mb-4">
            ⚠️ Sous-effectif: {{ total_committed }} joueurs engagés (6 requis)
          </div>
        {% endif %}

        {# Detailed breakdown table #}
        <div class="overflow-x-auto">
          <table class="w-full border-collapse">
            <thead>
              <tr class="bg-gray-100 border-b-2 border-gray-400">
                <th class="px-4 py-2 text-left">Statut</th>
                <th class="px-4 py-2 text-right">Nombre</th>
                <th class="px-4 py-2 text-center">Pourcentage</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b">
                <td class="px-4 py-2">✓ Présents</td>
                <td class="px-4 py-2 text-right">{{ part.present }}</td>
                <td class="px-4 py-2 text-center">{% if part.total_responses > 0 %}{{ (part.present / part.total_responses * 100)|round(0) }}{% else %}0{% endif %}%</td>
              </tr>
              <tr class="border-b bg-blue-50">
                <td class="px-4 py-2">◐ Disponibles</td>
                <td class="px-4 py-2 text-right">{{ part.available }}</td>
                <td class="px-4 py-2 text-center">{% if part.total_responses > 0 %}{{ (part.available / part.total_responses * 100)|round(0) }}{% else %}0{% endif %}%</td>
              </tr>
              <tr class="border-b bg-amber-50">
                <td class="px-4 py-2">★ Sélectionnés</td>
                <td class="px-4 py-2 text-right">{{ part.selected }}</td>
                <td class="px-4 py-2 text-center">{% if part.total_responses > 0 %}{{ (part.selected / part.total_responses * 100)|round(0) }}{% else %}0{% endif %}%</td>
              </tr>
              <tr class="border-b bg-red-50">
                <td class="px-4 py-2">✗ Indisponibles</td>
                <td class="px-4 py-2 text-right">{{ part.unavailable }}</td>
                <td class="px-4 py-2 text-center">{% if part.total_responses > 0 %}{{ (part.unavailable / part.total_responses * 100)|round(0) }}{% else %}0{% endif %}%</td>
              </tr>
              <tr class="border-b">
                <td class="px-4 py-2">✘ Absents</td>
                <td class="px-4 py-2 text-right">{{ part.absent }}</td>
                <td class="px-4 py-2 text-center">{% if part.total_responses > 0 %}{{ (part.absent / part.total_responses * 100)|round(0) }}{% else %}0{% endif %}%</td>
              </tr>
              <tr class="bg-gray-100">
                <td class="px-4 py-2">Total avec réponse</td>
                <td class="px-4 py-2 text-right">{{ part.total_responses }}</td>
                <td class="px-4 py-2 text-center">100%</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </article>

  <div class="mt-8 space-y-4">
    <a href="/agenda" class="block text-center bg-amber-600 hover:bg-amber-700 text-white px-6 py-3 rounded-lg">
      ← Retour à l'agenda
    </a>
    <a href="/" class="block text-center bg-gray-400 hover:bg-gray-500 text-white px-6 py-3 rounded-lg">
      Retour à l'accueil
    </a>
  </div>
</div>
{% endblock %}
