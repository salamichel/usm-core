{% extends 'base.twig' %}
{% block title %}Blog — USM Volley{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto px-4 py-10">
  <div class="flex items-center justify-between mb-6 border-b-4 border-black pb-3 flex-wrap gap-4">
    <h1 class="text-3xl font-black">Actualités</h1>
    {% if selected_tag %}
      <div class="flex items-center gap-2">
        <span class="text-sm text-gray-600">Filtre :</span>
        <div class="bg-blue-100 text-blue-800 border border-blue-400 px-3 py-1 rounded font-semibold text-sm">
          {{ selected_tag.name }}
          <a href="{{ url('blog') }}" class="ml-2 text-blue-600 hover:text-blue-900 font-black">×</a>
        </div>
      </div>
    {% endif %}
  </div>

  {% if all_tags|length %}
  <div class="mb-8 p-4 bg-gray-50 border-2 border-gray-200 rounded">
    <div class="text-xs font-black text-gray-600 mb-3 uppercase">Filtrer par tag</div>
    <div class="flex flex-wrap gap-2">
      {% for tag in all_tags %}
      {% set count = tag_counts[tag.id] ?? 0 %}
      {% if count > 0 or selected_tag and selected_tag.id == tag.id %}
        <a href="{{ url('blog/tag/' ~ tag.slug) }}"
           class="inline-block px-3 py-2 text-sm font-semibold rounded transition
           {% if selected_tag and selected_tag.id == tag.id %}
             bg-blue-600 text-white border border-blue-600
           {% else %}
             bg-white text-gray-700 border border-gray-300 hover:border-blue-400 hover:text-blue-600
           {% endif %}">
          {{ tag.name }}
          <span class="text-xs opacity-75">({{ count }})</span>
        </a>
      {% endif %}
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {% if posts|length %}
    <div class="space-y-6">
      {% for post in posts %}
      <article class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000]">
        <h2 class="text-xl font-black mb-1">
          <a href="{{ url('blog/' ~ post.slug) }}" class="hover:underline">{{ post.title }}</a>
        </h2>
        {% if post.published_at %}
          <time class="text-xs text-gray-500 mb-3 block">{{ post.published_at|date_fr }}</time>
        {% endif %}
        {% if post.excerpt %}
          <p class="text-gray-700">{{ post.excerpt }}</p>
        {% endif %}
        <a href="{{ url('blog/' ~ post.slug) }}" class="inline-block mt-3 text-sm font-bold underline hover:no-underline">Lire la suite →</a>
      </article>
      {% endfor %}
    </div>
  {% else %}
    <p class="text-gray-500 italic">Aucun article publié pour le moment.</p>
  {% endif %}
</div>
{% endblock %}
