{% extends 'base.twig' %}
{% block title %}Blog — USM Volley{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto px-4 py-10">
  <h1 class="text-3xl font-black mb-6 border-b-4 border-black pb-3">Actualités</h1>

  {% if posts|length %}
    <div class="space-y-6">
      {% for post in posts %}
      <article class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000]">
        <h2 class="text-xl font-black mb-1">
          <a href="{{ url('blog/' ~ post.slug) }}" class="hover:underline">{{ post.title }}</a>
        </h2>
        {% if post.published_at %}
          <time class="text-xs text-gray-500 mb-3 block">{{ post.published_at|date_fr }}</time>
        {% endif %}
        {% if post.excerpt %}
          <p class="text-gray-700">{{ post.excerpt }}</p>
        {% endif %}
        <a href="{{ url('blog/' ~ post.slug) }}" class="inline-block mt-3 text-sm font-bold underline hover:no-underline">Lire la suite →</a>
      </article>
      {% endfor %}
    </div>
  {% else %}
    <p class="text-gray-500 italic">Aucun article publié pour le moment.</p>
  {% endif %}
</div>
{% endblock %}
