{% extends 'base.twig' %}
{% block title %}Blog — USM Volley{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto px-4 py-10">
  <h1 class="text-3xl font-black mb-6 border-b-4 border-black pb-3">Actualités</h1>

  {# ── Barre de filtres ── #}
  {% if all_tags|length or months|length %}
  <form method="GET" action="{{ url('blog') }}"
        class="mb-8 flex flex-wrap items-center gap-2 p-3 border-2 border-gray-200 bg-gray-50 rounded">

    {% if all_tags|length %}
    <select name="tag" onchange="this.form.submit()"
            class="border-2 border-black bg-white px-3 py-1.5 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-black">
      <option value="">Toutes catégories</option>
      {% for tag in all_tags %}
        {% set count = tag_counts[tag.id] ?? 0 %}
        {% if count > 0 %}
          <option value="{{ tag.slug }}" {{ selected_tag and selected_tag.id == tag.id ? 'selected' : '' }}>
            {{ tag.name }} ({{ count }})
          </option>
        {% endif %}
      {% endfor %}
    </select>
    {% endif %}

    {% if months|length %}
    <select name="month" onchange="this.form.submit()"
            class="border-2 border-black bg-white px-3 py-1.5 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-black">
      <option value="">Tous les mois</option>
      {% for month in months %}
        <option value="{{ month }}" {{ selected_month == month ? 'selected' : '' }}>{{ month|month_fr }}</option>
      {% endfor %}
    </select>
    {% endif %}

    <noscript>
      <button type="submit" class="border-2 border-black bg-black text-white px-3 py-1.5 text-sm font-bold">Filtrer</button>
    </noscript>

    {% if selected_tag or selected_month %}
      <a href="{{ url('blog') }}"
         class="ml-auto text-sm font-bold text-gray-700 underline hover:no-underline">Réinitialiser</a>
    {% endif %}
  </form>
  {% endif %}

  {# ── Articles ── #}
  {% if posts|length %}
    <div class="space-y-6">
      {% for post in posts %}
      <article class="border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden">
        {% if post.cover %}
          <a href="{{ url('blog/' ~ post.slug) }}" class="block h-48 overflow-hidden bg-gray-200">
            <img src="{{ asset('uploads/' ~ post.cover.filename) }}" alt="{{ post.title }}" class="w-full h-full object-cover hover:scale-105 transition-transform">
          </a>
        {% endif %}
        <div class="p-6">
          <h2 class="text-xl font-black mb-1">
            <a href="{{ url('blog/' ~ post.slug) }}" class="hover:underline">{{ post.title }}</a>
          </h2>
          {% if post.published_at %}
            <time class="text-xs text-gray-500 mb-3 block">{{ post.published_at|date_fr }}</time>
          {% endif %}
          {% if post.excerpt %}
            <p class="text-gray-700">{{ post.excerpt }}</p>
          {% endif %}
          <a href="{{ url('blog/' ~ post.slug) }}" class="inline-block mt-3 text-sm font-bold underline hover:no-underline">Lire la suite →</a>
        </div>
      </article>
      {% endfor %}
    </div>
  {% else %}
    <p class="text-gray-500 italic">Aucun article pour ces filtres.</p>
  {% endif %}

  {# ── Pagination ── #}
  {% if pagination.totalPages > 1 %}
  <div class="flex flex-wrap items-center justify-center gap-2 mt-10 pt-8 border-t-2 border-gray-300">
    {% set qs = (selected_tag ? '&tag=' ~ selected_tag.slug : '') ~ (selected_month ? '&month=' ~ selected_month : '') %}

    {# Previous button #}
    {% if pagination.hasPrevious() %}
      <a href="{{ url('blog') ~ '?page=' ~ pagination.previousPage() ~ qs }}"
         class="px-4 py-2 border-2 border-black font-bold hover:bg-black hover:text-white transition">← Précédent</a>
    {% else %}
      <span class="px-4 py-2 border-2 border-gray-300 text-gray-400 font-bold">← Précédent</span>
    {% endif %}

    {# Page numbers #}
    <div class="flex gap-1">
      {% for page in pagination.getPageRange(7) %}
        {% if page == pagination.currentPage %}
          <span class="px-3 py-2 border-4 border-black bg-black text-white font-bold">{{ page }}</span>
        {% else %}
          <a href="{{ url('blog') ~ '?page=' ~ page ~ qs }}"
             class="px-3 py-2 border-2 border-black hover:bg-black hover:text-white transition font-bold">{{ page }}</a>
        {% endif %}
      {% endfor %}
    </div>

    {# Next button #}
    {% if pagination.hasNext() %}
      <a href="{{ url('blog') ~ '?page=' ~ pagination.nextPage() ~ qs }}"
         class="px-4 py-2 border-2 border-black font-bold hover:bg-black hover:text-white transition">Suivant →</a>
    {% else %}
      <span class="px-4 py-2 border-2 border-gray-300 text-gray-400 font-bold">Suivant →</span>
    {% endif %}
  </div>

  <div class="text-center text-sm text-gray-600 mt-4">
    Page {{ pagination.currentPage }} / {{ pagination.totalPages }}
  </div>
  {% endif %}

</div>
{% endblock %}
