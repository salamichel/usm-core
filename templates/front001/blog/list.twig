{% extends 'base.twig' %}
{% block title %}Blog — USM Volley{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto px-4 py-10">
  <h1 class="text-3xl font-black mb-6 border-b-4 border-black pb-3">Actualités</h1>

  {# ── Barre de filtres ── #}
  {% if all_tags|length or months|length %}
  <form method="GET" action="{{ url('blog') }}"
        class="mb-8 flex flex-wrap items-center gap-2 p-3 border-2 border-gray-200 bg-gray-50 rounded">

    {% if all_tags|length %}
    <select name="tag" onchange="this.form.submit()"
            class="border-2 border-black bg-white px-3 py-1.5 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-black">
      <option value="">Toutes catégories</option>
      {% for tag in all_tags %}
        {% set count = tag_counts[tag.id] ?? 0 %}
        {% if count > 0 %}
          <option value="{{ tag.slug }}" {{ selected_tag and selected_tag.id == tag.id ? 'selected' : '' }}>
            {{ tag.name }} ({{ count }})
          </option>
        {% endif %}
      {% endfor %}
    </select>
    {% endif %}

    {% if months|length %}
    <select name="month" onchange="this.form.submit()"
            class="border-2 border-black bg-white px-3 py-1.5 text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-black">
      <option value="">Tous les mois</option>
      {% for month in months %}
        <option value="{{ month }}" {{ selected_month == month ? 'selected' : '' }}>{{ month|month_fr }}</option>
      {% endfor %}
    </select>
    {% endif %}

    <noscript>
      <button type="submit" class="border-2 border-black bg-black text-white px-3 py-1.5 text-sm font-bold">Filtrer</button>
    </noscript>

    {% if selected_tag or selected_month %}
      <a href="{{ url('blog') }}"
         class="ml-auto text-sm font-bold text-gray-700 underline hover:no-underline">Réinitialiser</a>
    {% endif %}
  </form>
  {% endif %}

  {# ── Articles ── #}
  {% if posts|length %}

    {# Article vedette — premier article #}
    {% set featured = posts[0] %}
    <article class="border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden mb-8 md:flex">
      {% if featured.cover %}
        <a href="{{ url('blog/' ~ featured.slug) }}"
           class="block md:w-2/5 h-56 md:h-auto shrink-0 overflow-hidden bg-gray-200">
          <img src="{{ image_variant(featured.cover, 'medium') }}"
               alt="{{ featured.title }}"
               class="w-full h-full object-cover hover:scale-105 transition-transform duration-300">
        </a>
      {% endif %}
      <div class="p-6 md:p-8 flex flex-col justify-center {{ featured.cover ? '' : 'w-full' }}">
        {% if featured.published_at %}
          <time class="text-xs text-gray-500 mb-2 block font-semibold uppercase tracking-wide">
            {{ featured.published_at|date_fr }}
          </time>
        {% endif %}
        <h2 class="text-2xl md:text-3xl font-black mb-3 leading-tight">
          <a href="{{ url('blog/' ~ featured.slug) }}" class="hover:underline">{{ featured.title }}</a>
        </h2>
        {% if featured.excerpt %}
          <p class="text-gray-700 leading-relaxed line-clamp-3">{{ featured.excerpt }}</p>
        {% endif %}
        <a href="{{ url('blog/' ~ featured.slug) }}"
           class="inline-block mt-4 px-4 py-2 border-2 border-black bg-black text-white text-sm font-bold hover:bg-white hover:text-black transition self-start">
          Lire la suite →
        </a>
      </div>
    </article>

    {# Reste des articles en grille 2 colonnes #}
    {% if posts|length > 1 %}
    <div class="grid gap-6 md:grid-cols-2">
      {% for post in posts|slice(1) %}
      <article class="border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden flex flex-col">
        {% if post.cover %}
          <a href="{{ url('blog/' ~ post.slug) }}" class="block h-48 shrink-0 overflow-hidden bg-gray-200">
            <img src="{{ image_variant(post.cover, 'medium') }}"
                 alt="{{ post.title }}"
                 class="w-full h-full object-cover hover:scale-105 transition-transform duration-300">
          </a>
        {% endif %}
        <div class="p-5 flex flex-col flex-1">
          {% if post.published_at %}
            <time class="text-xs text-gray-500 mb-1 block font-semibold uppercase tracking-wide">
              {{ post.published_at|date_fr }}
            </time>
          {% endif %}
          <h2 class="text-lg font-black mb-2 leading-snug">
            <a href="{{ url('blog/' ~ post.slug) }}" class="hover:underline">{{ post.title }}</a>
          </h2>
          {% if post.excerpt %}
            <p class="text-gray-700 text-sm leading-relaxed line-clamp-2">{{ post.excerpt }}</p>
          {% endif %}
          <a href="{{ url('blog/' ~ post.slug) }}"
             class="inline-block mt-auto pt-3 text-sm font-bold underline hover:no-underline">
            Lire la suite →
          </a>
        </div>
      </article>
      {% endfor %}
    </div>
    {% endif %}

  {% else %}
    <p class="text-gray-500 italic">Aucun article pour ces filtres.</p>
  {% endif %}

  {# ── Pagination ── #}
  {% if pagination.totalPages > 1 %}
  <div class="flex flex-wrap items-center justify-center gap-2 mt-10 pt-8 border-t-2 border-gray-300">
    {% set qs = (selected_tag ? '&tag=' ~ selected_tag.slug : '') ~ (selected_month ? '&month=' ~ selected_month : '') %}

    {# Previous button #}
    {% if pagination.hasPrevious() %}
      <a href="{{ url('blog') ~ '?page=' ~ pagination.previousPage() ~ qs }}"
         class="px-4 py-2 border-2 border-black font-bold hover:bg-black hover:text-white transition">← Précédent</a>
    {% else %}
      <span class="px-4 py-2 border-2 border-gray-300 text-gray-400 font-bold">← Précédent</span>
    {% endif %}

    {# Page numbers #}
    <div class="flex gap-1">
      {% for page in pagination.getPageRange(7) %}
        {% if page == pagination.currentPage %}
          <span class="px-3 py-2 border-4 border-black bg-black text-white font-bold">{{ page }}</span>
        {% else %}
          <a href="{{ url('blog') ~ '?page=' ~ page ~ qs }}"
             class="px-3 py-2 border-2 border-black hover:bg-black hover:text-white transition font-bold">{{ page }}</a>
        {% endif %}
      {% endfor %}
    </div>

    {# Next button #}
    {% if pagination.hasNext() %}
      <a href="{{ url('blog') ~ '?page=' ~ pagination.nextPage() ~ qs }}"
         class="px-4 py-2 border-2 border-black font-bold hover:bg-black hover:text-white transition">Suivant →</a>
    {% else %}
      <span class="px-4 py-2 border-2 border-gray-300 text-gray-400 font-bold">Suivant →</span>
    {% endif %}
  </div>

  <div class="text-center text-sm text-gray-600 mt-4">
    Page {{ pagination.currentPage }} / {{ pagination.totalPages }}
  </div>
  {% endif %}

</div>
{% endblock %}
