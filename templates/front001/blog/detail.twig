{% extends 'base.twig' %}
{% import '_gallery.twig' as components %}
{% block title %}{{ post.title }} — USM Volley{% endblock %}

{% block content %}
<div class="max-w-3xl mx-auto px-4 py-10">
  <a href="{{ url('blog') }}" class="inline-block mb-6 text-sm font-bold hover:underline">← Retour aux actualités</a>

  <article class="border-4 border-black bg-white p-8 shadow-[8px_8px_0_#000]">
    <h1 class="text-3xl font-black mb-2">{{ post.title }}</h1>
    <div class="flex items-center gap-3 mb-6 flex-wrap">
      {% if post.published_at %}
        <time class="text-sm text-gray-500">{{ post.published_at|date_fr('d/m/Y') }}</time>
      {% endif %}
      {% if post.canalblog_id %}
        <span class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded font-semibold">Importé de CanalBlog</span>
      {% endif %}
    </div>
    <div class="prose prose-gray max-w-none">
      {{ post.content|raw }}
    </div>

    {% if tags|length %}
    <div class="mt-8 pt-8 border-t-2 border-gray-200">
      <div class="text-sm font-black text-gray-600 mb-3">Tags</div>
      <div class="flex flex-wrap gap-2">
        {% for tag in tags %}
        <a href="{{ url('blog/tag/' ~ tag.slug) }}"
           class="inline-block px-3 py-2 text-sm bg-gray-100 hover:bg-blue-100 text-gray-700 hover:text-blue-700 border border-gray-300 hover:border-blue-300 rounded transition">
          {{ tag.name }}
        </a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {{ components.gallery(photos) }}
  </article>
</div>
{% endblock %}

{% block scripts %}
{% if photos|length %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script>
  GLightbox({ selector: '.glightbox', touchNavigation: true, loop: true });
</script>
{% endif %}
{% endblock %}
