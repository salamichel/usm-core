{% extends 'base.twig' %}
{% import '_gallery.twig' as components %}
{% block title %}{{ post.title }} — USM Volley{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto px-4 py-10">
  <a href="{{ url('blog') }}" class="inline-block mb-6 text-sm font-bold hover:underline">← Retour aux actualités</a>

  <article class="border-4 border-black bg-white shadow-[8px_8px_0_#000] overflow-hidden">

    {# Image de couverture hero #}
    {% if post.cover %}
      <div class="h-72 md:h-96 overflow-hidden bg-gray-200">
        <img src="{{ image_variant(post.cover, 'large') }}"
             alt="{{ post.title }}"
             class="w-full h-full object-cover">
      </div>
    {% endif %}

    <div class="p-6 md:p-10">
      <h1 class="text-3xl md:text-4xl font-black mb-2 leading-tight">{{ post.title }}</h1>
      {% if post.published_at %}
        <time class="text-sm text-gray-500 block mb-8 font-semibold uppercase tracking-wide">
          {{ post.published_at|date_fr('d/m/Y') }}
        </time>
      {% endif %}
      <div class="prose prose-gray max-w-none">
        {{ post.content|render_with_config|raw }}
      </div>

      {% if tags|length %}
      <div class="mt-8 pt-8 border-t-2 border-gray-200">
        <div class="text-sm font-black text-gray-600 mb-3">Tags</div>
        <div class="flex flex-wrap gap-2">
          {% for tag in tags %}
          <a href="{{ url('blog/tag/' ~ tag.slug) }}"
             class="inline-block px-3 py-2 text-sm bg-gray-100 hover:bg-blue-100 text-gray-700 hover:text-blue-700 border border-gray-300 hover:border-blue-300 rounded transition">
            {{ tag.name }}
          </a>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      {{ components.gallery(photos) }}

      {# Navigation précédent / suivant #}
      {% if prev_post or next_post %}
      <div class="mt-10 pt-8 border-t-2 border-gray-200 grid grid-cols-2 gap-4">
        <div>
          {% if prev_post %}
          <a href="{{ url('blog/' ~ prev_post.slug) }}"
             class="flex flex-col border-2 border-black hover:bg-amber-50 transition group overflow-hidden">
            {% if prev_post.cover %}
              <img src="{{ image_variant(prev_post.cover, 'thumb') }}" alt="" class="w-full h-24 object-cover">
            {% endif %}
            <div class="p-3">
              <span class="text-xs font-black uppercase tracking-wide text-gray-500">← Article précédent</span>
              <p class="text-sm font-bold leading-snug mt-1 group-hover:underline">{{ prev_post.title }}</p>
            </div>
          </a>
          {% endif %}
        </div>
        <div>
          {% if next_post %}
          <a href="{{ url('blog/' ~ next_post.slug) }}"
             class="flex flex-col border-2 border-black hover:bg-amber-50 transition group overflow-hidden text-right">
            {% if next_post.cover %}
              <img src="{{ image_variant(next_post.cover, 'thumb') }}" alt="" class="w-full h-24 object-cover">
            {% endif %}
            <div class="p-3">
              <span class="text-xs font-black uppercase tracking-wide text-gray-500">Article suivant →</span>
              <p class="text-sm font-bold leading-snug mt-1 group-hover:underline">{{ next_post.title }}</p>
            </div>
          </a>
          {% endif %}
        </div>
      </div>
      {% endif %}
    </div>
  </article>
</div>
{% endblock %}

{% block scripts %}
{% if photos|length %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script>
  GLightbox({ selector: '.glightbox', touchNavigation: true, loop: true });
</script>
{% endif %}
{% endblock %}
