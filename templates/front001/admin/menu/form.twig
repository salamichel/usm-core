{% extends 'admin/layout.twig' %}
{% block title %}{{ item ? 'Éditer' : 'Ajouter' }} un élément de menu{% endblock %}

{% block content %}
<div class="flex items-center gap-4 mb-6">
  <a href="{{ url('admin/menu') }}" class="font-bold hover:underline text-sm">← Retour</a>
  <h1 class="text-3xl font-black">{{ item ? 'Éditer l\'élément' : 'Nouvel élément de menu' }}</h1>
</div>

{% if error %}
  <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-5 font-semibold text-sm">{{ error }}</div>
{% endif %}

<form method="POST" action="{{ action }}" class="space-y-6">
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4 max-w-xl">

    <div>
      <label class="block font-black mb-1" for="label">Libellé *</label>
      <input type="text" id="label" name="label" required
             value="{{ item.label ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>

    <div>
      <label class="block font-black mb-1" for="link_type">Type de lien</label>
      <select id="link_type" name="link_type"
              class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown"
              onchange="toggleTarget(this.value)">
        <option value="none"  {% if (item.link_type ?? 'none') == 'none'  %}selected{% endif %}>Aucun (groupe parent)</option>
        <option value="page"  {% if (item.link_type ?? '') == 'page'  %}selected{% endif %}>Page statique</option>
        <option value="url"   {% if (item.link_type ?? '') == 'url'   %}selected{% endif %}>URL externe</option>
      </select>
    </div>

    <div id="target-page" class="{% if (item.link_type ?? 'none') != 'page' %}hidden{% endif %}">
      <label class="block font-black mb-1" for="target_page">Page</label>
      <select name="target" id="target_page_sel"
              class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
        <option value="">— Choisir une page —</option>
        {% for page in pages %}
          <option value="{{ page.slug }}" {% if (item.target ?? '') == page.slug %}selected{% endif %}>
            {{ page.title }} ({{ page.slug }})
          </option>
        {% endfor %}
      </select>
    </div>

    <div id="target-url" class="{% if (item.link_type ?? 'none') != 'url' %}hidden{% endif %}">
      <label class="block font-black mb-1" for="target_url">URL</label>
      <input type="text" id="target_url" name="target_url"
             value="{{ (item.link_type ?? '') == 'url' ? (item.target ?? '') : '' }}"
             placeholder="https://..."
             class="w-full border-2 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>

    <div>
      <label class="block font-black mb-1" for="parent_id">Parent (niveau 2)</label>
      <select id="parent_id" name="parent_id"
              class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
        <option value="">— Aucun (racine) —</option>
        {% for root in roots %}
          {% if item is null or root.id != item.id %}
          <option value="{{ root.id }}" {% if (item.parent_id ?? '') == root.id %}selected{% endif %}>
            {{ root.label }}
          </option>
          {% endif %}
        {% endfor %}
      </select>
    </div>

    <div>
      <label class="block font-black mb-1" for="position">Position</label>
      <input type="number" id="position" name="position" min="0"
             value="{{ item.position ?? 0 }}"
             class="w-32 border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>
  </div>

  <button type="submit"
          class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    Enregistrer
  </button>
</form>
{% endblock %}

{% block scripts %}
<script>
function toggleTarget(type) {
  document.getElementById('target-page').classList.toggle('hidden', type !== 'page');
  document.getElementById('target-url').classList.toggle('hidden', type !== 'url');
}
// On submit: set the hidden target depending on type
document.querySelector('form').addEventListener('submit', function() {
  const type = document.getElementById('link_type').value;
  if (type === 'page') {
    document.getElementById('target_url').name = '_target_url_disabled';
    document.getElementById('target_page_sel').name = 'target';
  } else if (type === 'url') {
    document.getElementById('target_page_sel').name = '_target_page_disabled';
    document.getElementById('target_url').name = 'target';
  }
});
</script>
{% endblock %}
