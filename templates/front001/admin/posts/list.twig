{% extends 'admin/layout.twig' %}
{% block title %}Articles{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-black">Articles</h1>
  <a href="{{ url('admin/posts/create') }}" class="border-4 border-black bg-usm-brown text-white font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    + Nouveau
  </a>
</div>

{# ── Filtres ── #}
{% if all_tags|length or months|length %}
<div class="mb-6 space-y-3">

  {# Statut #}
  <div class="p-3 bg-gray-50 border-2 border-gray-200 rounded">
    <div class="text-xs font-black text-gray-500 uppercase mb-2">Statut</div>
    <div class="flex flex-wrap gap-2">
      {% set base_qs = (selected_tag ? '&tag=' ~ selected_tag : '') ~ (selected_month ? '&month=' ~ selected_month : '') %}
      <a href="{{ url('admin/posts') ~ '?' ~ base_qs|trim('&') }}"
         class="px-3 py-1 text-sm font-semibold rounded border transition
                {{ not selected_status ? 'bg-black text-white border-black' : 'bg-white text-gray-700 border-gray-300 hover:border-black' }}">
        Tous
      </a>
      <a href="{{ url('admin/posts') ~ '?status=published' ~ base_qs }}"
         class="px-3 py-1 text-sm font-semibold rounded border transition
                {{ selected_status == 'published' ? 'bg-black text-white border-black' : 'bg-white text-gray-700 border-gray-300 hover:border-black' }}">
        Publiés
      </a>
      <a href="{{ url('admin/posts') ~ '?status=draft' ~ base_qs }}"
         class="px-3 py-1 text-sm font-semibold rounded border transition
                {{ selected_status == 'draft' ? 'bg-black text-white border-black' : 'bg-white text-gray-700 border-gray-300 hover:border-black' }}">
        Brouillons
      </a>
    </div>
  </div>

  {# Tags #}
  {% if all_tags|length %}
  <div class="p-3 bg-gray-50 border-2 border-gray-200 rounded">
    <div class="text-xs font-black text-gray-500 uppercase mb-2">Par catégorie</div>
    <div class="flex flex-wrap gap-2">
      {% set status_qs = selected_status ? '&status=' ~ selected_status : '' %}
      {% set month_qs  = selected_month  ? '&month='  ~ selected_month  : '' %}
      <a href="{{ url('admin/posts') ~ '?' ~ (status_qs ~ month_qs)|trim('&') }}"
         class="px-3 py-1 text-sm font-semibold rounded border transition
                {{ not selected_tag ? 'bg-black text-white border-black' : 'bg-white text-gray-700 border-gray-300 hover:border-black' }}">
        Tous
      </a>
      {% for tag in all_tags %}
        <a href="{{ url('admin/posts') ~ '?tag=' ~ tag.slug ~ status_qs ~ month_qs }}"
           class="px-3 py-1 text-sm font-semibold rounded border transition
                  {{ selected_tag == tag.slug ? 'bg-black text-white border-black' : 'bg-white text-gray-700 border-gray-300 hover:border-black' }}">
          {{ tag.name }}
        </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# Mois #}
  {% if months|length %}
  <div class="p-3 bg-gray-50 border-2 border-gray-200 rounded">
    <div class="text-xs font-black text-gray-500 uppercase mb-2">Par mois</div>
    <div class="flex flex-wrap gap-2">
      {% set status_qs = selected_status ? '&status=' ~ selected_status : '' %}
      {% set tag_qs    = selected_tag    ? '&tag='    ~ selected_tag    : '' %}
      <a href="{{ url('admin/posts') ~ '?' ~ (status_qs ~ tag_qs)|trim('&') }}"
         class="px-3 py-1 text-sm font-semibold rounded border transition
                {{ not selected_month ? 'bg-black text-white border-black' : 'bg-white text-gray-700 border-gray-300 hover:border-black' }}">
        Tous
      </a>
      {% for month in months %}
        <a href="{{ url('admin/posts') ~ '?month=' ~ month ~ status_qs ~ tag_qs }}"
           class="px-3 py-1 text-sm font-semibold rounded border transition
                  {{ selected_month == month ? 'bg-black text-white border-black' : 'bg-white text-gray-700 border-gray-300 hover:border-black' }}">
          {{ month|month_fr }}
        </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

</div>
{% endif %}

{# ── Filtres actifs ── #}
{% if selected_tag or selected_month or selected_status %}
<div class="flex flex-wrap items-center gap-2 mb-4 text-sm">
  <span class="text-gray-500">Filtres :</span>
  {% if selected_status %}
    <span class="bg-black text-white px-3 py-1 rounded font-semibold">
      {{ selected_status == 'published' ? 'Publiés' : 'Brouillons' }}
      <a href="{{ url('admin/posts') ~ '?' ~ (selected_tag ? 'tag=' ~ selected_tag : '') ~ (selected_month ? '&month=' ~ selected_month : '') }}" class="ml-2 hover:text-gray-300">×</a>
    </span>
  {% endif %}
  {% if selected_tag %}
    <span class="bg-black text-white px-3 py-1 rounded font-semibold">
      {{ selected_tag }}
      <a href="{{ url('admin/posts') ~ '?' ~ (selected_status ? 'status=' ~ selected_status : '') ~ (selected_month ? '&month=' ~ selected_month : '') }}" class="ml-2 hover:text-gray-300">×</a>
    </span>
  {% endif %}
  {% if selected_month %}
    <span class="bg-black text-white px-3 py-1 rounded font-semibold">
      {{ selected_month|month_fr }}
      <a href="{{ url('admin/posts') ~ '?' ~ (selected_status ? 'status=' ~ selected_status : '') ~ (selected_tag ? '&tag=' ~ selected_tag : '') }}" class="ml-2 hover:text-gray-300">×</a>
    </span>
  {% endif %}
</div>
{% endif %}

{% if posts|length %}

{# ── Mobile : cartes empilées ── #}
<div class="sm:hidden space-y-3">
  {% for post in posts %}
  <div class="border-4 border-black bg-white p-4 shadow-[4px_4px_0_#000]">
    <div class="font-black text-base mb-1 break-words flex items-center gap-2">
      <span>{{ post.title }}</span>
      {% if post.canalblog_id %}
        <span class="bg-blue-100 text-blue-800 border border-blue-400 px-2 py-0.5 text-xs font-bold rounded">API</span>
      {% endif %}
    </div>
    <div class="flex items-center gap-2 flex-wrap text-xs mb-2">
      {% if post.is_published %}
        <span class="bg-green-100 text-green-800 border border-green-400 px-2 py-0.5 font-bold rounded">Publié</span>
      {% else %}
        <span class="bg-gray-100 text-gray-600 border border-gray-400 px-2 py-0.5 font-bold rounded">Brouillon</span>
      {% endif %}
      {% if post.published_at %}
        <span class="text-gray-500">{{ post.published_at|date_fr }}</span>
      {% endif %}
    </div>
    <div class="text-gray-500 font-mono text-xs mb-3 break-all">{{ post.slug }}</div>
    <div class="flex flex-wrap gap-2">
      <a href="{{ url('blog/' ~ post.slug) }}" target="_blank" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Voir</a>
      <a href="{{ url('admin/posts/' ~ post.id ~ '/edit') }}" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Éditer</a>
      <form method="POST" action="{{ url('admin/posts/' ~ post.id ~ '/delete') }}"
            onsubmit="return confirm('Supprimer cet article ?')">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
      </form>
    </div>
  </div>
  {% endfor %}
</div>

{# ── Desktop : tableau ── #}
<div class="hidden sm:block border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-black text-white">
      <tr>
        <th class="text-left px-4 py-3 font-black">Titre</th>
        <th class="text-left px-4 py-3 font-black">Slug</th>
        <th class="text-left px-4 py-3 font-black">Statut</th>
        <th class="text-left px-4 py-3 font-black">Date</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for post in posts %}
      <tr class="border-t-2 border-gray-200 hover:bg-amber-50">
        <td class="px-4 py-3">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="font-semibold">{{ post.title }}</span>
            {% if post.canalblog_id %}
              <span class="bg-blue-100 text-blue-800 border border-blue-400 px-2 py-0.5 text-xs font-bold rounded">API</span>
            {% endif %}
          </div>
        </td>
        <td class="px-4 py-3 text-gray-500 font-mono text-xs">{{ post.slug }}</td>
        <td class="px-4 py-3">
          {% if post.is_published %}
            <span class="bg-green-100 text-green-800 border border-green-400 px-2 py-0.5 text-xs font-bold rounded">Publié</span>
          {% else %}
            <span class="bg-gray-100 text-gray-600 border border-gray-400 px-2 py-0.5 text-xs font-bold rounded">Brouillon</span>
          {% endif %}
        </td>
        <td class="px-4 py-3 text-gray-500 text-xs">{{ post.published_at|date_fr }}</td>
        <td class="px-4 py-3 flex gap-2 justify-end">
          <a href="{{ url('blog/' ~ post.slug) }}" target="_blank" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Voir</a>
          <a href="{{ url('admin/posts/' ~ post.id ~ '/edit') }}" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Éditer</a>
          <form method="POST" action="{{ url('admin/posts/' ~ post.id ~ '/delete') }}"
                onsubmit="return confirm('Supprimer cet article ?')">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
          </form>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
  <p class="text-gray-500 italic">Aucun article.</p>
{% endif %}
{% endblock %}
