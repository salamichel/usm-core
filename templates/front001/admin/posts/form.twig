{% extends 'admin/layout.twig' %}
{% block title %}{{ post ? 'Éditer' : 'Nouvel' }} article{% endblock %}

{% block content %}
<div class="flex items-center gap-4 mb-6">
  <a href="{{ url('admin/posts') }}" class="font-bold hover:underline text-sm">← Retour</a>
  <h1 class="text-3xl font-black">{{ post ? 'Éditer l\'article' : 'Nouvel article' }}</h1>
</div>

{% if error %}
  <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-5 font-semibold text-sm">{{ error }}</div>
{% endif %}

<form method="POST" action="{{ action }}" enctype="multipart/form-data" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">

    {% if post and post.canalblog_id %}
    <div class="bg-blue-50 border-2 border-blue-300 p-3 rounded">
      <div class="text-xs text-blue-600 font-bold mb-1">Importé via API CanalBlog</div>
      <div class="font-mono text-sm text-blue-900">ID: {{ post.canalblog_id }}</div>
    </div>
    {% endif %}

    <div>
      <label class="block font-black mb-1" for="title">Titre *</label>
      <input type="text" id="title" name="title" required
             value="{{ post.title ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>

    <div>
      <label class="block font-black mb-1" for="slug">Slug</label>
      <input type="text" id="slug" name="slug"
             value="{{ post.slug ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-usm-brown"
             placeholder="généré automatiquement depuis le titre">
      <div class="text-xs text-gray-600 mt-1" id="slug-preview"></div>
    </div>

    <div>
      <label class="block font-black mb-1" for="excerpt">Extrait</label>
      <textarea id="excerpt" name="excerpt" rows="3"
                class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">{{ post.excerpt ?? '' }}</textarea>
    </div>

    <div>
      <label class="block font-black mb-1" for="content">Contenu</label>
      <textarea id="content" name="content">{{ post.content ?? '' }}</textarea>
    </div>

    <div class="flex flex-wrap gap-6 items-start">
      <div>
        <label class="block font-black mb-1" for="published_at">Date de publication</label>
        <input type="datetime-local" id="published_at" name="published_at"
               value="{{ post.published_at ?? default_date ?? '' }}"
               class="border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
      </div>
      <div class="flex items-center gap-3 pt-7">
        <input type="checkbox" id="is_published" name="is_published" value="1"
               {% if post is null or post.is_published %}checked{% endif %}
               class="w-5 h-5 border-2 border-black">
        <label class="font-black" for="is_published">Publié</label>
      </div>
      <div class="flex items-center gap-3 pt-7">
        <input type="checkbox" id="is_slider" name="is_slider" value="1"
               {% if post and post.is_slider %}checked{% endif %}
               class="w-5 h-5 border-2 border-amber-500">
        <label class="font-black" for="is_slider">📌 Épingler dans le slider</label>
      </div>
    </div>

    <div>
      <label class="block font-black mb-3">Tags</label>
      {% if all_tags|length %}
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {% for tag in all_tags %}
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="tags[]" value="{{ tag.id }}"
                 {% if tag.id in tag_ids %}checked{% endif %}
                 class="w-4 h-4 border-2 border-black">
          <span class="text-sm">{{ tag.name }}</span>
        </label>
        {% endfor %}
      </div>
      {% else %}
      <div class="bg-amber-50 border-2 border-amber-300 p-3 rounded text-sm text-amber-800">
        <strong>Aucun tag disponible.</strong> Les tags seront créés automatiquement lors de l'import d'articles CanalBlog ou peuvent être ajoutés via l'API.
      </div>
      {% endif %}
    </div>
  </div>

  {# ── Galerie photos (Dropzone) ── #}
  {% include 'admin/_photo_dropzone.twig' with {
    entity_id:   post ? post.id : 0,
    entity_type: 'post',
    upload_url:  post ? url('admin/posts/' ~ post.id ~ '/photos/upload') : '',
    photos:      photos
  } %}

  <button type="submit"
          class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    Enregistrer
  </button>
</form>
{% endblock %}

{% block scripts %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/jodit@3/build/jodit.min.css">
<link rel="stylesheet" href="{{ asset('content-styles.css') }}">
<script src="https://cdn.jsdelivr.net/npm/jodit@3/build/jodit.min.js"></script>
<script>
  (function () {
    const csrfToken = document.querySelector('[name="_csrf_token"]').value;
    const uploadUrl = '{{ url("admin/media/upload") }}';

    const editor = Jodit.make('#content', {
      language: 'fr',
      height: 400,
      toolbarButtonSize: 'small',
      buttons: 'bold,italic,underline,strikethrough,eraser,|,ul,ol,|,align,|,fontsize,paragraph,|,link,image,file,|,table,|,undo,redo,|,source',
      controls: {
        paragraph: {
          list: {
            p:          'Paragraphe',
            h1:         'Titre 1',
            h2:         'Titre 2',
            h3:         'Titre 3',
            h4:         'Titre 4',
            blockquote: 'Citation',
          }
        }
      },
      uploader: {
        url: uploadUrl,
        data: { _csrf_token: csrfToken },
        format: 'json',
        isSuccess: function (resp) { return resp.ok === true; },
        getMessage: function (resp) { return resp.error || 'Erreur inconnue'; },
        process: function (resp) {
          return {
            files:    [resp.url],
            path:     '',
            baseurl:  '',
            error:    resp.ok ? 0 : 1,
            msg:      resp.error || '',
            isImages: [resp.isImage],
            names:    [resp.name],
          };
        },
        defaultHandlerSuccess: function (data) {
          if (!data.files || !data.files.length) return;
          data.files.forEach(function (url, i) {
            const isImage = data.isImages && data.isImages[i];
            const name    = (data.names && data.names[i]) ? data.names[i] : url.split('/').pop();
            if (isImage) {
              editor.s.insertImage(url, null, '100%');
            } else {
              const link = editor.createInside.element('a');
              link.setAttribute('href', url);
              link.setAttribute('target', '_blank');
              link.setAttribute('rel', 'noopener noreferrer');
              link.textContent = name;
              editor.s.insertNode(link);
            }
          });
        }
      }
    });
  }());

  const titleInput = document.getElementById('title');
  const publishedAtInput = document.getElementById('published_at');
  const slugInput = document.getElementById('slug');
  const slugPreview = document.getElementById('slug-preview');

  function normalizeSlugText(text) {
    text = text.toLowerCase();
    const replacements = {
      'à': 'a', 'á': 'a', 'â': 'a', 'ã': 'a', 'ä': 'a',
      'è': 'e', 'é': 'e', 'ê': 'e', 'ë': 'e',
      'ì': 'i', 'í': 'i', 'î': 'i', 'ï': 'i',
      'ò': 'o', 'ó': 'o', 'ô': 'o', 'õ': 'o', 'ö': 'o',
      'ù': 'u', 'ú': 'u', 'û': 'u', 'ü': 'u',
      'ç': 'c', 'ñ': 'n'
    };
    for (let char in replacements) {
      text = text.replaceAll(char, replacements[char]);
    }
    // Replace special characters with hyphens, keep alphanumeric and hyphens
    text = text.replace(/[^a-z0-9\-\s]/g, '-').trim();
    // Convert spaces to hyphens
    text = text.replace(/\s+/g, '-');
    // Remove duplicate hyphens
    text = text.replace(/-+/g, '-');
    return text.replace(/^-+|-+$/g, '');
  }

  function updateSlugPreview() {
    if (slugInput.value) {
      slugPreview.textContent = 'Slug personnalisé';
      return;
    }

    const title = titleInput.value.trim();
    const publishedAt = publishedAtInput.value;

    if (!title) {
      slugPreview.textContent = '';
      return;
    }

    let preview = normalizeSlugText(title);

    if (publishedAt) {
      const date = new Date(publishedAt);
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, '0');
      const day = String(date.getDate()).padStart(2, '0');
      preview = `${year}/${month}/${day}/${preview}`;
    }

    slugPreview.textContent = 'Aperçu: ' + preview;
  }

  titleInput.addEventListener('input', updateSlugPreview);
  publishedAtInput.addEventListener('change', updateSlugPreview);
  slugInput.addEventListener('input', updateSlugPreview);

  updateSlugPreview();
</script>
{% endblock %}
