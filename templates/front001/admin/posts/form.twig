{% extends 'admin/layout.twig' %}
{% block title %}{{ post ? 'Éditer' : 'Nouvel' }} article{% endblock %}

{% block content %}
<div class="flex items-center gap-4 mb-6">
  <a href="{{ url('admin/posts') }}" class="font-bold hover:underline text-sm">← Retour</a>
  <h1 class="text-3xl font-black">{{ post ? 'Éditer l\'article' : 'Nouvel article' }}</h1>
</div>

{% if error %}
  <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-5 font-semibold text-sm">{{ error }}</div>
{% endif %}

<form method="POST" action="{{ action }}" enctype="multipart/form-data" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">

    <div>
      <label class="block font-black mb-1" for="title">Titre *</label>
      <input type="text" id="title" name="title" required
             value="{{ post.title ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>

    <div>
      <label class="block font-black mb-1" for="slug">Slug</label>
      <input type="text" id="slug" name="slug"
             value="{{ post.slug ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-usm-brown"
             placeholder="généré automatiquement depuis le titre">
    </div>

    <div>
      <label class="block font-black mb-1" for="excerpt">Extrait</label>
      <textarea id="excerpt" name="excerpt" rows="3"
                class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">{{ post.excerpt ?? '' }}</textarea>
      <p class="text-xs text-gray-600 mt-1">Laissez vide pour générer automatiquement via IA</p>
    </div>

    <div>
      <label class="block font-black mb-1" for="meta_description">Description SEO (méta)</label>
      <input type="text" id="meta_description" name="meta_description" maxlength="160"
             value="{{ post.meta_description ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown"
             placeholder="Max. 160 caractères">
      <p class="text-xs text-gray-600 mt-1">Laissez vide pour générer automatiquement via IA</p>
    </div>

    <div>
      <div class="flex justify-between items-center mb-2">
        <label class="block font-black" for="content">Contenu</label>
        <button type="button" id="improve-content-btn"
                class="border-2 border-black bg-yellow-300 text-black font-bold px-4 py-1 text-sm hover:bg-yellow-200 transition-all">
          ✨ Améliorer le contenu
        </button>
      </div>
      <div id="editor" class="border-2 border-black min-h-[300px]">{{ post and post.content ? post.content|raw : '' }}</div>
      <input type="hidden" id="content" name="content" value="{{ post.content ?? '' }}">
    </div>

    <div class="flex flex-wrap gap-6 items-start">
      <div>
        <label class="block font-black mb-1" for="published_at">Date de publication</label>
        <input type="datetime-local" id="published_at" name="published_at"
               value="{{ post.published_at ?? '' }}"
               class="border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
      </div>
      <div class="flex items-center gap-3 pt-7">
        <input type="checkbox" id="is_published" name="is_published" value="1"
               {% if post is not null and post.is_published %}checked{% endif %}
               class="w-5 h-5 border-2 border-black">
        <label class="font-black" for="is_published">Publié</label>
      </div>
    </div>
  </div>

  {# ── Galerie photos (Dropzone) ── #}
  {% include 'admin/_photo_dropzone.twig' with {
    entity_id:   post ? post.id : 0,
    entity_type: 'post',
    upload_url:  post ? url('admin/posts/' ~ post.id ~ '/photos/upload') : '',
    photos:      photos
  } %}

  <button type="submit"
          class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    Enregistrer
  </button>
</form>
{% endblock %}

{% block scripts %}
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
  const quill = new Quill('#editor', {
    theme: 'snow',
    modules: {
      toolbar: [
        [{ header: [1,2,3,false] }],
        ['bold','italic','underline','strike'],
        [{ list: 'ordered' },{ list: 'bullet' }],
        ['link','image'],
        ['clean']
      ]
    }
  });

  document.querySelector('form').addEventListener('submit', () => {
    document.getElementById('content').value = quill.root.innerHTML;
  });

  // Improve content button handler
  document.getElementById('improve-content-btn')?.addEventListener('click', async function(e) {
    e.preventDefault();

    const text = quill.getText();
    if (!text.trim()) {
      alert('Veuillez remplir le contenu avant de demander une amélioration');
      return;
    }

    const btn = this;
    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = '⏳ Génération...';

    try {
      const response = await fetch('{{ url("admin/api/improve-content") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'text=' + encodeURIComponent(text)
      });

      const data = await response.json();

      if (data.success) {
        const confirmed = confirm('Voici la version améliorée :\n\n' + data.improved_text.substring(0, 200) + '...\n\nRemplacer le contenu ?');
        if (confirmed) {
          quill.setContents(quill.clipboard.convert(data.improved_text));
        }
      } else {
        alert('Erreur : ' + (data.error || 'Impossible de générer'));
      }
    } catch (error) {
      alert('Erreur réseau : ' + error.message);
    } finally {
      btn.disabled = false;
      btn.textContent = originalText;
    }
  });
</script>
{% endblock %}
