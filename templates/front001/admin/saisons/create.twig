{% extends 'admin/layout.twig' %}
{% block title %}Nouvelle saison{% endblock %}

{% block content %}
<div class="mb-6">
  <a href="{{ url('admin/saisons') }}" class="text-sm text-gray-500 hover:underline">← Saisons</a>
  <h1 class="mt-1">Nouvelle saison</h1>
</div>

{% if error is defined and error %}
  <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-4 font-semibold">{{ error }}</div>
{% endif %}

<div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] max-w-lg">
  <form method="POST" action="{{ url('admin/saisons/create') }}">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
    <label class="block font-black mb-1" for="libelle">Libellé (ex: 2024-2025)</label>
    <input id="libelle" name="libelle" type="text"
           value="{{ saison.libelle ?? '' }}"
           class="w-full border-4 border-black px-3 py-2 font-semibold focus:outline-none focus:ring-2 focus:ring-amber-400 mb-4"
           placeholder="2024-2025" required autofocus>
    <button type="submit"
            class="border-4 border-black bg-usm-brown text-white font-black px-6 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
      Créer
    </button>
  </form>
</div>
{% endblock %}
