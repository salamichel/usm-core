{% extends 'admin/layout.twig' %}
{% block title %}Saisons{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-black">Saisons</h1>
  <a href="{{ url('admin/saisons/create') }}"
     class="border-4 border-black bg-usm-brown text-white font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    + Nouvelle saison
  </a>
</div>

{% if saisons|length %}
<div class="border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-black text-white">
      <tr>
        <th class="text-left px-4 py-3 font-black">Libellé</th>
        <th class="text-left px-4 py-3 font-black">Statut</th>
        <th class="text-left px-4 py-3 font-black">Joueurs</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for s in saisons %}
      <tr class="border-t-2 border-gray-200 hover:bg-amber-50">
        <td class="px-4 py-3 font-semibold">{{ s.libelle }}</td>
        <td class="px-4 py-3">
          {% if s.is_active %}
            <span class="bg-green-100 text-green-800 border border-green-400 px-2 py-0.5 text-xs font-bold rounded">Active</span>
          {% else %}
            <span class="bg-gray-100 text-gray-500 border border-gray-300 px-2 py-0.5 text-xs font-bold rounded">Inactive</span>
          {% endif %}
        </td>
        <td class="px-4 py-3 text-gray-600">{{ s.snapshot_count }} joueurs</td>
        <td class="px-4 py-3">
          <div class="flex gap-2 justify-end flex-wrap">
            {% if not s.is_active %}
            <form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/activate') }}">
              <button type="submit" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Activer</button>
            </form>
            {% endif %}
            <form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/flash') }}"
                  onsubmit="return confirm('Flasher la saison « {{ s.libelle }} » ? Les ajustements manuels des équipes seront réinitialisés.')">
              <button type="submit" class="border-2 border-usm-brown text-usm-brown px-2 py-1 text-xs font-bold hover:bg-usm-brown hover:text-white transition">Flash</button>
            </form>
            <a href="{{ url('admin/saisons/' ~ s.id ~ '/snapshots') }}"
               class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Joueurs</a>
            {% if not s.is_active %}
            <form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/delete') }}"
                  onsubmit="return confirm('Supprimer la saison « {{ s.libelle }} » et tous ses snapshots ?')">
              <button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
            </form>
            {% endif %}
          </div>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
  <p class="text-gray-500 italic">Aucune saison. Créez la première ci-dessus.</p>
{% endif %}
{% endblock %}
