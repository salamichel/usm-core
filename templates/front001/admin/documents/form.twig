{% extends 'admin/layout.twig' %}
{% block title %}{{ document ? 'Éditer le' : 'Ajouter un' }} document{% endblock %}

{% block content %}
<div class="flex items-center gap-4 mb-6">
  <a href="{{ url('admin/documents') }}" class="font-bold hover:underline text-sm">← Retour</a>
  <h1 class="text-3xl font-black">{{ document ? 'Éditer le document' : 'Ajouter un document' }}</h1>
</div>

{% if error %}
  <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-5 font-semibold text-sm">{{ error }}</div>
{% endif %}

<form method="POST" action="{{ action }}" enctype="multipart/form-data" class="space-y-6">
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4 max-w-xl">

    <div>
      <label class="block font-black mb-1" for="title">Titre *</label>
      <input type="text" id="title" name="title" required
             value="{{ document.title ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>

    <div>
      <label class="block font-black mb-1" for="doc_type">Catégorie</label>
      <input type="text" id="doc_type" name="doc_type"
             value="{{ document.doc_type ?? '' }}"
             placeholder="ex. Règlement, Convocation, Résultat…"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>

    <div>
      <label class="block font-black mb-1" for="file">
        Fichier {% if not document %}*{% else %}(laisser vide pour conserver l'actuel){% endif %}
      </label>
      {% if document %}
        <p class="text-xs text-gray-500 mb-2">Fichier actuel : <span class="font-mono">{{ document.filename }}</span></p>
      {% endif %}
      <input type="file" id="file" name="file" {% if not document %}required{% endif %}
             accept=".pdf,.jpg,.jpeg,.png,.webp"
             class="w-full border-2 border-black px-3 py-2 bg-white">
      <p class="text-xs text-gray-500 mt-1">Formats acceptés : PDF, JPG, PNG, WebP — max 10 Mo</p>
    </div>

    <div class="flex items-center gap-3">
      <input type="checkbox" id="is_public" name="is_public" value="1"
             {% if (document.is_public ?? 1) %}checked{% endif %}
             class="w-5 h-5 border-2 border-black">
      <label class="font-black" for="is_public">Visible publiquement</label>
    </div>
  </div>

  <button type="submit"
          class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    Enregistrer
  </button>
</form>
{% endblock %}
