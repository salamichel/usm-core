{% extends 'admin/layout.twig' %}
{% block title %}{{ equipe ? 'Modifier : ' ~ equipe.libelle : 'Nouvelle équipe' }}{% endblock %}

{% block content %}
<div class="mb-6">
  <a href="{{ url('admin/equipes-config') }}" class="text-sm text-gray-500 hover:underline">← Équipes</a>
  <h1 class="mt-1">{{ equipe ? equipe.libelle : 'Nouvelle équipe' }}</h1>
</div>

{% if error is defined and error %}
  <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-4 font-semibold">{{ error }}</div>
{% endif %}

<div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] max-w-xl mb-8">
  <form method="POST" action="{{ action }}">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block font-black mb-1 text-sm" for="slug_colonne">Colonne DB</label>
        <input id="slug_colonne" name="slug_colonne" type="text"
               value="{{ equipe.slug_colonne ?? '' }}"
               class="w-full border-4 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-amber-400"
               placeholder="Eq_L1" required>
      </div>
      <div>
        <label class="block font-black mb-1 text-sm" for="libelle">Libellé</label>
        <input id="libelle" name="libelle" type="text"
               value="{{ equipe.libelle ?? '' }}"
               class="w-full border-4 border-black px-3 py-2 font-semibold focus:outline-none focus:ring-2 focus:ring-amber-400"
               placeholder="Loisir 1" required>
      </div>
      <div>
        <label class="block font-black mb-1 text-sm" for="slug">Slug SEO</label>
        <input id="slug" name="slug" type="text"
               value="{{ equipe.slug ?? '' }}"
               class="w-full border-4 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-amber-400"
               placeholder="loisir-1">
      </div>
      <div>
        <label class="block font-black mb-1 text-sm" for="categorie">Catégorie</label>
        <input id="categorie" name="categorie" type="text"
               value="{{ equipe.categorie ?? '' }}"
               class="w-full border-4 border-black px-3 py-2 font-semibold focus:outline-none focus:ring-2 focus:ring-amber-400"
               placeholder="Compétition" required>
      </div>
      <div>
        <label class="block font-black mb-1 text-sm" for="ordre">Ordre</label>
        <input id="ordre" name="ordre" type="number" min="0"
               value="{{ equipe.ordre ?? 0 }}"
               class="w-full border-4 border-black px-3 py-2 font-semibold focus:outline-none focus:ring-2 focus:ring-amber-400">
      </div>
    </div>

    {# Agenda Filter Mapping #}
    <fieldset class="border-2 border-gray-300 p-4 mb-4 rounded">
      <legend class="font-black text-sm px-2">Filtres Agenda</legend>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block font-black mb-1 text-sm" for="team_filter">Code équipe (Team Filter)</label>
          <input id="team_filter" name="team_filter" type="text"
                 value="{{ equipe.team_filter ?? equipe.slug_colonne ?? '' }}"
                 class="w-full border-4 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-amber-400"
                 placeholder="Ex: Eq_L2">
          <p class="text-xs text-gray-600 mt-1">Code équipe pour filtrer l'agenda (auto-rempli depuis colonne DB)</p>
        </div>
        <div>
          <label class="block font-black mb-1 text-sm" for="manifestation_filter">Filtre manifestation</label>
          <input id="manifestation_filter" name="manifestation_filter" type="text"
                 value="{{ equipe.manifestation_filter ?? '' }}"
                 class="w-full border-4 border-black px-3 py-2 font-semibold focus:outline-none focus:ring-2 focus:ring-amber-400"
                 placeholder="Ex: Match L2">
          <p class="text-xs text-gray-600 mt-1">Filtre supplémentaire pour l'agenda (optionnel)</p>
        </div>
      </div>
    </fieldset>
    <label class="flex items-center gap-2 mb-4 cursor-pointer">
      <input type="checkbox" name="is_active" value="1"
             {% if equipe is null or equipe.is_active %}checked{% endif %}
             class="w-4 h-4 border-2 border-black">
      <span class="font-semibold text-sm">Active</span>
    </label>
    <button type="submit"
            class="border-4 border-black bg-usm-brown text-white font-black px-6 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
      Enregistrer
    </button>
  </form>
</div>

{% if equipe and saisons|length %}
<div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000]">
  <h2 class="mb-4">Photos & joueurs par saison</h2>
  <table class="w-full text-sm">
    <thead class="bg-black text-white">
      <tr>
        <th class="text-left px-4 py-3 font-black">Saison</th>
        <th class="text-left px-4 py-3 font-black">Photos</th>
        <th class="text-left px-4 py-3 font-black">Joueurs</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for s in saisons %}
      <tr class="border-t-2 border-gray-200 hover:bg-amber-50">
        <td class="px-4 py-3 font-semibold">
          {{ s.libelle }}
          {% if s.is_active %}<span class="ml-2 text-xs text-green-700 font-bold">Active</span>{% endif %}
        </td>
        <td class="px-4 py-3 text-gray-500">{{ s.photo_count }}</td>
        <td class="px-4 py-3 text-gray-500">{{ s.joueur_count }}</td>
        <td class="px-4 py-3 flex gap-2 justify-end">
          <a href="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ s.id ~ '/photos') }}"
             class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Photos</a>
          <a href="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ s.id ~ '/joueurs') }}"
             class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Joueurs</a>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}
{% endblock %}
