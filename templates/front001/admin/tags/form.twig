{% extends 'admin/layout.twig' %}
{% block title %}{{ tag ? 'Éditer' : 'Nouveau' }} tag{% endblock %}

{% block content %}
<div class="flex items-center gap-4 mb-6">
  <a href="{{ url('admin/tags') }}" class="font-bold hover:underline text-sm">← Retour</a>
  <h1>{{ tag ? 'Éditer le tag' : 'Nouveau tag' }}</h1>
</div>

{% if error %}
  <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-5 font-semibold text-sm">{{ error }}</div>
{% endif %}

<form method="POST" action="{{ action }}" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">
    <div>
      <label class="block font-black mb-1" for="name">Nom *</label>
      <input type="text" id="name" name="name" required
             value="{{ tag.name ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>

    <div>
      <label class="block font-black mb-1" for="slug">Slug</label>
      <input type="text" id="slug" name="slug"
             value="{{ tag.slug ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-usm-brown"
             placeholder="généré automatiquement depuis le nom">
    </div>

    {% if tag and tag.post_count > 0 %}
    <div class="bg-blue-50 border-2 border-blue-300 p-3 rounded text-sm">
      <span class="text-blue-900 font-semibold">{{ tag.post_count }} article(s)</span> utilise(nt) ce tag
    </div>
    {% endif %}
  </div>

  <div class="flex gap-3">
    <button type="submit" class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
      {{ tag ? 'Mettre à jour' : 'Créer' }}
    </button>
    {% if tag %}
    <a href="{{ url('admin/tags') }}" class="border-4 border-black bg-white text-black font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
      Annuler
    </a>
    {% endif %}
  </div>
</form>
{% endblock %}
