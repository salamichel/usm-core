{% extends 'admin/layout.twig' %}
{% block title %}{{ page ? 'Éditer la' : 'Nouvelle' }} page{% endblock %}

{% block content %}
<div class="flex items-center gap-4 mb-6">
  <a href="{{ url('admin/pages') }}" class="font-bold hover:underline text-sm">← Retour</a>
  <h1 class="text-3xl font-black">{{ page ? 'Éditer la page' : 'Nouvelle page' }}</h1>
</div>

{% if error %}
  <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-5 font-semibold text-sm">{{ error }}</div>
{% endif %}

<form method="POST" action="{{ action }}" enctype="multipart/form-data" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">

    <div>
      <label class="block font-black mb-1" for="title">Titre *</label>
      <input type="text" id="title" name="title" required
             value="{{ page.title ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>

    <div>
      <label class="block font-black mb-1" for="slug">Slug</label>
      <input type="text" id="slug" name="slug"
             value="{{ page.slug ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-usm-brown"
             placeholder="généré automatiquement depuis le titre">
    </div>

    <div>
      <label class="block font-black mb-1" for="content">Contenu</label>
      <textarea id="content" name="content">{{ page.content ?? '' }}</textarea>
    </div>

    <div class="flex items-center gap-3">
      <input type="checkbox" id="is_published" name="is_published" value="1"
             {% if page is null or page.is_published %}checked{% endif %}
             class="w-5 h-5 border-2 border-black">
      <label class="font-black" for="is_published">Publiée</label>
    </div>
  </div>

  {# ── Galerie photos (Dropzone) ── #}
  {% include 'admin/_photo_dropzone.twig' with {
    entity_id:   page ? page.id : 0,
    entity_type: 'page',
    upload_url:  page ? url('admin/pages/' ~ page.id ~ '/photos/upload') : '',
    photos:      photos
  } %}

  <button type="submit"
          class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    Enregistrer
  </button>
</form>
{% endblock %}

{% block scripts %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.20/summernote-lite.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.20/summernote-lite.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.20/lang/summernote-fr-FR.min.js"></script>
<style>
  .note-editor .note-editable ul,
  .note-editor .note-editable ol {
    margin-left: 0 !important;
    padding-left: 0 !important;
    margin-top: 0.5rem !important;
    margin-bottom: 0.5rem !important;
  }
  .note-editor .note-editable ul {
    counter-reset: none !important;
  }
  .note-editor .note-editable ul li {
    margin-left: 2rem !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    padding-left: 0.5rem !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    list-style: none !important;
    position: relative;
  }
  .note-editor .note-editable ul li::before {
    content: '🏐';
    position: absolute;
    left: -1.5rem;
    width: 1.5rem;
    text-align: center;
  }
  .note-editor .note-editable ol {
    counter-reset: custom-counter;
    margin-left: 0 !important;
    padding-left: 0 !important;
  }
  .note-editor .note-editable ol li {
    counter-increment: custom-counter;
    margin-left: 2rem !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    padding-left: 0.5rem !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    list-style: none !important;
    position: relative;
  }
  .note-editor .note-editable ol li::before {
    content: counter(custom-counter) '.';
    position: absolute;
    left: -2rem;
    width: 1.5rem;
    text-align: right;
  }
</style>
<script>
  $('#content').summernote({
    height: 400,
    lang: 'fr-FR',
    toolbar: [
      ['style',  ['style']],
      ['font',   ['bold', 'italic', 'underline', 'strikethrough', 'clear']],
      ['para',   ['ul', 'ol']],
      ['table',  ['table']],
      ['insert', ['link', 'picture']],
      ['view',   ['codeview']]
    ]
  });
  $('form').on('submit', function () {
    document.getElementById('content').value = $('#content').summernote('code');
  });
</script>
{% endblock %}
