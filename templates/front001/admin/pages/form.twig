{% extends 'admin/layout.twig' %}
{% block title %}{{ page ? 'Éditer la' : 'Nouvelle' }} page{% endblock %}

{% block content %}
<div class="flex items-center gap-4 mb-6">
  <a href="{{ url('admin/pages') }}" class="font-bold hover:underline text-sm">← Retour</a>
  <h1 class="text-3xl font-black">{{ page ? 'Éditer la page' : 'Nouvelle page' }}</h1>
</div>

{% if error %}
  <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-5 font-semibold text-sm">{{ error }}</div>
{% endif %}

<form method="POST" action="{{ action }}" enctype="multipart/form-data" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">

    <div>
      <label class="block font-black mb-1" for="title">Titre *</label>
      <input type="text" id="title" name="title" required
             value="{{ page.title ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>

    <div>
      <label class="block font-black mb-1" for="slug">Slug</label>
      <input type="text" id="slug" name="slug"
             value="{{ page.slug ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-usm-brown"
             placeholder="généré automatiquement depuis le titre">
    </div>

    <div>
      <label class="block font-black mb-1" for="meta_description">Description SEO (méta)</label>
      <input type="text" id="meta_description" name="meta_description" maxlength="160"
             value="{{ page.meta_description ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown"
             placeholder="Max. 160 caractères">
      <p class="text-xs text-gray-600 mt-1">Laissez vide pour générer automatiquement via IA</p>
    </div>

    <div>
      <div class="flex justify-between items-center mb-2">
        <label class="block font-black" for="content">Contenu</label>
        <button type="button" id="improve-content-btn"
                class="border-2 border-black bg-yellow-300 text-black font-bold px-4 py-1 text-sm hover:bg-yellow-200 transition-all">
          ✨ Améliorer le contenu
        </button>
      </div>
      <div id="editor" class="border-2 border-black min-h-[400px]">{{ page and page.content ? page.content|raw : '' }}</div>
      <input type="hidden" id="content" name="content" value="{{ page.content ?? '' }}">
    </div>

    <div class="flex items-center gap-3">
      <input type="checkbox" id="is_published" name="is_published" value="1"
             {% if page is null or page.is_published %}checked{% endif %}
             class="w-5 h-5 border-2 border-black">
      <label class="font-black" for="is_published">Publiée</label>
    </div>
  </div>

  {# ── Galerie photos (Dropzone) ── #}
  {% include 'admin/_photo_dropzone.twig' with {
    entity_id:   page ? page.id : 0,
    entity_type: 'page',
    upload_url:  page ? url('admin/pages/' ~ page.id ~ '/photos/upload') : '',
    photos:      photos
  } %}

  <button type="submit"
          class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    Enregistrer
  </button>
</form>

{# ── Modal pour les suggestions d'amélioration ── #}
<div id="improve-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
  <div class="bg-white border-4 border-black shadow-[8px_8px_0_#000] max-w-2xl w-full max-h-[80vh] overflow-y-auto">
    <div class="bg-gradient-to-r from-yellow-300 to-yellow-200 border-b-4 border-black p-6">
      <h2 class="text-2xl font-black text-black">✨ Version améliorée</h2>
      <p class="text-sm text-gray-700 mt-1">Proposée par notre IA magique 🎩</p>
    </div>

    <div class="p-8">
      <div id="improved-text-display" class="prose prose-sm max-w-none mb-8 p-6 bg-amber-50 border-2 border-dashed border-usm-brown rounded-lg">
        <!-- Le texte amélioré s'affichera ici -->
      </div>

      <div class="bg-yellow-50 border-2 border-yellow-300 p-4 rounded mb-6 text-sm">
        <p class="text-gray-700">
          <span class="font-bold">💡 Conseil :</span> Le texte proposé a été amélioré pour plus de clarté, d'engagement et de style. N'hésite pas à le personnaliser davantage si besoin !
        </p>
      </div>
    </div>

    <div class="border-t-4 border-black bg-gray-50 p-6 flex gap-3">
      <button id="modal-cancel-btn" type="button"
              class="flex-1 border-2 border-black bg-white text-black font-bold px-6 py-3 hover:bg-gray-200 transition-all">
        ← Refuser
      </button>
      <button id="modal-accept-btn" type="button"
              class="flex-1 border-4 border-black bg-green-400 text-black font-black px-6 py-3 shadow-[3px_3px_0_#000] hover:shadow-[1px_1px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
        ✓ Accepter & remplacer
      </button>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
  const quill = new Quill('#editor', {
    theme: 'snow',
    modules: {
      toolbar: [
        [{ header: [1,2,3,false] }],
        ['bold','italic','underline','strike'],
        [{ list: 'ordered' },{ list: 'bullet' }],
        ['link','image'],
        ['clean']
      ]
    }
  });

  document.querySelector('form').addEventListener('submit', () => {
    document.getElementById('content').value = quill.root.innerHTML;
  });

  // Improve content button handler
  let pendingImprovedText = null;

  document.getElementById('improve-content-btn')?.addEventListener('click', async function(e) {
    e.preventDefault();

    const text = quill.getText();
    if (!text.trim()) {
      alert('Veuillez remplir le contenu avant de demander une amélioration');
      return;
    }

    const btn = this;
    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = '⏳ Génération en cours...';

    try {
      const response = await fetch('{{ url("admin/api/improve-content") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'text=' + encodeURIComponent(text)
      });

      const data = await response.json();

      if (data.success) {
        pendingImprovedText = data.improved_text;
        showImproveModal(data.improved_text);
      } else {
        alert('❌ Oups ! ' + (data.error || 'Impossible de générer une amélioration'));
      }
    } catch (error) {
      alert('🔌 Erreur réseau : ' + error.message);
    } finally {
      btn.disabled = false;
      btn.textContent = originalText;
    }
  });

  function showImproveModal(text) {
    const modal = document.getElementById('improve-modal');
    const display = document.getElementById('improved-text-display');

    // Format le texte avec des paragraphes et du styling
    const formatted = text
      .split('\n\n')
      .filter(p => p.trim())
      .map(p => '<p class="mb-4 leading-relaxed">' + p.trim() + '</p>')
      .join('');

    display.innerHTML = formatted;
    modal.classList.remove('hidden');
  }

  function hideImproveModal() {
    document.getElementById('improve-modal').classList.add('hidden');
    pendingImprovedText = null;
  }

  document.getElementById('modal-cancel-btn')?.addEventListener('click', hideImproveModal);

  document.getElementById('modal-accept-btn')?.addEventListener('click', function() {
    if (pendingImprovedText) {
      quill.setContents(quill.clipboard.convert(pendingImprovedText));
      hideImproveModal();
    }
  });

  // Fermer la modal au clic en dehors
  document.getElementById('improve-modal')?.addEventListener('click', function(e) {
    if (e.target === this) {
      hideImproveModal();
    }
  });
</script>
{% endblock %}
