{% extends 'admin/layout.twig' %}
{% block title %}Pages statiques{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-black">Pages statiques</h1>
  <a href="{{ url('admin/pages/create') }}" class="border-4 border-black bg-usm-brown text-white font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    + Nouvelle
  </a>
</div>

{% if pages|length %}

{# ── Mobile : cartes empilées ── #}
<div class="sm:hidden space-y-3">
  {% for page in pages %}
  <div class="border-4 border-black bg-white p-4 shadow-[4px_4px_0_#000]">
    <div class="font-black text-base mb-1 break-words">{{ page.title }}</div>
    <div class="text-xs mb-2">
      {% if page.is_published %}
        <span class="bg-green-100 text-green-800 border border-green-400 px-2 py-0.5 font-bold rounded">Publiée</span>
      {% else %}
        <span class="bg-gray-100 text-gray-600 border border-gray-400 px-2 py-0.5 font-bold rounded">Brouillon</span>
      {% endif %}
    </div>
    <div class="text-gray-500 font-mono text-xs mb-3 break-all">/p/{{ page.slug }}</div>
    <div class="flex flex-wrap gap-2">
      <a href="{{ url('p/' ~ page.slug) }}" target="_blank" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Voir</a>
      <a href="{{ url('admin/pages/' ~ page.id ~ '/edit') }}" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Éditer</a>
      <form method="POST" action="{{ url('admin/pages/' ~ page.id ~ '/delete') }}"
            onsubmit="return confirm('Supprimer cette page ?')">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
      </form>
    </div>
  </div>
  {% endfor %}
</div>

{# ── Desktop : tableau ── #}
<div class="hidden sm:block border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-black text-white">
      <tr>
        <th class="text-left px-4 py-3 font-black">Titre</th>
        <th class="text-left px-4 py-3 font-black">Slug</th>
        <th class="text-left px-4 py-3 font-black">Statut</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for page in pages %}
      <tr class="border-t-2 border-gray-200 hover:bg-amber-50">
        <td class="px-4 py-3 font-semibold">{{ page.title }}</td>
        <td class="px-4 py-3 text-gray-500 font-mono text-xs">/p/{{ page.slug }}</td>
        <td class="px-4 py-3">
          {% if page.is_published %}
            <span class="bg-green-100 text-green-800 border border-green-400 px-2 py-0.5 text-xs font-bold rounded">Publiée</span>
          {% else %}
            <span class="bg-gray-100 text-gray-600 border border-gray-400 px-2 py-0.5 text-xs font-bold rounded">Brouillon</span>
          {% endif %}
        </td>
        <td class="px-4 py-3 flex gap-2 justify-end">
          <a href="{{ url('p/' ~ page.slug) }}" target="_blank" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Voir</a>
          <a href="{{ url('admin/pages/' ~ page.id ~ '/edit') }}" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Éditer</a>
          <form method="POST" action="{{ url('admin/pages/' ~ page.id ~ '/delete') }}"
                onsubmit="return confirm('Supprimer cette page ?')">
            <button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
          </form>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
  <p class="text-gray-500 italic">Aucune page.</p>
{% endif %}
{% endblock %}
