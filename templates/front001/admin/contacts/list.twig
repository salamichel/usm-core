{% extends "admin/layout.twig" %}

{% block title %}Messages de contact{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">Messages de contact</h1>

    {% if flash %}
        {% if flash.type == 'success' %}
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6" role="alert">
                {{ flash.message }}
            </div>
        {% elseif flash.type == 'error' %}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6" role="alert">
                {{ flash.message }}
            </div>
        {% endif %}
    {% endif %}

    <!-- Tabs for filtering -->
    <div class="flex gap-4 mb-6 border-b">
        <a
            href="{{ url('admin/contacts') }}?status=new"
            class="px-4 py-2 {% if currentStatus == 'new' %}border-b-2 border-blue-600 text-blue-600 font-semibold{% else %}text-gray-600{% endif %}"
        >
            Nouveaux ({{ newCount }})
        </a>
        <a
            href="{{ url('admin/contacts') }}?status=replied"
            class="px-4 py-2 {% if currentStatus == 'replied' %}border-b-2 border-blue-600 text-blue-600 font-semibold{% else %}text-gray-600{% endif %}"
        >
            Répondus ({{ repliedCount }})
        </a>
        <a
            href="{{ url('admin/contacts') }}?status=archived"
            class="px-4 py-2 {% if currentStatus == 'archived' %}border-b-2 border-blue-600 text-blue-600 font-semibold{% else %}text-gray-600{% endif %}"
        >
            Archivés ({{ archivedCount }})
        </a>
        <a
            href="{{ url('admin/contacts') }}?status=all"
            class="px-4 py-2 {% if currentStatus == 'all' %}border-b-2 border-blue-600 text-blue-600 font-semibold{% else %}text-gray-600{% endif %}"
        >
            Tous
        </a>
    </div>

    {% if contacts %}
        <form method="POST" action="{{ url('admin/contacts/bulk-action') }}" id="bulkForm">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

            <!-- Actions toolbar -->
            <div class="bg-gray-100 border border-gray-300 rounded-lg p-4 mb-4 flex items-center justify-between gap-4 flex-wrap">
                <div class="flex items-center gap-2">
                    <input type="checkbox" id="selectAll" class="w-5 h-5 cursor-pointer">
                    <label for="selectAll" class="text-sm font-semibold cursor-pointer">Sélectionner tous</label>
                    <span id="selectedCount" class="text-xs text-gray-600 ml-2">(0 sélectionné)</span>
                </div>

                <div class="flex gap-2">
                    <select name="action" id="bulkAction" class="px-3 py-2 border border-gray-300 rounded text-sm font-semibold">
                        <option value="">— Choisir une action —</option>
                        <option value="archive">📦 Archiver</option>
                        <option value="delete">🗑️ Supprimer</option>
                    </select>
                    <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded text-sm" id="submitBtn" disabled>
                        Appliquer
                    </button>
                </div>
            </div>

            <!-- Messages list -->
            <div class="space-y-4">
                {% for contact in contacts %}
                    <div class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-md transition flex gap-4">
                        <input type="checkbox" name="contact_ids[]" value="{{ contact.id }}" class="w-5 h-5 cursor-pointer contact-checkbox mt-1" />

                        <div class="flex-1">
                            <div class="flex justify-between items-start mb-3">
                                <div class="flex-1">
                                    <h3 class="text-xl font-semibold">
                                        <a href="{{ url('admin/contacts/' ~ contact.id) }}" class="text-blue-600 hover:text-blue-800">
                                            {{ contact.subject }}
                                        </a>
                                    </h3>
                                    <p class="text-gray-600 text-sm">
                                        <strong>De :</strong> {{ contact.name }} ({{ contact.email }})
                                    </p>
                                </div>
                                <span class="px-3 py-1 rounded-full text-sm font-semibold
                                    {% if contact.status == 'new' %}
                                        bg-blue-100 text-blue-800
                                    {% elseif contact.status == 'replied' %}
                                        bg-green-100 text-green-800
                                    {% else %}
                                        bg-gray-100 text-gray-800
                                    {% endif %}
                                ">
                                    {% if contact.status == 'new' %}Nouveau
                                    {% elseif contact.status == 'replied' %}Répondu
                                    {% else %}Archivé
                                    {% endif %}
                                </span>
                            </div>
                            <p class="text-gray-700 mb-3">{{ contact.message[:150] }}{% if contact.message|length > 150 %}...{% endif %}</p>
                            <p class="text-gray-500 text-xs">
                                Reçu le {{ contact.created_at|date_fr }}
                            </p>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </form>

        <script>
            const selectAll = document.getElementById('selectAll');
            const checkboxes = document.querySelectorAll('.contact-checkbox');
            const selectedCount = document.getElementById('selectedCount');
            const bulkAction = document.getElementById('bulkAction');
            const submitBtn = document.getElementById('submitBtn');
            const bulkForm = document.getElementById('bulkForm');

            function updateCount() {
                const checked = document.querySelectorAll('.contact-checkbox:checked').length;
                selectedCount.textContent = `(${checked} sélectionné${checked > 1 ? 's' : ''})`;
                submitBtn.disabled = checked === 0 || bulkAction.value === '';
            }

            selectAll.addEventListener('change', function() {
                checkboxes.forEach(cb => cb.checked = this.checked);
                updateCount();
            });

            checkboxes.forEach(cb => {
                cb.addEventListener('change', function() {
                    selectAll.checked = Array.from(checkboxes).every(c => c.checked);
                    updateCount();
                });
            });

            bulkAction.addEventListener('change', updateCount);

            bulkForm.addEventListener('submit', function(e) {
                const action = bulkAction.value;
                const checked = document.querySelectorAll('.contact-checkbox:checked').length;

                if (checked === 0) {
                    alert('Veuillez sélectionner au moins un message');
                    e.preventDefault();
                    return false;
                }

                let message = `Êtes-vous sûr de vouloir ${action === 'archive' ? 'archiver' : 'supprimer'} ${checked} message${checked > 1 ? 's' : ''} ?`;
                if (action === 'delete') {
                    message += '\n\n⚠️ Cette action est irréversible !';
                }

                if (!confirm(message)) {
                    e.preventDefault();
                    return false;
                }
            });
        </script>
    {% else %}
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-8 text-center">
            <p class="text-gray-600">Aucun message à afficher.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
