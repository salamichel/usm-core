{% extends "admin/layout.twig" %}

{% block title %}Message de contact - {{ contact.subject }}{% endblock %}

{% block content %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-4xl mx-auto">
        <div class="flex justify-between items-start mb-6">
            <div>
                <h1 class="text-3xl font-bold">{{ contact.subject }}</h1>
                <p class="text-gray-600 mt-2">
                    <strong>De :</strong> {{ contact.name }} &lt;{{ contact.email }}&gt;<br>
                    <strong>Date :</strong> {{ contact.created_at|date_fr }}
                </p>
            </div>
            <span class="px-4 py-2 rounded-full text-sm font-semibold
                {% if contact.status == 'new' %}
                    bg-blue-100 text-blue-800
                {% elseif contact.status == 'replied' %}
                    bg-green-100 text-green-800
                {% else %}
                    bg-gray-100 text-gray-800
                {% endif %}
            ">
                {% if contact.status == 'new' %}Nouveau
                {% elseif contact.status == 'replied' %}Répondu
                {% else %}Archivé
                {% endif %}
            </span>
        </div>

        {% if flash %}
            {% if flash.type == 'success' %}
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-6" role="alert">
                    {{ flash.message }}
                </div>
            {% elseif flash.type == 'error' %}
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-6" role="alert">
                    {{ flash.message }}
                </div>
            {% endif %}
        {% endif %}

        <!-- Original message -->
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 mb-8">
            <h2 class="text-lg font-semibold mb-4">Message original</h2>
            <p class="text-gray-700 whitespace-pre-wrap">{{ contact.message }}</p>
        </div>

        <!-- Previous replies -->
        {% if replies %}
            <div class="mb-8">
                <h2 class="text-lg font-semibold mb-4">Historique des réponses</h2>
                <div class="space-y-4">
                    {% for reply in replies %}
                        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
                            <div class="flex justify-between items-start mb-3">
                                <p class="text-sm text-gray-600">
                                    <strong>Réponse de :</strong> {{ reply.from_email }}
                                </p>
                                <p class="text-xs text-gray-500">{{ reply.created_at|date_fr }}</p>
                            </div>
                            <p class="text-gray-700 whitespace-pre-wrap">{{ reply.reply_text }}</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        <!-- Reply form -->
        <div class="bg-white border border-gray-200 rounded-lg p-6 mb-8">
            <h2 class="text-lg font-semibold mb-4">Répondre</h2>
            <form method="POST" action="{{ url('admin/contacts/' ~ contact.id ~ '/reply') }}">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                <div class="mb-6">
                    <label for="reply" class="block text-gray-700 font-semibold mb-2">Votre réponse *</label>
                    <textarea
                        id="reply"
                        name="reply"
                        rows="8"
                        required
                        placeholder="Entrez votre réponse ici..."
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-500"
                    ></textarea>
                </div>

                <div class="flex justify-between">
                    <a href="{{ url('admin/contacts') }}" class="text-gray-600 hover:text-gray-800">← Retour à la liste</a>
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded-lg">
                        Envoyer la réponse
                    </button>
                </div>
            </form>
        </div>

        <!-- Actions -->
        <div class="flex gap-4">
            {% if contact.status != 'archived' %}
                <form method="POST" action="{{ url('admin/contacts/' ~ contact.id ~ '/status') }}" style="display: inline;">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                    <input type="hidden" name="status" value="archived">
                    <button type="submit" class="bg-gray-500 hover:bg-gray-600 text-white font-semibold py-2 px-4 rounded-lg">
                        Archiver
                    </button>
                </form>
            {% endif %}

            <form method="POST" action="{{ url('admin/contacts/' ~ contact.id ~ '/delete') }}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr ?');">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded-lg">
                    Supprimer
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
