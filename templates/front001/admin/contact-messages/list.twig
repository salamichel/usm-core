{% extends 'admin/layout.twig' %}
{% block title %}Messages de contact{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-black">Messages de contact</h1>
</div>

<p class="text-sm text-gray-600 mb-6">
  Tous les messages reçus via le formulaire de contact.
</p>

{% if messages|length %}
  <div class="border-4 border-black bg-white shadow-[6px_6px_0_#000] divide-y-4 divide-black">
    {% for message in messages %}
    <div class="p-6 hover:bg-amber-50 transition">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-1">
            <h3 class="font-black text-lg">{{ message.name }}</h3>
            {% if not message.read_at %}
              <span class="inline-block bg-usm-brown text-white text-xs px-2 py-0.5 rounded font-black">NOUVEAU</span>
            {% endif %}
          </div>
          <p class="text-sm text-gray-700 font-semibold mb-1">{{ message.subject }}</p>
          <div class="text-xs text-gray-500 mb-2">
            <a href="mailto:{{ message.email }}" class="hover:underline">{{ message.email }}</a>
            {% if message.phone %}
              · <a href="tel:{{ message.phone|replace({' ': ''}) }}" class="hover:underline">{{ message.phone }}</a>
            {% endif %}
            · {{ message.created_at|date_fr }}
          </div>
          <p class="text-sm text-gray-700 line-clamp-2">{{ message.message }}</p>
        </div>
        <div class="flex gap-2 flex-shrink-0">
          <a href="{{ url('admin/contact-messages/' ~ message.id) }}" class="border-2 border-black px-3 py-1 text-sm font-bold hover:bg-black hover:text-white transition">Lire</a>
          <form method="POST" action="{{ url('admin/contact-messages/' ~ message.id ~ '/delete') }}" onsubmit="return confirm('Supprimer ce message ?')">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="border-2 border-red-600 text-red-600 px-3 py-1 text-sm font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
          </form>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
{% else %}
  <div class="border-4 border-black bg-amber-100 p-6 shadow-[4px_4px_0_#000] text-center">
    <p class="text-gray-700 font-semibold">Aucun message pour le moment.</p>
  </div>
{% endif %}
{% endblock %}
