{% extends 'admin/layout.twig' %}
{% block title %}Configuration du site{% endblock %}

{% block content %}
<div class="flex items-center gap-4 mb-6">
  <h1 class="text-3xl font-black">Configuration du site</h1>
</div>

<p class="text-sm text-gray-600 mb-6">
  Ces valeurs sont utilisées dans le footer du site (et plus tard sur la page contact).
</p>

<form method="POST" action="{{ url('admin/site-config') }}" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  {# ── Identité ── #}
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">
    <h2 class="font-black text-lg">Identité du club</h2>

    <div>
      <label class="block font-black mb-1" for="club_name">Nom du club</label>
      <input type="text" id="club_name" name="club_name"
             value="{{ config.club_name|default('') }}"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>

    <div>
      <label class="block font-black mb-1" for="club_tagline">Phrase d'accroche</label>
      <input type="text" id="club_tagline" name="club_tagline"
             value="{{ config.club_tagline|default('') }}"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
      <div class="text-xs text-gray-500 mt-1">Affichée sous le nom du club dans le footer.</div>
    </div>

    <div>
      <label class="block font-black mb-1" for="address">Adresse</label>
      <textarea id="address" name="address" rows="3"
                class="w-full border-2 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-usm-brown">{{ config.address|default('') }}</textarea>
      <div class="text-xs text-gray-500 mt-1">Une ligne par paragraphe (les retours à la ligne sont conservés).</div>
    </div>
  </div>

  {# ── Contact ── #}
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">
    <h2 class="font-black text-lg">Contact</h2>

    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label class="block font-black mb-1" for="email">Email</label>
        <input type="email" id="email" name="email"
               value="{{ config.email|default('') }}"
               placeholder="contact@usm-volley.fr"
               class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
      </div>
      <div>
        <label class="block font-black mb-1" for="phone">Téléphone (optionnel)</label>
        <input type="text" id="phone" name="phone"
               value="{{ config.phone|default('') }}"
               placeholder="06 12 34 56 78"
               class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
      </div>
    </div>
  </div>

  {# ── Réseaux ── #}
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">
    <h2 class="font-black text-lg">Réseaux sociaux</h2>
    <p class="text-xs text-gray-500">Laissez vide pour masquer l'icône dans le footer.</p>

    <div>
      <label class="block font-black mb-1" for="facebook_url">URL Facebook</label>
      <input type="url" id="facebook_url" name="facebook_url"
             value="{{ config.facebook_url|default('') }}"
             placeholder="https://www.facebook.com/usmvolley"
             class="w-full border-2 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>

    <div>
      <label class="block font-black mb-1" for="instagram_url">URL Instagram</label>
      <input type="url" id="instagram_url" name="instagram_url"
             value="{{ config.instagram_url|default('') }}"
             placeholder="https://www.instagram.com/usmvolley"
             class="w-full border-2 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>
  </div>

  {# ── Mentions légales ── #}
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">
    <h2 class="font-black text-lg">Mentions légales</h2>

    <div>
      <label class="block font-black mb-1" for="legal_text">Texte (footer bas)</label>
      <textarea id="legal_text" name="legal_text" rows="2"
                class="w-full border-2 border-black px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-usm-brown">{{ config.legal_text|default('') }}</textarea>
    </div>
  </div>

  {# ── Affichage home page ── #}
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">
    <h2 class="font-black text-lg">Affichage page d'accueil</h2>
    <p class="text-xs text-gray-500">Configuration du nombre d'articles affichés sur la page d'accueil.</p>

    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label class="block font-black mb-1" for="home_slider_posts_count">Posts dans le slider héro</label>
        <input type="number" id="home_slider_posts_count" name="home_slider_posts_count"
               value="{{ config.home_slider_posts_count|default('3') }}"
               min="1" max="10"
               class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
        <div class="text-xs text-gray-500 mt-1">Nombre d'articles dans le slider d'accueil (1-10).</div>
      </div>

      <div>
        <label class="block font-black mb-1" for="home_latest_posts_count">Posts en bas de page</label>
        <input type="number" id="home_latest_posts_count" name="home_latest_posts_count"
               value="{{ config.home_latest_posts_count|default('3') }}"
               min="1" max="12"
               class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
        <div class="text-xs text-gray-500 mt-1">Nombre d'articles "Dernières actualités" (1-12).</div>
      </div>
    </div>
  </div>

  {# ── Apparence ── #}
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-6">
    <h2 class="font-black text-lg">Apparence</h2>

    {# Couleur principale #}
    <div>
      <label class="block font-black mb-2" for="primary_color">Couleur principale</label>
      <div class="flex items-center gap-3 mb-3">
        <input type="color" id="primary_color" name="primary_color"
               value="{{ config.primary_color|default('#94674d') }}"
               class="w-12 h-12 border-2 border-black cursor-pointer p-0.5 bg-white"
               oninput="document.getElementById('hex_input').value=this.value">
        <input type="text" id="hex_input" placeholder="#94674d" maxlength="7"
               value="{{ config.primary_color|default('#94674d') }}"
               class="w-28 border-2 border-black px-2 py-2 font-mono text-sm focus:outline-none"
               oninput="if(/^#[0-9A-Fa-f]{6}$/.test(this.value)){document.getElementById('primary_color').value=this.value}">
        <span class="text-xs text-gray-500">ou saisir le code hex</span>
      </div>
      <div class="flex flex-wrap gap-2">
        {% for preset in [
          {l:'Marron',   v:'#94674d'},{l:'Marine',   v:'#1e3a5f'},{l:'Vert',     v:'#2d6a4f'},
          {l:'Bordeaux', v:'#7b2d3e'},{l:'Ardoise',  v:'#475569'},{l:'Orange',   v:'#c2410c'},
          {l:'Rose',     v:'#be185d'},{l:'Indigo',   v:'#4f46e5'},{l:'Cyan',     v:'#0e7490'},
          {l:'Noir',     v:'#111827'}
        ] %}
          <button type="button"
                  onclick="document.getElementById('primary_color').value='{{ preset.v }}';document.getElementById('hex_input').value='{{ preset.v }}';"
                  class="flex items-center gap-1.5 px-2 py-1 border border-black text-xs font-semibold hover:bg-gray-50 transition">
            <span class="w-3 h-3 border border-black/30 rounded-sm inline-block" style="background:{{ preset.v }}"></span>{{ preset.l }}
          </button>
        {% endfor %}
      </div>
    </div>

    {# Couleurs du header — tableau de prévisualisation #}
    <div class="border-2 border-black p-4 bg-gray-50">
      <p class="font-black text-sm mb-3 uppercase">Couleurs du header</p>
      <p class="text-xs text-gray-500 mb-4">Prévisualisation en bas de page · La <strong>couleur principale</strong> sert d'accent (logo, hover, titres méga menu).</p>

      <div class="grid sm:grid-cols-3 gap-6">

        {# Fond du header #}
        <div>
          <label class="block font-black mb-2 text-sm" for="header_bg_color">Fond du menu</label>
          <div class="flex items-center gap-2 mb-2">
            <input type="color" id="header_bg_color" name="header_bg_color"
                   value="{{ config.header_bg_color|default('#ffffff') }}"
                   class="w-10 h-10 border-2 border-black cursor-pointer p-0.5 bg-white"
                   oninput="syncHex(this,'hex_bg');previewHeader()">
            <input type="text" id="hex_bg" maxlength="7"
                   value="{{ config.header_bg_color|default('#ffffff') }}"
                   class="w-24 border-2 border-black px-2 py-1.5 font-mono text-xs focus:outline-none"
                   oninput="if(/^#[0-9A-Fa-f]{6}$/.test(this.value)){document.getElementById('header_bg_color').value=this.value;previewHeader()}">
          </div>
          <div class="flex flex-wrap gap-1">
            {% for p in [{l:'Blanc',v:'#ffffff'},{l:'Crème',v:'#fffdef'},{l:'Noir',v:'#111827'},{l:'Marine',v:'#1e3a5f'},{l:'Marron',v:'#94674d'}] %}
              <button type="button" onclick="setColor('header_bg_color','hex_bg','{{ p.v }}')"
                      class="flex items-center gap-1 px-1.5 py-0.5 border border-black text-xs hover:bg-gray-100">
                <span class="w-3 h-3 border border-black/20 inline-block" style="background:{{ p.v }}"></span>{{ p.l }}
              </button>
            {% endfor %}
          </div>
        </div>

        {# Texte normal #}
        <div>
          <label class="block font-black mb-2 text-sm" for="header_text_color">Texte des liens</label>
          <div class="flex items-center gap-2 mb-2">
            <input type="color" id="header_text_color" name="header_text_color"
                   value="{{ config.header_text_color|default('#000000') }}"
                   class="w-10 h-10 border-2 border-black cursor-pointer p-0.5 bg-white"
                   oninput="syncHex(this,'hex_text');previewHeader()">
            <input type="text" id="hex_text" maxlength="7"
                   value="{{ config.header_text_color|default('#000000') }}"
                   class="w-24 border-2 border-black px-2 py-1.5 font-mono text-xs focus:outline-none"
                   oninput="if(/^#[0-9A-Fa-f]{6}$/.test(this.value)){document.getElementById('header_text_color').value=this.value;previewHeader()}">
          </div>
          <div class="flex flex-wrap gap-1">
            {% for p in [{l:'Noir',v:'#000000'},{l:'Blanc',v:'#ffffff'},{l:'Marine',v:'#1e3a5f'},{l:'Marron',v:'#4a2c1a'},{l:'Ardoise',v:'#475569'}] %}
              <button type="button" onclick="setColor('header_text_color','hex_text','{{ p.v }}')"
                      class="flex items-center gap-1 px-1.5 py-0.5 border border-black text-xs hover:bg-gray-100">
                <span class="w-3 h-3 border border-black/20 inline-block" style="background:{{ p.v }}"></span>{{ p.l }}
              </button>
            {% endfor %}
          </div>
        </div>

        {# Texte au survol #}
        <div>
          <label class="block font-black mb-2 text-sm" for="header_hover_text_color">Texte au survol</label>
          <div class="flex items-center gap-2 mb-2">
            <input type="color" id="header_hover_text_color" name="header_hover_text_color"
                   value="{{ config.header_hover_text_color|default('#000000') }}"
                   class="w-10 h-10 border-2 border-black cursor-pointer p-0.5 bg-white"
                   oninput="syncHex(this,'hex_hover');previewHeader()">
            <input type="text" id="hex_hover" maxlength="7"
                   value="{{ config.header_hover_text_color|default('#000000') }}"
                   class="w-24 border-2 border-black px-2 py-1.5 font-mono text-xs focus:outline-none"
                   oninput="if(/^#[0-9A-Fa-f]{6}$/.test(this.value)){document.getElementById('header_hover_text_color').value=this.value;previewHeader()}">
          </div>
          <div class="flex flex-wrap gap-1">
            {% for p in [{l:'Noir',v:'#000000'},{l:'Blanc',v:'#ffffff'},{l:'Crème',v:'#fffdef'},{l:'Marine',v:'#1e3a5f'},{l:'Marron',v:'#4a2c1a'}] %}
              <button type="button" onclick="setColor('header_hover_text_color','hex_hover','{{ p.v }}')"
                      class="flex items-center gap-1 px-1.5 py-0.5 border border-black text-xs hover:bg-gray-100">
                <span class="w-3 h-3 border border-black/20 inline-block" style="background:{{ p.v }}"></span>{{ p.l }}
              </button>
            {% endfor %}
          </div>
        </div>

      </div>

      {# Live preview #}
      <div class="mt-4">
        <p class="text-xs text-gray-500 mb-1">Aperçu :</p>
        <div id="header-preview" class="h-14 flex items-center px-6 gap-4 border-4 border-black shadow-[4px_4px_0_#000]"
             style="background:{{ config.header_bg_color|default('#ffffff') }}">
          <span id="prev-logo" class="font-black text-sm px-3 py-1 border-2 border-black shadow-[2px_2px_0_#000]"
                style="background:{{ config.primary_color|default('#94674d') }};color:{{ config.header_text_color|default('#000000') }}">
            USM VOLLEY
          </span>
          <span id="prev-link" class="font-black text-xs uppercase px-3 py-1 border-2 border-transparent"
                style="color:{{ config.header_text_color|default('#000000') }}">
            Agenda
          </span>
          <span id="prev-hover" class="font-black text-xs uppercase px-3 py-1 border-2 border-black shadow-[2px_2px_0_#000]"
                style="background:{{ config.primary_color|default('#94674d') }};color:{{ config.header_hover_text_color|default('#000000') }}">
            Équipes ↗
          </span>
        </div>
      </div>
    </div>

    {# Typographie #}
    <div>
      <label class="block font-black mb-2">Typographie</label>
      {% set knownFonts = ['Inter','Space Grotesk','DM Sans','Syne','Outfit','Poppins','Plus Jakarta Sans','Raleway','Montserrat','Work Sans','Unbounded'] %}
      {% set currentFont = config.font_family|default('') %}
      {% set isCustom = currentFont is not empty and currentFont not in knownFonts %}

      <div class="space-y-1.5 mb-3">

        {# Système #}
        <label class="flex items-center gap-3 px-3 py-2 border-2 cursor-pointer transition
                      {{ currentFont == '' ? 'border-black bg-amber-50' : 'border-gray-200 hover:border-gray-400' }}">
          <input type="radio" name="font_family" value="" class="w-4 h-4 font-radio"
                 {{ currentFont == '' ? 'checked' : '' }}>
          <span class="text-sm font-semibold w-36">Système (défaut)</span>
          <span class="text-base text-gray-500" style="font-family: ui-sans-serif, system-ui, sans-serif">Club USM Mios — Volley</span>
        </label>

        {# Polices connues #}
        {% for f in knownFonts %}
          <label class="flex items-center gap-3 px-3 py-2 border-2 cursor-pointer transition
                        {{ currentFont == f ? 'border-black bg-amber-50' : 'border-gray-200 hover:border-gray-400' }}">
            <input type="radio" name="font_family" value="{{ f }}" class="w-4 h-4 font-radio"
                   {{ currentFont == f ? 'checked' : '' }}>
            <span class="text-sm font-semibold w-36">{{ f }}</span>
            <span class="text-base text-gray-700" style="font-family: '{{ f }}', sans-serif">Club USM Mios — Volley</span>
          </label>
        {% endfor %}

        {# Police personnalisée #}
        <label class="flex items-center gap-3 px-3 py-2 border-2 cursor-pointer transition
                      {{ isCustom ? 'border-black bg-amber-50' : 'border-gray-200 hover:border-gray-400' }}"
               id="custom-font-label">
          <input type="radio" name="font_family" value="__custom__" class="w-4 h-4 font-radio" id="radio-custom"
                 {{ isCustom ? 'checked' : '' }}>
          <span class="text-sm font-semibold w-36">Personnalisée</span>
          <input type="text" id="custom_font_input"
                 value="{{ isCustom ? currentFont : '' }}"
                 placeholder="Ex: Nunito, Josefin Sans, Pacifico…"
                 class="flex-1 border border-gray-300 px-2 py-0.5 text-sm focus:outline-none focus:border-black"
                 onclick="document.getElementById('radio-custom').checked=true"
                 oninput="document.getElementById('radio-custom').checked=true">
        </label>
      </div>
      <div class="text-xs text-gray-500">Noms exacts tels qu'ils apparaissent sur <a href="https://fonts.google.com" target="_blank" class="underline">fonts.google.com</a>.</div>
    </div>
  </div>

  <button type="submit"
          class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    Enregistrer
  </button>
</form>
{% endblock %}

{% block head %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=Space+Grotesk:wght@400;600;700;900&family=DM+Sans:wght@400;600;700;900&family=Syne:wght@400;600;700;900&family=Outfit:wght@400;600;700;900&family=Poppins:wght@400;600;700;900&family=Plus+Jakarta+Sans:wght@400;600;700;900&family=Raleway:wght@400;600;700;900&family=Montserrat:wght@400;600;700;900&family=Work+Sans:wght@400;600;700;900&family=Unbounded:wght@400;600;700;900&display=swap">
{% endblock %}

{% block scripts %}
<script>
  // Sync custom font radio value before submit
  document.querySelector('form').addEventListener('submit', function () {
    const radio = document.getElementById('radio-custom');
    if (radio.checked) {
      const val = document.getElementById('custom_font_input').value.trim();
      radio.value = val;
    }
  });

  function syncHex(colorInput, hexId) {
    document.getElementById(hexId).value = colorInput.value;
  }

  function setColor(colorId, hexId, val) {
    document.getElementById(colorId).value = val;
    document.getElementById(hexId).value = val;
    previewHeader();
  }

  function previewHeader() {
    const bg       = document.getElementById('header_bg_color').value;
    const text     = document.getElementById('header_text_color').value;
    const hoverTxt = document.getElementById('header_hover_text_color').value;
    const accent   = document.getElementById('primary_color').value;

    document.getElementById('header-preview').style.background = bg;
    document.getElementById('prev-logo').style.background      = accent;
    document.getElementById('prev-logo').style.color           = text;
    document.getElementById('prev-link').style.color           = text;
    document.getElementById('prev-hover').style.background     = accent;
    document.getElementById('prev-hover').style.color          = hoverTxt;
  }

  // Update preview when primary color changes too
  document.getElementById('primary_color').addEventListener('input', previewHeader);
</script>
{% endblock %}
