{% extends 'admin/layout.twig' %}
{% block title %}{{ categorie ? 'Éditer : ' ~ categorie.nom : 'Nouvelle catégorie' }}{% endblock %}

{% block content %}
<div class="flex items-center gap-4 mb-6">
  <a href="{{ url('admin/categories-equipes') }}" class="font-bold hover:underline text-sm">← Catégories</a>
  <h1 class="text-3xl font-black">{{ categorie ? 'Éditer la catégorie' : 'Nouvelle catégorie' }}</h1>
</div>

{% if error is defined and error %}
  <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-5 font-semibold text-sm">{{ error }}</div>
{% endif %}

<form method="POST" action="{{ action }}" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">

    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block font-black mb-1 text-sm" for="nom">Nom *</label>
        <input id="nom" name="nom" type="text" required
               value="{{ categorie.nom ?? '' }}"
               class="w-full border-4 border-black px-3 py-2 font-semibold focus:outline-none focus:ring-2 focus:ring-amber-400"
               placeholder="Compétition">
        <p class="text-xs text-gray-500 mt-1">Doit correspondre exactement au champ Catégorie des équipes.</p>
      </div>
      <div>
        <label class="block font-black mb-1 text-sm" for="ordre">Ordre d'affichage</label>
        <input id="ordre" name="ordre" type="number" min="0"
               value="{{ categorie.ordre ?? 0 }}"
               class="w-full border-4 border-black px-3 py-2 font-semibold focus:outline-none focus:ring-2 focus:ring-amber-400">
      </div>
    </div>


    <div>
      <label class="block font-black mb-1 text-sm" for="description">Description</label>
      <textarea id="description" name="description">{{ categorie.description ?? '' }}</textarea>
    </div>

  </div>

  <div class="flex gap-3">
    <button type="submit"
            class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
      {{ categorie ? 'Mettre à jour' : 'Créer' }}
    </button>
    <a href="{{ url('admin/categories-equipes') }}"
       class="border-4 border-black bg-white text-black font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
      Annuler
    </a>
  </div>
</form>
{% endblock %}

{% block scripts %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.20/summernote-lite.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.20/summernote-lite.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.20/lang/summernote-fr-FR.min.js"></script>
<style>
  .note-editor .note-editable ul li { margin-left: 2rem !important; list-style: disc !important; }
  .note-editor .note-editable ol li { margin-left: 2rem !important; list-style: decimal !important; }
</style>
<script>
  $('#description').summernote({
    height: 250,
    lang: 'fr-FR',
    toolbar: [
      ['style',  ['style']],
      ['font',   ['bold', 'italic', 'underline', 'clear']],
      ['para',   ['ul', 'ol']],
      ['insert', ['link']],
      ['view',   ['codeview']]
    ]
  });
  $('form').on('submit', function () {
    document.getElementById('description').value = $('#description').summernote('code');
  });
</script>
{% endblock %}
