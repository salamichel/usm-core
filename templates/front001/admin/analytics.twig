{% extends 'admin/layout.twig' %}
{% block title %}Analytics{% endblock %}

{% block content %}
<div class="space-y-6">

  {# ── Header ── #}
  <div class="flex items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-black">📊 Analytics</h1>
      <p class="text-gray-600 mt-1">Statistiques Google Analytics 4</p>
    </div>
  </div>

  {# ── Configuration status ── #}
  {% if not analytics_configured %}
  <div class="border-4 border-orange-500 bg-orange-50 p-6 rounded">
    <h2 class="font-black text-lg text-orange-700 mb-2">⚠️ Google Analytics non configuré</h2>
    <p class="text-orange-700 mb-3">Pour activer le suivi des statistiques, configurez les variables d'environnement :</p>
    <ul class="list-disc list-inside text-orange-700 space-y-1 ml-2">
      <li><code class="bg-white px-2 py-1 border border-orange-300 rounded">GA_PROPERTY_ID</code> — votre identifiant GA4</li>
      <li><code class="bg-white px-2 py-1 border border-orange-300 rounded">GA_CREDENTIALS_PATH</code> — chemin vers credentials.json</li>
    </ul>
    <p class="text-orange-700 mt-3 text-sm">Status: <strong>{{ config_status }}</strong></p>
  </div>
  {% else %}

  {# ── Date range selector ── #}
  <div class="flex items-center gap-3 p-4 bg-gray-50 border-2 border-gray-300 rounded">
    <span class="font-semibold text-sm">Période :</span>
    <div class="flex gap-2">
      {% for key, range_data in ranges %}
        <a href="?range={{ key }}"
           class="px-3 py-1 text-sm font-semibold border-2 rounded transition
                  {% if selected_range == key %}
                    border-black bg-black text-white
                  {% else %}
                    border-gray-400 text-gray-700 hover:border-black
                  {% endif %}">
          {{ range_data[2] }}
        </a>
      {% endfor %}
    </div>
  </div>

  {# ── Key metrics row ── #}
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

    {# Pageviews #}
    <div class="border-4 border-black bg-white p-6 shadow-[4px_4px_0_#000]">
      <p class="text-sm font-black text-gray-600 uppercase mb-1">Vues de page</p>
      <p class="text-4xl font-black text-usm-brown">{{ pageviews|number_format }}</p>
      <p class="text-xs text-gray-500 mt-2">{{ range_label }}</p>
    </div>

    {# Active Users #}
    <div class="border-4 border-black bg-white p-6 shadow-[4px_4px_0_#000]">
      <p class="text-sm font-black text-gray-600 uppercase mb-1">Utilisateurs actifs</p>
      <p class="text-4xl font-black text-green-700">{{ active_users|number_format }}</p>
      <p class="text-xs text-gray-500 mt-2">{{ range_label }}</p>
    </div>

    {# Bounce Rate #}
    <div class="border-4 border-black bg-white p-6 shadow-[4px_4px_0_#000]">
      <p class="text-sm font-black text-gray-600 uppercase mb-1">Taux de rebond</p>
      <p class="text-4xl font-black text-blue-700">{{ bounce_rate }}</p>
      <p class="text-xs text-gray-500 mt-2">{{ range_label }}</p>
    </div>

    {# Form Submissions #}
    <div class="border-4 border-black bg-white p-6 shadow-[4px_4px_0_#000]">
      <p class="text-sm font-black text-gray-600 uppercase mb-1">Formulaires</p>
      <p class="text-4xl font-black text-purple-700">{{ form_submissions }}</p>
      <p class="text-xs text-gray-500 mt-2">Envois totaux</p>
    </div>

  </div>

  {# ── Events row ── #}
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

    {# Contact Form #}
    <div class="border-2 border-gray-300 bg-white p-4 rounded">
      <p class="font-black text-sm text-gray-700 mb-2">💬 Formulaires de contact</p>
      <p class="text-3xl font-black text-usm-brown">{{ contact_form_submissions }}</p>
    </div>

    {# Downloads #}
    <div class="border-2 border-gray-300 bg-white p-4 rounded">
      <p class="font-black text-sm text-gray-700 mb-2">📥 Téléchargements</p>
      <p class="text-3xl font-black text-blue-600">{{ downloads }}</p>
    </div>

    {# External Links #}
    <div class="border-2 border-gray-300 bg-white p-4 rounded">
      <p class="font-black text-sm text-gray-700 mb-2">🔗 Liens externes</p>
      <p class="text-3xl font-black text-orange-600">{{ external_links }}</p>
    </div>

  </div>

  {# ── Top pages ── #}
  {% if top_pages|length %}
  <div class="border-4 border-black bg-white p-6 shadow-[4px_4px_0_#000]">
    <h2 class="text-xl font-black mb-4">🏆 Pages les plus visitées</h2>
    <div class="space-y-2">
      {% for page in top_pages %}
        <div class="flex items-center justify-between p-3 bg-gray-50 border-l-4 border-usm-brown rounded">
          <div class="flex-1">
            <p class="font-semibold text-sm">{{ page.path }}</p>
          </div>
          <span class="font-black text-lg text-usm-brown">{{ page.views }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# ── Top sources ── #}
  {% if top_sources|length %}
  <div class="border-4 border-black bg-white p-6 shadow-[4px_4px_0_#000]">
    <h2 class="text-xl font-black mb-4">🚀 Principales sources de trafic</h2>
    <div class="space-y-2">
      {% for source in top_sources %}
        <div class="flex items-center justify-between p-3 bg-gray-50 border-l-4 border-green-600 rounded">
          <div class="flex-1">
            <p class="font-semibold text-sm">
              {% if source.source == '(direct)' %}
                📍 Direct
              {% elseif source.source == 'google' %}
                🔍 Google Search
              {% elseif source.source == 'google-paid' %}
                🔍 Google Ads
              {% else %}
                {{ source.source|capitalize }}
              {% endif %}
            </p>
          </div>
          <span class="font-black text-lg text-green-700">{{ source.users }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# ── Info box ── #}
  <div class="border-2 border-blue-300 bg-blue-50 p-4 rounded text-sm text-blue-800">
    <p class="font-semibold mb-1">ℹ️ À propos de ces données</p>
    <p>Les statistiques affichées proviennent de <strong>Google Analytics 4</strong>. Les données peuvent prendre jusqu'à 24-48 heures pour apparaître.</p>
    <p class="mt-2">
      <a href="https://analytics.google.com" target="_blank" rel="noopener" class="underline hover:text-blue-600">
        Voir le rapport complet →
      </a>
    </p>
  </div>

  {% endif %}

</div>
{% endblock %}
