{% extends 'admin/layout.twig' %}
{% block title %}{{ block ? 'Éditer' : 'Nouveau' }} bloc{% endblock %}

{% block content %}
<div class="flex items-center gap-4 mb-6">
  <a href="{{ url('admin/home-blocks') }}" class="font-bold hover:underline text-sm">← Retour</a>
  <h1 class="text-3xl font-black">{{ block ? 'Éditer le bloc' : 'Nouveau bloc' }}</h1>
</div>

{% if error %}
  <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-5 font-semibold text-sm">{{ error }}</div>
{% endif %}

<form method="POST" action="{{ action }}" enctype="multipart/form-data" class="space-y-6">
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">

    <div>
      <label class="block font-black mb-1" for="titre">Titre *</label>
      <input type="text" id="titre" name="titre" required
             value="{{ block.titre ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
    </div>

    <div>
      <label class="block font-black mb-1" for="contenu">Contenu</label>
      <div id="editor" class="border-2 border-black min-h-[220px] bg-white">{{ block and block.contenu ? block.contenu|raw : '' }}</div>
      <input type="hidden" id="contenu" name="contenu" value="{{ block.contenu ?? '' }}">
    </div>

    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label class="block font-black mb-1" for="cta_label">Libellé du bouton</label>
        <input type="text" id="cta_label" name="cta_label"
               value="{{ block.cta_label ?? '' }}"
               placeholder="ex: Découvrir"
               class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
      </div>
      <div>
        <label class="block font-black mb-1" for="cta_url">Lien du bouton</label>
        <input type="text" id="cta_url" name="cta_url"
               value="{{ block.cta_url ?? '' }}"
               placeholder="ex: /equipes ou https://..."
               class="w-full border-2 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-usm-brown">
      </div>
    </div>

    <div class="flex flex-wrap gap-6 items-start">
      <div>
        <label class="block font-black mb-1" for="position">Position</label>
        <input type="number" id="position" name="position" step="1"
               value="{{ block.position ?? 0 }}"
               class="w-32 border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
        <div class="text-xs text-gray-500 mt-1">Plus petit = affiché en premier</div>
      </div>
      <div class="flex items-center gap-3 pt-7">
        <input type="checkbox" id="is_active" name="is_active" value="1"
               {% if block is null or block.is_active %}checked{% endif %}
               class="w-5 h-5 border-2 border-black">
        <label class="font-black" for="is_active">Actif</label>
      </div>
    </div>
  </div>

  {# ── Image (Dropzone, single) ── #}
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000]">
    <h2 class="font-black text-lg mb-4">Image d'illustration</h2>

    <input type="hidden" id="image" name="image" value="{{ block.image ?? '' }}">

    <div id="image-preview" class="mb-4 {% if not block or not block.image %}hidden{% endif %}">
      <div class="relative inline-block border-2 border-black">
        <img id="image-thumb"
             src="{% if block and block.image %}{{ asset('uploads/' ~ block.image) }}{% endif %}"
             alt="" class="block max-w-xs h-40 object-cover">
        <button type="button" id="image-clear"
                class="absolute top-1 right-1 bg-black/80 text-white text-xs font-black px-2 py-1 hover:bg-red-600">
          ✕ Retirer
        </button>
      </div>
    </div>

    <div id="image-dropzone"
         class="dropzone border-4 border-dashed border-black bg-amber-50 cursor-pointer
                min-h-[120px] flex items-center justify-center
                hover:bg-amber-100 transition-colors">
      <div class="dz-message text-center text-gray-600 font-semibold pointer-events-none">
        <div class="text-3xl mb-1">🖼️</div>
        <div class="font-black">Glissez une image ici</div>
        <div class="text-xs text-gray-400 mt-1">JPG · PNG · WebP — max 10 Mo</div>
      </div>
    </div>
  </div>

  <button type="submit"
          class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    Enregistrer
  </button>
</form>
{% endblock %}

{% block scripts %}
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/dropzone.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/dropzone.min.js"></script>
<script>
  // ── Quill ───────────────────────────────────────────────────────────────────
  const quill = new Quill('#editor', {
    theme: 'snow',
    modules: {
      toolbar: [
        [{ header: [1,2,3,false] }],
        ['bold','italic','underline','strike'],
        [{ list: 'ordered' },{ list: 'bullet' }],
        ['link'],
        ['clean']
      ]
    }
  });
  document.querySelector('form').addEventListener('submit', () => {
    document.getElementById('contenu').value = quill.root.innerHTML;
  });

  // ── Dropzone image unique ───────────────────────────────────────────────────
  Dropzone.autoDiscover = false;
  const imgInput   = document.getElementById('image');
  const previewBox = document.getElementById('image-preview');
  const previewImg = document.getElementById('image-thumb');
  const clearBtn   = document.getElementById('image-clear');

  const dz = new Dropzone('#image-dropzone', {
    url:              '{{ url('admin/home-blocks/upload') }}',
    paramName:        'file',
    acceptedFiles:    'image/jpeg,image/png,image/webp,image/gif',
    maxFilesize:      10,
    maxFiles:         1,
    parallelUploads:  1,
    uploadMultiple:   false,
    addRemoveLinks:   false,
    previewTemplate:  '<div style="display:none"></div>',
    clickable:        true,
    dictDefaultMessage: '',
    init() {
      this.on('success', (file, resp) => {
        if (!resp.ok) { alert(resp.error || 'Erreur upload'); return; }
        imgInput.value      = resp.filename;
        previewImg.src      = resp.url;
        previewBox.classList.remove('hidden');
        this.removeFile(file);
      });
      this.on('error', (file, msg) => {
        const txt = typeof msg === 'string' ? msg : (msg.error || 'Erreur inconnue');
        alert('Erreur : ' + txt);
        this.removeFile(file);
      });
    }
  });

  clearBtn.addEventListener('click', () => {
    imgInput.value = '';
    previewImg.src = '';
    previewBox.classList.add('hidden');
  });
</script>
{% endblock %}
