{% extends 'admin/layout.twig' %}
{% block title %}Blocs page d'accueil{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-black">Blocs page d'accueil</h1>
  <a href="{{ url('admin/home-blocks/create') }}"
     class="border-4 border-black bg-usm-brown text-white font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    + Nouveau bloc
  </a>
</div>

<p class="text-sm text-gray-600 mb-6">
  Les blocs actifs sont affichés sur la page d'accueil dans l'ordre défini ci-dessous (du plus petit au plus grand).
</p>

{% if blocks|length %}

{# ── Mobile : cartes empilées ── #}
<div class="sm:hidden space-y-3">
  {% for block in blocks %}
  <div class="border-4 border-black bg-white p-4 shadow-[4px_4px_0_#000]">
    <div class="flex items-start gap-3 mb-2">
      {% if block.image %}
        <img src="{{ asset('uploads/' ~ block.image) }}" alt="" class="w-16 h-16 object-cover border-2 border-black flex-shrink-0">
      {% endif %}
      <div class="flex-1 min-w-0">
        <div class="font-black text-base mb-1 break-words">{{ block.titre }}</div>
        <div class="flex items-center gap-2 flex-wrap text-xs">
          {% if block.is_active %}
            <span class="bg-green-100 text-green-800 border border-green-400 px-2 py-0.5 font-bold rounded">Actif</span>
          {% else %}
            <span class="bg-gray-100 text-gray-600 border border-gray-400 px-2 py-0.5 font-bold rounded">Inactif</span>
          {% endif %}
          <span class="text-gray-500 font-mono">pos. {{ block.position }}</span>
        </div>
      </div>
    </div>
    {% if block.cta_label %}
      <div class="text-xs text-gray-600 mb-3">CTA&nbsp;: {{ block.cta_label }}</div>
    {% endif %}
    <div class="flex flex-wrap gap-2">
      <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/move-up') }}" class="inline">
        <button type="submit" title="Monter" class="border-2 border-black w-8 h-8 text-xs font-bold hover:bg-black hover:text-white transition">▲</button>
      </form>
      <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/move-down') }}" class="inline">
        <button type="submit" title="Descendre" class="border-2 border-black w-8 h-8 text-xs font-bold hover:bg-black hover:text-white transition">▼</button>
      </form>
      <a href="{{ url('admin/home-blocks/' ~ block.id ~ '/edit') }}"
         class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Éditer</a>
      <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/delete') }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            onsubmit="return confirm('Supprimer ce bloc ?')">
        <button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
      </form>
    </div>
  </div>
  {% endfor %}
</div>

{# ── Desktop : tableau ── #}
<div class="hidden sm:block border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-black text-white">
      <tr>
        <th class="text-left px-4 py-3 font-black w-12">#</th>
        <th class="text-left px-4 py-3 font-black">Titre</th>
        <th class="text-left px-4 py-3 font-black">Image</th>
        <th class="text-left px-4 py-3 font-black">CTA</th>
        <th class="text-left px-4 py-3 font-black">Statut</th>
        <th class="text-left px-4 py-3 font-black">Ordre</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for block in blocks %}
      <tr class="border-t-2 border-gray-200 hover:bg-amber-50">
        <td class="px-4 py-3 font-mono text-gray-400">{{ loop.index }}</td>
        <td class="px-4 py-3 font-semibold">{{ block.titre }}</td>
        <td class="px-4 py-3">
          {% if block.image %}
            <img src="{{ asset('uploads/' ~ block.image) }}" alt="" class="w-16 h-12 object-cover border-2 border-black">
          {% else %}
            <span class="text-xs text-gray-400 italic">aucune</span>
          {% endif %}
        </td>
        <td class="px-4 py-3 text-xs text-gray-600">
          {% if block.cta_label %}{{ block.cta_label }}{% else %}<span class="italic text-gray-400">—</span>{% endif %}
        </td>
        <td class="px-4 py-3">
          {% if block.is_active %}
            <span class="bg-green-100 text-green-800 border border-green-400 px-2 py-0.5 text-xs font-bold rounded">Actif</span>
          {% else %}
            <span class="bg-gray-100 text-gray-600 border border-gray-400 px-2 py-0.5 text-xs font-bold rounded">Inactif</span>
          {% endif %}
        </td>
        <td class="px-4 py-3">
          <div class="flex items-center gap-2">
            <span class="font-mono text-xs text-gray-500">{{ block.position }}</span>
            <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/move-up') }}" class="inline">
              <button type="submit" title="Monter"
                      class="border-2 border-black w-7 h-7 text-xs font-bold hover:bg-black hover:text-white transition">▲</button>
            </form>
            <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/move-down') }}" class="inline">
              <button type="submit" title="Descendre"
                      class="border-2 border-black w-7 h-7 text-xs font-bold hover:bg-black hover:text-white transition">▼</button>
            </form>
          </div>
        </td>
        <td class="px-4 py-3 flex gap-2 justify-end">
          <a href="{{ url('admin/home-blocks/' ~ block.id ~ '/edit') }}"
             class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Éditer</a>
          <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/delete') }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                onsubmit="return confirm('Supprimer ce bloc ?')">
            <button type="submit"
                    class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">
              Supprimer
            </button>
          </form>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
  <p class="text-gray-500 italic">Aucun bloc. <a href="{{ url('admin/home-blocks/create') }}" class="underline font-bold">Créez le premier</a>.</p>
{% endif %}
{% endblock %}
