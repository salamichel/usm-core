{# Macro réutilisable : galerie photos avec lightbox GLightbox #}
{% macro gallery(photos) %}
{% if photos|length %}
<section class="mt-10">
  <h2 class="mb-4 border-b-4 border-black pb-2">Galerie photos</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
    {% for photo in photos %}
    <a href="{{ asset('uploads/' ~ photo.filename) }}"
       class="glightbox border-4 border-black shadow-[4px_4px_0_#000] overflow-hidden block
              hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all"
       {% if photo.caption %}data-glightbox="description: {{ photo.caption }}"{% endif %}
       data-gallery="gallery-{{ photo.entity_type }}-{{ photo.entity_id }}">
      <img src="{{ asset('uploads/' ~ photo.filename) }}"
           alt="{{ photo.caption ? photo.caption|truncate(125) : 'Photo' }}"
           loading="lazy"
           decoding="async"
           class="w-full h-40 object-cover">
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}
{% endmacro %}
