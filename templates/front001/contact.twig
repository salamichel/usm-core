{% extends 'base.twig' %}
{% block title %}Contact — USM Volley{% endblock %}

{% block head %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<style>
  #map {
    height: 500px;
    border: 4px solid black;
    box-shadow: 6px 6px 0 #000;
  }
</style>
{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto px-4 py-12">
  <h1 class="text-4xl font-black mb-2">Nous contacter</h1>
  <p class="text-lg text-gray-600 mb-8">Envoyez-nous un message ou visitez nos gymnases</p>

  <div class="grid gap-12 lg:grid-cols-3 mb-12">
    {# ── Infos de contact ── #}
    <div class="lg:col-span-1">
      <div class="border-4 border-black bg-white p-6 shadow-[4px_4px_0_#000] space-y-6">
        <div>
          <h2 class="font-black text-lg mb-4">Informations</h2>
        </div>

        {% if site_config.email %}
        <div>
          <p class="text-xs font-black text-gray-600 uppercase tracking-wider mb-1">Email</p>
          <a href="mailto:{{ site_config.email }}" class="text-usm-brown font-semibold hover:underline break-all">
            {{ site_config.email }}
          </a>
        </div>
        {% endif %}

        {% if site_config.phone %}
        <div>
          <p class="text-xs font-black text-gray-600 uppercase tracking-wider mb-1">Téléphone</p>
          <a href="tel:{{ site_config.phone|replace({' ': ''}) }}" class="text-usm-brown font-semibold hover:underline">
            {{ site_config.phone }}
          </a>
        </div>
        {% endif %}

        {% if site_config.address %}
        <div>
          <p class="text-xs font-black text-gray-600 uppercase tracking-wider mb-1">Adresse</p>
          <address class="not-italic text-sm text-gray-700 whitespace-pre-line leading-relaxed">
            {{ site_config.address }}
          </address>
        </div>
        {% endif %}

        {% if site_config.facebook_url or site_config.instagram_url %}
        <div class="pt-4 border-t-2 border-gray-200">
          <p class="text-xs font-black text-gray-600 uppercase tracking-wider mb-3">Suivez-nous</p>
          <div class="flex gap-2">
            {% if site_config.facebook_url %}
              <a href="{{ site_config.facebook_url }}" target="_blank" rel="noopener"
                 class="w-10 h-10 border-2 border-black flex items-center justify-center hover:bg-black hover:text-white transition">
                <span class="text-sm">f</span>
              </a>
            {% endif %}
            {% if site_config.instagram_url %}
              <a href="{{ site_config.instagram_url }}" target="_blank" rel="noopener"
                 class="w-10 h-10 border-2 border-black flex items-center justify-center hover:bg-black hover:text-white transition">
                <span class="text-sm">📷</span>
              </a>
            {% endif %}
          </div>
        </div>
        {% endif %}
      </div>
    </div>

    {# ── Formulaire de contact ── #}
    <div class="lg:col-span-2">
      <div class="border-4 border-black bg-white p-6 shadow-[4px_4px_0_#000]">
        <h2 class="font-black text-lg mb-4">Nous envoyer un message</h2>

        {% if error %}
          <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-6 font-semibold text-sm rounded">
            {{ error }}
          </div>
        {% endif %}

        <form method="POST" action="{{ url('contact') }}" class="space-y-4">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block font-black mb-1 text-sm" for="name">Nom *</label>
              <input type="text" id="name" name="name" required
                     value="{{ form.name|default('') }}"
                     class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
            </div>

            <div>
              <label class="block font-black mb-1 text-sm" for="email">Email *</label>
              <input type="email" id="email" name="email" required
                     value="{{ form.email|default('') }}"
                     class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
            </div>
          </div>

          <div>
            <label class="block font-black mb-1 text-sm" for="phone">Téléphone</label>
            <input type="tel" id="phone" name="phone"
                   value="{{ form.phone|default('') }}"
                   placeholder="06 12 34 56 78"
                   class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
          </div>

          <div>
            <label class="block font-black mb-1 text-sm" for="subject">Sujet *</label>
            <input type="text" id="subject" name="subject" required
                   value="{{ form.subject|default('') }}"
                   placeholder="Renseignements, demande, avis..."
                   class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
          </div>

          <div>
            <label class="block font-black mb-1 text-sm" for="message">Message *</label>
            <textarea id="message" name="message" required rows="5"
                      placeholder="Votre message..."
                      class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">{{ form.message|default('') }}</textarea>
          </div>

          <button type="submit"
                  class="w-full border-4 border-black bg-usm-brown text-white font-black px-6 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
            Envoyer
          </button>
        </form>
      </div>
    </div>
  </div>

  {# ── Gymnases ── #}
  {% if locations|length %}
  <div class="space-y-8">
    <div>
      <h2 class="text-3xl font-black mb-2">Nos gymnases</h2>
      <p class="text-gray-600">Localisez nos lieux d'entraînement sur la carte interactive</p>
    </div>

    {# Carte #}
    <div class="mb-8">
      <div id="map"></div>
    </div>

    {# Liste des emplacements #}
    <div class="grid gap-6 sm:grid-cols-2">
      {% for location in locations %}
      <div class="border-4 border-black bg-white shadow-[4px_4px_0_#000] overflow-hidden flex flex-col">
        {% if location.latitude and location.longitude %}
        <div class="map-mini" id="map-{{ location.id }}" style="height: 250px; border-bottom: 4px solid black;"></div>
        {% endif %}
        <div class="p-6 flex-1 flex flex-col">
          <h3 class="text-xl font-black mb-2">{{ location.name }}</h3>
          <address class="not-italic text-sm text-gray-700 whitespace-pre-line leading-relaxed mb-4">
            {{ location.address }}
          </address>
          {% if location.latitude and location.longitude %}
            <p class="text-xs mt-auto">
              <span class="inline-block bg-green-100 text-green-700 px-2 py-1 rounded font-semibold text-xs">✓ Sur la carte</span>
            </p>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}
</div>

{% if locations|length %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script>
(function() {
  const locations = {{ locations|json_encode|raw }};
  const validLocations = locations.filter(loc => loc.latitude && loc.longitude);

  if (validLocations.length === 0) {
    document.getElementById('map').innerHTML = '<p class="p-4 text-gray-500 text-center">Aucun emplacement géolocalisé.</p>';
    return;
  }

  // Grande carte avec tous les emplacements
  const map = L.map('map').setView([validLocations[0].latitude, validLocations[0].longitude], 13);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors',
    maxZoom: 19
  }).addTo(map);

  const markers = [];
  validLocations.forEach(function(location) {
    const marker = L.marker([location.latitude, location.longitude])
      .bindPopup('<strong>' + location.name + '</strong><br>' + location.address.replace(/\n/g, '<br>'))
      .addTo(map);
    markers.push(marker);
  });

  if (markers.length > 1) {
    const group = new L.featureGroup(markers);
    map.fitBounds(group.getBounds().pad(0.1));
  }

  // Petites cartes pour chaque emplacement
  validLocations.forEach(function(location) {
    const mapId = 'map-' + location.id;
    const mapElement = document.getElementById(mapId);
    if (!mapElement) return;

    const miniMap = L.map(mapId).setView([location.latitude, location.longitude], 15);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap',
      maxZoom: 19
    }).addTo(miniMap);

    L.marker([location.latitude, location.longitude])
      .bindPopup('<strong>' + location.name + '</strong>')
      .addTo(miniMap)
      .openPopup();
  });
})();
</script>
{% endif %}

{% endblock %}
