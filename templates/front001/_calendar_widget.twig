<div class="calendar-widget border-4 border-black bg-white shadow-[4px_4px_0_#000] inline-block">
  {# Titre du mois #}
  <div class="border-b-4 border-black px-4 py-3 bg-gray-100">
    <h3 class="text-center font-black text-lg">{{ calendar.monthName|upper }} {{ calendar.year }}</h3>
  </div>

  {# Tableau du calendrier #}
  <table class="w-full text-xs border-collapse">
    {# En-têtes jours #}
    <thead>
      <tr>
        {% for dayName in calendar.dayHeaders %}
          <th class="border-b-2 border-gray-300 px-2 py-1 text-center font-bold text-gray-700 w-8">
            {{ dayName }}
          </th>
        {% endfor %}
      </tr>
    </thead>

    {# Corps du calendrier #}
    <tbody>
      {% for week in calendar.weeks %}
        <tr>
          {% for day in week %}
            <td class="border border-gray-300 h-12 align-top relative cursor-pointer hover:bg-gray-50 transition group"
                {% if day %}
                  data-date="{{ day.date }}"
                  data-events="{{ calendar.eventsByDate[day.date]|length }}"
                {% endif %}>
              {% if day %}
                {# Jour actuel : surlignage spécial #}
                {% if day.isToday %}
                  <div class="absolute inset-0 bg-blue-200 border-2 border-blue-600"></div>
                {% endif %}

                {# Jour avec événements : point indicateur #}
                {% if calendar.eventsByDate[day.date]|length > 0 %}
                  <div class="absolute top-0 right-0 w-2 h-2 bg-red-600 rounded-full"></div>
                {% endif %}

                <div class="relative z-10 p-1 text-right">
                  <span class="font-bold text-gray-800">{{ day.day }}</span>
                </div>

                {# Popup avec événements au survol #}
                {% set dayEvents = calendar.eventsByDate[day.date]|default([]) %}
                {% if dayEvents|length > 0 %}
                  <div class="absolute bottom-full mb-1 left-0 right-0 bg-gray-900 text-white rounded px-2 py-1 text-xs whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none z-20 transition hidden group-hover:block">
                    {% for event in dayEvents %}
                      <div class="truncate">
                        {% if event.time %}{{ event.time }} {% endif %}{{ event.title }}
                      </div>
                    {% endfor %}
                  </div>
                {% endif %}
              {% endif %}
            </td>
          {% endfor %}
        </tr>
      {% endfor %}
    </tbody>
  </table>

  {# Légende et événements actuels #}
  <div class="border-t-4 border-black px-4 py-3 bg-gray-50 text-xs max-h-40 overflow-y-auto">
    <div class="mb-2 pb-2 border-b border-gray-300">
      <div class="flex items-center gap-2 text-gray-600">
        <span class="inline-block w-3 h-3 bg-blue-200 border-2 border-blue-600"></span>
        <span>Aujourd'hui</span>
      </div>
      <div class="flex items-center gap-2 text-gray-600 mt-1">
        <span class="inline-block w-2 h-2 bg-red-600 rounded-full"></span>
        <span>Avec événement</span>
      </div>
    </div>

    {# Afficher les événements d'aujourd'hui #}
    {% set todayEvents = calendar.eventsByDate[calendar.today]|default([]) %}
    {% if todayEvents|length > 0 %}
      <div class="mt-2">
        <p class="font-bold text-gray-700 mb-2">📅 Aujourd'hui :</p>
        {% for event in todayEvents %}
          <div class="py-1.5 px-2 bg-white border-l-2 border-blue-600 text-gray-700 mb-1">
            {% if event.time %}
              <div class="font-semibold text-blue-700">{{ event.time }}</div>
            {% endif %}
            <div class="font-semibold">{{ event.title }}</div>
            <div class="text-xs text-gray-600">{{ event.type }}</div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="mt-2 text-gray-600 italic text-xs">Aucun événement aujourd'hui</div>
    {% endif %}

    {# Prochains événements du mois #}
    {% set upcomingEvents = [] %}
    {% for date, events in calendar.eventsByDate %}
      {% if date > calendar.today and events|length > 0 and upcomingEvents|length < 2 %}
        {% set upcomingEvents = upcomingEvents|merge(events[:1]) %}
      {% endif %}
    {% endfor %}

    {% if upcomingEvents|length > 0 %}
      <div class="mt-3 pt-2 border-t border-gray-300">
        <p class="font-bold text-gray-700 mb-2">⏰ Prochains :</p>
        {% for event in upcomingEvents %}
          <div class="py-1.5 px-2 bg-white border-l-2 border-red-600 text-gray-700 mb-1">
            {% if event.time %}
              <div class="font-semibold text-red-700">{{ event.time }}</div>
            {% endif %}
            <div class="font-semibold text-sm">{{ event.title }}</div>
            <div class="text-xs text-gray-600">{{ event.type }}</div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<style>
  .calendar-widget table td {
    @apply transition-colors;
  }
  .calendar-widget table td[data-events="0"]:hover {
    @apply bg-gray-50;
  }
  .calendar-widget table td[data-events="0"]:active {
    @apply bg-gray-100;
  }
</style>
