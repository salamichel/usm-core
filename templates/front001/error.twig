{% extends 'base.twig' %}
{% block title %}Erreur{% endblock %}

{% block content %}
<div class="container mx-auto py-12">
  <div class="max-w-md mx-auto border-4 border-black bg-white p-8 shadow-[6px_6px_0_#000]">
    <h1 class="text-red-600 mb-4">⚠ Erreur</h1>
    <p class="text-gray-700 mb-6">{{ error }}</p>
    <a href="{{ url('/') }}" class="border-4 border-black bg-usm-brown text-white font-black px-6 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all inline-block">
      ← Accueil
    </a>
  </div>
</div>
{% endblock %}
