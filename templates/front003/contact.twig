{% extends 'base.twig' %}
{% block title %}Contact — {{ site_config.club_name|default('USM Volley') }}{% endblock %}

{% block head %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<style>
  #map { height: 460px; border-radius: 24px; overflow: hidden; border: 1px solid color-mix(in srgb, var(--ink) 10%, transparent); }
  .map-mini { border-bottom: 1px solid color-mix(in srgb, var(--ink) 10%, transparent); border-radius: 24px 24px 0 0; overflow: hidden; }
</style>
{% endblock %}

{% block content %}
<section class="page-header grain">
  <div class="inner">
    <div class="eyebrow">Contact</div>
    <h1 class="page-title">Nous contacter.</h1>
    <p class="page-intro">Envoie-nous un message — on revient vers toi par mail.</p>
  </div>
</section>

<section class="section-paper">
  <div class="shell py-16">
    <div class="grid gap-10 lg:grid-cols-3 mb-20">

      <aside class="lg:col-span-1">
        <div class="frame frame-lg space-y-6">
          <h2 class="font-display text-ink text-[20px]">Informations</h2>

          {% if site_config.phone %}
            <div>
              <p class="form-label">Téléphone</p>
              <a href="tel:{{ site_config.phone|replace({' ': ''}) }}" class="text-flame font-bold hover:text-ember">
                {{ site_config.phone }}
              </a>
            </div>
          {% endif %}

          {% if site_config.address %}
            <div>
              <p class="form-label">Adresse</p>
              <address class="not-italic text-sm text-ink/80 whitespace-pre-line leading-relaxed">{{ site_config.address }}</address>
            </div>
          {% endif %}

          {% if site_config.facebook_url or site_config.instagram_url %}
            <div class="pt-5 border-t border-ink/10">
              <p class="form-label">Suivez-nous</p>
              <div class="flex gap-2">
                {% if site_config.facebook_url %}
                  <a href="{{ site_config.facebook_url }}" target="_blank" rel="noopener" class="footer-social" aria-label="Facebook">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12.07C22 6.48 17.52 2 11.93 2 6.36 2 1.88 6.48 1.88 12.07c0 5.02 3.66 9.18 8.46 9.93v-7.03H7.83v-2.9h2.51V9.83c0-2.48 1.48-3.85 3.74-3.85 1.08 0 2.21.19 2.21.19v2.43h-1.25c-1.23 0-1.61.77-1.61 1.55v1.86h2.74l-.44 2.9h-2.3V22c4.8-.75 8.46-4.91 8.46-9.93z"/></svg>
                  </a>
                {% endif %}
                {% if site_config.instagram_url %}
                  <a href="{{ site_config.instagram_url }}" target="_blank" rel="noopener" class="footer-social" aria-label="Instagram">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/></svg>
                  </a>
                {% endif %}
              </div>
            </div>
          {% endif %}
        </div>
      </aside>

      <div class="lg:col-span-2">
        <div class="frame frame-lg">
          <h2 class="font-display text-ink text-[22px] mb-6">Nous envoyer un message</h2>

          {% if error %}
            <div class="rounded-2xl border border-flame/30 bg-flame/10 text-ember px-4 py-3 mb-6 text-sm font-medium">
              {{ error }}
            </div>
          {% endif %}

          <form method="POST" action="{{ url('contact') }}" class="space-y-5">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label class="form-label" for="name">Nom *</label>
                <input type="text" id="name" name="name" required value="{{ form_data.name|default('') }}" class="form-input">
              </div>
              <div>
                <label class="form-label" for="email">Email *</label>
                <input type="email" id="email" name="email" required value="{{ form_data.email|default('') }}" class="form-input">
              </div>
            </div>
            <div>
              <label class="form-label" for="phone">Téléphone *</label>
              <input type="tel" id="phone" name="phone" required value="{{ form_data.phone|default('') }}" placeholder="06 12 34 56 78" class="form-input">
            </div>
            <div>
              <label class="form-label" for="subject">Sujet *</label>
              <select id="subject" name="subject" required class="form-select">
                <option value="" disabled {% if not form_data.subject %}selected{% endif %}>— Choisissez un sujet —</option>
                {% set subjects = [
                  'Adhésion / Inscription', 'Tarifs et licences', 'Informations sur les entraînements',
                  'Matchs et compétitions', 'Partenariat / Sponsor', 'Bénévolat', 'Question générale', 'Autre'
                ] %}
                {% for s in subjects %}
                  <option value="{{ s }}" {% if form_data.subject == s %}selected{% endif %}>{{ s }}</option>
                {% endfor %}
              </select>
            </div>
            <div>
              <label class="form-label" for="message">Message *</label>
              <textarea id="message" name="message" required rows="6" placeholder="Votre message..." class="form-textarea">{{ form_data.message|default('') }}</textarea>
            </div>
            <button type="submit" class="btn-flame w-full justify-center">
              Envoyer le message
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </form>
        </div>
      </div>
    </div>

    {% if locations|length %}
      <div class="space-y-10">
        <div>
          <div class="eyebrow">Nos lieux</div>
          <h2 class="mt-3 font-display text-ink text-[32px] sm:text-[40px]">Nos gymnases.</h2>
        </div>

        <div id="map"></div>

        <div class="grid gap-6 sm:grid-cols-2">
          {% for location in locations %}
            <div class="frame overflow-hidden flex flex-col p-0">
              {% if location.latitude and location.longitude %}
                <div class="map-mini" id="map-{{ location.id }}" style="height: 240px;"></div>
              {% endif %}
              <div class="p-6 flex-1 flex flex-col">
                <h3 class="font-display text-ink text-[20px] mb-2">{{ location.name }}</h3>
                <address class="not-italic text-sm text-ink/70 whitespace-pre-line leading-relaxed mb-4">{{ location.address }}</address>
                {% if not (location.latitude and location.longitude) %}
                  <a href="https://www.google.com/maps/search/{{ location.address|url_encode }}" target="_blank" rel="noopener" class="btn-ghost btn-sm self-start">
                    Google Maps →
                  </a>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

{% if locations|length %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script>
(function() {
  var locations = {{ locations|json_encode|raw }};
  var valid = locations.filter(function(l) { return l.latitude && l.longitude; });
  if (valid.length === 0) {
    document.getElementById('map').innerHTML = '<p style="padding:1.5rem; text-align:center; color:#666;">Aucun emplacement géolocalisé.</p>';
    return;
  }
  var map = L.map('map').setView([valid[0].latitude, valid[0].longitude], 13);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap', maxZoom: 19 }).addTo(map);
  var markers = [];
  valid.forEach(function(l) {
    var m = L.marker([l.latitude, l.longitude]).bindPopup('<strong>'+l.name+'</strong><br>'+l.address.replace(/\n/g,'<br>')).addTo(map);
    markers.push(m);
    var el = document.getElementById('map-'+l.id);
    if (el) {
      var mini = L.map('map-'+l.id).setView([l.latitude, l.longitude], 15);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:19}).addTo(mini);
      L.marker([l.latitude, l.longitude]).addTo(mini);
    }
  });
  if (markers.length > 1) map.fitBounds(new L.featureGroup(markers).getBounds().pad(0.1));
})();
</script>
{% endif %}
{% endblock %}
