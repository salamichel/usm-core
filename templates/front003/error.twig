{% extends 'base.twig' %}
{% block title %}Erreur — {{ site_config.club_name|default('USM Volley') }}{% endblock %}

{% block content %}
<section class="section-bone">
  <div class="shell py-20">
    <div class="frame frame-lg max-w-2xl mx-auto text-center">
      <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-flame text-paper mb-6">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <h1 class="font-display text-[28px] sm:text-[36px] text-ink mb-3">Une erreur est survenue</h1>
      <p class="text-ink/60 leading-relaxed mb-8">{{ error }}</p>
      <a href="{{ url('/') }}" class="btn-flame inline-flex">Retour à l'accueil</a>
    </div>
  </div>
</section>
{% endblock %}
