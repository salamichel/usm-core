{% extends 'base.twig' %}
{% block title %}Page introuvable — {{ site_config.club_name|default('USM Volley') }}{% endblock %}

{% block content %}
<section class="section-bone grain">
  <div class="shell py-24 text-center relative">
    <div class="error-num">404</div>
    <h1 class="mt-2 font-display text-[28px] sm:text-[40px] text-ink">Page introuvable.</h1>
    <p class="mt-4 text-ink/60 max-w-md mx-auto leading-relaxed">
      La page que tu cherches n'existe pas ou a été déplacée.
    </p>
    <a href="{{ url('/') }}" class="btn-flame mt-8 inline-flex">
      Retour à l'accueil
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>
</section>
{% endblock %}
