        </div>

        {# Zone 5 : Actif #}
        <div class="border-2 border-black bg-white p-3">
          <p class="font-black text-xs uppercase mb-2">⑤ Actif</p>
          <div class="space-y-2">
            <div>
              <p class="text-xs text-gray-500 mb-1">Fond</p>
              <div class="flex items-center gap-2">
                <input type="color" id="header_active_bg_color" name="header_active_bg_color"
