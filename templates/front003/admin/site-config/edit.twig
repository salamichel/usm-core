              <div class="flex items-center gap-2">
                <input type="color" id="header_hover_text_color" name="header_hover_text_color"
                       value="{{ config.header_hover_text_color|default('#000000') }}"
                       class="w-9 h-9 border-2 border-black cursor-pointer p-0.5"
                       oninput="syncHex(this,'hex_hover_txt');previewHeader()">
                <input type="text" id="hex_hover_txt" maxlength="7"
                       value="{{ config.header_hover_text_color|default('#000000') }}"
                       class="w-20 border-2 border-black px-2 py-1 font-mono text-xs focus:outline-none"
                       oninput="if(/^#[0-9A-Fa-f]{6}$/.test(this.value)){document.getElementById('header_hover_text_color').value=this.value;previewHeader()}">
              </div>
              <div class="flex flex-wrap gap-1 mt-1">
                {% for p in [{l:'Noir',v:'#000000'},{l:'Blanc',v:'#ffffff'},{l:'Crème',v:'#fffdef'},{l:'Marine',v:'#1e3a5f'}] %}
                  <button type="button" onclick="setColor('header_hover_text_color','hex_hover_txt','{{ p.v }}')"
