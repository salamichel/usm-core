                <input type="color" id="header_active_text_color" name="header_active_text_color"
                       value="{{ config.header_active_text_color|default(config.header_hover_text_color|default('#000000')) }}"
                       class="w-9 h-9 border-2 border-black cursor-pointer p-0.5"
                       oninput="syncHex(this,'hex_active_txt');previewHeader()">
                <input type="text" id="hex_active_txt" maxlength="7"
                       value="{{ config.header_active_text_color|default(config.header_hover_text_color|default('#000000')) }}"
                       class="w-20 border-2 border-black px-2 py-1 font-mono text-xs focus:outline-none"
