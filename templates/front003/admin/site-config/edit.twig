    {# Typographie #}
    <div>
      <label class="block font-black mb-2">Typographie</label>
      {% set knownFonts = ['Inter','Space Grotesk','DM Sans','Syne','Outfit','Poppins','Plus Jakarta Sans','Raleway','Montserrat','Work Sans','Unbounded'] %}
      {% set currentFont = config.font_family|default('') %}
      {% set isCustom = currentFont is not empty and currentFont not in knownFonts %}

      <div class="space-y-1.5 mb-3">

        {# Système #}
        <label class="flex items-center gap-3 px-3 py-2 border-2 cursor-pointer transition
                      {{ currentFont == '' ? 'border-black bg-amber-50' : 'border-gray-200 hover:border-gray-400' }}">
          <input type="radio" name="font_family" value="" class="w-4 h-4 font-radio"
                 {{ currentFont == '' ? 'checked' : '' }}>
          <span class="text-sm font-semibold w-36">Système (défaut)</span>
          <span class="text-base text-gray-500" style="font-family: ui-sans-serif, system-ui, sans-serif">Club USM Mios — Volley</span>
        </label>

        {# Polices connues #}
        {% for f in knownFonts %}
          <label class="flex items-center gap-3 px-3 py-2 border-2 cursor-pointer transition
                        {{ currentFont == f ? 'border-black bg-amber-50' : 'border-gray-200 hover:border-gray-400' }}">
            <input type="radio" name="font_family" value="{{ f }}" class="w-4 h-4 font-radio"
                   {{ currentFont == f ? 'checked' : '' }}>
            <span class="text-sm font-semibold w-36">{{ f }}</span>
            <span class="text-base text-gray-700" style="font-family: '{{ f }}', sans-serif">Club USM Mios — Volley</span>
          </label>
        {% endfor %}

        {# Police personnalisée #}
        <label class="flex items-center gap-3 px-3 py-2 border-2 cursor-pointer transition
                      {{ isCustom ? 'border-black bg-amber-50' : 'border-gray-200 hover:border-gray-400' }}"
               id="custom-font-label">
          <input type="radio" name="font_family" value="__custom__" class="w-4 h-4 font-radio" id="radio-custom"
                 {{ isCustom ? 'checked' : '' }}>
          <span class="text-sm font-semibold w-36">Personnalisée</span>
          <input type="text" id="custom_font_input"
                 value="{{ isCustom ? currentFont : '' }}"
                 placeholder="Ex: Nunito, Josefin Sans, Pacifico…"
                 class="flex-1 border border-gray-300 px-2 py-0.5 text-sm focus:outline-none focus:border-black"
                 onclick="document.getElementById('radio-custom').checked=true"
                 oninput="document.getElementById('radio-custom').checked=true">
        </label>
      </div>
      <div class="text-xs text-gray-500">Noms exacts tels qu'ils apparaissent sur <a href="https://fonts.google.com" target="_blank" class="underline">fonts.google.com</a>.</div>
    </div>
  </div>

  <button type="submit"
          class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    Enregistrer
  </button>
</form>
{% endblock %}

{% block head %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=Space+Grotesk:wght@400;600;700;900&family=DM+Sans:wght@400;600;700;900&family=Syne:wght@400;600;700;900&family=Outfit:wght@400;600;700;900&family=Poppins:wght@400;600;700;900&family=Plus+Jakarta+Sans:wght@400;600;700;900&family=Raleway:wght@400;600;700;900&family=Montserrat:wght@400;600;700;900&family=Work+Sans:wght@400;600;700;900&family=Unbounded:wght@400;600;700;900&display=swap">
{% endblock %}

{% block scripts %}
<script>
  // Sync custom font radio value before submit
  document.querySelector('form').addEventListener('submit', function () {
    const radio = document.getElementById('radio-custom');
    if (radio.checked) {
      const val = document.getElementById('custom_font_input').value.trim();
      radio.value = val;
    }
  });

  function syncHex(colorInput, hexId) {
    document.getElementById(hexId).value = colorInput.value;
  }

  function setColor(colorId, hexId, val) {
    document.getElementById(colorId).value = val;
    document.getElementById(hexId).value = val;
    previewHeader();
  }

  function previewHeader() {
    const bg        = document.getElementById('header_bg_color').value;
    const logoBg    = document.getElementById('logo_bg_color').value;
    const logoTxt   = document.getElementById('logo_text_color').value;
    const text      = document.getElementById('header_text_color').value;
    const hoverBg   = document.getElementById('header_hover_bg_color').value;
    const hoverTxt  = document.getElementById('header_hover_text_color').value;

    document.getElementById('header-preview').style.background = bg;
    document.getElementById('prev-logo').style.background      = logoBg;
    document.getElementById('prev-logo').style.color           = logoTxt;
    document.getElementById('prev-link').style.color           = text;
    document.getElementById('prev-link2').style.color          = text;
    document.getElementById('prev-hover').style.background     = hoverBg;
    document.getElementById('prev-hover').style.color          = hoverTxt;
  }
</script>
{% endblock %}
