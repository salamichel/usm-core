             style="background:{{ config.header_bg_color|default('#ffffff') }}">
          <span id="prev-logo" class="font-black text-sm px-3 py-1.5 border-2 border-black shadow-[3px_3px_0_#000]"
                style="background:{{ config.logo_bg_color|default(config.primary_color|default('#94674d')) }};color:{{ config.logo_text_color|default('#000000') }}">
            USM VOLLEY
          </span>
          <span id="prev-link" class="font-black text-xs uppercase px-3 py-1 border-2 border-transparent"
                style="color:{{ config.header_text_color|default('#000000') }}">
            Agenda
          </span>
          <span id="prev-link2" class="font-black text-xs uppercase px-3 py-1 border-2 border-transparent"
                style="color:{{ config.header_text_color|default('#000000') }}">
