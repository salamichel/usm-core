              <div class="flex flex-wrap gap-1 mt-1">
                {% for p in [{l:'Marron',v:'#94674d'},{l:'Doré',v:'#f1c40f'},{l:'Marine',v:'#1e3a5f'},{l:'Noir',v:'#111827'},{l:'Blanc',v:'#ffffff'}] %}
