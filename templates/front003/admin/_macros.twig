{# ============================================================
   Macros réutilisables pour les pages admin (CRUD)
   ============================================================ #}

{# Badge statut publié / brouillon #}
{% macro status_badge(is_published, pub_label, draft_label) %}
  {% if is_published %}
    <span class="bg-green-100 text-green-800 border border-green-400 px-2 py-0.5 text-xs font-bold rounded">
      {{ pub_label|default('Publié') }}
    </span>
  {% else %}
    <span class="bg-gray-100 text-gray-600 border border-gray-400 px-2 py-0.5 text-xs font-bold rounded">
      {{ draft_label|default('Brouillon') }}
    </span>
  {% endif %}
{% endmacro %}

{# Boutons d'action : Voir (optionnel) + Éditer + Supprimer #}
{% macro action_buttons(edit_url, delete_url, delete_message, csrf_token, view_url) %}
  <div class="flex gap-2 items-center flex-wrap">
    {% if view_url %}
      <a href="{{ view_url }}" target="_blank" rel="noopener"
         class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition focus:outline-none focus:ring-1 focus:ring-black">
        Voir
      </a>
    {% endif %}
    <a href="{{ edit_url }}"
       class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition focus:outline-none focus:ring-1 focus:ring-black">
      Éditer
    </a>
    <form method="POST" action="{{ delete_url }}" data-confirm="{{ delete_message }}">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
      <button type="submit"
              class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition focus:outline-none focus:ring-1 focus:ring-red-600">
        Supprimer
      </button>
    </form>
  </div>
{% endmacro %}

{# Bouton Nouveau / Créer standardisé #}
{% macro btn_create(url, label) %}
  <a href="{{ url }}"
     class="border-4 border-black bg-usm-brown text-white font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all focus:outline-none focus:ring-2 focus:ring-offset-1 focus:ring-usm-brown">
    {{ label|default('+ Nouveau') }}
  </a>
{% endmacro %}

{# En-tête de page liste (titre + bouton créer) #}
{% macro page_header(title, create_url, create_label) %}
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-3xl font-black">{{ title }}</h1>
    {% if create_url %}
      <a href="{{ create_url }}"
         class="border-4 border-black bg-usm-brown text-white font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all focus:outline-none focus:ring-2 focus:ring-offset-1 focus:ring-usm-brown">
        {{ create_label|default('+ Nouveau') }}
      </a>
    {% endif %}
  </div>
{% endmacro %}

{# Champ input texte/date/etc. #}
{% macro field_input(id, name, label, value, type, required, placeholder, extra_class) %}
  <div>
    <label class="block font-black mb-1" for="{{ id }}">{{ label }}{% if required %} *{% endif %}</label>
    <input type="{{ type|default('text') }}"
           id="{{ id }}"
           name="{{ name }}"
           {% if required %}required{% endif %}
           value="{{ value ?? '' }}"
           {% if placeholder %}placeholder="{{ placeholder }}"{% endif %}
           class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown {{ extra_class ?? '' }}">
  </div>
{% endmacro %}

{# Champ textarea #}
{% macro field_textarea(id, name, label, value, rows, required) %}
  <div>
    <label class="block font-black mb-1" for="{{ id }}">{{ label }}{% if required %} *{% endif %}</label>
    <textarea id="{{ id }}"
              name="{{ name }}"
              rows="{{ rows|default(3) }}"
              {% if required %}required{% endif %}
              class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">{{ value ?? '' }}</textarea>
  </div>
{% endmacro %}

{# Champ checkbox #}
{% macro field_checkbox(id, name, label, checked, value) %}
  <div class="flex items-center gap-3">
    <input type="checkbox"
           id="{{ id }}"
           name="{{ name }}"
           value="{{ value|default('1') }}"
           {% if checked %}checked{% endif %}
           class="w-5 h-5 border-2 border-black">
    <label class="font-black" for="{{ id }}">{{ label }}</label>
  </div>
{% endmacro %}

{# Message d'erreur de formulaire #}
{% macro form_error(message) %}
  {% if message %}
    <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-5 font-semibold text-sm" role="alert">
      {{ message }}
    </div>
  {% endif %}
{% endmacro %}

{# Bouton submit de formulaire #}
{% macro btn_submit(label) %}
  <button type="submit"
          class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all focus:outline-none focus:ring-2 focus:ring-offset-1 focus:ring-usm-brown">
    {{ label|default('Enregistrer') }}
  </button>
{% endmacro %}

{# État vide (empty state) pour les listes #}
{% macro empty_state(message) %}
  <p class="text-gray-500 italic">{{ message|default('Aucun élément.') }}</p>
{% endmacro %}
