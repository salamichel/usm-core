{% extends 'admin/layout.twig' %}
{% block title %}Catégories d'équipes{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-black">Catégories d'équipes</h1>
  <a href="{{ url('admin/categories-equipes/create') }}"
     class="border-4 border-black bg-usm-brown text-white font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    + Nouvelle catégorie
  </a>
</div>

{% if categories|length %}

{# Mobile #}
<div class="sm:hidden space-y-3">
  {% for cat in categories %}
  <div class="border-4 border-black bg-white p-4 shadow-[4px_4px_0_#000]">
    <div class="font-black text-base mb-1">{{ cat.nom }}</div>
    <div class="text-xs text-gray-500 mb-3">Ordre {{ cat.ordre }} — {% if cat.description %}Description renseignée{% else %}Pas de description{% endif %}</div>
    <div class="flex flex-wrap gap-2">
      <a href="{{ url('admin/categories-equipes/' ~ cat.id ~ '/edit') }}"
         class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Éditer</a>
      <form method="POST" action="{{ url('admin/categories-equipes/' ~ cat.id ~ '/delete') }}" data-confirm="Supprimer cette catégorie ?">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
      </form>
    </div>
  </div>
  {% endfor %}
</div>

{# Desktop #}
<div class="hidden sm:block border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-black text-white">
      <tr>
        <th class="text-left px-4 py-3 font-black">Nom</th>
        <th class="text-left px-4 py-3 font-black">Ordre</th>
        <th class="text-left px-4 py-3 font-black">Description</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for cat in categories %}
      <tr class="border-t-2 border-gray-200 hover:bg-amber-50">
        <td class="px-4 py-3 font-semibold">{{ cat.nom }}</td>
        <td class="px-4 py-3 text-gray-500">{{ cat.ordre }}</td>
        <td class="px-4 py-3 text-gray-500 text-xs">{% if cat.description %}✓ Renseignée{% else %}—{% endif %}</td>
        <td class="px-4 py-3 flex gap-2 justify-end">
          <a href="{{ url('admin/categories-equipes/' ~ cat.id ~ '/edit') }}"
             class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Éditer</a>
          <form method="POST" action="{{ url('admin/categories-equipes/' ~ cat.id ~ '/delete') }}" data-confirm="Supprimer cette catégorie ?">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
          </form>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{% else %}
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000]">
    <p class="text-gray-500 italic">Aucune catégorie configurée.</p>
  </div>
{% endif %}
{% endblock %}
