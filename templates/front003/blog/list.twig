{% extends 'base.twig' %}
{% block title %}Actualités — {{ site_config.club_name|default('USM Volley') }}{% endblock %}

{% block content %}
<section class="page-header grain">
  <div class="inner">
    <div class="eyebrow">Le journal du club</div>
    <h1 class="page-title">Actualités.</h1>
    <p class="page-intro">Matchs, vie du club, événements et résultats de la saison.</p>
  </div>
</section>

<section class="section-paper">
  <div class="shell py-16">

    {# Filtres #}
    {% if all_tags|length or months|length %}
      <form method="GET" action="{{ url('blog') }}" class="mb-10 flex flex-wrap items-center gap-3">
        {% if all_tags|length %}
          <div class="flex items-center gap-2">
            <span class="form-label" style="margin: 0;">Catégorie</span>
            <select name="tag" onchange="this.form.submit()" class="form-select" style="width: auto;">
              <option value="">Toutes</option>
              {% for tag in all_tags %}
                {% set count = tag_counts[tag.id] ?? 0 %}
                {% if count > 0 %}
                  <option value="{{ tag.slug }}" {{ selected_tag and selected_tag.id == tag.id ? 'selected' : '' }}>
                    {{ tag.name }} ({{ count }})
                  </option>
                {% endif %}
              {% endfor %}
            </select>
          </div>
        {% endif %}
        {% if months|length %}
          <div class="flex items-center gap-2">
            <span class="form-label" style="margin: 0;">Mois</span>
            <select name="month" onchange="this.form.submit()" class="form-select" style="width: auto;">
              <option value="">Tous</option>
              {% for month in months %}
                <option value="{{ month }}" {{ selected_month == month ? 'selected' : '' }}>{{ month|month_fr }}</option>
              {% endfor %}
            </select>
          </div>
        {% endif %}
        {% if selected_tag or selected_month %}
          <a href="{{ url('blog') }}" class="ml-auto text-sm text-ink/60 hover:text-flame underline underline-offset-2">Réinitialiser</a>
        {% endif %}
      </form>
    {% endif %}

    {% if posts|length %}
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {% for post in posts %}
          <a href="{{ url('blog/' ~ post.slug) }}" class="card-news">
            <div class="card-art">
              {% if post.cover %}
                <img src="{{ image_variant(post.cover, 'medium') }}" alt="{{ post.title }}" loading="lazy">
              {% endif %}
              {% if post.tags is defined and post.tags|length %}
                <div class="absolute top-3 left-3 z-10">
                  <span class="chip" style="background: var(--paper); color: var(--ink);">{{ post.tags[0].name }}</span>
                </div>
              {% endif %}
            </div>
            <div class="card-body flex-1">
              {% if post.published_at %}
                <div class="text-[11px] font-bold tracking-widest uppercase text-ink/50">{{ post.published_at|date_fr }}</div>
              {% endif %}
              <h3 class="mt-2">{{ post.title }}</h3>
              {% if post.excerpt %}
                <p class="mt-2 text-[14px] text-ink/60 leading-relaxed line-clamp-3">{{ post.excerpt }}</p>
              {% endif %}
              <div class="mt-4 inline-flex items-center gap-1.5 text-[12px] font-bold tracking-widest uppercase text-ink">
                Lire l'article
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </div>
            </div>
          </a>
        {% endfor %}
      </div>

      {% if pagination.totalPages > 1 %}
        <nav class="flex flex-wrap items-center justify-center gap-2 mt-16 pt-10 border-t border-ink/10">
          {% set qs = (selected_tag ? '&tag=' ~ selected_tag.slug : '') ~ (selected_month ? '&month=' ~ selected_month : '') %}
          {% if pagination.hasPrevious() %}
            <a href="{{ url('blog') ~ '?page=' ~ pagination.previousPage() ~ qs }}" class="btn-ghost btn-sm">← Précédent</a>
          {% endif %}
          <div class="flex gap-1 mx-2">
            {% for page in pagination.getPageRange(7) %}
              {% if page == pagination.currentPage %}
                <span class="px-3.5 py-1.5 rounded-2xl bg-flame text-paper text-sm font-semibold">{{ page }}</span>
              {% else %}
                <a href="{{ url('blog') ~ '?page=' ~ page ~ qs }}" class="px-3.5 py-1.5 rounded-2xl border border-ink/15 text-sm font-medium text-ink hover:border-ink transition">{{ page }}</a>
              {% endif %}
            {% endfor %}
          </div>
          {% if pagination.hasNext() %}
            <a href="{{ url('blog') ~ '?page=' ~ pagination.nextPage() ~ qs }}" class="btn-ghost btn-sm">Suivant →</a>
          {% endif %}
        </nav>
      {% endif %}

    {% else %}
      <div class="frame frame-amber frame-center text-ink/60">Aucun article pour ces filtres.</div>
    {% endif %}
  </div>
</section>
{% endblock %}
