<header class="nav-sticky" id="site-header">
  <div class="shell">
    <div class="flex items-center justify-between h-16 sm:h-20">
      {# Logo + nom #}
      <a href="{{ url('/') }}" class="flex items-center gap-3 group">
        <span class="logo-tile">
          {% include '_logo.twig' with {size: 28} %}
        </span>
        <span class="leading-none hidden sm:block">
          <span class="block font-display text-ink text-[15px] tracking-tight">
            {{ site_config.club_name|default('USM VOLLEY')|upper }}
          </span>
          {% if site_config.club_tagline %}
            <span class="block text-[10px] font-semibold tracking-[0.18em] text-ink/60 uppercase mt-0.5">
              {{ site_config.club_tagline|truncate(34, true, '') }}
            </span>
          {% endif %}
        </span>
      </a>

      {# Menu desktop #}
      <nav class="hidden lg:flex items-center gap-1" aria-label="Navigation principale">
        {% for item in menu_items %}
          <a href="{{ item_url(item) }}"
             class="nav-link {{ current_path is same as(item_url(item)) ? 'active' : '' }}">
            {{ item.label }}
          </a>
        {% endfor %}
      </nav>

      {# CTA + burger #}
      <div class="flex items-center gap-2">
        <a href="{{ url(site_config.adherer_url|default('contact')|trim('/')) }}"
           class="hidden sm:inline-flex items-center gap-1.5 btn-ink btn-sm btn-pill">
          Adhérer
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
          </svg>
        </a>
        <button type="button" id="burger-toggle" aria-label="Menu" class="lg:hidden nav-burger">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="4" y1="7" x2="20" y2="7"/>
            <line x1="4" y1="12" x2="20" y2="12"/>
            <line x1="4" y1="17" x2="20" y2="17"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>
<script>
  (function() {
    var h = document.getElementById('site-header');
    if (!h) return;
    var onScroll = function() { h.classList.toggle('scrolled', window.scrollY > 8); };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    var burger = document.getElementById('burger-toggle');
    if (burger) burger.addEventListener('click', function() {
      var m = document.getElementById('mobile-menu');
      if (m) m.classList.toggle('hidden');
    });
  })();
</script>
