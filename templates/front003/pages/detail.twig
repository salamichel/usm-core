{% extends 'base.twig' %}
{% import '_gallery.twig' as components %}
{% block title %}{{ page.title }} — {{ site_config.club_name|default('USM Volley') }}{% endblock %}

{% block content %}
<section class="page-header grain">
  <div class="inner max-w-3xl">
    <div class="eyebrow">{{ site_config.club_name|default('USM Volley') }}</div>
    <h1 class="page-title">{{ page.title }}</h1>
  </div>
</section>

<section class="section-paper">
  <article class="shell py-12 max-w-3xl mx-auto">
    <div class="cms-body">{{ page.content|render_with_config|raw }}</div>
    {{ components.gallery(photos) }}
  </article>
</section>
{% endblock %}

{% block scripts %}
{% if photos|length %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script>GLightbox({ selector: '.glightbox', touchNavigation: true, loop: true });</script>
{% endif %}
{% endblock %}
