{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}{{ location ? 'Éditer' : 'Créer' }} un emplacement{% endblock %}

{% block content %}

{# ── En-tête avec breadcrumb ── #}
<div class="relative overflow-hidden bg-slate-900 rounded-3xl p-6 md:p-8 text-white shadow-sm mb-8">
  <div class="relative">
    <nav class="flex items-center gap-1.5 text-xs text-slate-400 font-medium mb-2">
      <a href="{{ url('admin') }}" class="hover:text-white transition">Admin</a>
      <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      <a href="{{ url('admin/locations') }}" class="hover:text-white transition">Emplacements</a>
      <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      <span class="text-slate-200">{{ location ? 'Éditer' : 'Nouvel emplacement' }}</span>
    </nav>
    <h1 class="text-2xl font-black tracking-tight">
      {{ location ? 'Éditer l\'emplacement' : 'Nouvel emplacement' }}
    </h1>
  </div>
</div>

{{ m.form_error(error) }}

<form method="POST" action="{{ action }}" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  <div class="bg-white border border-slate-100 rounded-3xl shadow-sm p-6 md:p-8 space-y-6">
    <h2 class="font-bold text-base text-slate-800 border-b border-slate-100 pb-3">Informations générales</h2>

    {{ m.field_input('name', 'name', 'Nom du lieu', location.name ?? '', 'text', true, 'Ex: Gymnase Jean Moulin') }}
    {{ m.field_textarea('address', 'address', 'Adresse complète', location.address ?? '', 3, true, '12 Rue de la Paix&#10;33380 Mios') }}

    <div class="bg-sky-50/60 border border-sky-100 p-5 rounded-2xl space-y-4">
      <div class="flex items-center gap-2 text-sky-800 font-bold text-sm">
        <svg class="w-4 h-4 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        Coordonnées GPS (optionnel)
      </div>
      <p class="text-xs text-sky-700 font-medium">Entrez les coordonnées GPS pour afficher une carte interactive. Sinon, un lien Google Maps s'affichera.</p>

      <div class="grid sm:grid-cols-2 gap-4">
        {{ m.field_input('latitude', 'latitude', 'Latitude', location.latitude ?? '', 'number', false, 'Ex: 44.52556') }}
        {{ m.field_input('longitude', 'longitude', 'Longitude', location.longitude ?? '', 'number', false, 'Ex: -0.69171') }}
      </div>
    </div>

    {% if location and location.latitude and location.longitude %}
    <div class="flex items-center gap-3 bg-emerald-50 border border-emerald-200 px-4 py-3 rounded-xl text-sm">
      <svg class="w-5 h-5 text-emerald-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
      <div>
        <div class="font-bold text-emerald-800">Coordonnées GPS définies</div>
        <div class="text-xs font-mono text-emerald-700">Lat: {{ location.latitude|number_format(6) }}, Lng: {{ location.longitude|number_format(6) }}</div>
      </div>
    </div>
    {% endif %}
  </div>

  <div class="flex items-center gap-3 pt-2">
    {{ m.btn_submit(location ? 'Mettre à jour' : 'Enregistrer') }}
    <a href="{{ url('admin/locations') }}"
       class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-slate-700 transition">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
      Annuler
    </a>
  </div>
</form>
{% endblock %}
