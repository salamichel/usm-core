{% extends 'admin/layout.twig' %}
{% block title %}Emplacements{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-black">Emplacements du club</h1>
  <a href="{{ url('admin/locations/create') }}" class="border-4 border-black bg-usm-brown text-white font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    + Ajouter un lieu
  </a>
</div>

<p class="text-sm text-gray-600 mb-6">
  Gérez les gymnases et lieux d'entraînement du club. Chaque emplacement sera affiché sur la page contact avec une carte interactive.
</p>

{% if locations|length %}

<form id="bulk-delete-form" method="POST" action="{{ url('admin/locations/delete-bulk') }}">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  <div class="border-4 border-black bg-white p-3 mb-4 shadow-[4px_4px_0_#000] flex flex-wrap items-center justify-between gap-3">
    <div class="flex items-center gap-3">
      <label class="flex items-center gap-2 font-black text-sm cursor-pointer select-none">
        <input type="checkbox" id="select-all-locations" class="w-5 h-5 cursor-pointer accent-black" />
        <span>Tout sélectionner</span>
      </label>
      <span id="selected-count-badge" class="hidden text-xs font-bold bg-amber-200 border border-black px-2 py-0.5 rounded-full">
        0 sélectionné(s)
      </span>
    </div>
    <div>
      <button type="submit" id="btn-bulk-delete" disabled class="border-2 border-red-600 bg-red-50 text-red-600 px-4 py-1.5 font-bold text-sm disabled:opacity-50 disabled:cursor-not-allowed hover:bg-red-600 hover:text-white transition cursor-pointer">
        🗑️ Supprimer la sélection (<span id="bulk-delete-count">0</span>)
      </button>
    </div>
  </div>

  <div class="border-4 border-black bg-white shadow-[6px_6px_0_#000] divide-y-4 divide-black">
    {% for location in locations %}
    <div class="p-6 flex items-start justify-between hover:bg-amber-50 transition gap-4">
      <div class="flex items-start gap-3 flex-1">
        <input type="checkbox" name="ids[]" value="{{ location.id }}" class="item-checkbox w-5 h-5 cursor-pointer accent-black mt-1" />
        <div>
          <h3 class="font-black text-lg">{{ location.name }}</h3>
          <address class="not-italic text-sm text-gray-600 whitespace-pre-line leading-relaxed mt-1 mb-2">{{ location.address }}</address>
          {% if location.latitude and location.longitude %}
            <span class="inline-block text-xs bg-green-100 border border-green-400 text-green-700 px-2 py-0.5 rounded font-semibold">✓ Sur la carte interactive</span>
          {% else %}
            <span class="inline-block text-xs bg-blue-100 border border-blue-400 text-blue-700 px-2 py-0.5 rounded font-semibold">🔗 Lien Google Maps</span>
          {% endif %}
        </div>
      </div>
      <div class="flex gap-2 ml-4">
        <a href="{{ url('admin/locations/' ~ location.id ~ '/edit') }}" class="border-2 border-black px-3 py-1 text-sm font-bold hover:bg-black hover:text-white transition">Éditer</a>
        <form method="POST" action="{{ url('admin/locations/' ~ location.id ~ '/delete') }}" data-confirm="Supprimer cet emplacement ?">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
          <button type="submit" class="border-2 border-red-600 text-red-600 px-3 py-1 text-sm font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
        </form>
      </div>
    </div>
    {% endfor %}
  </div>
</form>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const selectAllGlobal = document.getElementById('select-all-locations');
  const checkboxes = document.querySelectorAll('.item-checkbox');
  const btnBulkDelete = document.getElementById('btn-bulk-delete');
  const bulkDeleteCount = document.getElementById('bulk-delete-count');
  const selectedBadge = document.getElementById('selected-count-badge');
  const form = document.getElementById('bulk-delete-form');

  function updateState() {
    const checked = document.querySelectorAll('.item-checkbox:checked');
    const count = checked.length;
    const total = checkboxes.length;

    if (bulkDeleteCount) bulkDeleteCount.textContent = count;
    if (selectedBadge) {
      if (count > 0) {
        selectedBadge.textContent = count + ' sélectionné(s)';
        selectedBadge.classList.remove('hidden');
      } else {
        selectedBadge.classList.add('hidden');
      }
    }
    if (btnBulkDelete) btnBulkDelete.disabled = (count === 0);

    if (selectAllGlobal) selectAllGlobal.checked = (total > 0 && count === total);
  }

  if (selectAllGlobal) {
    selectAllGlobal.addEventListener('change', function() {
      checkboxes.forEach(cb => { cb.checked = selectAllGlobal.checked; });
      updateState();
    });
  }

  checkboxes.forEach(cb => cb.addEventListener('change', updateState));

  if (form) {
    form.addEventListener('submit', function(e) {
      const count = document.querySelectorAll('.item-checkbox:checked').length;
      if (count === 0) {
        e.preventDefault();
        return;
      }
      if (!confirm('Voulez-vous vraiment supprimer les ' + count + ' emplacement(s) sélectionné(s) ?')) {
        e.preventDefault();
      }
    });
  }
  updateState();
});
</script>

{% else %}
  <div class="border-4 border-black bg-amber-100 p-6 shadow-[4px_4px_0_#000] text-center">
    <p class="text-gray-700 font-semibold">Aucun emplacement défini pour le moment.</p>
  </div>
{% endif %}
{% endblock %}
