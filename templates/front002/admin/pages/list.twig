{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}Pages statiques{% endblock %}

{% block content %}
{{ m.page_header('Pages statiques', url('admin/pages/create'), '+ Nouvelle') }}

{% if pages|length %}

<form id="bulk-delete-form" method="POST" action="{{ url('admin/pages/delete-bulk') }}">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  <div class="border-4 border-black bg-white p-3 mb-4 shadow-[4px_4px_0_#000] flex flex-wrap items-center justify-between gap-3">
    <div class="flex items-center gap-3">
      <label class="flex items-center gap-2 font-black text-sm cursor-pointer select-none">
        <input type="checkbox" id="select-all-pages" class="w-5 h-5 cursor-pointer accent-black" />
        <span>Tout sélectionner</span>
      </label>
      <span id="selected-count-badge" class="hidden text-xs font-bold bg-amber-200 border border-black px-2 py-0.5 rounded-full">
        0 sélectionnée(s)
      </span>
    </div>
    <div>
      <button type="submit" id="btn-bulk-delete" disabled class="border-2 border-red-600 bg-red-50 text-red-600 px-4 py-1.5 font-bold text-sm disabled:opacity-50 disabled:cursor-not-allowed hover:bg-red-600 hover:text-white transition cursor-pointer">
        🗑️ Supprimer la sélection (<span id="bulk-delete-count">0</span>)
      </button>
    </div>
  </div>

  {# ── Mobile : cartes ── #}
  <div class="sm:hidden space-y-3">
    {% for page in pages %}
    <div class="border-4 border-black bg-white p-4 shadow-[4px_4px_0_#000]">
      <div class="font-black text-base mb-1 break-words flex items-center gap-2">
        <input type="checkbox" name="ids[]" value="{{ page.id }}" class="item-checkbox w-5 h-5 cursor-pointer accent-black" />
        <span>{{ page.title }}</span> <span class="text-gray-500 font-mono text-xs">#{{ page.id }}</span>
      </div>
      <div class="text-xs mb-2">{{ m.status_badge(page.is_published, 'Publiée', 'Brouillon') }}</div>
      <div class="text-gray-500 font-mono text-xs mb-3 break-all">/p/{{ page.slug }}</div>
      {{ m.action_buttons(
        url('admin/pages/' ~ page.id ~ '/edit'),
        url('admin/pages/' ~ page.id ~ '/delete'),
        'Supprimer cette page ?',
        csrf_token,
        url('p/' ~ page.slug)
      ) }}
    </div>
    {% endfor %}
  </div>

  {# ── Desktop : tableau ── #}
  <div class="hidden sm:block border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-black text-white">
        <tr>
          <th class="w-10 px-4 py-3 text-center">
            <input type="checkbox" id="select-all-desktop" class="w-4 h-4 cursor-pointer accent-white" />
          </th>
          <th class="text-left px-4 py-3 font-black">ID</th>
          <th class="text-left px-4 py-3 font-black">Titre</th>
          <th class="text-left px-4 py-3 font-black">Slug</th>
          <th class="text-left px-4 py-3 font-black">Statut</th>
          <th class="px-4 py-3" aria-label="Actions"></th>
        </tr>
      </thead>
      <tbody>
        {% for page in pages %}
        <tr class="border-t-2 border-gray-200 hover:bg-amber-50">
          <td class="px-4 py-3 text-center">
            <input type="checkbox" name="ids[]" value="{{ page.id }}" class="item-checkbox w-4 h-4 cursor-pointer accent-black" />
          </td>
          <td class="px-4 py-3 text-gray-500 font-mono text-xs">{{ page.id }}</td>
          <td class="px-4 py-3 font-semibold">{{ page.title }}</td>
          <td class="px-4 py-3 text-gray-500 font-mono text-xs">/p/{{ page.slug }}</td>
          <td class="px-4 py-3">{{ m.status_badge(page.is_published, 'Publiée', 'Brouillon') }}</td>
          <td class="px-4 py-3">
            {{ m.action_buttons(
              url('admin/pages/' ~ page.id ~ '/edit'),
              url('admin/pages/' ~ page.id ~ '/delete'),
              'Supprimer cette page ?',
              csrf_token,
              url('p/' ~ page.slug)
            ) }}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</form>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const selectAllGlobal = document.getElementById('select-all-pages');
  const selectAllDesktop = document.getElementById('select-all-desktop');
  const checkboxes = document.querySelectorAll('.item-checkbox');
  const btnBulkDelete = document.getElementById('btn-bulk-delete');
  const bulkDeleteCount = document.getElementById('bulk-delete-count');
  const selectedBadge = document.getElementById('selected-count-badge');
  const form = document.getElementById('bulk-delete-form');

  function updateState() {
    const checked = document.querySelectorAll('.item-checkbox:checked');
    const count = checked.length;
    const total = checkboxes.length;

    if (bulkDeleteCount) bulkDeleteCount.textContent = count;
    if (selectedBadge) {
      if (count > 0) {
        selectedBadge.textContent = count + ' sélectionnée(s)';
        selectedBadge.classList.remove('hidden');
      } else {
        selectedBadge.classList.add('hidden');
      }
    }
    if (btnBulkDelete) btnBulkDelete.disabled = (count === 0);

    const allChecked = total > 0 && count === total;
    if (selectAllGlobal) selectAllGlobal.checked = allChecked;
    if (selectAllDesktop) selectAllDesktop.checked = allChecked;
  }

  function toggleAll(checked) {
    checkboxes.forEach(cb => { cb.checked = checked; });
    updateState();
  }

  if (selectAllGlobal) selectAllGlobal.addEventListener('change', function() { toggleAll(this.checked); });
  if (selectAllDesktop) selectAllDesktop.addEventListener('change', function() { toggleAll(this.checked); });

  checkboxes.forEach(cb => cb.addEventListener('change', updateState));

  if (form) {
    form.addEventListener('submit', function(e) {
      const count = document.querySelectorAll('.item-checkbox:checked').length;
      if (count === 0) {
        e.preventDefault();
        return;
      }
      if (!confirm('Voulez-vous vraiment supprimer les ' + count + ' page(s) sélectionnée(s) ?')) {
        e.preventDefault();
      }
    });
  }
  updateState();
});
</script>

{% else %}
  {{ m.empty_state('Aucune page.') }}
{% endif %}
{% endblock %}
