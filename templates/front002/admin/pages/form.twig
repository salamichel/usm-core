{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}{{ page ? 'Éditer la' : 'Nouvelle' }} page{% endblock %}

{% block content %}

{# ── En-tête avec breadcrumb ── #}
<div class="relative overflow-hidden bg-slate-900 rounded-3xl p-6 md:p-8 text-white shadow-sm mb-8">
  <div class="relative">
    <nav class="flex items-center gap-1.5 text-xs text-slate-400 font-medium mb-2">
      <a href="{{ url('admin') }}" class="hover:text-white transition">Admin</a>
      <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      <a href="{{ url('admin/pages') }}" class="hover:text-white transition">Pages</a>
      <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      <span class="text-slate-200">{{ page ? 'Éditer' : 'Nouvelle page' }}</span>
    </nav>
    <h1 class="text-2xl font-black tracking-tight">
      {{ page ? 'Éditer la page' : 'Nouvelle page' }}
    </h1>
  </div>
</div>

{{ m.form_error(error) }}

<form method="POST" action="{{ action }}" enctype="multipart/form-data" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  <div class="bg-white border border-slate-100 rounded-3xl shadow-sm p-6 md:p-8 space-y-6">
    {{ m.field_input('title', 'title', 'Titre', page.title ?? '', 'text', true, 'Titre de la page...') }}

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5" for="slug">Slug URL</label>
        <input type="text" id="slug" name="slug"
               value="{{ page.slug ?? '' }}"
               class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-mono text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition"
               placeholder="généré automatiquement depuis le titre">
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5" for="category">Catégorie</label>
        <input type="text" id="category" name="category"
               value="{{ page.category ?? '' }}"
               class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition"
               placeholder="Ex: Club, Pratique...">
      </div>
    </div>

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5" for="content">Contenu</label>
      <textarea id="content" name="content">{{ page.content ?? '' }}</textarea>
    </div>

    <div class="pt-2 border-t border-slate-50">
      {{ m.field_checkbox('is_published', 'is_published', 'Publiée', page is null or page.is_published, '1') }}
    </div>
  </div>

  {# ── Galerie photos (Dropzone) ── #}
  {% include 'admin/_photo_dropzone.twig' with {
    entity_id:   page ? page.id : 0,
    entity_type: 'page',
    upload_url:  page ? url('admin/pages/' ~ page.id ~ '/photos/upload') : '',
    photos:      photos
  } %}

  <div class="flex items-center gap-3 pt-2">
    {{ m.btn_submit('Enregistrer') }}
    <a href="{{ url('admin/pages') }}"
       class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-slate-700 transition">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
      Annuler
    </a>
  </div>
</form>
{% endblock %}

{% block scripts %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/jodit@3/build/jodit.min.css">
<link rel="stylesheet" href="{{ asset('content-styles.css') }}">
<script src="https://cdn.jsdelivr.net/npm/jodit@3/build/jodit.min.js" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var csrfToken = document.querySelector('[name="_csrf_token"]').value;
    var uploadUrl = '{{ url("admin/media/upload") }}';

    var editor = Jodit.make('#content', {
      language: 'fr',
      height: 500,
      toolbarButtonSize: 'small',
      buttons: 'bold,italic,underline,strikethrough,eraser,|,ul,ol,|,align,|,fontsize,paragraph,|,link,image,file,|,table,|,undo,redo,|,source',
      controls: {
        paragraph: {
          list: {
            p:          'Paragraphe',
            h1:         'Titre 1',
            h2:         'Titre 2',
            h3:         'Titre 3',
            h4:         'Titre 4',
            blockquote: 'Citation',
          }
        }
      },
      uploader: {
        url: uploadUrl,
        data: { _csrf_token: csrfToken },
        format: 'json',
        isSuccess: function (resp) { return resp.ok === true; },
        getMessage: function (resp) { return resp.error || 'Erreur inconnue'; },
        process: function (resp) {
          return {
            files:    [resp.url],
            path:     '',
            baseurl:  '',
            error:    resp.ok ? 0 : 1,
            msg:      resp.error || '',
            isImages: [resp.isImage],
            names:    [resp.name],
          };
        },
        defaultHandlerSuccess: function (data) {
          if (!data.files || !data.files.length) return;
          data.files.forEach(function (url, i) {
            var isImage = data.isImages && data.isImages[i];
            var name    = (data.names && data.names[i]) ? data.names[i] : url.split('/').pop();
            if (isImage) {
              editor.s.insertImage(url, null, '100%');
            } else {
              var link = editor.createInside.element('a');
              link.setAttribute('href', url);
              link.setAttribute('target', '_blank');
              link.setAttribute('rel', 'noopener noreferrer');
              link.textContent = name;
              editor.s.insertNode(link);
            }
          });
        }
      }
    });
  });
</script>
{% endblock %}
