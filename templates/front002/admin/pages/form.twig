{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}{{ page ? 'Éditer la' : 'Nouvelle' }} page{% endblock %}

{% block content %}
<div class="flex items-center gap-4 mb-6">
  <a href="{{ url('admin/pages') }}" class="font-bold hover:underline text-sm">← Retour</a>
  <h1 class="text-3xl font-black">{{ page ? 'Éditer la page' : 'Nouvelle page' }}</h1>
</div>

{{ m.form_error(error) }}

<form method="POST" action="{{ action }}" enctype="multipart/form-data" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">

    {{ m.field_input('title', 'title', 'Titre', page.title ?? '', 'text', true) }}

    <div>
      <label class="block font-black mb-1" for="slug">Slug</label>
      <input type="text" id="slug" name="slug"
             value="{{ page.slug ?? '' }}"
             class="w-full border-2 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-usm-brown"
             placeholder="généré automatiquement depuis le titre">
    </div>

    <div class="form-group">
        <label for="rubrique">Catégorie</label>        
        <input type="text" name="category" id="category" 
        value="{{ page.category ?? '' }}" 
        class="w-full border-2 border-black px-3 py-2 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-usm-brown"
        placeholder="Nom de la Catégorie">
        >
    </div>    

    <div>
      <label class="block font-black mb-1" for="content">Contenu</label>
      <textarea id="content" name="content">{{ page.content ?? '' }}</textarea>
    </div>

    {{ m.field_checkbox('is_published', 'is_published', 'Publiée', page is null or page.is_published, '1') }}
  </div>

  {# ── Galerie photos (Dropzone) ── #}
  {% include 'admin/_photo_dropzone.twig' with {
    entity_id:   page ? page.id : 0,
    entity_type: 'page',
    upload_url:  page ? url('admin/pages/' ~ page.id ~ '/photos/upload') : '',
    photos:      photos
  } %}

  {{ m.btn_submit('Enregistrer') }}
</form>
{% endblock %}

{% block scripts %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/jodit@3/build/jodit.min.css">
<link rel="stylesheet" href="{{ asset('content-styles.css') }}">
<script src="https://cdn.jsdelivr.net/npm/jodit@3/build/jodit.min.js" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var csrfToken = document.querySelector('[name="_csrf_token"]').value;
    var uploadUrl = '{{ url("admin/media/upload") }}';

    var editor = Jodit.make('#content', {
      language: 'fr',
      height: 500,
      toolbarButtonSize: 'small',
      buttons: 'bold,italic,underline,strikethrough,eraser,|,ul,ol,|,align,|,fontsize,paragraph,|,link,image,file,|,table,|,undo,redo,|,source',
      controls: {
        paragraph: {
          list: {
            p:          'Paragraphe',
            h1:         'Titre 1',
            h2:         'Titre 2',
            h3:         'Titre 3',
            h4:         'Titre 4',
            blockquote: 'Citation',
          }
        }
      },
      uploader: {
        url: uploadUrl,
        data: { _csrf_token: csrfToken },
        format: 'json',
        isSuccess: function (resp) { return resp.ok === true; },
        getMessage: function (resp) { return resp.error || 'Erreur inconnue'; },
        process: function (resp) {
          return {
            files:    [resp.url],
            path:     '',
            baseurl:  '',
            error:    resp.ok ? 0 : 1,
            msg:      resp.error || '',
            isImages: [resp.isImage],
            names:    [resp.name],
          };
        },
        defaultHandlerSuccess: function (data) {
          if (!data.files || !data.files.length) return;
          data.files.forEach(function (url, i) {
            var isImage = data.isImages && data.isImages[i];
            var name    = (data.names && data.names[i]) ? data.names[i] : url.split('/').pop();
            if (isImage) {
              editor.s.insertImage(url, null, '100%');
            } else {
              var link = editor.createInside.element('a');
              link.setAttribute('href', url);
              link.setAttribute('target', '_blank');
              link.setAttribute('rel', 'noopener noreferrer');
              link.textContent = name;
              editor.s.insertNode(link);
            }
          });
        }
      }
    });
  });
</script>
{% endblock %}
