{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}{{ categorie ? 'Éditer : ' ~ categorie.nom : 'Nouvelle catégorie' }}{% endblock %}

{% block content %}

{# ── En-tête avec breadcrumb ── #}
<div class="relative overflow-hidden bg-slate-900 rounded-3xl p-6 md:p-8 text-white shadow-sm mb-8">
  <div class="relative">
    <nav class="flex items-center gap-1.5 text-xs text-slate-400 font-medium mb-2">
      <a href="{{ url('admin') }}" class="hover:text-white transition">Admin</a>
      <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      <a href="{{ url('admin/categories-equipes') }}" class="hover:text-white transition">Catégories d'équipes</a>
      <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      <span class="text-slate-200">{{ categorie ? 'Éditer' : 'Nouvelle catégorie' }}</span>
    </nav>
    <h1 class="text-2xl font-black tracking-tight">
      {{ categorie ? 'Éditer la catégorie' : 'Nouvelle catégorie' }}
    </h1>
  </div>
</div>

{{ m.form_error(error ?? null) }}

<form method="POST" action="{{ action }}" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  <div class="bg-white border border-slate-100 rounded-3xl shadow-sm p-6 md:p-8 space-y-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        {{ m.field_input('nom', 'nom', 'Nom de la catégorie', categorie.nom ?? '', 'text', true, 'Compétition') }}
        <p class="text-xs text-slate-400 font-medium mt-1">Doit correspondre exactement au champ Catégorie des équipes.</p>
      </div>
      <div>
        {{ m.field_input('ordre', 'ordre', 'Ordre d\'affichage', categorie.ordre ?? 0, 'number') }}
      </div>
    </div>

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5" for="description">Description</label>
      <textarea id="description" name="description">{{ categorie.description ?? '' }}</textarea>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2">
    {{ m.btn_submit(categorie ? 'Mettre à jour' : 'Enregistrer') }}
    <a href="{{ url('admin/categories-equipes') }}"
       class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-slate-700 transition">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
      Annuler
    </a>
  </div>
</form>
{% endblock %}

{% block scripts %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.20/summernote-lite.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.20/summernote-lite.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.20/lang/summernote-fr-FR.min.js"></script>
<style>
  .note-editor .note-editable ul li { margin-left: 2rem !important; list-style: disc !important; }
  .note-editor .note-editable ol li { margin-left: 2rem !important; list-style: decimal !important; }
</style>
<script>
  $('#description').summernote({
    height: 250,
    lang: 'fr-FR',
    toolbar: [
      ['style',  ['style']],
      ['font',   ['bold', 'italic', 'underline', 'clear']],
      ['para',   ['ul', 'ol']],
      ['insert', ['link']],
      ['view',   ['codeview']]
    ]
  });
  $('form').on('submit', function () {
    document.getElementById('description').value = $('#description').summernote('code');
  });
</script>
{% endblock %}
