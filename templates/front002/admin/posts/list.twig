{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}Articles{% endblock %}

{% block content %}

{# ── En-tête de page ── #}
{{ m.page_header('Articles', url('admin/posts/create'), '+ Nouvel article') }}

{# ── Barre de filtres ── #}
{% if all_tags|length or months|length %}
<div class="bg-white border border-slate-100 rounded-2xl shadow-sm p-4 mb-6">
  <form method="GET" action="{{ url('admin/posts') }}"
        class="flex flex-wrap items-center gap-3">

    <select name="status" onchange="this.form.submit()"
            class="border border-slate-200 bg-white rounded-xl px-3 py-2 text-sm font-semibold text-slate-700 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
      <option value="">Tous statuts</option>
      <option value="published" {{ selected_status == 'published' ? 'selected' : '' }}>Publiés</option>
      <option value="draft"     {{ selected_status == 'draft'     ? 'selected' : '' }}>Brouillons</option>
    </select>

    {% if all_tags|length %}
    <select name="tag" onchange="this.form.submit()"
            class="border border-slate-200 bg-white rounded-xl px-3 py-2 text-sm font-semibold text-slate-700 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
      <option value="">Toutes catégories</option>
      {% for tag in all_tags %}
        <option value="{{ tag.slug }}" {{ selected_tag == tag.slug ? 'selected' : '' }}>{{ tag.name }}</option>
      {% endfor %}
    </select>
    {% endif %}

    {% if months|length %}
    <select name="month" onchange="this.form.submit()"
            class="border border-slate-200 bg-white rounded-xl px-3 py-2 text-sm font-semibold text-slate-700 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
      <option value="">Tous les mois</option>
      {% for month in months %}
        <option value="{{ month }}" {{ selected_month == month ? 'selected' : '' }}>{{ month|month_fr }}</option>
      {% endfor %}
    </select>
    {% endif %}

    <noscript>
      <button type="submit" class="bg-slate-900 text-white rounded-xl px-4 py-2 text-sm font-bold">Filtrer</button>
    </noscript>

    {% if selected_status or selected_tag or selected_month %}
      <a href="{{ url('admin/posts') }}"
         class="ml-auto flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-slate-700 transition">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        Réinitialiser
      </a>
    {% endif %}

    {% if posts is defined %}
      <span class="ml-auto text-xs font-bold text-slate-400">{{ posts|length }} article{{ posts|length > 1 ? 's' : '' }}</span>
    {% endif %}
  </form>
</div>
{% endif %}

{% if posts|length %}

{# ── Mobile : cartes ── #}
<div class="sm:hidden space-y-3">
  {% for post in posts %}
  <div class="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
    {% if post_covers[post.id] %}
    <div class="aspect-video w-full overflow-hidden">
      <img src="{{ image_variant(post_covers[post.id], 'medium') }}" alt=""
           loading="lazy" class="w-full h-full object-cover">
    </div>
    {% endif %}
    <div class="p-4">
      <div class="font-bold text-base text-slate-900 mb-1.5 flex items-center gap-2 flex-wrap">
        <span>{{ post.title }}</span>
        {% if post.canalblog_id %}
          <span class="bg-indigo-50 text-indigo-700 border border-indigo-200 px-2 py-0.5 text-xs font-bold rounded-full">API</span>
        {% endif %}
      </div>
      <div class="flex items-center gap-2 flex-wrap mb-3">
        {{ m.status_badge(post.is_published, 'Publié', 'Brouillon') }}
        {% if post.published_at %}
          <span class="text-xs text-slate-400 font-medium">{{ post.published_at|date_fr }}</span>
        {% endif %}
      </div>
      {{ m.action_buttons(
        url('admin/posts/' ~ post.id ~ '/edit'),
        url('admin/posts/' ~ post.id ~ '/delete'),
        'Supprimer cet article ?',
        csrf_token,
        url('blog/' ~ post.slug)
      ) }}
    </div>
  </div>
  {% endfor %}
</div>

{# ── Desktop : tableau ── #}
<div class="hidden sm:block bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-800 text-white">
      <tr>
        <th class="px-5 py-3.5 font-bold w-20 text-slate-300 text-left text-xs uppercase tracking-wider">Photo</th>
        <th class="px-5 py-3.5 font-bold text-left text-xs uppercase tracking-wider">Titre</th>
        <th class="px-5 py-3.5 font-bold text-left text-xs uppercase tracking-wider">Statut</th>
        <th class="px-5 py-3.5 font-bold text-left text-xs uppercase tracking-wider">Slider</th>
        <th class="px-5 py-3.5 font-bold text-left text-xs uppercase tracking-wider">Date</th>
        <th class="px-5 py-3.5 text-xs uppercase tracking-wider text-right"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-50">
      {% for post in posts %}
      <tr class="hover:bg-slate-50/70 transition duration-100">
        <td class="px-5 py-3.5">
          {% if post_covers[post.id] %}
            <img src="{{ image_variant(post_covers[post.id], 'thumb') }}" alt=""
                 loading="lazy" class="w-14 h-10 object-cover rounded-lg border border-slate-100">
          {% else %}
            <div class="w-14 h-10 bg-slate-100 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            </div>
          {% endif %}
        </td>
        <td class="px-5 py-3.5">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="font-semibold text-slate-900">{{ post.title }}</span>
            {% if post.canalblog_id %}
              <span class="bg-indigo-50 text-indigo-700 border border-indigo-200 px-2 py-0.5 text-[10px] font-bold rounded-full">API</span>
            {% endif %}
          </div>
        </td>
        <td class="px-5 py-3.5">{{ m.status_badge(post.is_published, 'Publié', 'Brouillon') }}</td>
        <td class="px-5 py-3.5">
          <form method="POST" action="{{ url('admin/posts/' ~ post.id ~ '/toggle-slider') }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" title="{{ post.is_slider ? 'Retirer du slider' : 'Épingler dans le slider' }}"
                    class="inline-flex items-center gap-1.5 px-2.5 py-1.5 text-xs font-semibold rounded-lg transition
                           {{ post.is_slider
                              ? 'bg-amber-50 border border-amber-200 text-amber-700 hover:bg-amber-100'
                              : 'bg-slate-50 border border-slate-200 text-slate-400 hover:border-amber-300 hover:text-amber-600' }}">
              <svg class="w-3 h-3" fill="{{ post.is_slider ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" /></svg>
              {{ post.is_slider ? 'Épinglé' : 'Épingler' }}
            </button>
          </form>
        </td>
        <td class="px-5 py-3.5 text-slate-400 text-xs font-medium">{{ post.published_at|date_fr }}</td>
        <td class="px-5 py-3.5 text-right">
          {{ m.action_buttons(
            url('admin/posts/' ~ post.id ~ '/edit'),
            url('admin/posts/' ~ post.id ~ '/delete'),
            'Supprimer cet article ?',
            csrf_token,
            url('blog/' ~ post.slug)
          ) }}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{% else %}
  {{ m.empty_state('Aucun article pour le moment.', url('admin/posts/create'), '+ Écrire un article') }}
{% endif %}
{% endblock %}
