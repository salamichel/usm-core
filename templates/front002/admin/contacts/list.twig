{% extends "admin/layout.twig" %}
{% import 'admin/_macros.twig' as m %}
{% block title %}Messages de contact{% endblock %}

{% block content %}

{# ── En-tête de page ── #}
{{ m.page_header('Messages de contact', null, null) }}

{# ── Filtres / Onglets ── #}
<div class="flex gap-2 mb-6 border-b border-slate-200 pb-2 overflow-x-auto">
  <a href="{{ url('admin/contacts') }}?status=new"
     class="px-4 py-2 rounded-xl text-xs font-bold transition flex items-center gap-2 {{ currentStatus == 'new' ? 'bg-slate-900 text-white shadow-sm' : 'text-slate-600 hover:bg-slate-100' }}">
    {% if newCount > 0 %}<span class="w-2 h-2 rounded-full bg-rose-500 animate-pulse"></span>{% endif %}
    Nouveaux ({{ newCount }})
  </a>
  <a href="{{ url('admin/contacts') }}?status=replied"
     class="px-4 py-2 rounded-xl text-xs font-bold transition {{ currentStatus == 'replied' ? 'bg-slate-900 text-white shadow-sm' : 'text-slate-600 hover:bg-slate-100' }}">
    Répondus ({{ repliedCount }})
  </a>
  <a href="{{ url('admin/contacts') }}?status=archived"
     class="px-4 py-2 rounded-xl text-xs font-bold transition {{ currentStatus == 'archived' ? 'bg-slate-900 text-white shadow-sm' : 'text-slate-600 hover:bg-slate-100' }}">
    Archivés ({{ archivedCount }})
  </a>
  <a href="{{ url('admin/contacts') }}?status=all"
     class="px-4 py-2 rounded-xl text-xs font-bold transition {{ currentStatus == 'all' ? 'bg-slate-900 text-white shadow-sm' : 'text-slate-600 hover:bg-slate-100' }}">
    Tous
  </a>
</div>

{% if contacts %}
  <form method="POST" action="{{ url('admin/contacts/bulk-action') }}" id="bulkForm">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

    {# ── Actions toolbar ── #}
    <div class="bg-white border border-slate-100 rounded-2xl shadow-sm p-4 mb-4 flex items-center justify-between gap-4 flex-wrap">
      <label class="flex items-center gap-2.5 cursor-pointer select-none">
        <input type="checkbox" id="selectAll" class="w-4 h-4 rounded border-slate-300 text-[#94674d] focus:ring-[#94674d]/30" />
        <span class="text-sm font-semibold text-slate-700">Tout sélectionner</span>
        <span id="selectedCount" class="text-xs font-bold text-slate-400 ml-1">(0 sélectionné)</span>
      </label>

      <div class="flex gap-2">
        <select name="action" id="bulkAction" class="border border-slate-200 bg-white rounded-xl px-3 py-1.5 text-xs font-semibold text-slate-700 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
          <option value="">— Choisir une action —</option>
          <option value="archive">📦 Archiver</option>
          <option value="delete">🗑️ Supprimer</option>
        </select>
        <button type="submit" id="submitBtn" disabled
                class="bg-slate-900 hover:bg-slate-800 text-white font-bold px-4 py-1.5 rounded-xl text-xs transition disabled:opacity-40 disabled:cursor-not-allowed shadow-sm">
          Appliquer
        </button>
      </div>
    </div>

    {# ── Messages list ── #}
    <div class="space-y-3">
      {% for contact in contacts %}
        <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm hover:shadow-md transition duration-150 flex gap-4">
          <input type="checkbox" name="contact_ids[]" value="{{ contact.id }}" class="contact-checkbox w-4 h-4 rounded border-slate-300 text-[#94674d] focus:ring-[#94674d]/30 mt-1" />

          <div class="flex-1">
            <div class="flex justify-between items-start mb-2 flex-wrap gap-2">
              <div>
                <h3 class="text-base font-bold text-slate-900 hover:text-[#94674d] transition">
                  <a href="{{ url('admin/contacts/' ~ contact.id) }}">
                    {{ contact.subject }}
                  </a>
                </h3>
                <p class="text-xs text-slate-500 font-medium mt-0.5">
                  <strong class="text-slate-700">De :</strong> {{ contact.name }} ({{ contact.email }}){% if contact.phone %} | 📱 {{ contact.phone }}{% endif %}
                </p>
              </div>
              <div>
                {% if contact.status == 'new' %}
                  <span class="inline-flex items-center gap-1 bg-rose-50 text-rose-700 border border-rose-200 px-2.5 py-0.5 text-xs font-bold rounded-full">
                    <span class="w-1.5 h-1.5 rounded-full bg-rose-500 animate-pulse"></span>Nouveau
                  </span>
                {% elseif contact.status == 'replied' %}
                  <span class="inline-flex items-center gap-1 bg-emerald-50 text-emerald-700 border border-emerald-200 px-2.5 py-0.5 text-xs font-bold rounded-full">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Répondu
                  </span>
                {% else %}
                  <span class="inline-flex items-center gap-1 bg-slate-100 text-slate-500 border border-slate-200 px-2.5 py-0.5 text-xs font-bold rounded-full">
                    Archivé
                  </span>
                {% endif %}
              </div>
            </div>
            <p class="text-slate-600 text-xs leading-relaxed mb-3 line-clamp-2">{{ contact.message }}</p>
            <div class="flex items-center justify-between text-[11px] text-slate-400 font-medium">
              <span>Reçu le {{ contact.created_at|date_fr }}</span>
              <a href="{{ url('admin/contacts/' ~ contact.id) }}" class="text-[#94674d] hover:underline font-bold">Lire le message →</a>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </form>

  <script>
    const selectAll = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('.contact-checkbox');
    const selectedCount = document.getElementById('selectedCount');
    const bulkAction = document.getElementById('bulkAction');
    const submitBtn = document.getElementById('submitBtn');
    const bulkForm = document.getElementById('bulkForm');

    function updateCount() {
      const checked = document.querySelectorAll('.contact-checkbox:checked').length;
      selectedCount.textContent = `(${checked} sélectionné${checked > 1 ? 's' : ''})`;
      submitBtn.disabled = checked === 0 || bulkAction.value === '';
    }

    if (selectAll) {
      selectAll.addEventListener('change', function() {
        checkboxes.forEach(cb => cb.checked = this.checked);
        updateCount();
      });
    }

    checkboxes.forEach(cb => {
      cb.addEventListener('change', function() {
        if (selectAll) selectAll.checked = Array.from(checkboxes).every(c => c.checked);
        updateCount();
      });
    });

    if (bulkAction) bulkAction.addEventListener('change', updateCount);

    if (bulkForm) {
      bulkForm.addEventListener('submit', function(e) {
        const action = bulkAction.value;
        const checked = document.querySelectorAll('.contact-checkbox:checked').length;
        if (checked === 0) { e.preventDefault(); return false; }
        let message = `Voulez-vous ${action === 'archive' ? 'archiver' : 'supprimer'} ${checked} message${checked > 1 ? 's' : ''} ?`;
        if (!confirm(message)) { e.preventDefault(); return false; }
      });
    }
  </script>
{% else %}
  {{ m.empty_state('Aucun message à afficher.') }}
{% endif %}
{% endblock %}
