{% extends "admin/layout.twig" %}
{% import 'admin/_macros.twig' as m %}
{% block title %}Message — {{ contact.subject }}{% endblock %}

{% block content %}

{# ── En-tête avec breadcrumb ── #}
<div class="relative overflow-hidden bg-slate-900 rounded-3xl p-6 md:p-8 text-white shadow-sm mb-8">
  <div class="relative flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
      <nav class="flex items-center gap-1.5 text-xs text-slate-400 font-medium mb-2">
        <a href="{{ url('admin') }}" class="hover:text-white transition">Admin</a>
        <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <a href="{{ url('admin/contacts') }}" class="hover:text-white transition">Messages</a>
        <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <span class="text-slate-200">Détail</span>
      </nav>
      <h1 class="text-2xl font-black tracking-tight">{{ contact.subject }}</h1>
      <div class="text-xs text-slate-400 font-medium mt-1">
        De : <strong class="text-white">{{ contact.name }}</strong> &lt;{{ contact.email }}&gt;
        {% if contact.phone %} | Tél : {{ contact.phone }}{% endif %}
        | Reçu le {{ contact.created_at|date_fr }}
      </div>
    </div>
    <div>
      {% if contact.status == 'new' %}
        <span class="inline-flex items-center gap-1 bg-rose-500/20 text-rose-300 border border-rose-500/30 px-3 py-1 text-xs font-bold rounded-full">
          <span class="w-2 h-2 rounded-full bg-rose-400 animate-pulse"></span>Nouveau
        </span>
      {% elseif contact.status == 'replied' %}
        <span class="inline-flex items-center gap-1 bg-emerald-500/20 text-emerald-300 border border-emerald-500/30 px-3 py-1 text-xs font-bold rounded-full">
          <span class="w-2 h-2 rounded-full bg-emerald-400"></span>Répondu
        </span>
      {% else %}
        <span class="inline-flex items-center gap-1 bg-slate-800 text-slate-400 border border-slate-700 px-3 py-1 text-xs font-bold rounded-full">
          Archivé
        </span>
      {% endif %}
    </div>
  </div>
</div>

<div class="space-y-6">

  {# ── Message original ── #}
  <div class="bg-white border border-slate-100 rounded-3xl p-6 md:p-8 shadow-sm space-y-3">
    <h2 class="text-sm font-bold text-slate-400 uppercase tracking-wider">Message original</h2>
    <div class="text-slate-800 text-sm leading-relaxed whitespace-pre-wrap font-medium bg-slate-50/70 p-5 rounded-2xl border border-slate-100">
      {{ contact.message }}
    </div>
  </div>

  {# ── Historique des réponses ── #}
  {% if replies %}
    <div class="bg-white border border-slate-100 rounded-3xl p-6 md:p-8 shadow-sm space-y-4">
      <h2 class="text-sm font-bold text-slate-400 uppercase tracking-wider">Historique des réponses ({{ replies|length }})</h2>
      <div class="space-y-3">
        {% for reply in replies %}
          <div class="bg-indigo-50/50 border border-indigo-100 rounded-2xl p-5 space-y-2">
            <div class="flex justify-between items-start text-xs text-indigo-900 font-semibold">
              <span>Par : {{ reply.from_email }}</span>
              <span class="text-indigo-400 font-normal">{{ reply.created_at|date_fr }}</span>
            </div>
            <p class="text-slate-700 text-sm leading-relaxed whitespace-pre-wrap font-medium">{{ reply.reply_text }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {# ── Formulaire de réponse ── #}
  <div class="bg-white border border-slate-100 rounded-3xl p-6 md:p-8 shadow-sm space-y-4">
    <h2 class="text-base font-bold text-slate-800 border-b border-slate-100 pb-3">Répondre à {{ contact.name }}</h2>
    <form method="POST" action="{{ url('admin/contacts/' ~ contact.id ~ '/reply') }}" class="space-y-4">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

      {{ m.field_textarea('reply', 'reply', 'Votre réponse', '', 6, true, 'Entrez votre réponse ici...') }}

      <div class="flex items-center justify-between pt-2">
        <a href="{{ url('admin/contacts') }}"
           class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-slate-700 transition">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
          Retour aux messages
        </a>
        {{ m.btn_submit('Envoyer la réponse') }}
      </div>
    </form>
  </div>

  {# ── Actions secondaires ── #}
  <div class="flex gap-3 justify-end items-center pt-2">
    {% if contact.status != 'archived' %}
      <form method="POST" action="{{ url('admin/contacts/' ~ contact.id ~ '/status') }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <input type="hidden" name="status" value="archived">
        <button type="submit" class="bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 px-4 py-2 text-sm font-semibold rounded-xl transition shadow-sm">
          📦 Archiver ce message
        </button>
      </form>
    {% endif %}

    <form method="POST" action="{{ url('admin/contacts/' ~ contact.id ~ '/delete') }}" data-confirm="Supprimer ce message de contact définitivement ?">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
      <button type="submit" class="bg-rose-50 border border-rose-200 text-rose-600 hover:bg-rose-100 px-4 py-2 text-sm font-bold rounded-xl transition">
        Supprimer
      </button>
    </form>
  </div>

</div>
{% endblock %}
