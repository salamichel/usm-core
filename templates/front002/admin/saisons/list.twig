{% extends 'admin/layout.twig' %}
{% block title %}Saisons
{% endblock %}

{% block content %}
	<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
		<h1 class="text-3xl font-black">Saisons</h1>
		<div class="flex items-center gap-3">
			<form method="POST" action="{{ url('admin/saisons/send-weekly-reminder') }}" data-confirm="Envoyer maintenant le rappel hebdomadaire de présence par e-mail à tous les joueurs abonnés ?">
				<input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
				<button type="submit" class="border-4 border-black bg-white text-black font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all flex items-center gap-2">
					🔔 Rappel hebdomadaire manuel
				</button>
			</form>
			<a href="{{ url('admin/saisons/create') }}" class="border-4 border-black bg-usm-brown text-white font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
				+ Nouvelle saison
			</a>
		</div>
	</div>

	{% if saisons|length %}

		<form id="bulk-delete-form" method="POST" action="{{ url('admin/saisons/delete-bulk') }}">
			<input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

			<div class="border-4 border-black bg-white p-3 mb-4 shadow-[4px_4px_0_#000] flex flex-wrap items-center justify-between gap-3">
				<div class="flex items-center gap-3">
					<label class="flex items-center gap-2 font-black text-sm cursor-pointer select-none">
						<input type="checkbox" id="select-all-saisons" class="w-5 h-5 cursor-pointer accent-black"/>
						<span>Tout sélectionner</span>
					</label>
					<span id="selected-count-badge" class="hidden text-xs font-bold bg-amber-200 border border-black px-2 py-0.5 rounded-full">
						0 sélectionnée(s)
					</span>
				</div>
				<div>
					<button type="submit" id="btn-bulk-delete" disabled class="border-2 border-red-600 bg-red-50 text-red-600 px-4 py-1.5 font-bold text-sm disabled:opacity-50 disabled:cursor-not-allowed hover:bg-red-600 hover:text-white transition cursor-pointer">
						🗑️ Supprimer la sélection (<span id="bulk-delete-count">0</span>)
					</button>
				</div>
			</div>

			{# ── Mobile : cartes empilées ── #}
			<div class="sm:hidden space-y-3">
				{% for s in saisons %}
					<div class="border-4 border-black bg-white p-4 shadow-[4px_4px_0_#000]">
						<div class="flex items-center gap-2 mb-1">
							<input type="checkbox" name="ids[]" value="{{ s.id }}" class="item-checkbox w-5 h-5 cursor-pointer accent-black"/>
							<div class="font-black text-base">{{ s.libelle }}</div>
						</div>
						<div class="text-xs text-gray-500 mb-2">
							Du
							{{ s.date_debut ? s.date_debut|date('d/m/Y') : '—' }}
							au
							{{ s.date_fin ? s.date_fin|date('d/m/Y') : '—' }}
						</div>
						<div class="flex items-center gap-2 flex-wrap text-xs mb-3">
							{% if s.is_active %}
								<span class="bg-green-100 text-green-800 border border-green-400 px-2 py-0.5 font-bold rounded">Active</span>
							{% else %}
								<span class="bg-gray-100 text-gray-500 border border-gray-300 px-2 py-0.5 font-bold rounded">Inactive</span>
							{% endif %}
							<span class="text-gray-600">{{ s.snapshot_count }}
								joueurs</span>
						</div>
						<div class="flex flex-wrap gap-2">
							<form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/flash') }}" data-confirm="Flasher la saison « {{ s.libelle }} » ? Les ajustements manuels des équipes seront réinitialisés (les capitaines locaux seront conservés et aucun nouveau capitaine externe ne sera importé).">
								<input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
								<button type="submit" class="border-2 border-usm-brown text-usm-brown px-2 py-1 text-xs font-bold hover:bg-usm-brown hover:text-white transition">Flash</button>
							</form>
							<a href="{{ url('admin/saisons/' ~ s.id ~ '/edit') }}" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Modifier</a>
							<a href="{{ url('admin/saisons/' ~ s.id ~ '/snapshots') }}" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Joueurs</a>
							<form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/purge') }}" data-confirm="Purger tous les joueurs, adhésions et abonnements e-mails de la saison « {{ s.libelle }} » pour recommencer à zéro ? Cette action est irréversible.">
								<input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
								<button type="submit" class="border-2 border-amber-600 text-amber-600 px-2 py-1 text-xs font-bold hover:bg-amber-600 hover:text-white transition">Purger</button>
							</form>
							{% if not s.is_active %}
								<form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/delete') }}" data-confirm="Supprimer la saison « {{ s.libelle }} » et tous ses snapshots ?">
									<input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
									<button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
								</form>
							{% endif %}
						</div>
					</div>
				{% endfor %}
			</div>

			{# ── Desktop : tableau ── #}
			<div class="hidden sm:block border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden">
				<table class="w-full text-sm">
					<thead class="bg-black text-white">
						<tr>
							<th class="w-10 px-4 py-3 text-center">
								<input type="checkbox" id="select-all-desktop" class="w-4 h-4 cursor-pointer accent-white"/>
							</th>
							<th class="text-left px-4 py-3 font-black">Libellé</th>
							<th class="text-left px-4 py-3 font-black">Date de début</th>
							<th class="text-left px-4 py-3 font-black">Date de fin</th>
							<th class="text-left px-4 py-3 font-black">Statut</th>
							<th class="text-left px-4 py-3 font-black">Joueurs</th>
							<th class="px-4 py-3"></th>
						</tr>
					</thead>
					<tbody>
						{% for s in saisons %}
							<tr class="border-t-2 border-gray-200 hover:bg-amber-50">
								<td class="px-4 py-3 text-center">
									<input type="checkbox" name="ids[]" value="{{ s.id }}" class="item-checkbox w-4 h-4 cursor-pointer accent-black"/>
								</td>
								<td class="px-4 py-3 font-semibold">{{ s.libelle }}</td>
								<td class="px-4 py-3 text-gray-600">{{ s.date_debut ? s.date_debut|date('d/m/Y') : '—' }}</td>
								<td class="px-4 py-3 text-gray-600">{{ s.date_fin ? s.date_fin|date('d/m/Y') : '—' }}</td>
								<td class="px-4 py-3">
									{% if s.is_active %}
										<span class="bg-green-100 text-green-800 border border-green-400 px-2 py-0.5 text-xs font-bold rounded">Active</span>
									{% else %}
										<span class="bg-gray-100 text-gray-500 border border-gray-300 px-2 py-0.5 text-xs font-bold rounded">Inactive</span>
									{% endif %}
								</td>
								<td class="px-4 py-3 text-gray-600">{{ s.snapshot_count }}
									joueurs</td>
								<td class="px-4 py-3">
									<div class="flex gap-2 justify-end flex-wrap">
										<form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/flash') }}" data-confirm="Flasher la saison « {{ s.libelle }} » ? Les ajustements manuels des équipes seront réinitialisés (les capitaines locaux seront conservés et aucun nouveau capitaine externe ne sera importé).">
											<input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
											<button type="submit" class="border-2 border-usm-brown text-usm-brown px-2 py-1 text-xs font-bold hover:bg-usm-brown hover:text-white transition">Flash</button>
										</form>
										<a href="{{ url('admin/saisons/' ~ s.id ~ '/edit') }}" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Modifier</a>
										<a href="{{ url('admin/saisons/' ~ s.id ~ '/snapshots') }}" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Joueurs</a>
										<form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/purge') }}" data-confirm="Purger tous les joueurs, adhésions et abonnements e-mails de la saison « {{ s.libelle }} » pour recommencer à zéro ? Cette action est irréversible.">
											<input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
											<button type="submit" class="border-2 border-amber-600 text-amber-600 px-2 py-1 text-xs font-bold hover:bg-amber-600 hover:text-white transition">Purger</button>
										</form>
										{% if not s.is_active %}
											<form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/delete') }}" data-confirm="Supprimer la saison « {{ s.libelle }} » et tous ses snapshots ?">
												<input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
												<button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
											</form>
										{% endif %}
									</div>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</form>

		<script>
			document.addEventListener('DOMContentLoaded', function () {
const selectAllGlobal = document.getElementById('select-all-saisons');
const selectAllDesktop = document.getElementById('select-all-desktop');
const checkboxes = document.querySelectorAll('.item-checkbox');
const btnBulkDelete = document.getElementById('btn-bulk-delete');
const bulkDeleteCount = document.getElementById('bulk-delete-count');
const selectedBadge = document.getElementById('selected-count-badge');
const form = document.getElementById('bulk-delete-form');

function updateState() {
const checked = document.querySelectorAll('.item-checkbox:checked');
const count = checked.length;
const total = checkboxes.length;

if (bulkDeleteCount) 
bulkDeleteCount.textContent = count;

if (selectedBadge) {
if (count > 0) {
selectedBadge.textContent = count + ' sélectionnée(s)';
selectedBadge.classList.remove('hidden');
} else {
selectedBadge.classList.add('hidden');
}
}
if (btnBulkDelete) 
btnBulkDelete.disabled = (count === 0);


const allChecked = total > 0 && count === total;
if (selectAllGlobal) 
selectAllGlobal.checked = allChecked;

if (selectAllDesktop) 
selectAllDesktop.checked = allChecked;

}

function toggleAll(checked) {
checkboxes.forEach(cb => {
cb.checked = checked;
});
updateState();
}

if (selectAllGlobal) 
selectAllGlobal.addEventListener('change', function () {
toggleAll(this.checked);
});

if (selectAllDesktop) 
selectAllDesktop.addEventListener('change', function () {
toggleAll(this.checked);
});


checkboxes.forEach(cb => cb.addEventListener('change', updateState));

if (form) {
form.addEventListener('submit', function (e) {
const count = document.querySelectorAll('.item-checkbox:checked').length;
if (count === 0) {
e.preventDefault();
return;
}
if (!confirm('Voulez-vous vraiment supprimer les ' + count + ' saison(s) sélectionnée(s) et tous leurs snapshots ?')) {
e.preventDefault();
}
});
}
updateState();
});
		</script>

	{% else %}
		<p class="text-gray-500 italic">Aucune saison. Créez la première ci-dessus.</p>
	{% endif %}
{% endblock %}
