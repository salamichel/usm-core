{% extends 'admin/layout.twig' %}{% import 'admin/_macros.twig' as m %}{% block title %}Saisons{% endblock %}{% block content %}{# ── En-tête de page ── #}{{ m.page_header('Saisons', url('admin/saisons/create'), '+ Nouvelle saison') }}{# ── Actions globales ── #}<div class="flex flex-wrap items-center justify-between gap-3 mb-6">  <p class="text-sm text-slate-500 font-medium">{{ saisons|length }} saison{{ saisons|length > 1 ? 's' : '' }} enregistrée{{ saisons|length > 1 ? 's' : '' }}</p>  <form method="POST" action="{{ url('admin/saisons/send-weekly-reminder') }}"        data-confirm="Envoyer maintenant le rappel hebdomadaire de présence par e-mail à tous les joueurs abonnés ?">    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">    <button type="submit"            class="inline-flex items-center gap-2 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 font-semibold px-4 py-2 text-sm rounded-xl transition shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-300">      <svg class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">        <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />      </svg>      Rappel hebdomadaire manuel    </button>  </form></div>{% if saisons|length %}{# ── Barre de suppression en masse ── #}<form id="bulk-delete-form" method="POST" action="{{ url('admin/saisons/delete-bulk') }}">  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">  <div class="bg-white border border-slate-100 rounded-2xl shadow-sm p-4 mb-4 flex flex-wrap items-center justify-between gap-3">    <label class="flex items-center gap-2.5 cursor-pointer select-none">      <input type="checkbox" id="select-all-saisons" class="w-4 h-4 rounded border-slate-300 text-[#94674d] focus:ring-[#94674d]/30" />      <span class="text-sm font-semibold text-slate-700">Tout sélectionner</span>      <span id="selected-count-badge" class="hidden text-xs font-bold bg-[#94674d]/10 text-[#94674d] px-2.5 py-0.5 rounded-full">0 sélectionnée(s)</span>    </label>    <button type="submit" id="btn-bulk-delete" disabled            class="inline-flex items-center gap-1.5 bg-rose-50 border border-rose-200 text-rose-600 hover:bg-rose-100 px-3 py-1.5 text-xs font-bold rounded-lg transition disabled:opacity-40 disabled:cursor-not-allowed">      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>      Supprimer la sélection (<span id="bulk-delete-count">0</span>)    </button>  </div>  {# ── Mobile : cartes ── #}  <div class="sm:hidden space-y-3">    {% for s in saisons %}    <div class="bg-white border border-slate-100 rounded-2xl shadow-sm p-4 {% if s.is_active %}ring-2 ring-emerald-200{% endif %}">      <div class="flex items-start justify-between mb-2">        <label class="flex items-center gap-2.5 cursor-pointer">          <input type="checkbox" name="ids[]" value="{{ s.id }}" class="item-checkbox w-4 h-4 rounded border-slate-300 text-[#94674d] focus:ring-[#94674d]/30" />          <div class="font-bold text-base text-slate-900">{{ s.libelle }}</div>        </label>        {% if s.is_active %}          <span class="inline-flex items-center gap-1 bg-emerald-50 text-emerald-700 border border-emerald-200 px-2.5 py-0.5 text-xs font-bold rounded-full flex-shrink-0">            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Active          </span>        {% else %}          <span class="inline-flex items-center gap-1 bg-slate-100 text-slate-500 border border-slate-200 px-2.5 py-0.5 text-xs font-bold rounded-full flex-shrink-0">            <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>Inactive          </span>        {% endif %}      </div>      <div class="text-xs text-slate-400 font-medium mb-1">        Du {{ s.date_debut ? s.date_debut|date('d/m/Y') : '—' }} au {{ s.date_fin ? s.date_fin|date('d/m/Y') : '—' }}      </div>      <div class="text-xs text-slate-500 font-semibold mb-3">{{ s.snapshot_count }} joueur{{ s.snapshot_count > 1 ? 's' : '' }}</div>      <div class="flex flex-wrap gap-2">        <form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/flash') }}"              data-confirm="Flasher la saison « {{ s.libelle }} » ? Les ajustements manuels des équipes seront réinitialisés.">          <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">          <button type="submit" class="inline-flex items-center gap-1 bg-[#94674d]/10 border border-[#94674d]/30 text-[#94674d] hover:bg-[#94674d] hover:text-white px-2.5 py-1.5 text-xs font-bold rounded-lg transition">            ⚡ Flash          </button>        </form>        <a href="{{ url('admin/saisons/' ~ s.id ~ '/edit') }}"           class="inline-flex items-center gap-1 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 px-2.5 py-1.5 text-xs font-semibold rounded-lg transition">          Modifier        </a>        <a href="{{ url('admin/saisons/' ~ s.id ~ '/snapshots') }}"           class="inline-flex items-center gap-1 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 px-2.5 py-1.5 text-xs font-semibold rounded-lg transition">          Joueurs        </a>        <form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/purge') }}"              data-confirm="Purger tous les joueurs, adhésions et abonnements e-mails de la saison « {{ s.libelle }} » ? Cette action est irréversible.">          <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">          <button type="submit" class="inline-flex items-center gap-1 bg-amber-50 border border-amber-200 text-amber-700 hover:bg-amber-100 px-2.5 py-1.5 text-xs font-bold rounded-lg transition">            Purger          </button>        </form>        {% if not s.is_active %}        <form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/delete') }}"              data-confirm="Supprimer la saison « {{ s.libelle }} » et tous ses snapshots ?">          <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">          <button type="submit" class="inline-flex items-center gap-1 bg-rose-50 border border-rose-200 text-rose-600 hover:bg-rose-100 px-2.5 py-1.5 text-xs font-bold rounded-lg transition">            Supprimer          </button>        </form>        {% endif %}      </div>    </div>    {% endfor %}  </div>  {# ── Desktop : tableau ── #}  <div class="hidden sm:block bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">    <table class="w-full text-sm">      <thead class="bg-slate-800 text-white">        <tr>          <th class="w-10 px-5 py-3.5 text-center">            <input type="checkbox" id="select-all-desktop" class="w-4 h-4 rounded border-slate-600 bg-slate-700" />          </th>          <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Libellé</th>          <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Période</th>          <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Statut</th>          <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Joueurs</th>          <th class="px-5 py-3.5 text-right"></th>        </tr>      </thead>      <tbody class="divide-y divide-slate-50">        {% for s in saisons %}        <tr class="hover:bg-slate-50/70 transition duration-100 {% if s.is_active %}bg-emerald-50/30{% endif %}">          <td class="px-5 py-4 text-center">            <input type="checkbox" name="ids[]" value="{{ s.id }}" class="item-checkbox w-4 h-4 rounded border-slate-300 text-[#94674d] focus:ring-[#94674d]/30" />          </td>          <td class="px-5 py-4">            <span class="font-semibold text-slate-900">{{ s.libelle }}</span>          </td>          <td class="px-5 py-4 text-slate-500 text-xs font-medium">            {{ s.date_debut ? s.date_debut|date('d/m/Y') : '—' }}            <span class="text-slate-300 mx-1">→</span>            {{ s.date_fin ? s.date_fin|date('d/m/Y') : '—' }}          </td>          <td class="px-5 py-4">            {% if s.is_active %}              <span class="inline-flex items-center gap-1 bg-emerald-50 text-emerald-700 border border-emerald-200 px-2.5 py-0.5 text-xs font-bold rounded-full">                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Active              </span>            {% else %}              <span class="inline-flex items-center gap-1 bg-slate-100 text-slate-500 border border-slate-200 px-2.5 py-0.5 text-xs font-bold rounded-full">                <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>Inactive              </span>            {% endif %}          </td>          <td class="px-5 py-4 text-slate-500 text-xs font-semibold">{{ s.snapshot_count }} joueur{{ s.snapshot_count > 1 ? 's' : '' }}</td>          <td class="px-5 py-4">            <div class="flex gap-1.5 justify-end flex-wrap items-center">              <form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/flash') }}"                    data-confirm="Flasher la saison « {{ s.libelle }} » ? Les ajustements manuels des équipes seront réinitialisés (les capitaines locaux seront conservés et aucun nouveau capitaine externe ne sera importé).">                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">                <button type="submit"                        class="inline-flex items-center gap-1 bg-[#94674d]/10 border border-[#94674d]/30 text-[#94674d] hover:bg-[#94674d] hover:text-white px-2.5 py-1.5 text-xs font-bold rounded-lg transition">                  ⚡ Flash                </button>              </form>              <a href="{{ url('admin/saisons/' ~ s.id ~ '/edit') }}"                 class="inline-flex items-center gap-1 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 px-2.5 py-1.5 text-xs font-semibold rounded-lg transition">                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>                Modifier              </a>              <a href="{{ url('admin/saisons/' ~ s.id ~ '/snapshots') }}"                 class="inline-flex items-center gap-1 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 px-2.5 py-1.5 text-xs font-semibold rounded-lg transition">                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>                Joueurs              </a>              <form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/purge') }}"                    data-confirm="Purger tous les joueurs, adhésions et abonnements e-mails de la saison « {{ s.libelle }} » pour recommencer à zéro ? Cette action est irréversible.">                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">                <button type="submit"                        class="inline-flex items-center gap-1 bg-amber-50 border border-amber-200 text-amber-700 hover:bg-amber-100 px-2.5 py-1.5 text-xs font-bold rounded-lg transition">                  Purger                </button>              </form>              {% if not s.is_active %}              <form method="POST" action="{{ url('admin/saisons/' ~ s.id ~ '/delete') }}"                    data-confirm="Supprimer la saison « {{ s.libelle }} » et tous ses snapshots ?">                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">                <button type="submit"                        class="inline-flex items-center gap-1 bg-rose-50 border border-rose-200 text-rose-600 hover:bg-rose-100 px-2.5 py-1.5 text-xs font-bold rounded-lg transition">                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>                  Supprimer                </button>              </form>              {% endif %}            </div>          </td>        </tr>        {% endfor %}      </tbody>    </table>  </div></form><script>document.addEventListener('DOMContentLoaded', function () {  const selectAllGlobal = document.getElementById('select-all-saisons');  const selectAllDesktop = document.getElementById('select-all-desktop');  const checkboxes = document.querySelectorAll('.item-checkbox');  const btnBulkDelete = document.getElementById('btn-bulk-delete');  const bulkDeleteCount = document.getElementById('bulk-delete-count');  const selectedBadge = document.getElementById('selected-count-badge');  const form = document.getElementById('bulk-delete-form');  function updateState() {    const checked = document.querySelectorAll('.item-checkbox:checked');    const count = checked.length;    const total = checkboxes.length;    if (bulkDeleteCount) bulkDeleteCount.textContent = count;    if (selectedBadge) {      selectedBadge.textContent = count + ' sélectionnée(s)';      selectedBadge.classList.toggle('hidden', count === 0);    }    if (btnBulkDelete) btnBulkDelete.disabled = (count === 0);    const allChecked = total > 0 && count === total;    if (selectAllGlobal) selectAllGlobal.checked = allChecked;    if (selectAllDesktop) selectAllDesktop.checked = allChecked;  }  function toggleAll(checked) { checkboxes.forEach(cb => { cb.checked = checked; }); updateState(); }  if (selectAllGlobal) selectAllGlobal.addEventListener('change', function () { toggleAll(this.checked); });  if (selectAllDesktop) selectAllDesktop.addEventListener('change', function () { toggleAll(this.checked); });  checkboxes.forEach(cb => cb.addEventListener('change', updateState));  if (form) {    form.addEventListener('submit', function (e) {      const count = document.querySelectorAll('.item-checkbox:checked').length;      if (count === 0) { e.preventDefault(); return; }      if (!confirm('Supprimer les ' + count + ' saison(s) sélectionnée(s) et tous leurs snapshots ?')) { e.preventDefault(); }    });  }  updateState();});</script>{% else %}  {{ m.empty_state('Aucune saison. Créez la première.', url('admin/saisons/create'), '+ Nouvelle saison') }}{% endif %}{% endblock %}