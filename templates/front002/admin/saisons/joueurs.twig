{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}Joueurs (base externe){% endblock %}

{% block content %}

{# ── En-tête de page ── #}
{{ m.page_header('Joueurs (Base Externe)', null, null) }}

<p class="text-xs text-slate-400 font-medium -mt-2 mb-6">Données en temps réel depuis la base USM. Lecture seule.</p>

{% if seasons|length %}
<div class="bg-white border border-slate-100 rounded-2xl p-6 shadow-sm mb-6 space-y-4">
  <div class="flex items-center gap-2 text-slate-900 font-bold text-base">
    <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
    Importer / Flasher les joueurs
  </div>
  <p class="text-xs text-slate-500 leading-relaxed font-medium">
    Cette action récupère les joueurs de la base externe ci-dessous et les enregistre (snapshot) pour la saison de votre choix. 
    Les liaisons d'équipes seront automatiquement créées. <strong class="text-rose-600">Attention : cela réinitialise les ajustements manuels de composition d'équipe (les capitaines locaux seront conservés).</strong>
  </p>

  <form method="POST" action="{{ url('admin/saisons/flash-select') }}" class="flex flex-col sm:flex-row gap-3 items-end sm:items-center pt-2" data-confirm="Voulez-vous vraiment flasher les joueurs pour la saison sélectionnée ?">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
    <div class="flex-1 w-full">
      <label class="block text-xs font-bold uppercase tracking-wider mb-1 text-slate-500" for="saison_id">Sélectionner la saison :</label>
      <select id="saison_id" name="saison_id"
              class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2 text-sm font-bold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
        {% for s in seasons %}
          <option value="{{ s.id }}" {% if saison_active and s.id == saison_active.id %}selected{% endif %}>
            {{ s.libelle }} {% if s.is_active %}(Active){% endif %}
          </option>
        {% endfor %}
      </select>
    </div>
    <button type="submit" class="w-full sm:w-auto bg-[#94674d] hover:bg-[#7a5540] text-white font-bold px-6 py-2.5 rounded-xl transition text-xs shadow-sm whitespace-nowrap">
      ⚡ Flasher les joueurs
    </button>
  </form>
</div>
{% else %}
<div class="bg-amber-50 border border-amber-200 rounded-2xl p-4 mb-6">
  <p class="font-bold text-xs text-amber-800">
    ⚠️ Aucune saison n'est disponible. Veuillez <a href="{{ url('admin/saisons/create') }}" class="underline">créer une saison</a> avant de pouvoir flasher les joueurs.
  </p>
</div>
{% endif %}

{{ m.form_error(error) }}

{% if joueurs|length %}
<div class="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-800 text-white">
      <tr>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Nom</th>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Prénom</th>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Email</th>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Équipes actives</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-50">
      {% for j in joueurs %}
      {% set flags = [] %}
      {% for col in categories %}
        {% if j[col] is defined and j[col] %}
          {% set flags = flags|merge([col]) %}
        {% endif %}
      {% endfor %}
      <tr class="hover:bg-slate-50/70 transition duration-100">
        <td class="px-5 py-3.5 font-semibold text-slate-900">{{ j.Nom }}</td>
        <td class="px-5 py-3.5 font-medium text-slate-800">{{ j['Prénom'] }}</td>
        <td class="px-5 py-3.5 text-slate-400 text-xs font-mono">{{ j.Mel ?: '—' }}</td>
        <td class="px-5 py-3.5 text-xs text-slate-600 font-medium">{{ flags|length ? flags|join(', ') : '—' }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
  {{ m.empty_state('Aucun joueur trouvé dans la base externe.') }}
{% endif %}
{% endblock %}
