{% extends 'admin/layout.twig' %}
{% block title %}{{ motCle ? 'Éditer' : 'Créer' }} un mot-clé{% endblock %}

{% block content %}
<div class="flex items-center gap-4 mb-6">
  <a href="{{ url('admin/mots-cles') }}" class="font-bold hover:underline text-sm">&larr; Retour</a>
  <h1 class="text-3xl font-black">{{ motCle ? 'Éditer le mot-clé' : 'Nouveau mot-clé' }}</h1>
</div>

{% if error %}
  <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-6 font-semibold text-sm rounded">{{ error }}</div>
{% endif %}

<form method="POST" action="{{ action }}" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-6">
    <h2 class="font-black text-lg">Détails du mot-clé</h2>

    {# Sélection de la catégorie #}
    <div class="space-y-4">
      <div>
        <label class="block font-black mb-1" for="categorie">Catégorie existante</label>
        <select id="categorie" name="categorie" class="w-full border-2 border-black px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-usm-brown font-semibold">
          <option value="">-- Sélectionner une catégorie existante --</option>
          {% for cat in categories %}
            <option value="{{ cat }}" {{ motCle.Catégorie == cat ? 'selected' : '' }}>{{ cat }}</option>
          {% endfor %}
        </select>
        <div class="text-xs text-gray-500 mt-1">Choisissez une catégorie parmi celles déjà enregistrées.</div>
      </div>

      <div class="relative flex py-2 items-center">
        <div class="flex-grow border-t border-gray-300"></div>
        <span class="flex-shrink mx-4 text-gray-400 text-xs font-black uppercase">OU</span>
        <div class="flex-grow border-t border-gray-300"></div>
      </div>

      <div>
        <label class="block font-black mb-1" for="nouvelle_categorie">Créer une nouvelle catégorie</label>
        <input type="text" id="nouvelle_categorie" name="nouvelle_categorie"
               placeholder="Ex: MonNouveauType"
               class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
        <div class="text-xs text-gray-500 mt-1">Saisissez le nom d'une nouvelle catégorie si elle n'est pas dans la liste ci-dessus.</div>
      </div>
    </div>

    <hr class="border-t-2 border-black">

    {# Saisie du mot #}
    <div>
      <label class="block font-black mb-1" for="mot">Mot-clé *</label>
      <input type="text" id="mot" name="mot" required
             value="{{ motCle.Mot ?? '' }}"
             placeholder="Ex: Gymnase Mios"
             class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
      <div class="text-xs text-gray-500 mt-1">La valeur textuelle du mot-clé à ajouter.</div>
    </div>
  </div>

  <button type="submit"
          class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    {{ motCle ? 'Mettre à jour' : 'Créer' }}
  </button>
</form>
{% endblock %}
