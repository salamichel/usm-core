{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}Mots-clés{% endblock %}

{% block content %}

{# ── En-tête de page ── #}
{{ m.page_header('Mots-clés (Base Externe)', url('admin/mots-cles/create'), '+ Ajouter un mot-clé') }}

{# ── Barre de filtrage ── #}
<div class="bg-white border border-slate-100 rounded-2xl shadow-sm p-4 mb-6">
  <form method="GET" class="flex flex-col sm:flex-row items-end sm:items-center gap-3">
    <div class="flex-1 w-full">
      <label for="category-filter" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Filtrer par catégorie</label>
      <select id="category-filter" name="category" onchange="this.form.submit()"
              class="w-full border border-slate-200 bg-white rounded-xl px-3 py-2 text-sm font-semibold text-slate-700 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
        <option value="">-- Toutes les catégories --</option>
        {% for cat in categories %}
          <option value="{{ cat }}" {{ selectedCat == cat ? 'selected' : '' }}>{{ cat }}</option>
        {% endfor %}
      </select>
    </div>
    {% if selectedCat %}
      <a href="{{ url('admin/mots-cles') }}" class="flex items-center gap-1 text-sm font-semibold text-slate-500 hover:text-slate-700 transition">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        Réinitialiser
      </a>
    {% endif %}
  </form>
</div>

{% if motsCles|length %}

<form id="bulk-delete-form" method="POST" action="{{ url('admin/mots-cles/delete-bulk') }}">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  {# ── Barre de suppression en masse ── #}
  <div class="bg-white border border-slate-100 rounded-2xl shadow-sm p-4 mb-4 flex flex-wrap items-center justify-between gap-3">
    <label class="flex items-center gap-2.5 cursor-pointer select-none">
      <input type="checkbox" id="select-all-motscles" class="w-4 h-4 rounded border-slate-300 text-[#94674d] focus:ring-[#94674d]/30" />
      <span class="text-sm font-semibold text-slate-700">Tout sélectionner</span>
      <span id="selected-count-badge" class="hidden text-xs font-bold bg-[#94674d]/10 text-[#94674d] px-2.5 py-0.5 rounded-full">0 sélectionné(s)</span>
    </label>
    <button type="submit" id="btn-bulk-delete" disabled
            class="inline-flex items-center gap-1.5 bg-rose-50 border border-rose-200 text-rose-600 hover:bg-rose-100 px-3 py-1.5 text-xs font-bold rounded-lg transition disabled:opacity-40 disabled:cursor-not-allowed">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
      Supprimer la sélection (<span id="bulk-delete-count">0</span>)
    </button>
  </div>

  {# ── Mobile : cartes ── #}
  <div class="sm:hidden space-y-3">
    {% for mc in motsCles %}
    <div class="bg-white border border-slate-100 rounded-2xl shadow-sm p-4">
      <div class="flex items-center gap-2.5 mb-2">
        <input type="checkbox" name="ids[]" value="{{ mc.id_mot_clef }}" class="item-checkbox w-4 h-4 rounded border-slate-300 text-[#94674d] focus:ring-[#94674d]/30" />
        <span class="text-xs font-mono font-bold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-md border border-slate-200">{{ mc.Catégorie }}</span>
      </div>
      <div class="font-bold text-base text-slate-900 mb-3 ml-6.5">{{ mc.Mot }}</div>
      <div class="flex flex-wrap gap-2">
        {{ m.action_buttons(
          url('admin/mots-cles/' ~ mc.id_mot_clef ~ '/edit'),
          url('admin/mots-cles/' ~ mc.id_mot_clef ~ '/delete'),
          'Supprimer ce mot-clé ?',
          csrf_token
        ) }}
      </div>
    </div>
    {% endfor %}
  </div>

  {# ── Desktop : tableau ── #}
  <div class="hidden sm:block bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-slate-800 text-white">
        <tr>
          <th class="w-10 px-5 py-3.5 text-center">
            <input type="checkbox" id="select-all-desktop" class="w-4 h-4 rounded border-slate-600 bg-slate-700" />
          </th>
          <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider w-1/3">Catégorie</th>
          <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Mot-clé</th>
          <th class="px-5 py-3.5 text-right w-1/4"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-50">
        {% for mc in motsCles %}
        <tr class="hover:bg-slate-50/70 transition duration-100">
          <td class="px-5 py-3.5 text-center">
            <input type="checkbox" name="ids[]" value="{{ mc.id_mot_clef }}" class="item-checkbox w-4 h-4 rounded border-slate-300 text-[#94674d] focus:ring-[#94674d]/30" />
          </td>
          <td class="px-5 py-3.5 font-semibold text-slate-600">
            <span class="bg-slate-100 border border-slate-200 px-2.5 py-1 rounded-lg text-xs font-mono font-medium text-slate-700">{{ mc.Catégorie }}</span>
          </td>
          <td class="px-5 py-3.5 font-semibold text-slate-900">{{ mc.Mot }}</td>
          <td class="px-5 py-3.5 text-right">
            {{ m.action_buttons(
              url('admin/mots-cles/' ~ mc.id_mot_clef ~ '/edit'),
              url('admin/mots-cles/' ~ mc.id_mot_clef ~ '/delete'),
              'Supprimer ce mot-clé ?',
              csrf_token
            ) }}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</form>

{# Pagination #}
{% if pagesCount > 1 %}
<div class="flex items-center justify-center gap-3 mt-6 text-sm font-semibold">
  {% if currentPage > 1 %}
    <a href="?page={{ currentPage - 1 }}{{ selectedCat ? '&category=' ~ selectedCat : '' }}" class="bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 px-3.5 py-1.5 rounded-xl transition shadow-sm">
      ← Précédent
    </a>
  {% else %}
    <span class="bg-slate-50 border border-slate-100 text-slate-300 px-3.5 py-1.5 rounded-xl cursor-not-allowed">
      ← Précédent
    </span>
  {% endif %}

  <span class="text-xs text-slate-500 font-bold px-2">Page {{ currentPage }} sur {{ pagesCount }} ({{ total }} mots-clés)</span>

  {% if currentPage < pagesCount %}
    <a href="?page={{ currentPage + 1 }}{{ selectedCat ? '&category=' ~ selectedCat : '' }}" class="bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 px-3.5 py-1.5 rounded-xl transition shadow-sm">
      Suivant →
    </a>
  {% else %}
    <span class="bg-slate-50 border border-slate-100 text-slate-300 px-3.5 py-1.5 rounded-xl cursor-not-allowed">
      Suivant →
    </span>
  {% endif %}
</div>
{% endif %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  const selectAllGlobal = document.getElementById('select-all-motscles');
  const selectAllDesktop = document.getElementById('select-all-desktop');
  const checkboxes = document.querySelectorAll('.item-checkbox');
  const btnBulkDelete = document.getElementById('btn-bulk-delete');
  const bulkDeleteCount = document.getElementById('bulk-delete-count');
  const selectedBadge = document.getElementById('selected-count-badge');
  const form = document.getElementById('bulk-delete-form');

  function updateState() {
    const checked = document.querySelectorAll('.item-checkbox:checked');
    const count = checked.length;
    const total = checkboxes.length;
    if (bulkDeleteCount) bulkDeleteCount.textContent = count;
    if (selectedBadge) {
      selectedBadge.textContent = count + ' sélectionné(s)';
      selectedBadge.classList.toggle('hidden', count === 0);
    }
    if (btnBulkDelete) btnBulkDelete.disabled = (count === 0);
    const allChecked = total > 0 && count === total;
    if (selectAllGlobal) selectAllGlobal.checked = allChecked;
    if (selectAllDesktop) selectAllDesktop.checked = allChecked;
  }

  function toggleAll(checked) { checkboxes.forEach(cb => { cb.checked = checked; }); updateState(); }

  if (selectAllGlobal) selectAllGlobal.addEventListener('change', function() { toggleAll(this.checked); });
  if (selectAllDesktop) selectAllDesktop.addEventListener('change', function() { toggleAll(this.checked); });
  checkboxes.forEach(cb => cb.addEventListener('change', updateState));

  if (form) {
    form.addEventListener('submit', function(e) {
      const count = document.querySelectorAll('.item-checkbox:checked').length;
      if (count === 0) { e.preventDefault(); return; }
      if (!confirm('Supprimer les ' + count + ' mot(s)-clé(s) sélectionné(s) ?')) { e.preventDefault(); }
    });
  }
  updateState();
});
</script>

{% else %}
  {{ m.empty_state('Aucun mot-clé trouvé.', url('admin/mots-cles/create'), '+ Ajouter un mot-clé') }}
{% endif %}

{% endblock %}
