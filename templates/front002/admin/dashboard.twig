{% extends 'admin/layout.twig' %}
{% block title %}Tableau de bord{% endblock %}

{% block content %}
<div class="space-y-8">

  {# ── En-tête de bienvenue & Actions rapides ── #}
  <div class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-900 to-slate-800 p-6 md:p-8 rounded-3xl text-white shadow-sm">
    {# Décor fond #}
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -right-8 -top-8 w-56 h-56 rounded-full bg-[#94674d]/10"></div>
      <div class="absolute right-24 -bottom-12 w-40 h-40 rounded-full bg-white/3"></div>
      <div class="absolute right-4 top-1/2 -translate-y-1/2 text-8xl opacity-8 select-none">🏐</div>
    </div>
    <div class="relative z-10 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div>
        <div class="text-[10px] font-black uppercase tracking-widest text-[#94674d] mb-1">Console d'administration</div>
        <h1 class="text-2xl md:text-3xl font-black tracking-tight mb-1.5">Tableau de bord</h1>
        <p class="text-slate-400 text-sm font-medium">USM Volley · Bienvenue dans l'espace de gestion</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="{{ url('admin/posts/create') }}"
           class="inline-flex items-center gap-2 bg-white hover:bg-slate-100 text-slate-900 font-bold px-4 py-2.5 rounded-xl transition text-xs shadow-sm flex-shrink-0">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
          Écrire un article
        </a>
        <a href="{{ url('admin/saisons/create') }}"
           class="inline-flex items-center gap-2 bg-[#94674d] hover:bg-[#7a5540] text-white font-bold px-4 py-2.5 rounded-xl transition text-xs shadow-sm flex-shrink-0">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
          Nouvelle saison
        </a>
      </div>
    </div>
  </div>

  {# ── Section : Statistiques de visites (Google Analytics) ── #}
  {% if gaStats.success %}
    <div class="space-y-6">
      <div class="flex items-center justify-between">
        <h2 class="text-base font-black text-slate-800 flex items-center gap-2.5">
          <span class="p-1.5 bg-indigo-50 text-indigo-600 rounded-lg">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          </span>
          Statistiques de visites
          <span class="text-[10px] bg-indigo-50 text-indigo-600 px-2.5 py-1 rounded-full font-bold uppercase tracking-wider">30 derniers jours</span>
        </h2>
        <a href="{{ url('admin/stats') }}" class="text-xs font-bold text-[#94674d] hover:underline flex items-center gap-1">
          Rapport détaillé
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>

      {# Grille de KPI visites #}
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {# Visiteurs uniques #}
        <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm hover:shadow-md transition duration-200">
          <div class="flex justify-between items-start mb-3">
            <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Visiteurs uniques</span>
            <span class="p-1.5 bg-sky-50 text-sky-600 rounded-lg">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </span>
          </div>
          <div class="text-2xl font-black text-slate-800">{{ gaStats.data.totals.users|number_format(0, ',', ' ') }}</div>
          <p class="text-[10px] font-bold text-sky-600 mt-1">Utilisateurs actifs</p>
        </div>

        {# Sessions #}
        <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm hover:shadow-md transition duration-200">
          <div class="flex justify-between items-start mb-3">
            <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Sessions</span>
            <span class="p-1.5 bg-amber-50 text-amber-600 rounded-lg">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </span>
          </div>
          <div class="text-2xl font-black text-slate-800">{{ gaStats.data.totals.sessions|number_format(0, ',', ' ') }}</div>
          <p class="text-[10px] font-bold text-amber-600 mt-1">Visites totales</p>
        </div>

        {# Pages vues #}
        <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm hover:shadow-md transition duration-200">
          <div class="flex justify-between items-start mb-3">
            <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Pages vues</span>
            <span class="p-1.5 bg-emerald-50 text-emerald-600 rounded-lg">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            </span>
          </div>
          <div class="text-2xl font-black text-slate-800">{{ gaStats.data.totals.views|number_format(0, ',', ' ') }}</div>
          <p class="text-[10px] font-bold text-emerald-600 mt-1">Total affichages</p>
        </div>

        {# Durée moyenne #}
        <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm hover:shadow-md transition duration-200">
          <div class="flex justify-between items-start mb-3">
            <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Durée moyenne</span>
            <span class="p-1.5 bg-purple-50 text-purple-600 rounded-lg">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </span>
          </div>
          <div class="text-2xl font-black text-slate-800">{{ gaStats.data.totals.duration }}</div>
          <p class="text-[10px] font-bold text-purple-600 mt-1">Temps par session</p>
        </div>
      </div>

      {# Graphique Tendance & Top Pages #}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {# Tendance (2/3) #}
        <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm lg:col-span-2">
          <div class="mb-4">
            <h3 class="font-black text-slate-800 text-sm">Évolution journalière de l'audience</h3>
            <p class="text-[10px] text-slate-400 font-bold mt-0.5">Pages vues vs Visiteurs uniques</p>
          </div>
          <div class="h-64 w-full relative">
            <canvas id="trendChart"></canvas>
          </div>
        </div>

        {# Top Pages compact (1/3) #}
        <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm flex flex-col justify-between">
          <div class="space-y-4">
            <div>
              <h3 class="font-black text-slate-800 text-sm">Pages les plus consultées</h3>
              <p class="text-[10px] text-slate-400 font-bold mt-0.5">Top 5 de l'audience</p>
            </div>
            <div class="space-y-2 font-semibold text-xs">
              {% for page in gaStats.data.pages|slice(0, 5) %}
                <div class="flex items-center justify-between py-1.5 border-b border-slate-50 last:border-0 gap-3">
                  <div class="truncate flex-1">
                    <span class="block text-slate-700 font-bold truncate text-[11px]" title="{{ page.title }}">
                      {{ page.title|default('—') }}
                    </span>
                    <span class="text-[9px] text-slate-400 font-mono truncate block">{{ page.path }}</span>
                  </div>
                  <div class="text-slate-900 font-black text-right text-[11px] whitespace-nowrap">{{ page.views }} vues</div>
                </div>
              {% else %}
                <p class="text-slate-400 text-center py-4 text-xs">Aucune donnée</p>
              {% endfor %}
            </div>
          </div>
          <div class="mt-4 pt-3 border-t border-slate-100 flex items-center justify-between text-[10px] font-bold text-slate-400">
            <span>Rebonds : {{ gaStats.data.totals.bounce_rate }} %</span>
            <a href="{{ url('admin/stats') }}" class="text-[#94674d] hover:underline">Voir les sources →</a>
          </div>
        </div>
      </div>
    </div>
  {% else %}
    {# GA4 Non configuré / erreur #}
    <div class="bg-white border border-slate-100 rounded-3xl p-6 md:p-8 shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-6">
      <div class="flex items-start gap-4 max-w-xl">
        <div class="p-3 bg-indigo-50 text-indigo-500 rounded-2xl flex-shrink-0">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
        </div>
        <div class="space-y-1">
          <h2 class="text-base font-black text-slate-800">Visualisez les statistiques de vos visiteurs</h2>
          <p class="text-xs text-slate-500 leading-relaxed font-medium">
            Liez votre console Google Analytics 4 à ce site pour suivre en temps réel les visiteurs uniques, les pages consultées et l'origine de votre trafic.
          </p>
        </div>
      </div>
      <a href="{{ url('admin/site-config') }}"
         class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-5 py-3 rounded-xl transition text-xs text-center shadow-sm flex-shrink-0">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        Configurer Google Analytics
      </a>
    </div>
  {% endif %}

  {# ── Section : Vie du Club ── #}
  <div class="space-y-5">
    <h2 class="text-base font-black text-slate-800 flex items-center gap-2.5">
      <span class="p-1.5 bg-emerald-50 text-emerald-600 rounded-lg">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
      </span>
      Vie du Club
    </h2>

    {# Saison active status #}
    {% if clubStats.saison_active %}
      <div class="bg-white border border-emerald-100 rounded-2xl p-5 shadow-sm flex items-center justify-between flex-wrap gap-4">
        <div class="flex items-center gap-3">
          <div class="p-2 bg-emerald-50 rounded-xl flex-shrink-0">
            <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <div class="text-[9px] font-black uppercase tracking-wider text-emerald-700">Saison active en cours</div>
            <div class="text-lg font-black text-slate-900 mt-0.5">{{ clubStats.saison_active.libelle }}</div>
          </div>
        </div>
        <div class="flex gap-2">
          <a href="{{ url('admin/saisons/' ~ clubStats.saison_active.id ~ '/snapshots') }}"
             class="inline-flex items-center gap-1.5 bg-white hover:bg-slate-50 text-slate-800 border border-slate-200 px-4 py-2 rounded-xl font-bold text-xs shadow-sm transition">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            Voir les licenciés
          </a>
          <a href="{{ url('admin/saisons') }}"
             class="inline-flex items-center gap-1.5 bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-xl font-bold text-xs shadow-sm transition">
            Configuration saisons
          </a>
        </div>
      </div>
    {% else %}
      <div class="bg-white border border-amber-100 rounded-2xl p-5 shadow-sm flex items-center justify-between flex-wrap gap-4">
        <div class="flex items-center gap-3">
          <div class="p-2 bg-amber-50 rounded-xl flex-shrink-0">
            <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
          </div>
          <div>
            <div class="text-[9px] font-black uppercase tracking-wider text-amber-700">Aucune saison active</div>
            <div class="text-xs text-slate-500 mt-0.5 font-semibold">Activez une saison pour débloquer les fonctionnalités du club.</div>
          </div>
        </div>
        <a href="{{ url('admin/saisons/create') }}"
           class="inline-flex items-center gap-1.5 bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-xl font-bold text-xs shadow-sm transition">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
          Activer une saison
        </a>
      </div>
    {% endif %}

    {# Grille des métriques club #}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <a href="{{ url('admin/saisons') }}"
         class="bg-white border border-slate-100 rounded-2xl p-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition duration-200 flex flex-col justify-between group">
        <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Total Saisons</span>
        <div class="flex items-baseline justify-between mt-3">
          <span class="text-xl font-black text-slate-800">{{ clubStats.saisons }}</span>
          <span class="p-1.5 bg-slate-50 text-slate-400 group-hover:bg-[#94674d]/10 group-hover:text-[#94674d] rounded-lg transition">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          </span>
        </div>
      </a>

      <a href="{{ clubStats.saison_active ? url('admin/saisons/' ~ clubStats.saison_active.id ~ '/snapshots') : url('admin/saisons') }}"
         class="bg-white border border-slate-100 rounded-2xl p-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition duration-200 flex flex-col justify-between group">
        <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Joueurs Flashés</span>
        <div class="flex items-baseline justify-between mt-3">
          <span class="text-xl font-black text-slate-800">{{ clubStats.snapshots }}</span>
          <span class="p-1.5 bg-slate-50 text-slate-400 group-hover:bg-sky-50 group-hover:text-sky-500 rounded-lg transition">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </span>
        </div>
      </a>

      <a href="{{ url('admin/equipes-config') }}"
         class="bg-white border border-slate-100 rounded-2xl p-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition duration-200 flex flex-col justify-between group">
        <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Équipes Actives</span>
        <div class="flex items-baseline justify-between mt-3">
          <span class="text-xl font-black text-slate-800">{{ clubStats.equipes }}</span>
          <span class="p-1.5 bg-slate-50 text-slate-400 group-hover:bg-emerald-50 group-hover:text-emerald-500 rounded-lg transition">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>
          </span>
        </div>
      </a>

      <div class="bg-white border border-slate-100 rounded-2xl p-4 shadow-sm flex flex-col justify-between">
        <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Prochains Événements</span>
        <div class="flex justify-between mt-3 text-xs font-bold text-slate-700">
          <div class="flex flex-col items-center bg-slate-50 rounded-xl px-3 py-2 flex-1 mr-1.5">
            <span class="text-base font-black text-slate-800">{{ extStats.matchs ?? '—' }}</span>
            <span class="text-[8px] text-slate-400 uppercase font-black mt-0.5">Matchs</span>
          </div>
          <div class="flex flex-col items-center bg-slate-50 rounded-xl px-3 py-2 flex-1">
            <span class="text-base font-black text-slate-800">{{ extStats.entrainements ?? '—' }}</span>
            <span class="text-[8px] text-slate-400 uppercase font-black mt-0.5">Entraînements</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# ── Section : Contenu CMS & Support ── #}
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {# CMS / Contenu #}
    <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm space-y-4">
      <h3 class="font-black text-slate-800 text-sm flex items-center gap-2.5">
        <span class="p-1.5 bg-slate-100 text-slate-600 rounded-lg">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 12h6m-6-4h6" /></svg>
        </span>
        Contenu & Pages
      </h3>

      <div class="grid grid-cols-2 gap-3">
        <a href="{{ url('admin/posts') }}" class="bg-slate-50 hover:bg-slate-100/80 p-4 rounded-xl transition duration-150 block group">
          <div class="text-xl font-black text-slate-800 group-hover:text-[#94674d] transition">{{ stats.posts }}</div>
          <div class="text-[9px] font-bold uppercase tracking-wider text-slate-400 mt-1">Articles de blog</div>
        </a>

        <a href="{{ url('admin/pages') }}" class="bg-slate-50 hover:bg-slate-100/80 p-4 rounded-xl transition duration-150 block group">
          <div class="text-xl font-black text-slate-800 group-hover:text-[#94674d] transition">{{ stats.pages }}</div>
          <div class="text-[9px] font-bold uppercase tracking-wider text-slate-400 mt-1">Pages statiques</div>
        </a>

        <a href="{{ url('admin/menu') }}" class="bg-slate-50 hover:bg-slate-100/80 p-4 rounded-xl transition duration-150 block group">
          <div class="text-xl font-black text-slate-800 group-hover:text-[#94674d] transition">{{ stats.menu }}</div>
          <div class="text-[9px] font-bold uppercase tracking-wider text-slate-400 mt-1">Éléments du menu</div>
        </a>

        <a href="{{ url('admin/home-blocks') }}" class="bg-slate-50 hover:bg-slate-100/80 p-4 rounded-xl transition duration-150 block group">
          <div class="text-xl font-black text-slate-800 group-hover:text-[#94674d] transition">{{ stats.home_blocks }}</div>
          <div class="text-[9px] font-bold uppercase tracking-wider text-slate-400 mt-1">Blocs de l'accueil</div>
        </a>
      </div>
    </div>

    {# Support / Messages #}
    <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm flex flex-col justify-between space-y-4">
      <div>
        <h3 class="font-black text-slate-800 text-sm flex items-center gap-2.5 mb-4">
          <span class="p-1.5 bg-slate-100 text-slate-600 rounded-lg">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>
          </span>
          Support & Contacts
        </h3>

        <div class="space-y-2">
          <a href="{{ url('admin/contacts?status=new') }}"
             class="flex items-center justify-between p-3 rounded-xl transition duration-150 {% if supportStats.contacts_new > 0 %}bg-rose-50 border border-rose-100 text-rose-900{% else %}bg-slate-50 hover:bg-slate-100/80 text-slate-800{% endif %}">
            <span class="text-xs font-bold flex items-center gap-2">
              {% if supportStats.contacts_new > 0 %}
                <span class="w-2 h-2 rounded-full bg-rose-500 animate-pulse"></span>
              {% endif %}
              Nouveaux messages
            </span>
            <span class="px-2 py-0.5 text-[10px] font-black rounded-full {% if supportStats.contacts_new > 0 %}bg-rose-600 text-white{% else %}bg-slate-200 text-slate-500{% endif %}">
              {{ supportStats.contacts_new }}
            </span>
          </a>

          <a href="{{ url('admin/contacts?status=replied') }}"
             class="flex items-center justify-between p-3 bg-slate-50 hover:bg-slate-100/80 rounded-xl transition duration-150">
            <span class="text-xs font-bold text-slate-600">Messages répondus</span>
            <span class="text-xs font-black text-slate-800">{{ supportStats.contacts_replied }}</span>
          </a>

          <a href="{{ url('admin/contacts') }}"
             class="flex items-center justify-between p-3 bg-slate-50 hover:bg-slate-100/80 rounded-xl transition duration-150">
            <span class="text-xs font-bold text-slate-600">Total des messages reçus</span>
            <span class="text-xs font-black text-slate-800">{{ supportStats.contacts_total }}</span>
          </a>
        </div>
      </div>

      <a href="{{ url('admin/contacts') }}"
         class="inline-flex items-center justify-center gap-2 w-full bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold px-4 py-2.5 rounded-xl text-xs transition">
        Gérer tous les messages →
      </a>
    </div>
  </div>

  {# ── Section : Raccourcis rapides ── #}
  <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm">
    <h3 class="font-black text-slate-800 text-sm mb-4 flex items-center gap-2.5">
      <span class="p-1.5 bg-[#94674d]/10 text-[#94674d] rounded-lg">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
      </span>
      Raccourcis rapides
    </h3>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <a href="{{ url('admin/posts/create') }}"
         class="flex flex-col items-center gap-2 p-4 bg-slate-50 hover:bg-[#94674d]/5 border border-slate-100 hover:border-[#94674d]/20 rounded-2xl transition duration-150 text-center group">
        <div class="p-2 bg-white border border-slate-200 group-hover:border-[#94674d]/30 group-hover:bg-[#94674d]/5 rounded-xl transition">
          <svg class="w-5 h-5 text-slate-500 group-hover:text-[#94674d] transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
        </div>
        <span class="text-xs font-bold text-slate-600 group-hover:text-slate-900 transition leading-tight">Écrire un article</span>
      </a>

      <a href="{{ url('admin/saisons') }}"
         class="flex flex-col items-center gap-2 p-4 bg-slate-50 hover:bg-[#94674d]/5 border border-slate-100 hover:border-[#94674d]/20 rounded-2xl transition duration-150 text-center group">
        <div class="p-2 bg-white border border-slate-200 group-hover:border-[#94674d]/30 group-hover:bg-[#94674d]/5 rounded-xl transition">
          <svg class="w-5 h-5 text-slate-500 group-hover:text-[#94674d] transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        </div>
        <span class="text-xs font-bold text-slate-600 group-hover:text-slate-900 transition leading-tight">Gérer les saisons</span>
      </a>

      <a href="{{ url('admin/joueurs') }}"
         class="flex flex-col items-center gap-2 p-4 bg-slate-50 hover:bg-[#94674d]/5 border border-slate-100 hover:border-[#94674d]/20 rounded-2xl transition duration-150 text-center group">
        <div class="p-2 bg-white border border-slate-200 group-hover:border-[#94674d]/30 group-hover:bg-[#94674d]/5 rounded-xl transition">
          <svg class="w-5 h-5 text-slate-500 group-hover:text-[#94674d] transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
        </div>
        <span class="text-xs font-bold text-slate-600 group-hover:text-slate-900 transition leading-tight">Base des joueurs</span>
      </a>

      <a href="{{ url('admin/contacts') }}"
         class="flex flex-col items-center gap-2 p-4 bg-slate-50 hover:bg-[#94674d]/5 border border-slate-100 hover:border-[#94674d]/20 rounded-2xl transition duration-150 text-center group relative">
        <div class="p-2 bg-white border border-slate-200 group-hover:border-[#94674d]/30 group-hover:bg-[#94674d]/5 rounded-xl transition">
          <svg class="w-5 h-5 text-slate-500 group-hover:text-[#94674d] transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>
        </div>
        {% if contact_stats.new > 0 %}
          <span class="absolute top-2 right-2 w-5 h-5 bg-rose-500 text-white text-[9px] font-black rounded-full flex items-center justify-center">{{ contact_stats.new }}</span>
        {% endif %}
        <span class="text-xs font-bold text-slate-600 group-hover:text-slate-900 transition leading-tight">Messages contact</span>
      </a>
    </div>
  </div>

</div>
{% endblock %}

{% block scripts %}
{% if gaStats.success and gaStats.data and gaStats.data.trend %}
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const ctx = document.getElementById('trendChart').getContext('2d');

      const labels = {{ gaStats.data.trend.labels|json_encode|raw }};
      const views = {{ gaStats.data.trend.views|json_encode|raw }};
      const users = {{ gaStats.data.trend.users|json_encode|raw }};

      new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            {
              label: 'Pages vues',
              data: views,
              borderColor: '#94674d',
              backgroundColor: 'rgba(148, 103, 77, 0.06)',
              borderWidth: 2.5,
              fill: true,
              tension: 0.4,
              pointBackgroundColor: '#fff',
              pointBorderColor: '#94674d',
              pointBorderWidth: 2,
              pointRadius: 3,
              pointHoverRadius: 5,
              pointHoverBackgroundColor: '#94674d',
              pointHoverBorderColor: '#fff',
              pointHoverBorderWidth: 2
            },
            {
              label: 'Visiteurs uniques',
              data: users,
              borderColor: '#10b981',
              backgroundColor: 'rgba(16, 185, 129, 0.04)',
              borderWidth: 2.5,
              fill: true,
              tension: 0.4,
              pointBackgroundColor: '#fff',
              pointBorderColor: '#10b981',
              pointBorderWidth: 2,
              pointRadius: 3,
              pointHoverRadius: 5,
              pointHoverBackgroundColor: '#10b981',
              pointHoverBorderColor: '#fff',
              pointHoverBorderWidth: 2
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: {
              position: 'top',
              labels: {
                boxWidth: 8,
                boxHeight: 8,
                usePointStyle: true,
                pointStyle: 'circle',
                font: { family: 'sans-serif', size: 11, weight: 'bold' },
                color: '#64748b'
              }
            },
            tooltip: {
              padding: 12,
              backgroundColor: '#0f172a',
              cornerRadius: 10,
              titleFont: { family: 'sans-serif', size: 11, weight: 'bold' },
              bodyFont: { family: 'sans-serif', size: 10 }
            }
          },
          scales: {
            x: {
              grid: { color: 'rgba(0,0,0,0.03)', lineWidth: 1 },
              ticks: { font: { family: 'sans-serif', size: 9, weight: 'semibold' }, color: '#94a3b8' }
            },
            y: {
              grid: { color: 'rgba(0,0,0,0.03)', lineWidth: 1 },
              ticks: { beginAtZero: true, font: { family: 'sans-serif', size: 9, weight: 'semibold' }, color: '#94a3b8' }
            }
          }
        }
      });
    });
  </script>
{% endif %}
{% endblock %}
