{% extends 'admin/layout.twig' %}
{% block title %}Tableau de bord{% endblock %}

{% block content %}
<div class="space-y-8">

  {# ── En-tête de bienvenue & Actions rapides ── #}
  <div class="relative overflow-hidden bg-gradient-to-r from-slate-900 to-slate-800 p-6 md:p-8 rounded-3xl text-white shadow-sm">
    <div class="absolute right-0 top-0 opacity-10 pointer-events-none transform translate-x-12 -translate-y-6">
      <span class="text-9xl">🏐</span>
    </div>
    <div class="relative z-10 flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div>
        <h1 class="text-3xl font-black tracking-tight mb-1.5">Console d'administration</h1>
        <p class="text-slate-300 text-sm font-medium">USM Volley · Tableau de bord général de gestion</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="{{ url('admin/posts/create') }}" 
           class="bg-white hover:bg-slate-100 text-slate-900 font-bold px-4 py-2.5 rounded-xl transition text-xs flex items-center gap-2 shadow-sm">
          <span>➕</span> Écrire un article
        </a>
        <a href="{{ url('admin/saisons/create') }}" 
           class="bg-usm-brown hover:bg-[#855c45] text-white font-bold px-4 py-2.5 rounded-xl transition text-xs flex items-center gap-2 shadow-sm border border-usm-brown/10">
          <span>➕</span> Nouvelle saison
        </a>
      </div>
    </div>
  </div>

  {# ── Section : Statistiques de visites (Google Analytics) ── #}
  {% if gaStats.success %}
    <div class="space-y-6">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-black text-slate-800 flex items-center gap-2.5">
          <span class="text-xl">📈</span> Statistiques de visites
          <span class="text-[10px] bg-indigo-50 text-indigo-600 px-2.5 py-1 rounded-full font-bold uppercase tracking-wider">30 derniers jours</span>
        </h2>
        <a href="{{ url('admin/stats') }}" class="text-xs font-bold text-usm-brown hover:underline flex items-center gap-1">
          Rapport détaillé →
        </a>
      </div>

      {# Grille de KPI visites #}
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {# Visiteurs uniques #}
        <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm hover:shadow-md transition duration-200">
          <div class="flex justify-between items-start">
            <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Visiteurs uniques</span>
            <span class="p-1.5 bg-sky-50 text-sky-600 rounded-lg text-sm">👥</span>
          </div>
          <div class="text-2xl font-black text-slate-800 mt-2">{{ gaStats.data.totals.users|number_format(0, ',', ' ') }}</div>
          <p class="text-[9px] font-bold text-sky-600 mt-1">Utilisateurs actifs</p>
        </div>

        {# Sessions #}
        <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm hover:shadow-md transition duration-200">
          <div class="flex justify-between items-start">
            <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Sessions</span>
            <span class="p-1.5 bg-amber-50 text-amber-600 rounded-lg text-sm">🔑</span>
          </div>
          <div class="text-2xl font-black text-slate-800 mt-2">{{ gaStats.data.totals.sessions|number_format(0, ',', ' ') }}</div>
          <p class="text-[9px] font-bold text-amber-600 mt-1">Visites totales</p>
        </div>

        {# Pages vues #}
        <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm hover:shadow-md transition duration-200">
          <div class="flex justify-between items-start">
            <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Pages vues</span>
            <span class="p-1.5 bg-emerald-50 text-emerald-600 rounded-lg text-sm">📄</span>
          </div>
          <div class="text-2xl font-black text-slate-800 mt-2">{{ gaStats.data.totals.views|number_format(0, ',', ' ') }}</div>
          <p class="text-[9px] font-bold text-emerald-600 mt-1">Total affichages</p>
        </div>

        {# Durée moyenne #}
        <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm hover:shadow-md transition duration-200">
          <div class="flex justify-between items-start">
            <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Durée moyenne</span>
            <span class="p-1.5 bg-purple-50 text-purple-600 rounded-lg text-sm">⏱️</span>
          </div>
          <div class="text-2xl font-black text-slate-800 mt-2">{{ gaStats.data.totals.duration }}</div>
          <p class="text-[9px] font-bold text-purple-600 mt-1">Temps par session</p>
        </div>
      </div>

      {# Graphique Tendance & Top Pages #}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {# Tendance (2/3) #}
        <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm lg:col-span-2">
          <div class="mb-4">
            <h3 class="font-black text-slate-800 text-sm">Évolution journalière de l'audience</h3>
            <p class="text-[10px] text-slate-400 font-bold">Pages vues vs Visiteurs uniques</p>
          </div>
          <div class="h-64 w-full relative">
            <canvas id="trendChart"></canvas>
          </div>
        </div>

        {# Top Pages compact (1/3) #}
        <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm flex flex-col justify-between">
          <div class="space-y-4">
            <div>
              <h3 class="font-black text-slate-800 text-sm">Pages les plus consultées</h3>
              <p class="text-[10px] text-slate-400 font-bold">Top 5 de l'audience</p>
            </div>
            <div class="space-y-3 font-semibold text-xs">
              {% for page in gaStats.data.pages|slice(0, 5) %}
                <div class="flex items-center justify-between py-1.5 border-b border-slate-50 last:border-0 gap-3">
                  <div class="truncate flex-1">
                    <span class="block text-slate-700 font-bold truncate text-[11px]" title="{{ page.title }}">
                      {{ page.title|default('—') }}
                    </span>
                    <span class="text-[9px] text-slate-400 font-mono truncate block">{{ page.path }}</span>
                  </div>
                  <div class="text-slate-900 font-black text-right text-[11px] whitespace-nowrap">{{ page.views }} vues</div>
                </div>
              {% else %}
                <p class="text-slate-400 text-center py-4">Aucune donnée</p>
              {% endfor %}
            </div>
          </div>
          <div class="mt-4 pt-3 border-t border-slate-100 flex items-center justify-between text-[10px] font-bold text-slate-400">
            <span>Rebonds : {{ gaStats.data.totals.bounce_rate }} %</span>
            <a href="{{ url('admin/stats') }}" class="text-usm-brown hover:underline">Voir les sources →</a>
          </div>
        </div>
      </div>
    </div>
  {% else %}
    {# GA4 Non configuré / erreur #}
    <div class="bg-gradient-to-br from-indigo-50 via-white to-sky-50 border border-slate-100 rounded-3xl p-6 md:p-8 shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-6">
      <div class="space-y-2 max-w-xl">
        <div class="flex items-center gap-2.5">
          <span class="text-2xl">📈</span>
          <h2 class="text-lg font-black text-slate-800">Visualisez les statistiques de vos visiteurs</h2>
        </div>
        <p class="text-xs text-slate-600 leading-relaxed font-semibold">
          Liez votre console Google Analytics 4 à ce site afin de suivre en temps réel le nombre de visiteurs uniques, les pages consultées, ainsi que l'origine de votre trafic directement depuis ce tableau de bord.
        </p>
      </div>
      <a href="{{ url('admin/site-config') }}" 
         class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-5 py-3 rounded-xl transition text-xs text-center shadow-sm flex-shrink-0">
        ⚙️ Configurer Google Analytics
      </a>
    </div>
  {% endif %}

  {# ── Section : Vie du Club ── #}
  <div class="space-y-6">
    <h2 class="text-lg font-black text-slate-800 flex items-center gap-2.5">
      <span class="text-xl">📅</span> Vie du Club
    </h2>

    {# Saison active status #}
    <div>
      {% if clubStats.saison_active %}
        <div class="bg-gradient-to-r from-emerald-50 to-teal-50 border border-emerald-100/50 p-5 rounded-2xl shadow-sm flex items-center justify-between flex-wrap gap-4">
          <div>
            <div class="text-[9px] font-black uppercase tracking-wider text-emerald-800">Saison active en cours</div>
            <div class="text-xl font-black text-emerald-950 mt-0.5">{{ clubStats.saison_active.libelle }}</div>
          </div>
          <div class="flex gap-2">
            <a href="{{ url('admin/saisons/' ~ clubStats.saison_active.id ~ '/snapshots') }}"
               class="bg-white hover:bg-slate-50 text-slate-800 border border-slate-200/80 px-4 py-2 rounded-xl font-bold text-xs shadow-sm transition">
              👥 Voir les licenciés
            </a>
            <a href="{{ url('admin/saisons') }}"
               class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-xl font-bold text-xs shadow-sm transition">
              Configuration saisons
            </a>
          </div>
        </div>
      {% else %}
        <div class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-100/50 p-5 rounded-2xl shadow-sm flex items-center justify-between flex-wrap gap-4">
          <div>
            <div class="text-[9px] font-black uppercase tracking-wider text-amber-800">Aucune saison active</div>
            <div class="text-xs text-slate-600 mt-0.5 font-bold">Veuillez activer une saison pour débloquer les fonctionnalités liées au club.</div>
          </div>
          <a href="{{ url('admin/saisons/create') }}"
             class="bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-xl font-bold text-xs shadow-sm transition">
            ➕ Activer une saison
          </a>
        </div>
      {% endif %}
    </div>

    {# Grille des métriques club #}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <a href="{{ url('admin/saisons') }}" 
         class="bg-white border border-slate-100 rounded-2xl p-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition duration-200 flex flex-col justify-between">
        <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Total Saisons</span>
        <div class="flex items-baseline justify-between mt-3">
          <span class="text-xl font-black text-slate-800">{{ clubStats.saisons }}</span>
          <span class="text-slate-300 text-base">📅</span>
        </div>
      </a>

      <a href="{{ clubStats.saison_active ? url('admin/saisons/' ~ clubStats.saison_active.id ~ '/snapshots') : url('admin/saisons') }}" 
         class="bg-white border border-slate-100 rounded-2xl p-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition duration-200 flex flex-col justify-between">
        <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Joueurs Flashés</span>
        <div class="flex items-baseline justify-between mt-3">
          <span class="text-xl font-black text-slate-800">{{ clubStats.snapshots }}</span>
          <span class="text-slate-300 text-base">👥</span>
        </div>
      </a>

      <a href="{{ url('admin/equipes-config') }}" 
         class="bg-white border border-slate-100 rounded-2xl p-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition duration-200 flex flex-col justify-between">
        <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Équipes Actives</span>
        <div class="flex items-baseline justify-between mt-3">
          <span class="text-xl font-black text-slate-800">{{ clubStats.equipes }}</span>
          <span class="text-slate-300 text-base">⚽</span>
        </div>
      </a>

      <div class="bg-white border border-slate-100 rounded-2xl p-4 shadow-sm flex flex-col justify-between">
        <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Prochains Événements</span>
        <div class="flex justify-between mt-3 text-xs font-bold text-slate-700">
          <div class="flex flex-col">
            <span class="text-sm font-black text-slate-800">{{ extStats.matchs ?? '—' }}</span>
            <span class="text-[8px] text-slate-400 uppercase font-black">Matchs</span>
          </div>
          <div class="flex flex-col">
            <span class="text-sm font-black text-slate-800">{{ extStats.entrainements ?? '—' }}</span>
            <span class="text-[8px] text-slate-400 uppercase font-black">Entraînements</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# ── Section : Contenu CMS & Support ── #}
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {# CMS / Contenu #}
    <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm space-y-4">
      <h3 class="font-black text-slate-800 text-base flex items-center gap-2.5">
        <span class="text-lg">📰</span> Contenu & Pages
      </h3>
      
      <div class="grid grid-cols-2 gap-3">
        <a href="{{ url('admin/posts') }}" class="bg-slate-50 hover:bg-slate-100/80 p-4 rounded-xl transition duration-150 block">
          <div class="text-xl font-black text-slate-800">{{ stats.posts }}</div>
          <div class="text-[9px] font-bold uppercase tracking-wider text-slate-400 mt-1">Articles de blog</div>
        </a>
        
        <a href="{{ url('admin/pages') }}" class="bg-slate-50 hover:bg-slate-100/80 p-4 rounded-xl transition duration-150 block">
          <div class="text-xl font-black text-slate-800">{{ stats.pages }}</div>
          <div class="text-[9px] font-bold uppercase tracking-wider text-slate-400 mt-1">Pages statiques</div>
        </a>
        
        <a href="{{ url('admin/menu') }}" class="bg-slate-50 hover:bg-slate-100/80 p-4 rounded-xl transition duration-150 block">
          <div class="text-xl font-black text-slate-800">{{ stats.menu }}</div>
          <div class="text-[9px] font-bold uppercase tracking-wider text-slate-400 mt-1">Éléments du menu</div>
        </a>
        
        <a href="{{ url('admin/home-blocks') }}" class="bg-slate-50 hover:bg-slate-100/80 p-4 rounded-xl transition duration-150 block">
          <div class="text-xl font-black text-slate-800">{{ stats.home_blocks }}</div>
          <div class="text-[9px] font-bold uppercase tracking-wider text-slate-400 mt-1">Blocs de l'accueil</div>
        </a>
      </div>
    </div>

    {# Support / Messages #}
    <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm flex flex-col justify-between space-y-4">
      <div>
        <h3 class="font-black text-slate-800 text-base flex items-center gap-2.5">
          <span class="text-lg">💬</span> Support & Contacts
        </h3>
        
        <div class="mt-4 space-y-2">
          <a href="{{ url('admin/contacts?status=new') }}" 
             class="flex items-center justify-between p-3 rounded-xl transition duration-150 {% if supportStats.contacts_new > 0 %}bg-rose-50 border border-rose-100/50 text-rose-950{% else %}bg-slate-50 hover:bg-slate-100/80 text-slate-800{% endif %}">
            <span class="text-xs font-bold">Nouveaux messages</span>
            <span class="px-2 py-0.5 text-[10px] font-black rounded-full {% if supportStats.contacts_new > 0 %}bg-rose-600 text-white animate-pulse{% else %}bg-slate-200 text-slate-500{% endif %}">
              {{ supportStats.contacts_new }}
            </span>
          </a>

          <a href="{{ url('admin/contacts?status=replied') }}" 
             class="flex items-center justify-between p-3 bg-slate-50 hover:bg-slate-100/80 rounded-xl transition duration-150">
            <span class="text-xs font-bold text-slate-600">Messages répondus</span>
            <span class="text-xs font-black text-slate-800">{{ supportStats.contacts_replied }}</span>
          </a>

          <a href="{{ url('admin/contacts') }}" 
             class="flex items-center justify-between p-3 bg-slate-50 hover:bg-slate-100/80 rounded-xl transition duration-150">
            <span class="text-xs font-bold text-slate-600">Total des messages reçus</span>
            <span class="text-xs font-black text-slate-800">{{ supportStats.contacts_total }}</span>
          </a>
        </div>
      </div>
    </div>
  </div>

</div>
{% endblock %}

{% block scripts %}
{% if gaStats.success and gaStats.data and gaStats.data.trend %}
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const ctx = document.getElementById('trendChart').getContext('2d');
      
      const labels = {{ gaStats.data.trend.labels|json_encode|raw }};
      const views = {{ gaStats.data.trend.views|json_encode|raw }};
      const users = {{ gaStats.data.trend.users|json_encode|raw }};

      new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            {
              label: 'Pages vues',
              data: views,
              borderColor: '#94674d', // usm-brown
              backgroundColor: 'rgba(148, 103, 77, 0.04)',
              borderWidth: 2.5,
              fill: true,
              tension: 0.3,
              pointBackgroundColor: '#fff',
              pointBorderColor: '#94674d',
              pointBorderWidth: 1.5,
              pointHoverRadius: 5,
              pointHoverBackgroundColor: '#94674d',
              pointHoverBorderColor: '#fff',
              pointHoverBorderWidth: 1.5
            },
            {
              label: 'Visiteurs uniques',
              data: users,
              borderColor: '#10b981', // emerald
              backgroundColor: 'rgba(16, 185, 129, 0.04)',
              borderWidth: 2.5,
              fill: true,
              tension: 0.3,
              pointBackgroundColor: '#fff',
              pointBorderColor: '#10b981',
              pointBorderWidth: 1.5,
              pointHoverRadius: 5,
              pointHoverBackgroundColor: '#10b981',
              pointHoverBorderColor: '#fff',
              pointHoverBorderWidth: 1.5
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: {
            mode: 'index',
            intersect: false,
          },
          plugins: {
            legend: {
              position: 'top',
              labels: {
                boxWidth: 10,
                boxHeight: 10,
                font: {
                  family: 'sans-serif',
                  size: 11,
                  weight: 'bold'
                },
                color: '#64748b'
              }
            },
            tooltip: {
              padding: 10,
              backgroundColor: '#0f172a',
              titleFont: {
                family: 'sans-serif',
                size: 11,
                weight: 'bold'
              },
              bodyFont: {
                family: 'sans-serif',
                size: 10
              }
            }
          },
          scales: {
            x: {
              grid: {
                color: 'rgba(0, 0, 0, 0.02)',
                lineWidth: 1
              },
              ticks: {
                font: {
                  family: 'sans-serif',
                  size: 9,
                  weight: 'semibold'
                },
                color: '#64748b'
              }
            },
            y: {
              grid: {
                color: 'rgba(0, 0, 0, 0.02)',
                lineWidth: 1
              },
              ticks: {
                beginAtZero: true,
                font: {
                  family: 'sans-serif',
                  size: 9,
                  weight: 'semibold'
                },
                color: '#64748b'
              }
            }
          }
        }
      });
    });
  </script>
{% endif %}
{% endblock %}

