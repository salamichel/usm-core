{% block head %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&family=Space+Grotesk:wght@400;600;700;900&family=DM+Sans:wght@400;600;700;900&family=Syne:wght@400;600;700;900&family=Outfit:wght@400;600;700;900&family=Poppins:wght@400;600;700;900&family=Plus+Jakarta+Sans:wght@400;600;700;900&family=Raleway:wght@400;600;700;900&family=Montserrat:wght@400;600;700;900&family=Work+Sans:wght@400;600;700;900&family=Unbounded:wght@400;600;700;900&display=swap">
{% endblock %}

{% block scripts %}
<script>
  // Système d'onglets dynamique
  function switchTab(tabId) {
    // Masquer tous les contenus
    document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
    // Afficher le contenu actif
    const activeContent = document.getElementById('tab-content-' + tabId);
    if (activeContent) {
      activeContent.classList.remove('hidden');
    }

    // Gérer l'état actif des boutons (style neobrutaliste)
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.classList.remove('bg-amber-50', 'translate-y-1', 'translate-x-1', 'shadow-[1px_1px_0_#000]');
      btn.classList.add('bg-white', 'shadow-[4px_4px_0_#000]');
    });

    const activeBtn = document.getElementById('tab-btn-' + tabId);
    if (activeBtn) {
      activeBtn.classList.remove('bg-white', 'shadow-[4px_4px_0_#000]');
      activeBtn.classList.add('bg-amber-50', 'translate-y-1', 'translate-x-1', 'shadow-[1px_1px_0_#000]');
    }

    // Sauvegarder dans localStorage
    localStorage.setItem('active_config_tab', tabId);
  }

  // Restaurer l'onglet actif au chargement
  document.addEventListener('DOMContentLoaded', () => {
    const savedTab = localStorage.getItem('active_config_tab') || 'general';
    switchTab(savedTab);
  });

  // Sync custom font radio value before submit
  document.querySelector('form').addEventListener('submit', function () {
    const radio = document.getElementById('radio-custom');
    if (radio && radio.checked) {
      const val = document.getElementById('custom_font_input').value.trim();
      radio.value = val;
    }
  });

  function syncHex(colorInput, hexId) {
    document.getElementById(hexId).value = colorInput.value;
  }

  function setColor(colorId, hexId, val) {
    document.getElementById(colorId).value = val;
    document.getElementById(hexId).value = val;
    previewHeader();
  }

  function setColorFooter(colorId, hexId, val) {
    document.getElementById(colorId).value = val;
    document.getElementById(hexId).value = val;
    previewFooter();
  }

  function previewFooter() {
    const bg      = document.getElementById('footer_bg_color').value;
    const text    = document.getElementById('footer_text_color').value;
    const heading = document.getElementById('footer_heading_color').value;

    document.getElementById('footer-preview').style.background = bg;
    document.getElementById('fp-heading').style.color    = heading;
    document.getElementById('fp-text').style.color       = text;
    document.getElementById('fp-label').style.color      = text;
    document.getElementById('fp-link').style.color       = text;
    document.getElementById('fp-copyright').style.color  = text;
  }

  function previewHeader() {
    const bg        = document.getElementById('header_bg_color').value;
    const logoBg    = document.getElementById('logo_bg_color').value;
    const logoTxt   = document.getElementById('logo_text_color').value;
    const text      = document.getElementById('header_text_color').value;
    const hoverBg   = document.getElementById('header_hover_bg_color').value;
    const hoverTxt  = document.getElementById('header_hover_text_color').value;

    document.getElementById('header-preview').style.background = bg;
    document.getElementById('prev-logo').style.background      = logoBg;
    document.getElementById('prev-logo').style.color           = logoTxt;
    document.getElementById('prev-link').style.color           = text;
    document.getElementById('prev-link2').style.color          = text;
    document.getElementById('prev-hover').style.background     = hoverBg;
    document.getElementById('prev-hover').style.color          = hoverTxt;
  }
</script>
{% endblock %}
