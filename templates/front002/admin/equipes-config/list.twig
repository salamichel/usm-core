{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}Équipes{% endblock %}

{% block content %}

{# ── En-tête de page ── #}
{{ m.page_header('Équipes', url('admin/equipes-config/create'), '+ Ajouter une équipe') }}

{% if equipes|length %}

{# Grouper par catégorie #}
{% set grouped = {} %}
{% for eq in equipes %}
  {% set cat = eq.categorie %}
  {% if grouped[cat] is not defined %}
    {% set grouped = grouped|merge({(cat): []}) %}
  {% endif %}
  {% set grouped = grouped|merge({(cat): grouped[cat]|merge([eq])}) %}
{% endfor %}

{# ── Mobile : cartes ── #}
<div class="sm:hidden space-y-6">
  {% for cat, eqs in grouped %}
  <div>
    <h2 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-2 px-1">{{ cat }}</h2>
    <div class="space-y-3">
      {% for eq in eqs %}
      <div class="bg-white border border-slate-100 rounded-2xl shadow-sm p-4">
        <div class="flex items-start justify-between gap-2 mb-2">
          <div class="font-bold text-base text-slate-900 leading-tight">{{ eq.libelle }}</div>
          {{ m.status_badge(eq.is_active, 'Active', 'Inactive') }}
        </div>
        <div class="flex flex-wrap items-center gap-2 text-xs text-slate-500 mb-3">
          {% if eq.type %}<span class="bg-slate-100 px-2 py-0.5 rounded-md font-medium text-slate-600">{{ eq.type }}</span>{% endif %}
          {% if eq.hauteur_filet %}<span class="text-slate-400">🏐 {{ eq.hauteur_filet }}</span>{% endif %}
          <span class="font-mono text-slate-400 text-[10px]">{{ eq.slug_colonne }}</span>
          <span class="font-bold text-amber-700 bg-amber-50 px-2 py-0.5 border border-amber-200 rounded-full">👥 {{ eq.player_count ?: 0 }} joueurs</span>
        </div>
        <div class="flex flex-wrap gap-2 pt-2 border-t border-slate-50">
          {% if saison_active_id %}
            <a href="{{ url('admin/equipes-config/' ~ eq.id ~ '/saisons/' ~ saison_active_id ~ '/joueurs') }}"
               class="inline-flex items-center gap-1 bg-amber-50 border border-amber-200 text-amber-800 hover:bg-amber-100 px-2.5 py-1.5 text-xs font-semibold rounded-lg transition">
              👥 Joueurs
            </a>
            <a href="{{ url('admin/equipes-config/' ~ eq.id ~ '/saisons/' ~ saison_active_id ~ '/photos') }}"
               class="inline-flex items-center gap-1 bg-sky-50 border border-sky-200 text-sky-800 hover:bg-sky-100 px-2.5 py-1.5 text-xs font-semibold rounded-lg transition">
              🖼️ Photos
            </a>
          {% endif %}
          {{ m.action_buttons(
            url('admin/equipes-config/' ~ eq.id ~ '/edit'),
            url('admin/equipes-config/' ~ eq.id ~ '/delete'),
            'Supprimer cette équipe ?',
            csrf_token
          ) }}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endfor %}
</div>

{# ── Desktop : tableau groupé par catégorie ── #}
<div class="hidden sm:block bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-800 text-white">
      <tr>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Équipe</th>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider hidden md:table-cell">Type</th>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider hidden md:table-cell">Filet</th>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider hidden lg:table-cell">Slug DB</th>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Joueurs</th>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Statut</th>
        <th class="px-5 py-3.5 text-right"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-50">
      {% for cat, eqs in grouped %}
      {# Ligne de catégorie #}
      <tr class="bg-slate-100/70 border-t border-slate-200">
        <td colspan="7" class="px-5 py-2.5 font-bold text-xs uppercase tracking-widest text-slate-500">
          {{ cat }} <span class="font-normal text-slate-400">({{ eqs|length }})</span>
        </td>
      </tr>
      {% for eq in eqs %}
      <tr class="hover:bg-slate-50/70 transition duration-100">
        <td class="px-5 py-3.5">
          <span class="font-semibold text-slate-900">{{ eq.libelle }}</span>
          {% if eq.description_courte %}
            <p class="text-xs text-slate-400 italic mt-0.5 truncate max-w-xs">{{ eq.description_courte }}</p>
          {% endif %}
        </td>
        <td class="px-5 py-3.5 text-slate-500 text-xs hidden md:table-cell">{{ eq.type ?: '—' }}</td>
        <td class="px-5 py-3.5 text-slate-500 text-xs font-semibold hidden md:table-cell">{{ eq.hauteur_filet ?: '—' }}</td>
        <td class="px-5 py-3.5 font-mono text-xs text-slate-400 hidden lg:table-cell">{{ eq.slug_colonne }}</td>
        <td class="px-5 py-3.5">
          <span class="inline-flex items-center gap-1 bg-amber-50 text-amber-800 border border-amber-200 px-2.5 py-0.5 rounded-full text-xs font-bold">
            👥 {{ eq.player_count ?: 0 }}
          </span>
        </td>
        <td class="px-5 py-3.5">
          {{ m.status_badge(eq.is_active, 'Active', 'Inactive') }}
        </td>
        <td class="px-5 py-3.5 text-right">
          <div class="flex gap-1.5 justify-end items-center">
            {% if saison_active_id %}
              <a href="{{ url('admin/equipes-config/' ~ eq.id ~ '/saisons/' ~ saison_active_id ~ '/joueurs') }}"
                 title="Gérer les joueurs de l'équipe"
                 class="inline-flex items-center gap-1 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 px-2.5 py-1.5 text-xs font-semibold rounded-lg transition">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                Joueurs
              </a>
              <a href="{{ url('admin/equipes-config/' ~ eq.id ~ '/saisons/' ~ saison_active_id ~ '/photos') }}"
                 title="Gérer les photos d'équipe"
                 class="inline-flex items-center gap-1 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 px-2.5 py-1.5 text-xs font-semibold rounded-lg transition">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                Photos
              </a>
            {% endif %}
            {{ m.action_buttons(
              url('admin/equipes-config/' ~ eq.id ~ '/edit'),
              url('admin/equipes-config/' ~ eq.id ~ '/delete'),
              'Supprimer cette équipe ?',
              csrf_token
            ) }}
          </div>
        </td>
      </tr>
      {% endfor %}
      {% endfor %}
    </tbody>
  </table>
</div>

{% else %}
  {{ m.empty_state('Aucune équipe configurée.', url('admin/equipes-config/create'), '+ Ajouter une équipe') }}
{% endif %}
{% endblock %}
