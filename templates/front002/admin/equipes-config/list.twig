{% extends 'admin/layout.twig' %}
{% block title %}Équipes{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-black">Équipes</h1>
  <a href="{{ url('admin/equipes-config/create') }}"
     class="border-4 border-black bg-usm-brown text-white font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    + Ajouter
  </a>
</div>

{% if equipes|length %}

{# Grouper par catégorie #}
{% set grouped = {} %}
{% for eq in equipes %}
  {% set cat = eq.categorie %}
  {% if grouped[cat] is not defined %}
    {% set grouped = grouped|merge({(cat): []}) %}
  {% endif %}
  {% set grouped = grouped|merge({(cat): grouped[cat]|merge([eq])}) %}
{% endfor %}

{# ── Mobile : cartes empilées ── #}
<div class="sm:hidden space-y-6">
  {% for cat, eqs in grouped %}
  <div>
    <h2 class="text-sm font-black uppercase tracking-widest text-gray-500 mb-2 px-1">{{ cat }}</h2>
    <div class="space-y-3">
      {% for eq in eqs %}
      <div class="border-4 border-black bg-white p-4 shadow-[4px_4px_0_#000]">
        <div class="flex items-start justify-between gap-2 mb-2">
          <div class="font-black text-base leading-tight">{{ eq.libelle }}</div>
          {% if eq.is_active %}
            <span class="shrink-0 bg-green-100 text-green-800 border-2 border-green-600 px-2 py-0.5 text-xs font-black">Active</span>
          {% else %}
            <span class="shrink-0 bg-gray-100 text-gray-500 border-2 border-gray-400 px-2 py-0.5 text-xs font-black">Inactive</span>
          {% endif %}
        </div>
        <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs text-gray-500 mb-3">
          {% if eq.type %}<span>{{ eq.type }}</span>{% endif %}
          {% if eq.hauteur_filet %}<span>🏐 {{ eq.hauteur_filet }}</span>{% endif %}
          <span class="font-mono">{{ eq.slug_colonne }}</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {% if saison_active_id %}
            <a href="{{ url('admin/equipes-config/' ~ eq.id ~ '/saisons/' ~ saison_active_id ~ '/joueurs') }}"
               class="inline-flex items-center gap-1.5 border-2 border-black px-3 py-1.5 text-xs font-bold bg-amber-200 text-amber-950 hover:bg-amber-300 shadow-[2px_2px_0_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
              <span>Joueurs</span>
            </a>
            <a href="{{ url('admin/equipes-config/' ~ eq.id ~ '/saisons/' ~ saison_active_id ~ '/photos') }}"
               class="inline-flex items-center gap-1.5 border-2 border-black px-3 py-1.5 text-xs font-bold bg-sky-200 text-sky-950 hover:bg-sky-300 shadow-[2px_2px_0_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span>Photos</span>
            </a>
          {% endif %}
          <a href="{{ url('admin/equipes-config/' ~ eq.id ~ '/edit') }}"
             class="inline-flex items-center gap-1.5 border-2 border-black px-3 py-1.5 text-xs font-bold bg-emerald-100 text-emerald-950 hover:bg-emerald-200 shadow-[2px_2px_0_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            <span>Éditer</span>
          </a>
          <form method="POST" action="{{ url('admin/equipes-config/' ~ eq.id ~ '/delete') }}" data-confirm="Supprimer cette équipe ?" class="inline">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit"
                    class="inline-flex items-center gap-1.5 border-2 border-black px-3 py-1.5 text-xs font-bold bg-rose-200 text-rose-950 hover:bg-rose-300 shadow-[2px_2px_0_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
              <span>Supprimer</span>
            </button>
          </form>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endfor %}
</div>

{# ── Desktop : tableau groupé par catégorie ── #}
<div class="hidden sm:block border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-black text-white">
      <tr>
        <th class="text-left px-4 py-3 font-black">Équipe</th>
        <th class="text-left px-4 py-3 font-black">Type</th>
        <th class="text-left px-4 py-3 font-black">Filet</th>
        <th class="text-left px-4 py-3 font-black">Colonne DB</th>
        <th class="text-left px-4 py-3 font-black">Statut</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for cat, eqs in grouped %}
      {# Ligne de catégorie #}
      <tr class="bg-amber-50 border-t-4 border-black">
        <td colspan="6" class="px-4 py-2 font-black text-xs uppercase tracking-widest text-gray-600">
          {{ cat }} <span class="font-normal text-gray-400">({{ eqs|length }})</span>
        </td>
      </tr>
      {% for eq in eqs %}
      <tr class="border-t border-gray-100 hover:bg-amber-50 transition-colors">
        <td class="px-4 py-3">
          <span class="font-black text-gray-900">{{ eq.libelle }}</span>
          {% if eq.description_courte %}
            <p class="text-xs text-gray-400 italic mt-0.5 truncate max-w-xs">{{ eq.description_courte }}</p>
          {% endif %}
        </td>
        <td class="px-4 py-3 text-gray-600 text-xs">{{ eq.type ?: '—' }}</td>
        <td class="px-4 py-3 text-gray-600 text-xs font-semibold">{{ eq.hauteur_filet ?: '—' }}</td>
        <td class="px-4 py-3 font-mono text-xs text-gray-400">{{ eq.slug_colonne }}</td>
        <td class="px-4 py-3">
          {% if eq.is_active %}
            <span class="bg-green-100 text-green-800 border-2 border-green-600 px-2 py-0.5 text-xs font-black">Active</span>
          {% else %}
            <span class="bg-gray-100 text-gray-500 border-2 border-gray-400 px-2 py-0.5 text-xs font-black">Inactive</span>
          {% endif %}
        </td>
        <td class="px-4 py-3">
          <div class="flex gap-2 justify-end">
            {% if saison_active_id %}
              <a href="{{ url('admin/equipes-config/' ~ eq.id ~ '/saisons/' ~ saison_active_id ~ '/joueurs') }}"
                 title="Joueurs"
                 class="inline-flex items-center gap-1.5 border-2 border-black px-2 xl:px-3 py-1.5 text-xs font-bold bg-amber-200 text-amber-950 hover:bg-amber-300 shadow-[2px_2px_0_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                <span class="hidden xl:inline">Joueurs</span>
              </a>
              <a href="{{ url('admin/equipes-config/' ~ eq.id ~ '/saisons/' ~ saison_active_id ~ '/photos') }}"
                 title="Photos"
                 class="inline-flex items-center gap-1.5 border-2 border-black px-2 xl:px-3 py-1.5 text-xs font-bold bg-sky-200 text-sky-950 hover:bg-sky-300 shadow-[2px_2px_0_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span class="hidden xl:inline">Photos</span>
              </a>
            {% endif %}
            <a href="{{ url('admin/equipes-config/' ~ eq.id ~ '/edit') }}"
               title="Éditer"
               class="inline-flex items-center gap-1.5 border-2 border-black px-2 xl:px-3 py-1.5 text-xs font-bold bg-emerald-100 text-emerald-950 hover:bg-emerald-200 shadow-[2px_2px_0_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              <span class="hidden xl:inline">Éditer</span>
            </a>
            <form method="POST" action="{{ url('admin/equipes-config/' ~ eq.id ~ '/delete') }}" data-confirm="Supprimer cette équipe ?" class="inline">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
              <button type="submit"
                      title="Supprimer"
                      class="inline-flex items-center gap-1.5 border-2 border-black px-2 xl:px-3 py-1.5 text-xs font-bold bg-rose-200 text-rose-950 hover:bg-rose-300 shadow-[2px_2px_0_#000] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                <span class="hidden xl:inline">Supprimer</span>
              </button>
            </form>
          </div>
        </td>
      </tr>
      {% endfor %}
      {% endfor %}
    </tbody>
  </table>
</div>

{% else %}
  <div class="border-4 border-black bg-white p-8 text-center shadow-[4px_4px_0_#000]">
    <p class="text-gray-500 italic">Aucune équipe configurée.</p>
  </div>
{% endif %}
{% endblock %}
