{% extends 'admin/layout.twig' %}
{% block title %}Photos — {{ equipe.libelle }} / {{ saison.libelle }}{% endblock %}

{% block content %}
<div class="mb-6 flex flex-col md:flex-row md:items-end justify-between gap-4">
  <div>
    <a href="{{ url('admin/equipes-config/' ~ equipe.id ~ '/edit') }}" class="text-sm text-gray-500 hover:underline">← {{ equipe.libelle }}</a>
    <h1 class="text-3xl font-black mt-1">Photos — {{ equipe.libelle }} <span class="font-normal text-gray-500">/ {{ saison.libelle }}</span></h1>
  </div>

  {# Sélecteur de saison #}
  <div class="flex items-center gap-2">
    <label for="season-select" class="font-black text-sm whitespace-nowrap">Saison :</label>
    <select id="season-select" 
            onchange="window.location.href = this.value"
            class="border-4 border-black px-3 py-1.5 font-bold focus:outline-none focus:ring-2 focus:ring-amber-400 bg-white cursor-pointer text-sm">
      {% for s in saisons %}
        <option value="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ s.id ~ '/photos') }}" {% if s.id == saison.id %}selected{% endif %}>
          {{ s.libelle }} {% if s.is_active %}(Active){% endif %}
        </option>
      {% endfor %}
    </select>
  </div>
</div>

<div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000]">
  <h2 class="font-black text-lg mb-4">Galerie photos</h2>

  {# Dropzone upload #}
  <div id="photo-dropzone"
       class="dropzone border-4 border-dashed border-black bg-amber-50 rounded-none cursor-pointer
              min-h-[140px] flex items-center justify-center mb-5
              hover:bg-amber-100 transition-colors">
    <div class="dz-message text-center text-gray-600 font-semibold pointer-events-none">
      <div class="text-4xl mb-2">📸</div>
      <div class="text-base font-black">Glissez vos photos ici</div>
      <div class="text-sm font-normal mt-1">ou cliquez pour sélectionner</div>
      <div class="text-xs text-gray-400 mt-1">JPG · PNG · WebP — max 10 Mo</div>
    </div>
  </div>

  {# Photos existantes #}
  {% if photos %}
  <p class="text-xs text-gray-400 mb-2">Glissez-déposez les photos pour les réorganiser.</p>
  {% endif %}
  <div id="existing-photos" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3">
    {% for photo in photos %}
    <div class="photo-thumb relative border-2 border-black overflow-hidden group cursor-grab active:cursor-grabbing" data-id="{{ photo.id }}">
      <span class="drag-handle absolute top-1 left-1 z-10 bg-black/50 text-white text-xs px-1 rounded leading-none select-none pointer-events-none">⠿</span>
      <img src="{{ image_variant(photo, 'thumb') }}" alt="" class="w-full h-28 object-cover pointer-events-none">
      <button type="button"
              data-delete-url="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ saison.id ~ '/photos/' ~ photo.id ~ '/delete-xhr') }}"
              class="delete-photo absolute inset-0 flex items-center justify-center
                     opacity-0 group-hover:opacity-100 transition bg-black/60
                     text-white font-black text-sm border-0 cursor-pointer w-full">
        ✕ Supprimer
      </button>
    </div>
    {% endfor %}
  </div>
</div>
{% endblock %}

{% block scripts %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/dropzone.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/dropzone.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<script>
Dropzone.autoDiscover = false;
const dz = new Dropzone('#photo-dropzone', {
  url:             '{{ upload_url }}',
  paramName:       'file',
  params:          { '_csrf_token': '{{ csrf_token }}' },
  acceptedFiles:   'image/jpeg,image/png,image/webp',
  maxFilesize:     10,
  parallelUploads: 3,
  uploadMultiple:  false,
  addRemoveLinks:  false,
  previewTemplate: '<div style="display:none"></div>',
  clickable:       true,
  dictDefaultMessage: '',
  init() {
    this.on('success', (file, resp) => {
      if (!resp.ok) { alert(resp.error || 'Erreur upload'); return; }
      addThumb(resp.id, resp.url, resp.deleteUrl);
      this.removeFile(file);
    });
    this.on('error', (file, msg) => {
      const txt = typeof msg === 'string' ? msg : (msg.error || 'Erreur inconnue');
      alert('Erreur : ' + txt);
      this.removeFile(file);
    });
  }
});

function addThumb(id, url, deleteUrl) {
  const wrap = document.createElement('div');
  wrap.className = 'photo-thumb relative border-2 border-black overflow-hidden group cursor-grab active:cursor-grabbing';
  wrap.dataset.id = id;
  wrap.innerHTML = `
    <span class="drag-handle absolute top-1 left-1 z-10 bg-black/50 text-white text-xs px-1 rounded leading-none select-none pointer-events-none">⠿</span>
    <img src="${url}" alt="" class="w-full h-28 object-cover pointer-events-none">
    <button type="button" data-delete-url="${deleteUrl}"
            class="delete-photo absolute inset-0 flex items-center justify-center
                   opacity-0 group-hover:opacity-100 transition bg-black/60
                   text-white font-black text-sm border-0 cursor-pointer w-full">
      ✕ Supprimer
    </button>`;
  document.getElementById('existing-photos').appendChild(wrap);
  bindDelete(wrap.querySelector('.delete-photo'));
}

function bindDelete(btn) {
  btn.addEventListener('click', async () => {
    if (!confirm('Supprimer cette photo ?')) return;
    try {
      const r = await fetch(btn.dataset.deleteUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: '_csrf_token=' + encodeURIComponent('{{ csrf_token }}')
      });
      if (r.ok) btn.closest('.photo-thumb').remove();
      else alert('Impossible de supprimer la photo.');
    } catch { alert('Erreur réseau.'); }
  });
}
document.querySelectorAll('.delete-photo').forEach(bindDelete);

// Drag & drop reorder
Sortable.create(document.getElementById('existing-photos'), {
  animation:  150,
  ghostClass: 'opacity-40',
  onEnd() {
    const ids = [...document.querySelectorAll('#existing-photos .photo-thumb')].map(el => el.dataset.id);
    fetch('{{ url('admin/photos/reorder') }}', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ ids, _csrf_token: '{{ csrf_token }}' })
    });
  }
});
</script>
{% endblock %}
