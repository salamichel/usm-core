{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}Photos — {{ equipe.libelle }} / {{ saison.libelle }}{% endblock %}

{% block content %}

{# ── En-tête avec breadcrumb ── #}
<div class="relative overflow-hidden bg-slate-900 rounded-3xl p-6 md:p-8 text-white shadow-sm mb-8">
  <div class="relative flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
      <nav class="flex items-center gap-1.5 text-xs text-slate-400 font-medium mb-2">
        <a href="{{ url('admin') }}" class="hover:text-white transition">Admin</a>
        <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <a href="{{ url('admin/equipes-config') }}" class="hover:text-white transition">Équipes</a>
        <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <span class="text-slate-200">Photos ({{ saison.libelle }})</span>
      </nav>
      <h1 class="text-2xl font-black tracking-tight">Photos — {{ equipe.libelle }}</h1>
    </div>

    {# Sélecteur de saison #}
    <div class="flex items-center gap-2">
      <label for="season-select" class="text-xs font-bold text-slate-400">Saison :</label>
      <select id="season-select"
              onchange="window.location.href = this.value"
              class="bg-slate-800 text-white border border-slate-700 px-3 py-1.5 font-bold rounded-xl focus:outline-none focus:ring-2 focus:ring-[#94674d] cursor-pointer text-xs">
        {% for s in saisons %}
          <option value="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ s.id ~ '/photos') }}" {% if s.id == saison.id %}selected{% endif %}>
            {{ s.libelle }} {% if s.is_active %}(Active){% endif %}
          </option>
        {% endfor %}
      </select>
    </div>
  </div>
</div>

<div class="bg-white border border-slate-100 rounded-3xl shadow-sm p-6 md:p-8 space-y-6">
  <h2 class="font-bold text-base text-slate-800 border-b border-slate-100 pb-3">Galerie photos de l'équipe</h2>

  {# Dropzone upload #}
  <div id="photo-dropzone"
       class="dropzone border-2 border-dashed border-slate-200 bg-slate-50/50 rounded-2xl cursor-pointer
              min-h-[140px] flex items-center justify-center mb-5
              hover:bg-slate-100/50 hover:border-[#94674d]/40 transition duration-150">
    <div class="dz-message text-center text-slate-500 font-semibold pointer-events-none p-4">
      <svg class="w-10 h-10 mx-auto mb-2 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
      <div class="text-sm font-bold text-slate-700">Glissez vos photos ici ou cliquez pour choisir</div>
      <div class="text-xs text-slate-400 font-normal mt-1">JPG · PNG · WebP — max 10 Mo</div>
    </div>
  </div>

  {# Photos existantes #}
  {% if photos %}
  <p class="text-xs text-slate-400 font-medium">Glissez-déposez les photos pour les réorganiser.</p>
  {% endif %}
  <div id="existing-photos" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
    {% for photo in photos %}
    <div class="photo-thumb relative rounded-2xl overflow-hidden border border-slate-200 shadow-sm group cursor-grab active:cursor-grabbing bg-slate-100" data-id="{{ photo.id }}">
      <span class="drag-handle absolute top-2 left-2 z-10 bg-slate-900/60 text-white text-xs px-1.5 py-0.5 rounded-md leading-none select-none pointer-events-none backdrop-blur-sm">⠿</span>
      <img src="{{ image_variant(photo, 'thumb') }}" alt="" class="w-full h-32 object-cover pointer-events-none">
      <button type="button"
              data-delete-url="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ saison.id ~ '/photos/' ~ photo.id ~ '/delete-xhr') }}"
              class="delete-photo absolute inset-0 flex items-center justify-center
                     opacity-0 group-hover:opacity-100 transition bg-slate-900/75 backdrop-blur-xs
                     text-white font-bold text-xs cursor-pointer w-full">
        ✕ Supprimer
      </button>
    </div>
    {% endfor %}
  </div>
</div>
{% endblock %}

{% block scripts %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/dropzone.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/dropzone.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>
<script>
  Dropzone.autoDiscover = false;
  const dz = new Dropzone('#photo-dropzone', {
    url: '{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ saison.id ~ '/photos/upload') }}',
    paramName: 'file',
    params: { '_csrf_token': '{{ csrf_token }}' },
    acceptedFiles: 'image/jpeg,image/png,image/webp',
    maxFilesize: 10,
    parallelUploads: 2,
    init() {
      this.on('success', (file, resp) => {
        if (resp.ok) { location.reload(); }
        else { alert(resp.error || 'Erreur d\'upload'); }
      });
      this.on('error', (file, msg) => {
        alert(typeof msg === 'string' ? msg : (msg.error || 'Erreur'));
      });
    }
  });

  const grid = document.getElementById('existing-photos');
  if (grid) {
    Sortable.create(grid, {
      animation: 150,
      handle: '.photo-thumb',
      onEnd() {
        const ids = Array.from(grid.children).map(el => el.dataset.id);
        fetch('{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ saison.id ~ '/photos/reorder') }}', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({
            '_csrf_token': '{{ csrf_token }}',
            'order': JSON.stringify(ids)
          })
        });
      }
    });

    grid.addEventListener('click', (e) => {
      const btn = e.target.closest('.delete-photo');
      if (!btn) return;
      if (!confirm('Supprimer cette photo ?')) return;

      const thumb = btn.closest('.photo-thumb');
      fetch(btn.dataset.deleteUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({ '_csrf_token': '{{ csrf_token }}' })
      })
      .then(r => r.json())
      .then(d => {
        if (d.ok) { thumb.remove(); }
        else { alert(d.error || 'Erreur lors de la suppression'); }
      });
    });
  }
</script>
{% endblock %}
