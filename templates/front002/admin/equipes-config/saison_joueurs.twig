{% extends 'admin/layout.twig' %}
{% block title %}Joueurs — {{ equipe.libelle }} / {{ saison.libelle }}{% endblock %}

{% block content %}
<div class="mb-6 flex flex-col md:flex-row md:items-end justify-between gap-4">
  <div>
    <a href="{{ url('admin/equipes-config/' ~ equipe.id ~ '/edit') }}" class="text-sm text-gray-500 hover:underline">← {{ equipe.libelle }}</a>
    <h1 class="text-3xl font-black mt-1">Joueurs — {{ equipe.libelle }} <span class="font-normal text-gray-500">/ {{ saison.libelle }}</span></h1>
  </div>

  {# Sélecteur de saison #}
  <div class="flex items-center gap-2">
    <label for="season-select" class="font-black text-sm whitespace-nowrap">Saison :</label>
    <select id="season-select" 
            onchange="window.location.href = this.value"
            class="border-4 border-black px-3 py-1.5 font-bold focus:outline-none focus:ring-2 focus:ring-amber-400 bg-white cursor-pointer text-sm">
      {% for s in saisons %}
        <option value="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ s.id ~ '/joueurs') }}" {% if s.id == saison.id %}selected{% endif %}>
          {{ s.libelle }} {% if s.is_active %}(Active){% endif %}
        </option>
      {% endfor %}
    </select>
  </div>
</div>

<div class="border-2 border-amber-400 bg-amber-50 text-amber-800 p-3 mb-6 text-sm font-semibold">
  ⚠ Les ajustements manuels seront réinitialisés si vous re-flashez la saison.
</div>

{# Ajouter un joueur #}
{% if available|length %}
<div class="border-4 border-black bg-white p-4 shadow-[4px_4px_0_#000] mb-6 flex items-end gap-3">
  <form method="POST" action="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ saison.id ~ '/joueurs/add') }}"
        class="flex items-end gap-3 flex-wrap">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
    <div>
      <label class="block font-black text-sm mb-1">Ajouter un joueur</label>
      <select name="snapshot_id"
              class="border-4 border-black px-3 py-2 font-semibold focus:outline-none focus:ring-2 focus:ring-amber-400">
        {% for snap in available %}
        <option value="{{ snap.id }}">{{ snap.nom }} {{ snap.prenom }}</option>
        {% endfor %}
      </select>
    </div>
    <button type="submit"
            class="border-4 border-black bg-usm-brown text-white font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
      Ajouter
    </button>
  </form>
</div>
{% endif %}

{# Liste des membres #}
{% if joueurs|length %}
<div class="border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-black text-white">
      <tr>
        <th class="text-left px-4 py-3 font-black">Nom</th>
        <th class="text-left px-4 py-3 font-black">Prénom</th>
        <th class="text-left px-4 py-3 font-black">Email</th>
        <th class="text-left px-4 py-3 font-black">Rôle</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for j in joueurs %}
      <tr class="border-t-2 border-gray-200 hover:bg-amber-50">
        <td class="px-4 py-3 font-semibold">{{ j.nom }}</td>
        <td class="px-4 py-3">{{ j.prenom }}</td>
        <td class="px-4 py-3 text-gray-500 text-xs">{{ j.data.Mel ?? '—' }}</td>
        <td class="px-4 py-3 text-sm">
          {% if j.is_captain %}
            <span class="inline-flex items-center gap-x-1.5 rounded-md bg-green-100 px-2 py-1 text-xs font-semibold text-green-700">
              <svg class="h-1.5 w-1.5 fill-green-500" viewBox="0 0 6 6" aria-hidden="true">
                <circle cx="3" cy="3" r="3" />
              </svg>
              Capitaine
            </span>
          {% else %}
            <span class="text-gray-400 text-xs">—</span>
          {% endif %}
        </td>
        <td class="px-4 py-3 text-right">
          <div class="flex justify-end items-center gap-2">
            <form method="POST"
                  action="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ saison.id ~ '/joueurs/' ~ j.id ~ '/toggle-captain') }}">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
              <button type="submit" class="border-2 {{ j.is_captain ? 'border-gray-500 text-gray-600 hover:bg-gray-500 hover:text-white' : 'border-amber-500 text-amber-700 hover:bg-amber-500 hover:text-white' }} px-2 py-1 text-xs font-bold transition">
                {{ j.is_captain ? 'Retirer capitaine' : 'Nommer capitaine' }}
              </button>
            </form>
            <form method="POST"
                  action="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ saison.id ~ '/joueurs/' ~ j.id ~ '/remove') }}"
                  data-confirm="Retirer ce joueur de l'équipe ?">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
              <button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Retirer</button>
            </form>
          </div>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
  <p class="text-gray-500 italic">Aucun joueur dans cette équipe pour cette saison.</p>
{% endif %}
{% endblock %}
