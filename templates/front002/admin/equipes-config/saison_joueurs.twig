{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}Joueurs — {{ equipe.libelle }} / {{ saison.libelle }}{% endblock %}

{% block content %}

{# ── En-tête avec breadcrumb ── #}
<div class="relative overflow-hidden bg-slate-900 rounded-3xl p-6 md:p-8 text-white shadow-sm mb-8">
  <div class="relative flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
      <nav class="flex items-center gap-1.5 text-xs text-slate-400 font-medium mb-2">
        <a href="{{ url('admin') }}" class="hover:text-white transition">Admin</a>
        <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <a href="{{ url('admin/equipes-config') }}" class="hover:text-white transition">Équipes</a>
        <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <span class="text-slate-200">Joueurs ({{ saison.libelle }})</span>
      </nav>
      <h1 class="text-2xl font-black tracking-tight">Joueurs — {{ equipe.libelle }}</h1>
    </div>

    {# Sélecteur de saison #}
    <div class="flex items-center gap-2">
      <label for="season-select" class="text-xs font-bold text-slate-400">Saison :</label>
      <select id="season-select"
              onchange="window.location.href = this.value"
              class="bg-slate-800 text-white border border-slate-700 px-3 py-1.5 font-bold rounded-xl focus:outline-none focus:ring-2 focus:ring-[#94674d] cursor-pointer text-xs">
        {% for s in saisons %}
          <option value="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ s.id ~ '/joueurs') }}" {% if s.id == saison.id %}selected{% endif %}>
            {{ s.libelle }} {% if s.is_active %}(Active){% endif %}
          </option>
        {% endfor %}
      </select>
    </div>
  </div>
</div>

<div class="bg-amber-50/60 border border-amber-200 text-amber-800 rounded-2xl p-4 mb-6 text-xs font-semibold flex items-center gap-2">
  <svg class="w-4 h-4 text-amber-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
  <span>Les ajustements manuels seront réinitialisés si vous re-flashez la saison.</span>
</div>

{# Ajouter un joueur #}
{% if available|length %}
<div class="bg-white border border-slate-100 rounded-2xl shadow-sm p-4 mb-6">
  <form method="POST" action="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ saison.id ~ '/joueurs/add') }}"
        class="flex items-end gap-3 flex-wrap">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
    <div class="flex-1 min-w-[200px]">
      <label class="block text-xs font-bold text-slate-700 mb-1.5">Ajouter un joueur dans l'équipe</label>
      <select name="snapshot_id"
              class="w-full border border-slate-200 bg-white rounded-xl px-3.5 py-2 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
        {% for snap in available %}
        <option value="{{ snap.id }}">{{ snap.nom }} {{ snap.prenom }}</option>
        {% endfor %}
      </select>
    </div>
    <button type="submit"
            class="bg-[#94674d] hover:bg-[#7a5540] text-white font-bold px-4 py-2 text-sm rounded-xl transition shadow-sm">
      + Ajouter
    </button>
  </form>
</div>
{% endif %}

{# Liste des membres #}
{% if joueurs|length %}
<div class="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-800 text-white">
      <tr>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Nom</th>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Prénom</th>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Email</th>
        <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Rôle</th>
        <th class="px-5 py-3.5 text-right"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-50">
      {% for j in joueurs %}
      <tr class="hover:bg-slate-50/70 transition duration-100">
        <td class="px-5 py-3.5 font-semibold text-slate-900">{{ j.nom }}</td>
        <td class="px-5 py-3.5 font-medium text-slate-800">{{ j.prenom }}</td>
        <td class="px-5 py-3.5 text-slate-400 text-xs">{{ j.data.Mel ?? '—' }}</td>
        <td class="px-5 py-3.5">
          {% if j.is_captain %}
            <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 border border-emerald-200 px-2.5 py-0.5 text-xs font-bold text-emerald-700">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Capitaine
            </span>
          {% else %}
            <span class="text-slate-300 text-xs font-medium">—</span>
          {% endif %}
        </td>
        <td class="px-5 py-3.5 text-right">
          <div class="flex items-center gap-1.5 justify-end flex-wrap">
            <button type="button"
                    class="inline-flex items-center gap-1 bg-slate-50 border border-slate-200 text-slate-700 hover:bg-slate-100 px-2.5 py-1.5 text-xs font-semibold rounded-lg transition edit-preferences-btn"
                    data-player-id="{{ j.id_joueur }}"
                    data-player-name="{{ j.prenom }} {{ j.nom }}">
              ✉️ Abonnements
            </button>
            <form method="POST"
                  action="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ saison.id ~ '/joueurs/' ~ j.id ~ '/toggle-captain') }}" class="inline">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
              <button type="submit" class="inline-flex items-center gap-1 border px-2.5 py-1.5 text-xs font-bold rounded-lg transition {{ j.is_captain ? 'bg-slate-50 border-slate-200 text-slate-600 hover:bg-slate-100' : 'bg-amber-50 border-amber-200 text-amber-700 hover:bg-amber-100' }}">
                {{ j.is_captain ? 'Retirer capitaine' : 'Nommer capitaine' }}
              </button>
            </form>
            <form method="POST"
                  action="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ saison.id ~ '/joueurs/' ~ j.id ~ '/remove') }}"
                  data-confirm="Retirer ce joueur de l'équipe ?" class="inline">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
              <button type="submit" class="inline-flex items-center gap-1 bg-rose-50 border border-rose-200 text-rose-600 hover:bg-rose-100 px-2.5 py-1.5 text-xs font-bold rounded-lg transition">Retirer</button>
            </form>
          </div>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
  {{ m.empty_state('Aucun joueur dans cette équipe pour cette saison.') }}
{% endif %}

<!-- Modale de Gestion des Abonnements E-mail -->
<div id="email-preferences-modal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
  <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
    <div class="fixed inset-0 bg-slate-900/75 transition-opacity modal-close backdrop-blur-sm"></div>

    <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

    <div class="inline-block align-bottom bg-white rounded-3xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full border border-slate-100">
      <div class="bg-slate-900 px-6 py-4 flex items-center justify-between text-white">
        <h3 class="text-base font-bold leading-6 flex items-center gap-2" id="modal-title">
          ✉️ Abonnements de <span id="pref-modal-player-name" class="font-extrabold text-amber-400"></span>
        </h3>
        <button type="button" class="text-slate-400 hover:text-white transition modal-close">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <div class="p-6">
        <div id="pref-modal-loading" class="flex flex-col items-center justify-center py-8 gap-3">
          <div class="w-8 h-8 border-4 border-slate-200 border-t-[#94674d] rounded-full animate-spin"></div>
          <span class="text-sm font-semibold text-slate-500">Chargement des abonnements...</span>
        </div>

        <div id="pref-modal-error" class="hidden text-center py-8 text-rose-600 font-semibold text-sm">
          Erreur lors du chargement des préférences.
        </div>

        <form id="pref-modal-form" class="hidden space-y-4">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
          <input type="hidden" id="pref-player-id" name="player_id" value="">
          <input type="hidden" name="saison_id" value="{{ saison.id }}">

          <p class="text-xs text-slate-500 font-medium mb-4">
            Cochez les événements pour lesquels ce joueur doit recevoir un e-mail de rappel de présence.
          </p>

          <div id="pref-modal-checkboxes" class="space-y-2.5 max-h-60 overflow-y-auto pr-2">
            <!-- Dynamique via JS -->
          </div>

          <div class="pt-4 border-t border-slate-100 flex items-center justify-between gap-3">
            <button type="button" id="pref-modal-select-all" class="text-xs font-bold text-[#94674d] hover:underline">
              Tout cocher / Décocher
            </button>
            <div class="flex gap-2">
              <button type="button" class="px-4 py-2 border border-slate-200 text-slate-700 text-xs font-semibold rounded-xl hover:bg-slate-50 transition modal-close">
                Annuler
              </button>
              <button type="submit" id="pref-modal-submit" class="px-4 py-2 bg-[#94674d] hover:bg-[#7a5540] text-white text-xs font-bold rounded-xl transition shadow-sm">
                Enregistrer
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
  const modal = document.getElementById('email-preferences-modal');
  const loading = document.getElementById('pref-modal-loading');
  const errorBox = document.getElementById('pref-modal-error');
  const form = document.getElementById('pref-modal-form');
  const checkboxesContainer = document.getElementById('pref-modal-checkboxes');
  const playerNameSpan = document.getElementById('pref-modal-player-name');
  const playerIdInput = document.getElementById('pref-player-id');
  const selectAllBtn = document.getElementById('pref-modal-select-all');

  function closeModal() { modal.classList.add('hidden'); }
  document.querySelectorAll('.modal-close').forEach(btn => btn.addEventListener('click', closeModal));

  document.querySelectorAll('.edit-preferences-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const playerId = this.getAttribute('data-player-id');
      const playerName = this.getAttribute('data-player-name');

      playerNameSpan.textContent = playerName;
      playerIdInput.value = playerId;

      modal.classList.remove('hidden');
      loading.classList.remove('hidden');
      errorBox.classList.add('hidden');
      form.classList.add('hidden');

      fetch(`{{ url('admin/saisons/' ~ saison.id ~ '/joueurs/') }}${playerId}/email-preferences`)
        .then(res => res.json())
        .then(data => {
          loading.classList.add('hidden');
          if (!data.success) { errorBox.classList.remove('hidden'); return; }

          checkboxesContainer.innerHTML = '';
          data.preferences.forEach(pref => {
            const label = document.createElement('label');
            label.className = 'flex items-center gap-3 p-2 rounded-xl hover:bg-slate-50 border border-slate-100 cursor-pointer text-xs font-semibold text-slate-800 transition';
            label.innerHTML = `
              <input type="checkbox" name="preferences[${pref.key}]" value="1" ${pref.is_subscribed ? 'checked' : ''} class="w-4 h-4 rounded border-slate-300 text-[#94674d] focus:ring-[#94674d]/30">
              <span>${pref.label}</span>
            `;
            checkboxesContainer.appendChild(label);
          });
          form.classList.remove('hidden');
        })
        .catch(err => {
          loading.classList.add('hidden');
          errorBox.classList.remove('hidden');
        });
    });
  });

  if (selectAllBtn) {
    selectAllBtn.addEventListener('click', function() {
      const cbs = checkboxesContainer.querySelectorAll('input[type="checkbox"]');
      const allChecked = Array.from(cbs).every(cb => cb.checked);
      cbs.forEach(cb => cb.checked = !allChecked);
    });
  }

  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const playerId = playerIdInput.value;
      const formData = new FormData(form);

      const submitBtn = document.getElementById('pref-modal-submit');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enregistrement...';

      fetch(`{{ url('admin/saisons/' ~ saison.id ~ '/joueurs/') }}${playerId}/email-preferences`, {
        method: 'POST',
        body: formData
      })
      .then(res => res.json())
      .then(data => {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enregistrer';
        if (data.success) { closeModal(); } else { alert(data.error || 'Erreur lors de la sauvegarde'); }
      })
      .catch(err => {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enregistrer';
        alert('Erreur de connexion');
      });
    });
  }
});
</script>
{% endblock %}
