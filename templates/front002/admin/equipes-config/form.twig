{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}{{ equipe ? equipe.libelle : 'Nouvelle équipe' }}{% endblock %}

{% block content %}

{# ── En-tête avec breadcrumb ── #}
<div class="relative overflow-hidden bg-slate-900 rounded-3xl p-6 md:p-8 text-white shadow-sm mb-8">
  <div class="relative flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
      <nav class="flex items-center gap-1.5 text-xs text-slate-400 font-medium mb-2">
        <a href="{{ url('admin') }}" class="hover:text-white transition">Admin</a>
        <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <a href="{{ url('admin/equipes-config') }}" class="hover:text-white transition">Équipes</a>
        <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <span class="text-slate-200">{{ equipe ? 'Éditer' : 'Nouvelle équipe' }}</span>
      </nav>
      <h1 class="text-2xl font-black tracking-tight">{{ equipe ? equipe.libelle : 'Nouvelle équipe' }}</h1>
    </div>
    {% if equipe %}
      <div>
        {{ m.status_badge(equipe.is_active, 'Active', 'Inactive') }}
      </div>
    {% endif %}
  </div>
</div>

{{ m.form_error(error ?? null) }}

{# ── Layout desktop : 2 colonnes si saisons ── #}
<div class="{% if equipe and saisons|length %}lg:grid lg:grid-cols-[1fr_320px] lg:gap-6{% endif %}">

  {# ── Formulaire principal ── #}
  <form method="POST" action="{{ action }}" class="space-y-6">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

    {# Section 1 : Identité #}
    <div class="bg-white border border-slate-100 rounded-3xl shadow-sm p-6 md:p-8 space-y-6">
      <h2 class="font-bold text-base text-slate-800 border-b border-slate-100 pb-3">Identité de l'équipe</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          {{ m.field_input('libelle', 'libelle', 'Libellé', equipe.libelle ?? '', 'text', true, 'Loisir 1') }}
        </div>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-1.5" for="categorie">Catégorie *</label>
          <select id="categorie" name="categorie" required
                  class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
            <option value="">-- Sélectionner --</option>
            {% for cat in categories %}
              <option value="{{ cat.nom }}" {% if equipe and equipe.categorie == cat.nom %}selected{% endif %}>{{ cat.nom }}</option>
            {% endfor %}
          </select>
        </div>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-1.5" for="slug_colonne">Colonne DB *</label>
          <select id="slug_colonne" name="slug_colonne" required
                  class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-mono text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
            <option value="">-- Choisir une colonne --</option>
            {% for col in db_columns %}
              <option value="{{ col }}" {% if equipe and equipe.slug_colonne == col %}selected{% endif %}>{{ col }}</option>
            {% endfor %}
          </select>
        </div>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-1.5" for="slug">Slug SEO</label>
          <input id="slug" name="slug" type="text"
                 value="{{ equipe.slug ?? '' }}"
                 class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-mono text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition"
                 placeholder="loisir-1">
        </div>
        <div>
          {{ m.field_input('ordre', 'ordre', 'Ordre d\'affichage', equipe.ordre ?? 0, 'number') }}
        </div>
        <div>
          {{ m.field_input('min_players', 'min_players', 'Effectif minimum (Équipe complète)', equipe.min_players ?? 6, 'number', true) }}
        </div>
        <div class="sm:col-span-2 pt-2 border-t border-slate-50">
          {{ m.field_checkbox('is_active', 'is_active', 'Équipe active', equipe is null or equipe.is_active, '1') }}
        </div>
      </div>
    </div>

    {# Section 2 : Fiche équipe (carte) #}
    <div class="bg-white border border-slate-100 rounded-3xl shadow-sm p-6 md:p-8 space-y-6">
      <h2 class="font-bold text-base text-slate-800 border-b border-slate-100 pb-3">Fiche équipe <span class="font-normal text-slate-400 text-xs">— affichée sur les cartes</span></h2>
      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          {{ m.field_input('type', 'type', 'Type', equipe.type ?? '', 'text', false, 'Ex: Filles - 6×6') }}
        </div>
        <div>
          {{ m.field_input('hauteur_filet', 'hauteur_filet', 'Hauteur du filet', equipe.hauteur_filet ?? '', 'text', false, 'Ex: 2m43') }}
        </div>
        <div class="sm:col-span-2">
          {{ m.field_textarea('description_courte', 'description_courte', 'Description courte', equipe.description_courte ?? '', 2, false, 'Quelques mots affichés sous le titre sur la carte') }}
        </div>
      </div>
    </div>

    {# Section 3 : Description longue (WYSIWYG) #}
    <div class="bg-white border border-slate-100 rounded-3xl shadow-sm p-6 md:p-8 space-y-4">
      <h2 class="font-bold text-base text-slate-800 border-b border-slate-100 pb-3">Description complète <span class="font-normal text-slate-400 text-xs">— affichée sur la page détail</span></h2>
      <textarea id="description" name="description">{{ equipe.description ?? '' }}</textarea>
    </div>

    {# Section 4 : Filtres agenda & abonnements #}
    <div class="bg-white border border-slate-100 rounded-3xl shadow-sm p-6 md:p-8 space-y-6">
      <h2 class="font-bold text-base text-slate-800 border-b border-slate-100 pb-3">Filtres agenda & abonnements</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-1.5" for="team_filter">Code équipe (Agenda)</label>
          <input id="team_filter" name="team_filter" type="text"
                 value="{{ equipe.team_filter ?? equipe.slug_colonne ?? '' }}"
                 class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-mono text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition"
                 placeholder="Ex: L2">
        </div>
        <div>
          {{ m.field_input('manifestation_filter', 'manifestation_filter', 'Filtre manifestation (Match)', equipe.manifestation_filter ?? '', 'text', false, 'Ex: Match L2') }}
        </div>
      </div>

      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Entraînements associés pour les abonnements de présence</label>
        {% if training_types|length > 0 %}
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 p-4 border border-slate-200 bg-slate-50/50 rounded-2xl">
            {% for type in training_types %}
              {% set clean_type = type|replace({'Présences - ': '', 'Disponibilités - ': ''}) %}
              <label class="flex items-center gap-2.5 cursor-pointer text-sm font-semibold text-slate-700">
                <input type="checkbox" name="associated_trainings[]" value="{{ type }}"
                       {% if equipe and type in equipe.associated_trainings %}checked{% endif %}
                       class="w-4 h-4 rounded border-slate-300 text-[#94674d] focus:ring-[#94674d]/30">
                <span>{{ clean_type }}</span>
              </label>
            {% endfor %}
          </div>
        {% else %}
          <p class="text-xs text-slate-400 italic">Aucun type d'entraînement trouvé dans la base externe.</p>
        {% endif %}
      </div>
    </div>

    {# Section 5 : Lien FFVB #}
    <div class="bg-white border border-slate-100 rounded-3xl shadow-sm p-6 md:p-8 space-y-4">
      <h2 class="font-bold text-base text-slate-800 border-b border-slate-100 pb-3">Lien FFVB <span class="font-normal text-slate-400 text-xs">— optionnel</span></h2>
      {{ m.field_textarea('ffvb_link', 'ffvb_link', 'Lien(s) résultats FFVB de la saison', equipe.ffvb_link ?? '', 3, false, 'Phase 1 | https://...') }}
    </div>

    <div class="flex items-center gap-3 pt-2">
      {{ m.btn_submit(equipe ? 'Mettre à jour' : 'Créer l\'équipe') }}
      <a href="{{ url('admin/equipes-config') }}"
         class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-slate-700 transition">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
        Annuler
      </a>
    </div>
  </form>

  {# ── Panneau latéral : Saisons ── #}
  {% if equipe and saisons|length %}
  <div class="mt-6 lg:mt-0">
    <div class="bg-white border border-slate-100 rounded-3xl shadow-sm overflow-hidden sticky top-4">
      <div class="bg-slate-800 text-white px-5 py-4 font-bold text-xs uppercase tracking-wider">
        Saisons de l'équipe
      </div>
      <div class="divide-y divide-slate-100">
        {% for s in saisons %}
        <div class="p-4 space-y-3">
          <div class="flex items-center justify-between">
            <span class="font-bold text-sm text-slate-900">{{ s.libelle }}</span>
            {% if s.is_active %}
              <span class="bg-emerald-50 text-emerald-700 border border-emerald-200 px-2 py-0.5 text-[10px] font-bold rounded-full">Active</span>
            {% endif %}
          </div>
          <div class="flex items-center gap-3 text-xs text-slate-500 font-medium">
            <span>📷 {{ s.photo_count }} photo{{ s.photo_count != 1 ? 's' }}</span>
            <span>·</span>
            <span>👥 {{ s.joueur_count }} joueur{{ s.joueur_count != 1 ? 's' }}</span>
          </div>
          <div class="flex gap-2">
            <a href="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ s.id ~ '/photos') }}"
               class="flex-1 text-center bg-slate-50 hover:bg-slate-100 border border-slate-200 text-slate-700 px-2.5 py-1.5 text-xs font-semibold rounded-xl transition">
              📷 Photos
            </a>
            <a href="{{ url('admin/equipes-config/' ~ equipe.id ~ '/saisons/' ~ s.id ~ '/joueurs') }}"
               class="flex-1 text-center bg-slate-50 hover:bg-slate-100 border border-slate-200 text-slate-700 px-2.5 py-1.5 text-xs font-semibold rounded-xl transition">
              👥 Joueurs
            </a>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
  {% endif %}

</div>
{% endblock %}

{% block scripts %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.20/summernote-lite.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.20/summernote-lite.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.20/lang/summernote-fr-FR.min.js"></script>
<style>
  .note-editor .note-editable ul li { margin-left: 2rem !important; list-style: disc !important; }
  .note-editor .note-editable ol li { margin-left: 2rem !important; list-style: decimal !important; }
</style>
<script>
  $('#description').summernote({
    height: 250,
    lang: 'fr-FR',
    toolbar: [
      ['style',  ['style']],
      ['font',   ['bold', 'italic', 'underline', 'clear']],
      ['para',   ['ul', 'ol']],
      ['insert', ['link']],
      ['view',   ['codeview']]
    ]
  });
  $('form').on('submit', function () {
    document.getElementById('description').value = $('#description').summernote('code');
  });
</script>
{% endblock %}
