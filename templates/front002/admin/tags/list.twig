{% extends 'admin/layout.twig' %}
{% block title %}Tags{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-black">Tags</h1>
  <a href="{{ url('admin/tags/create') }}" class="border-4 border-black bg-usm-brown text-white font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    + Nouveau Tag
  </a>
</div>

{% if tags|length %}

{# Mobile #}
<div class="sm:hidden space-y-3">
  {% for tag in tags %}
  <div class="border-4 border-black bg-white p-4 shadow-[4px_4px_0_#000]">
    <div class="font-black text-base mb-2">{{ tag.name }}</div>
    <div class="text-xs text-gray-500 font-mono mb-3">{{ tag.slug }}</div>
    <div class="text-sm text-gray-600 mb-3">{{ tag.post_count }} article(s)</div>
    <div class="flex flex-wrap gap-2">
      <a href="{{ url('admin/tags/' ~ tag.id ~ '/edit') }}" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Éditer</a>
      <form method="POST" action="{{ url('admin/tags/' ~ tag.id ~ '/delete') }}" data-confirm="Supprimer ce tag ?">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
      </form>
    </div>
  </div>
  {% endfor %}
</div>

{# Desktop #}
<div class="hidden sm:block border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-black text-white">
      <tr>
        <th class="text-left px-4 py-3 font-black">Nom</th>
        <th class="text-left px-4 py-3 font-black">Slug</th>
        <th class="text-left px-4 py-3 font-black">Articles</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for tag in tags %}
      <tr class="border-t-2 border-gray-200 hover:bg-amber-50">
        <td class="px-4 py-3 font-semibold">{{ tag.name }}</td>
        <td class="px-4 py-3 text-gray-500 font-mono text-xs">{{ tag.slug }}</td>
        <td class="px-4 py-3 text-gray-600">{{ tag.post_count }}</td>
        <td class="px-4 py-3 flex gap-2 justify-end">
          <a href="{{ url('admin/tags/' ~ tag.id ~ '/edit') }}" class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Éditer</a>
          <form method="POST" action="{{ url('admin/tags/' ~ tag.id ~ '/delete') }}" data-confirm="Supprimer ce tag ?">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
          </form>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{% else %}
  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] text-center">
    <p class="text-gray-500 italic mb-4">Aucun tag créé pour le moment.</p>
    <p class="text-sm text-gray-600">Les tags seront créés automatiquement lors de l'import d'articles CanalBlog.</p>
  </div>
{% endif %}

{% endblock %}
