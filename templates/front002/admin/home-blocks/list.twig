{% extends 'admin/layout.twig' %}
{% block title %}Blocs page d'accueil{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-black">Blocs page d'accueil</h1>
  <a href="{{ url('admin/home-blocks/create') }}"
     class="border-4 border-black bg-usm-brown text-white font-black px-4 py-2 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    + Nouveau bloc
  </a>
</div>

<p class="text-sm text-gray-600 mb-6">
  Les blocs actifs sont affichés sur la page d'accueil dans l'ordre défini ci-dessous (du plus petit au plus grand).
</p>

{% if blocks|length %}

<form id="bulk-delete-form" method="POST" action="{{ url('admin/home-blocks/delete-bulk') }}">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  <div class="border-4 border-black bg-white p-3 mb-4 shadow-[4px_4px_0_#000] flex flex-wrap items-center justify-between gap-3">
    <div class="flex items-center gap-3">
      <label class="flex items-center gap-2 font-black text-sm cursor-pointer select-none">
        <input type="checkbox" id="select-all-blocks" class="w-5 h-5 cursor-pointer accent-black" />
        <span>Tout sélectionner</span>
      </label>
      <span id="selected-count-badge" class="hidden text-xs font-bold bg-amber-200 border border-black px-2 py-0.5 rounded-full">
        0 sélectionné(s)
      </span>
    </div>
    <div>
      <button type="submit" id="btn-bulk-delete" disabled class="border-2 border-red-600 bg-red-50 text-red-600 px-4 py-1.5 font-bold text-sm disabled:opacity-50 disabled:cursor-not-allowed hover:bg-red-600 hover:text-white transition cursor-pointer">
        🗑️ Supprimer la sélection (<span id="bulk-delete-count">0</span>)
      </button>
    </div>
  </div>

  {# ── Mobile : cartes empilées ── #}
  <div class="sm:hidden space-y-3">
    {% for block in blocks %}
    <div class="border-4 border-black bg-white p-4 shadow-[4px_4px_0_#000]">
      <div class="flex items-start gap-3 mb-2">
        <input type="checkbox" name="ids[]" value="{{ block.id }}" class="item-checkbox w-5 h-5 cursor-pointer accent-black mt-1" />
        {% if block.image %}
          <img src="{{ asset('uploads/' ~ block.image) }}" alt="" class="w-16 h-16 object-cover border-2 border-black flex-shrink-0">
        {% endif %}
        <div class="flex-1 min-w-0">
          <div class="font-black text-base mb-1 break-words">{{ block.titre }}</div>
          <div class="flex items-center gap-2 flex-wrap text-xs">
            {% if block.is_active %}
              <span class="bg-green-100 text-green-800 border border-green-400 px-2 py-0.5 font-bold rounded">Actif</span>
            {% else %}
              <span class="bg-gray-100 text-gray-600 border border-gray-400 px-2 py-0.5 font-bold rounded">Inactif</span>
            {% endif %}
            <span class="text-gray-500 font-mono">pos. {{ block.position }}</span>
          </div>
        </div>
      </div>
      {% if block.cta_label %}
        <div class="text-xs text-gray-600 mb-3">CTA&nbsp;: {{ block.cta_label }}</div>
      {% endif %}
      <div class="flex flex-wrap gap-2">
        <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/move-up') }}" class="inline">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
          <button type="submit" title="Monter" class="border-2 border-black w-8 h-8 text-xs font-bold hover:bg-black hover:text-white transition">▲</button>
        </form>
        <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/move-down') }}" class="inline">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
          <button type="submit" title="Descendre" class="border-2 border-black w-8 h-8 text-xs font-bold hover:bg-black hover:text-white transition">▼</button>
        </form>
        <a href="{{ url('admin/home-blocks/' ~ block.id ~ '/edit') }}"
           class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Éditer</a>
        <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/delete') }}" data-confirm="Supprimer ce bloc ?">
          <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
          <button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
        </form>
      </div>
    </div>
    {% endfor %}
  </div>

  {# ── Desktop : tableau ── #}
  <div class="hidden sm:block border-4 border-black bg-white shadow-[6px_6px_0_#000] overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-black text-white">
        <tr>
          <th class="w-10 px-4 py-3 text-center">
            <input type="checkbox" id="select-all-desktop" class="w-4 h-4 cursor-pointer accent-white" />
          </th>
          <th class="text-left px-4 py-3 font-black w-12">#</th>
          <th class="text-left px-4 py-3 font-black">Titre</th>
          <th class="text-left px-4 py-3 font-black">Image</th>
          <th class="text-left px-4 py-3 font-black">CTA</th>
          <th class="text-left px-4 py-3 font-black">Statut</th>
          <th class="text-left px-4 py-3 font-black">Ordre</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody>
        {% for block in blocks %}
        <tr class="border-t-2 border-gray-200 hover:bg-amber-50">
          <td class="px-4 py-3 text-center">
            <input type="checkbox" name="ids[]" value="{{ block.id }}" class="item-checkbox w-4 h-4 cursor-pointer accent-black" />
          </td>
          <td class="px-4 py-3 font-mono text-gray-400">{{ loop.index }}</td>
          <td class="px-4 py-3 font-semibold">{{ block.titre }}</td>
          <td class="px-4 py-3">
            {% if block.cover_photo %}
              <img src="{{ image_variant(block.cover_photo, 'medium') }}" alt="" class="w-16 h-12 object-cover border-2 border-black">
            {% else %}
              <span class="text-xs text-gray-400 italic">aucune</span>
            {% endif %}
          </td>
          <td class="px-4 py-3 text-xs text-gray-600">
            {% if block.cta_label %}{{ block.cta_label }}{% else %}<span class="italic text-gray-400">—</span>{% endif %}
          </td>
          <td class="px-4 py-3">
            {% if block.is_active %}
              <span class="bg-green-100 text-green-800 border border-green-400 px-2 py-0.5 text-xs font-bold rounded">Actif</span>
            {% else %}
              <span class="bg-gray-100 text-gray-600 border border-gray-400 px-2 py-0.5 text-xs font-bold rounded">Inactif</span>
            {% endif %}
          </td>
          <td class="px-4 py-3">
            <div class="flex items-center gap-2">
              <span class="font-mono text-xs text-gray-500">{{ block.position }}</span>
              <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/move-up') }}" class="inline">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <button type="submit" title="Monter"
                        class="border-2 border-black w-7 h-7 text-xs font-bold hover:bg-black hover:text-white transition">▲</button>
              </form>
              <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/move-down') }}" class="inline">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <button type="submit" title="Descendre"
                        class="border-2 border-black w-7 h-7 text-xs font-bold hover:bg-black hover:text-white transition">▼</button>
              </form>
            </div>
          </td>
          <td class="px-4 py-3 flex gap-2 justify-end">
            <a href="{{ url('admin/home-blocks/' ~ block.id ~ '/edit') }}"
               class="border-2 border-black px-2 py-1 text-xs font-bold hover:bg-black hover:text-white transition">Éditer</a>
            <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/delete') }}" data-confirm="Supprimer ce bloc ?">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
              <button type="submit" class="border-2 border-red-600 text-red-600 px-2 py-1 text-xs font-bold hover:bg-red-600 hover:text-white transition">Supprimer</button>
            </form>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</form>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const selectAllGlobal = document.getElementById('select-all-blocks');
  const selectAllDesktop = document.getElementById('select-all-desktop');
  const checkboxes = document.querySelectorAll('.item-checkbox');
  const btnBulkDelete = document.getElementById('btn-bulk-delete');
  const bulkDeleteCount = document.getElementById('bulk-delete-count');
  const selectedBadge = document.getElementById('selected-count-badge');
  const form = document.getElementById('bulk-delete-form');

  function updateState() {
    const checked = document.querySelectorAll('.item-checkbox:checked');
    const count = checked.length;
    const total = checkboxes.length;

    if (bulkDeleteCount) bulkDeleteCount.textContent = count;
    if (selectedBadge) {
      if (count > 0) {
        selectedBadge.textContent = count + ' sélectionné(s)';
        selectedBadge.classList.remove('hidden');
      } else {
        selectedBadge.classList.add('hidden');
      }
    }
    if (btnBulkDelete) btnBulkDelete.disabled = (count === 0);

    const allChecked = total > 0 && count === total;
    if (selectAllGlobal) selectAllGlobal.checked = allChecked;
    if (selectAllDesktop) selectAllDesktop.checked = allChecked;
  }

  function toggleAll(checked) {
    checkboxes.forEach(cb => { cb.checked = checked; });
    updateState();
  }

  if (selectAllGlobal) selectAllGlobal.addEventListener('change', function() { toggleAll(this.checked); });
  if (selectAllDesktop) selectAllDesktop.addEventListener('change', function() { toggleAll(this.checked); });

  checkboxes.forEach(cb => cb.addEventListener('change', updateState));

  if (form) {
    form.addEventListener('submit', function(e) {
      const count = document.querySelectorAll('.item-checkbox:checked').length;
      if (count === 0) {
        e.preventDefault();
        return;
      }
      if (!confirm('Voulez-vous vraiment supprimer les ' + count + ' bloc(s) sélectionné(s) ?')) {
        e.preventDefault();
      }
    });
  }
  updateState();
});
</script>

{% else %}
  <p class="text-gray-500 italic">Aucun bloc. <a href="{{ url('admin/home-blocks/create') }}" class="underline font-bold">Créez le premier</a>.</p>
{% endif %}
{% endblock %}
{% endblock %}
