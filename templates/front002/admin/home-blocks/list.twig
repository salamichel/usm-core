{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}Blocs page d'accueil{% endblock %}

{% block content %}

{# ── En-tête de page ── #}
{{ m.page_header('Blocs page d\'accueil', url('admin/home-blocks/create'), '+ Nouveau bloc') }}

<p class="text-sm text-slate-500 font-medium -mt-2 mb-6">
  Les blocs actifs sont affichés sur la page d'accueil dans l'ordre défini ci-dessous (du plus petit au plus grand).
</p>

{% if blocks|length %}

<form id="bulk-delete-form" method="POST" action="{{ url('admin/home-blocks/delete-bulk') }}">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  {# ── Barre de suppression en masse ── #}
  <div class="bg-white border border-slate-100 rounded-2xl shadow-sm p-4 mb-4 flex flex-wrap items-center justify-between gap-3">
    <label class="flex items-center gap-2.5 cursor-pointer select-none">
      <input type="checkbox" id="select-all-blocks" class="w-4 h-4 rounded border-slate-300 text-[#94674d] focus:ring-[#94674d]/30" />
      <span class="text-sm font-semibold text-slate-700">Tout sélectionner</span>
      <span id="selected-count-badge" class="hidden text-xs font-bold bg-[#94674d]/10 text-[#94674d] px-2.5 py-0.5 rounded-full">0 sélectionné(s)</span>
    </label>
    <button type="submit" id="btn-bulk-delete" disabled
            class="inline-flex items-center gap-1.5 bg-rose-50 border border-rose-200 text-rose-600 hover:bg-rose-100 px-3 py-1.5 text-xs font-bold rounded-lg transition disabled:opacity-40 disabled:cursor-not-allowed">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
      Supprimer la sélection (<span id="bulk-delete-count">0</span>)
    </button>
  </div>

  {# ── Mobile : cartes ── #}
  <div class="sm:hidden space-y-3">
    {% for block in blocks %}
    <div class="bg-white border border-slate-100 rounded-2xl shadow-sm p-4">
      <div class="flex items-start gap-3 mb-2">
        <input type="checkbox" name="ids[]" value="{{ block.id }}" class="item-checkbox w-4 h-4 rounded border-slate-300 text-[#94674d] focus:ring-[#94674d]/30 mt-1" />
        {% if block.cover_photo %}
          <img src="{{ image_variant(block.cover_photo, 'medium') }}" alt="" class="w-14 h-14 object-cover rounded-xl border border-slate-100 flex-shrink-0">
        {% endif %}
        <div class="flex-1 min-w-0">
          <div class="font-bold text-base text-slate-900 mb-1 flex items-center gap-2 flex-wrap">
            <span>{{ block.titre }}</span>
          </div>
          <div class="flex items-center gap-2 flex-wrap text-xs">
            {{ m.status_badge(block.is_active, 'Actif', 'Inactif') }}
            <span class="text-slate-400 font-mono text-[10px]">Pos. {{ block.position }}</span>
          </div>
        </div>
      </div>
      <div class="flex items-center justify-between pt-2 border-t border-slate-50 mt-3">
        <div class="flex gap-1">
          <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/move-up') }}" class="inline">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" title="Monter" class="bg-slate-100 hover:bg-slate-200 text-slate-700 w-7 h-7 rounded-lg text-xs font-bold transition">▲</button>
          </form>
          <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/move-down') }}" class="inline">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            <button type="submit" title="Descendre" class="bg-slate-100 hover:bg-slate-200 text-slate-700 w-7 h-7 rounded-lg text-xs font-bold transition">▼</button>
          </form>
        </div>
        {{ m.action_buttons(
          url('admin/home-blocks/' ~ block.id ~ '/edit'),
          url('admin/home-blocks/' ~ block.id ~ '/delete'),
          'Supprimer ce bloc ?',
          csrf_token
        ) }}
      </div>
    </div>
    {% endfor %}
  </div>

  {# ── Desktop : tableau ── #}
  <div class="hidden sm:block bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-slate-800 text-white">
        <tr>
          <th class="w-10 px-5 py-3.5 text-center">
            <input type="checkbox" id="select-all-desktop" class="w-4 h-4 rounded border-slate-600 bg-slate-700" />
          </th>
          <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider w-12">#</th>
          <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Titre</th>
          <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Image</th>
          <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">CTA</th>
          <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Statut</th>
          <th class="text-left px-5 py-3.5 font-bold text-xs uppercase tracking-wider">Ordre</th>
          <th class="px-5 py-3.5 text-right"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-50">
        {% for block in blocks %}
        <tr class="hover:bg-slate-50/70 transition duration-100">
          <td class="px-5 py-3.5 text-center">
            <input type="checkbox" name="ids[]" value="{{ block.id }}" class="item-checkbox w-4 h-4 rounded border-slate-300 text-[#94674d] focus:ring-[#94674d]/30" />
          </td>
          <td class="px-5 py-3.5 font-mono text-slate-400 text-xs">{{ loop.index }}</td>
          <td class="px-5 py-3.5 font-semibold text-slate-900">{{ block.titre }}</td>
          <td class="px-5 py-3.5">
            {% if block.cover_photo %}
              <img src="{{ image_variant(block.cover_photo, 'thumb') }}" alt="" class="w-14 h-10 object-cover rounded-lg border border-slate-100">
            {% else %}
              <span class="text-xs text-slate-400 italic">aucune</span>
            {% endif %}
          </td>
          <td class="px-5 py-3.5 text-xs font-semibold text-slate-600">
            {% if block.cta_label %}{{ block.cta_label }}{% else %}<span class="italic text-slate-300">—</span>{% endif %}
          </td>
          <td class="px-5 py-3.5">
            {{ m.status_badge(block.is_active, 'Actif', 'Inactif') }}
          </td>
          <td class="px-5 py-3.5">
            <div class="flex items-center gap-1.5">
              <span class="font-mono text-xs text-slate-500 font-semibold w-5">{{ block.position }}</span>
              <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/move-up') }}" class="inline">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <button type="submit" title="Monter"
                        class="bg-slate-100 hover:bg-slate-200 text-slate-700 w-6 h-6 rounded-md text-xs font-bold transition flex items-center justify-center">▲</button>
              </form>
              <form method="POST" action="{{ url('admin/home-blocks/' ~ block.id ~ '/move-down') }}" class="inline">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                <button type="submit" title="Descendre"
                        class="bg-slate-100 hover:bg-slate-200 text-slate-700 w-6 h-6 rounded-md text-xs font-bold transition flex items-center justify-center">▼</button>
              </form>
            </div>
          </td>
          <td class="px-5 py-3.5 text-right">
            {{ m.action_buttons(
              url('admin/home-blocks/' ~ block.id ~ '/edit'),
              url('admin/home-blocks/' ~ block.id ~ '/delete'),
              'Supprimer ce bloc ?',
              csrf_token
            ) }}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</form>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const selectAllGlobal = document.getElementById('select-all-blocks');
  const selectAllDesktop = document.getElementById('select-all-desktop');
  const checkboxes = document.querySelectorAll('.item-checkbox');
  const btnBulkDelete = document.getElementById('btn-bulk-delete');
  const bulkDeleteCount = document.getElementById('bulk-delete-count');
  const selectedBadge = document.getElementById('selected-count-badge');
  const form = document.getElementById('bulk-delete-form');

  function updateState() {
    const checked = document.querySelectorAll('.item-checkbox:checked');
    const count = checked.length;
    const total = checkboxes.length;
    if (bulkDeleteCount) bulkDeleteCount.textContent = count;
    if (selectedBadge) {
      selectedBadge.textContent = count + ' sélectionné(s)';
      selectedBadge.classList.toggle('hidden', count === 0);
    }
    if (btnBulkDelete) btnBulkDelete.disabled = (count === 0);
    const allChecked = total > 0 && count === total;
    if (selectAllGlobal) selectAllGlobal.checked = allChecked;
    if (selectAllDesktop) selectAllDesktop.checked = allChecked;
  }

  function toggleAll(checked) { checkboxes.forEach(cb => { cb.checked = checked; }); updateState(); }

  if (selectAllGlobal) selectAllGlobal.addEventListener('change', function() { toggleAll(this.checked); });
  if (selectAllDesktop) selectAllDesktop.addEventListener('change', function() { toggleAll(this.checked); });
  checkboxes.forEach(cb => cb.addEventListener('change', updateState));

  if (form) {
    form.addEventListener('submit', function(e) {
      const count = document.querySelectorAll('.item-checkbox:checked').length;
      if (count === 0) { e.preventDefault(); return; }
      if (!confirm('Supprimer les ' + count + ' bloc(s) sélectionné(s) ?')) { e.preventDefault(); }
    });
  }
  updateState();
});
</script>

{% else %}
  {{ m.empty_state('Aucun bloc sur la page d\'accueil.', url('admin/home-blocks/create'), '+ Nouveau bloc') }}
{% endif %}
{% endblock %}
