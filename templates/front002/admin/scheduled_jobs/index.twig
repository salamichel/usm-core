{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}

{% block title %}Tâches planifiées & Traces (Lazy Cron){% endblock %}

{% block content %}

{# ── En-tête avec breadcrumb ── #}
<div class="relative overflow-hidden bg-slate-900 rounded-3xl p-6 md:p-8 text-white shadow-sm mb-8">
  <div class="relative flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <nav class="flex items-center gap-1.5 text-xs text-slate-400 font-medium mb-2">
        <a href="{{ url('admin') }}" class="hover:text-white transition">Admin</a>
        <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <span class="text-slate-200">Lazy Cron</span>
      </nav>
      <h1 class="text-2xl font-black tracking-tight">⏱️ Tâches planifiées & Traces</h1>
      <p class="text-xs text-slate-400 font-medium mt-1">Programmation d'actions et journal détaillé des exécutions (logs) pour InfinityFree.</p>
    </div>

    <form method="POST" action="{{ url('admin/scheduled-jobs/run-now') }}">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
      <button type="submit"
              class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-bold px-4 py-2.5 rounded-xl transition text-xs shadow-sm whitespace-nowrap">
        ⚡ Forcer l'exécution maintenant
      </button>
    </form>
  </div>
</div>

<div class="space-y-8">
  {# Statuts et Résumé #}
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
      <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Dernière exécution</div>
      <div class="text-base font-bold text-slate-900 mt-2 font-mono">{{ last_execution }}</div>
    </div>
    <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
      <div class="text-[10px] font-bold text-amber-600 uppercase tracking-wider">En attente (pending)</div>
      <div class="text-2xl font-black text-amber-700 mt-1">{{ counts.pending }}</div>
    </div>
    <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
      <div class="text-[10px] font-bold text-emerald-600 uppercase tracking-wider">Terminées (completed)</div>
      <div class="text-2xl font-black text-emerald-700 mt-1">{{ counts.completed }}</div>
    </div>
    <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
      <div class="text-[10px] font-bold text-rose-600 uppercase tracking-wider">Échouées (failed)</div>
      <div class="text-2xl font-black text-rose-700 mt-1">{{ counts.failed }}</div>
    </div>
  </div>

  {# Formulaire de programmation d'une nouvelle tâche #}
  <div class="bg-white border border-slate-100 rounded-3xl p-6 md:p-8 shadow-sm space-y-6">
    <h2 class="font-bold text-base text-slate-800 border-b border-slate-100 pb-3">➕ Programmer une nouvelle tâche</h2>

    <form method="POST" action="{{ url('admin/scheduled-jobs') }}" class="space-y-6">
      <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <label for="action" class="block text-sm font-bold text-slate-700 mb-1.5">Type d'action *</label>
          <select id="action" name="action" required class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
            {% for key, label in actions_map %}
              <option value="{{ key }}">{{ label }} ({{ key }})</option>
            {% endfor %}
          </select>
        </div>

        <div>
          <label for="frequency" class="block text-sm font-bold text-slate-700 mb-1.5">Fréquence d'exécution *</label>
          <select id="frequency" name="frequency" required class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
            {% for key, label in frequencies_map %}
              <option value="{{ key }}">{{ label }}</option>
            {% endfor %}
          </select>
        </div>

        <div>
          <label for="execute_at" class="block text-sm font-bold text-slate-700 mb-1.5">Date & Heure de début *</label>
          <input type="datetime-local" id="execute_at" name="execute_at" value="{{ default_execute_at }}" required class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="end_at" class="block text-sm font-bold text-slate-700 mb-1.5">Date & Heure de fin (optionnel)</label>
          <input type="datetime-local" id="end_at" name="end_at" class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
          <p class="text-xs text-slate-400 font-medium mt-1">Laissez vide pour une récurrence indéfinie.</p>
        </div>

        <div>
          <label for="payload" class="block text-sm font-bold text-slate-700 mb-1.5">Paramètres JSON (optionnel)</label>
          <textarea id="payload" name="payload" rows="2" placeholder='{"event_id": 42, "team_id": 3}' class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-mono text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition"></textarea>
        </div>
      </div>

      <div class="pt-2">
        {{ m.btn_submit('Planifier l\'action') }}
      </div>
    </form>
  </div>

  {# Tableau 1 : File d'attente & Tâches planifiées #}
  <div class="bg-white border border-slate-100 rounded-3xl shadow-sm overflow-hidden">
    <div class="p-5 border-b border-slate-100 flex items-center justify-between">
      <h2 class="text-base font-bold text-slate-900">📋 Tâches programmées</h2>
      <span class="text-xs font-bold text-slate-400 bg-slate-50 px-3 py-1 rounded-full">{{ jobs|length }} tâche(s)</span>
    </div>

    {% if jobs is empty %}
      <div class="p-6">
        {{ m.empty_state('Aucune tâche planifiée en base de données.') }}
      </div>
    {% else %}
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead class="bg-slate-800 text-white font-bold uppercase text-xs">
            <tr>
              <th class="px-5 py-3.5">ID</th>
              <th class="px-5 py-3.5">Action & Fréquence</th>
              <th class="px-5 py-3.5">Prochain passage</th>
              <th class="px-5 py-3.5">Date de fin</th>
              <th class="px-5 py-3.5">Statut & Dernier passage</th>
              <th class="px-5 py-3.5">Détails / Erreur</th>
              <th class="px-5 py-3.5 text-right"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            {% for job in jobs %}
              <tr class="hover:bg-slate-50/70 transition duration-100">
                <td class="px-5 py-3.5 font-mono text-xs text-slate-400">#{{ job.id }}</td>
                <td class="px-5 py-3.5">
                  <div class="font-semibold text-slate-900">{{ actions_map[job.action] | default(job.action) }}</div>
                  <div class="mt-1 flex items-center gap-2">
                    <span class="bg-slate-100 text-slate-600 text-[10px] font-bold px-2 py-0.5 rounded-md border border-slate-200">
                      🔄 {{ frequencies_map[job.frequency] | default(job.frequency) }}
                    </span>
                  </div>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <div class="font-semibold text-slate-900 text-xs">{{ job.execute_at | date('d/m/Y à H:i') }}</div>
                  <div class="text-[10px] text-slate-400">Créé le {{ job.created_at | date('d/m/Y H:i') }}</div>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-xs text-slate-500">
                  {% if job.end_at %}
                    <div>{{ job.end_at | date('d/m/Y à H:i') }}</div>
                  {% else %}
                    <span class="text-slate-300 italic">Illimitée</span>
                  {% endif %}
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <div>
                    {% if job.status == 'pending' %}
                      <span class="bg-amber-50 text-amber-700 border border-amber-200 px-2 py-0.5 text-[10px] font-bold rounded-full">En attente</span>
                    {% elseif job.status == 'running' %}
                      <span class="bg-sky-50 text-sky-700 border border-sky-200 px-2 py-0.5 text-[10px] font-bold rounded-full animate-pulse">En cours...</span>
                    {% elseif job.status == 'completed' %}
                      <span class="bg-emerald-50 text-emerald-700 border border-emerald-200 px-2 py-0.5 text-[10px] font-bold rounded-full">Terminée</span>
                    {% else %}
                      <span class="bg-rose-50 text-rose-700 border border-rose-200 px-2 py-0.5 text-[10px] font-bold rounded-full">Échouée</span>
                    {% endif %}
                  </div>
                  {% if job.last_run_at %}
                    <div class="text-[10px] text-slate-400 font-mono mt-1">Dernier : {{ job.last_run_at | date('d/m/Y H:i') }}</div>
                  {% endif %}
                </td>
                <td class="px-5 py-3.5 max-w-xs">
                  {% if job.payload and job.payload != '{}' %}
                    <div class="text-[10px] font-mono bg-slate-50 border border-slate-100 p-1.5 rounded-lg truncate" title="{{ job.payload }}">
                      {{ job.payload }}
                    </div>
                  {% endif %}
                  {% if job.error_message %}
                    <div class="text-[10px] font-mono text-rose-600 bg-rose-50 p-1.5 rounded-lg mt-1 border border-rose-200">
                      {{ job.error_message }}
                    </div>
                  {% endif %}
                </td>
                <td class="px-5 py-3.5 text-right whitespace-nowrap">
                  <form method="POST" action="{{ url('admin/scheduled-jobs/' ~ job.id ~ '/delete') }}" data-confirm="Supprimer cette tâche planifiée ?">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                    <button type="submit" class="bg-rose-50 border border-rose-200 text-rose-600 hover:bg-rose-100 px-2.5 py-1 text-xs font-bold rounded-lg transition">
                      Supprimer
                    </button>
                  </form>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>

  {# Tableau 2 : Journal & Traces d'exécution #}
  <div class="bg-white border border-slate-100 rounded-3xl shadow-sm overflow-hidden">
    <div class="p-5 border-b border-slate-100 flex items-center justify-between">
      <h2 class="text-base font-bold text-slate-900 flex items-center gap-2">📜 Journal des exécutions (Traces)</h2>
      <span class="text-xs font-bold text-slate-400 bg-slate-50 px-3 py-1 rounded-full">{{ logs|length }} trace(s)</span>
    </div>

    {% if logs is empty %}
      <div class="p-6">
        {{ m.empty_state('Aucune trace d\'exécution enregistrée pour le moment.') }}
      </div>
    {% else %}
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead class="bg-slate-800 text-white font-bold uppercase text-xs">
            <tr>
              <th class="px-5 py-3.5">Horodatage</th>
              <th class="px-5 py-3.5">Action & Tâche</th>
              <th class="px-5 py-3.5">Résultat</th>
              <th class="px-5 py-3.5">Durée</th>
              <th class="px-5 py-3.5">Compte-rendu / Message</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50">
            {% for log in logs %}
              <tr class="hover:bg-slate-50/70 transition duration-100">
                <td class="px-5 py-3.5 whitespace-nowrap font-mono text-xs text-slate-400">
                  {{ log.executed_at | date('d/m/Y à H:i:s') }}
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="font-semibold text-slate-900 text-xs">{{ actions_map[log.action] | default(log.action) }}</span>
                  {% if log.job_id %}
                    <span class="text-[10px] font-mono text-slate-400 ml-1">(Job #{{ log.job_id }})</span>
                  {% else %}
                    <span class="text-[10px] italic text-slate-400 ml-1">(Direct)</span>
                  {% endif %}
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  {% if log.status == 'success' %}
                    <span class="bg-emerald-50 text-emerald-700 border border-emerald-200 px-2 py-0.5 text-[10px] font-bold rounded-full">
                      ✓ Succès
                    </span>
                  {% else %}
                    <span class="bg-rose-50 text-rose-700 border border-rose-200 px-2 py-0.5 text-[10px] font-bold rounded-full">
                      ✕ Échec
                    </span>
                  {% endif %}
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap font-mono text-xs text-slate-500">
                  ⚡ {{ log.duration_ms }} ms
                </td>
                <td class="px-5 py-3.5">
                  <div class="text-xs font-mono text-slate-600 leading-relaxed">
                    {{ log.details | default('—') }}
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
</div>
{% endblock %}
