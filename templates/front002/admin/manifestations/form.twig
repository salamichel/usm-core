{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}{{ manifestation ? 'Éditer' : 'Créer' }} une manifestation{% endblock %}

{% block content %}

{# ── En-tête avec breadcrumb ── #}
<div class="relative overflow-hidden bg-slate-900 rounded-3xl p-6 md:p-8 text-white shadow-sm mb-8">
  <div class="relative">
    <nav class="flex items-center gap-1.5 text-xs text-slate-400 font-medium mb-2">
      <a href="{{ url('admin') }}" class="hover:text-white transition">Admin</a>
      <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      <a href="{{ url('admin/manifestations') }}" class="hover:text-white transition">Manifestations</a>
      <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      <span class="text-slate-200">{{ manifestation ? 'Éditer' : 'Nouvelle manifestation' }}</span>
    </nav>
    <h1 class="text-2xl font-black tracking-tight">
      {{ manifestation ? 'Éditer la manifestation' : 'Nouvelle manifestation' }}
    </h1>
  </div>
</div>

{{ m.form_error(error) }}

<form method="POST" action="{{ action }}" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  <div class="bg-white border border-slate-100 rounded-3xl shadow-sm p-6 md:p-8 space-y-6">
    <h2 class="font-bold text-base text-slate-800 border-b border-slate-100 pb-3">Détails de la manifestation</h2>

    <div class="grid sm:grid-cols-2 gap-6">
      {# Type de manifestation #}
      <div class="sm:col-span-2">
        <label class="block text-sm font-bold text-slate-700 mb-1.5" for="manifestation_type">Type de manifestation *</label>
        <select id="manifestation_type" name="manifestation_type" required
                class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
          <option value="">-- Sélectionner un type --</option>
          {% for type in types %}
            <option value="{{ type }}" {{ manifestation.manifestation_type == type ? 'selected' : '' }}>{{ type }}</option>
          {% endfor %}
        </select>
      </div>

      {# Date #}
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5" for="date">Date & Heure *</label>
        <input type="datetime-local" id="date" name="date" required
               value="{{ manifestation.date ?? '' }}"
               class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
      </div>

      {# Durée #}
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5" for="duration">Durée *</label>
        <select id="duration" name="duration" required
                class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
          <option value="">-- Sélectionner une durée --</option>
          {% for dur in durations %}
            <option value="{{ dur }}" {{ manifestation.duration == dur ? 'selected' : '' }}>{{ dur }}</option>
          {% endfor %}
        </select>
      </div>

      {# Lieu #}
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5" for="location">Lieu *</label>
        <select id="location" name="location" required
                class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
          <option value="">-- Sélectionner un lieu --</option>
          {% for loc in locations %}
            <option value="{{ loc }}" {{ manifestation.location == loc ? 'selected' : '' }}>{{ loc }}</option>
          {% endfor %}
        </select>
      </div>

      {# Nombre de terrains #}
      <div>
        {{ m.field_input('nombre_terrain', 'nombre_terrain', 'Nombre de terrains', manifestation.nombre_terrain ?? 1, 'number', true) }}
      </div>

      {# Statut #}
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5" for="statut">Statut *</label>
        <select id="statut" name="statut" required
                class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
          {% for status in statuses %}
            <option value="{{ status }}" {{ (manifestation.statut ?? 'Confirmé') == status ? 'selected' : '' }}>{{ status }}</option>
          {% endfor %}
        </select>
      </div>

      {# Commentaire #}
      <div class="sm:col-span-2">
        {{ m.field_textarea('commentaire', 'commentaire', 'Commentaire (optionnel)', manifestation.commentaire ?? '', 3, false, 'Ex: Contre Pessac...') }}
      </div>

      {# Notification Email #}
      {% if not manifestation or not manifestation.id %}
      <div class="sm:col-span-2 pt-2 border-t border-slate-50">
        {{ m.field_checkbox('send_notification_email', 'send_notification_email', 'Envoyer une notification par e-mail aux abonnés', manifestation is null or manifestation.send_notification_email, '1') }}
      </div>
      {% endif %}
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2">
    {{ m.btn_submit(manifestation ? 'Mettre à jour' : 'Créer la manifestation') }}
    <a href="{{ url('admin/manifestations') }}"
       class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-slate-700 transition">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
      Annuler
    </a>
  </div>
</form>
{% endblock %}
