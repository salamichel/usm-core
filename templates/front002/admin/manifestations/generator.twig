{% extends 'admin/layout.twig' %}
{% block title %}Générer des entraînements{% endblock %}

{% block content %}
<div class="flex items-center gap-4 mb-6">
  <a href="{{ url('admin') }}" class="font-bold hover:underline text-sm">&larr; Dashboard</a>
  <h1 class="text-3xl font-black">Générer des entraînements hebdomadaires</h1>
</div>

{% if error %}
  <div class="border-2 border-red-600 bg-red-50 text-red-700 p-3 mb-6 font-semibold text-sm rounded">{{ error }}</div>
{% endif %}

<p class="text-sm text-gray-600 mb-6">
  Cet outil permet de planifier des entraînements de façon récurrente sur une période définie. Les événements seront insérés chaque semaine dans l'agenda de la base externe.
</p>

<form method="POST" action="{{ url('admin/manifestations/generator') }}" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-6">
    <h2 class="font-black text-lg">Paramètres de génération</h2>

    <div class="grid sm:grid-cols-2 gap-6">
      {# Type de manifestation #}
      <div class="sm:col-span-2">
        <label class="block font-black mb-1" for="manifestation_type">Type d'entraînement *</label>
        <select id="manifestation_type" name="manifestation_type" required class="w-full border-2 border-black px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-usm-brown font-semibold">
          <option value="">-- Sélectionner un type d'entraînement --</option>
          {% for type in trainingTypes %}
            <option value="{{ type }}" {{ data.manifestation_type == type ? 'selected' : '' }}>{{ type }}</option>
          {% endfor %}
        </select>
        <div class="text-xs text-gray-500 mt-1">Sélectionnez le type d'entraînement à planifier (mots-clés de catégorie ManifestationTypée contenant "Entrainement").</div>
      </div>

      {# Date Début #}
      <div>
        <label class="block font-black mb-1" for="date_debut">Premier entraînement (Date & Heure) *</label>
        <input type="datetime-local" id="date_debut" name="date_debut" required
               value="{{ data.date_debut ?? '' }}"
               class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
        <div class="text-xs text-gray-500 mt-1">Date et heure du premier entraînement de la série.</div>
      </div>

      {# Date Fin #}
      <div>
        <label class="block font-black mb-1" for="date_fin">Fin de la période (Date limite) *</label>
        <input type="date" id="date_fin" name="date_fin" required
               value="{{ data.date_fin ?? '' }}"
               class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
        <div class="text-xs text-gray-500 mt-1">Date limite de génération (les entraînements suivants ne seront pas créés).</div>
      </div>

      {# Lieu #}
      <div>
        <label class="block font-black mb-1" for="location">Lieu *</label>
        <select id="location" name="location" required class="w-full border-2 border-black px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-usm-brown font-semibold">
          <option value="">-- Sélectionner un lieu --</option>
          {% for loc in locations %}
            <option value="{{ loc }}" {{ data.location == loc ? 'selected' : '' }}>{{ loc }}</option>
          {% endfor %}
        </select>
        <div class="text-xs text-gray-500 mt-1">Lieu de déroulement de l'entraînement.</div>
      </div>

      {# Durée #}
      <div>
        <label class="block font-black mb-1" for="duration">Durée *</label>
        <select id="duration" name="duration" required class="w-full border-2 border-black px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-usm-brown font-semibold">
          <option value="">-- Sélectionner une durée --</option>
          {% for dur in durations %}
            <option value="{{ dur }}" {{ data.duration == dur ? 'selected' : '' }}>{{ dur }}</option>
          {% endfor %}
        </select>
        <div class="text-xs text-gray-500 mt-1">Durée du créneau de réservation.</div>
      </div>

      {# Nombre de terrains #}
      <div>
        <label class="block font-black mb-1" for="nombre_terrain">Nombre de terrains *</label>
        <input type="number" id="nombre_terrain" name="nombre_terrain" min="0" required
               value="{{ data.nombre_terrain ?? 1 }}"
               class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">
        <div class="text-xs text-gray-500 mt-1">Nombre de terrains alloués à l'entraînement (min 0).</div>
      </div>

      {# Statut #}
      <div>
        <label class="block font-black mb-1" for="statut">Statut *</label>
        <select id="statut" name="statut" required class="w-full border-2 border-black px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-usm-brown font-semibold">
          {% for status in statuses %}
            <option value="{{ status }}" {{ data.statut == status ? 'selected' : '' }}>{{ status }}</option>
          {% endfor %}
        </select>
        <div class="text-xs text-gray-500 mt-1">Statut initial de la série d'entraînements.</div>
      </div>

      {# Commentaire #}
      <div class="sm:col-span-2">
        <label class="block font-black mb-1" for="commentaire">Commentaire (optionnel)</label>
        <textarea id="commentaire" name="commentaire" rows="3"
                  placeholder="Ex: Entraînement habituel..."
                  class="w-full border-2 border-black px-3 py-2 focus:outline-none focus:ring-2 focus:ring-usm-brown">{{ data.commentaire ?? '' }}</textarea>
        <div class="text-xs text-gray-500 mt-1">Commentaire ou consigne visible par les joueurs.</div>
      </div>
    </div>
  </div>

  <button type="submit"
          class="border-4 border-black bg-usm-brown text-white font-black px-8 py-3 shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
    Générer la série d'entraînements
  </button>
</form>
{% endblock %}
