{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}Générer des entraînements{% endblock %}

{% block content %}

{# ── En-tête avec breadcrumb ── #}
<div class="relative overflow-hidden bg-slate-900 rounded-3xl p-6 md:p-8 text-white shadow-sm mb-8">
  <div class="relative">
    <nav class="flex items-center gap-1.5 text-xs text-slate-400 font-medium mb-2">
      <a href="{{ url('admin') }}" class="hover:text-white transition">Admin</a>
      <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      <a href="{{ url('admin/manifestations') }}" class="hover:text-white transition">Manifestations</a>
      <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      <span class="text-slate-200">Générateur récurrent</span>
    </nav>
    <h1 class="text-2xl font-black tracking-tight">
      Générer des entraînements hebdomadaires
    </h1>
  </div>
</div>

{{ m.form_error(error) }}

<p class="text-sm text-slate-500 font-medium -mt-2 mb-6">
  Cet outil permet de planifier des entraînements de façon récurrente sur une période définie. Les événements seront insérés chaque semaine dans l'agenda de la base externe.
</p>

<form method="POST" action="{{ url('admin/manifestations/generator') }}" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  <div class="bg-white border border-slate-100 rounded-3xl shadow-sm p-6 md:p-8 space-y-6">
    <h2 class="font-bold text-base text-slate-800 border-b border-slate-100 pb-3">Paramètres de génération</h2>

    <div class="grid sm:grid-cols-2 gap-6">
      {# Type #}
      <div class="sm:col-span-2">
        <label class="block text-sm font-bold text-slate-700 mb-1.5" for="manifestation_type">Type d'entraînement *</label>
        <select id="manifestation_type" name="manifestation_type" required
                class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
          <option value="">-- Sélectionner un type d'entraînement --</option>
          {% for type in trainingTypes %}
            <option value="{{ type }}" {{ data.manifestation_type == type ? 'selected' : '' }}>{{ type }}</option>
          {% endfor %}
        </select>
      </div>

      {# Date Début #}
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5" for="date_debut">Premier entraînement (Date & Heure) *</label>
        <input type="datetime-local" id="date_debut" name="date_debut" required
               value="{{ data.date_debut ?? '' }}"
               class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
      </div>

      {# Date Fin #}
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5" for="date_fin">Fin de la période (Date limite) *</label>
        <input type="date" id="date_fin" name="date_fin" required
               value="{{ data.date_fin ?? '' }}"
               class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
      </div>

      {# Lieu #}
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5" for="location">Lieu *</label>
        <select id="location" name="location" required
                class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
          <option value="">-- Sélectionner un lieu --</option>
          {% for loc in locations %}
            <option value="{{ loc }}" {{ data.location == loc ? 'selected' : '' }}>{{ loc }}</option>
          {% endfor %}
        </select>
      </div>

      {# Durée #}
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5" for="duration">Durée *</label>
        <select id="duration" name="duration" required
                class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
          <option value="">-- Sélectionner une durée --</option>
          {% for dur in durations %}
            <option value="{{ dur }}" {{ data.duration == dur ? 'selected' : '' }}>{{ dur }}</option>
          {% endfor %}
        </select>
      </div>

      {# Nombre de terrains #}
      <div>
        {{ m.field_input('nombre_terrain', 'nombre_terrain', 'Nombre de terrains', data.nombre_terrain ?? 1, 'number', true) }}
      </div>

      {# Statut #}
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-1.5" for="statut">Statut *</label>
        <select id="statut" name="statut" required
                class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
          {% for status in statuses %}
            <option value="{{ status }}" {{ data.statut == status ? 'selected' : '' }}>{{ status }}</option>
          {% endfor %}
        </select>
      </div>

      {# Commentaire #}
      <div class="sm:col-span-2">
        {{ m.field_textarea('commentaire', 'commentaire', 'Commentaire (optionnel)', data.commentaire ?? '', 3, false, 'Ex: Entraînement habituel...') }}
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3 pt-2">
    {{ m.btn_submit('Générer la série d\'entraînements') }}
    <a href="{{ url('admin/manifestations') }}"
       class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-slate-700 transition">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
      Annuler
    </a>
  </div>
</form>
{% endblock %}
