{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}Statistiques de visites{% endblock %}

{% block content %}

{# ── En-tête de page ── #}
<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl md:text-3xl font-black tracking-tight text-slate-900">Statistiques de visites</h1>
    {% if last_updated %}
      <p class="text-xs text-slate-400 font-medium mt-1">
        Dernière mise à jour : {{ last_updated|date('H:i:s') }} (mise en cache 15 min)
      </p>
    {% endif %}
  </div>

  <div class="flex flex-wrap items-center gap-2.5">
    {% if not not_configured %}
      <a href="{{ url('admin/stats?period=' ~ current_period ~ '&force_refresh=1') }}"
         class="inline-flex items-center gap-1.5 bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 font-bold px-3.5 py-2 text-xs rounded-xl transition shadow-sm">
        🔄 Actualiser
      </a>
    {% endif %}
    <a href="{{ url('admin/site-config') }}"
       class="inline-flex items-center gap-1.5 bg-[#94674d] hover:bg-[#7a5540] text-white font-bold px-3.5 py-2 text-xs rounded-xl transition shadow-sm">
      ⚙️ Configurer GA4
    </a>
  </div>
</div>

{# ── Sélecteur de période ── #}
<div class="flex bg-white border border-slate-100 rounded-2xl p-1.5 shadow-sm mb-6 overflow-x-auto">
  {% for key, p in periods %}
    <a href="{{ url('admin/stats?period=' ~ key) }}"
       class="px-4 py-2 font-bold text-xs rounded-xl whitespace-nowrap transition-all duration-150 {{ current_period == key ? 'bg-slate-900 text-white shadow-sm' : 'text-slate-600 hover:bg-slate-50' }}">
      {{ p.label }}
    </a>
  {% endfor %}
</div>

{# ── Écran : Non Configuré ── #}
{% if not_configured %}
  <div class="bg-white border border-slate-100 rounded-3xl p-6 md:p-8 shadow-sm space-y-6">
    <div class="flex items-center gap-3">
      <span class="text-3xl">📈</span>
      <h2 class="text-xl font-bold text-slate-900">Google Analytics n'est pas encore configuré</h2>
    </div>

    <p class="text-sm text-slate-600 leading-relaxed font-medium">
      Pour afficher les statistiques de fréquentation du site directement dans cette administration, vous devez configurer la liaison API avec Google Analytics 4 (GA4).
    </p>

    <div class="border-t border-slate-100 pt-6">
      <h3 class="font-bold text-sm text-slate-800 mb-4">Étapes de configuration :</h3>
      <ol class="space-y-3 text-xs font-medium text-slate-600 list-decimal pl-5">
        <li class="pl-2">Activer l'API <strong class="text-slate-900 font-semibold">Google Analytics Data API (v1beta)</strong> sur votre console Google Cloud.</li>
        <li class="pl-2">Créer un <strong class="text-slate-900 font-semibold">Compte de Service</strong> sur Google Cloud, puis télécharger sa clé au format JSON.</li>
        <li class="pl-2">Ajouter l'adresse du compte de service en tant que <strong class="text-slate-900 font-semibold">Lecteur</strong> dans GA4 (Gestion des accès).</li>
        <li class="pl-2">Récupérer votre <strong class="text-slate-900 font-semibold">ID de propriété GA4</strong>.</li>
        <li class="pl-2">Saisir ces informations dans la page de configuration du site.</li>
      </ol>
    </div>

    <div class="pt-2">
      <a href="{{ url('admin/site-config') }}"
         class="inline-flex items-center gap-2 bg-[#94674d] hover:bg-[#7a5540] text-white px-5 py-2.5 font-bold text-xs rounded-xl transition shadow-sm">
        Accéder à la configuration →
      </a>
    </div>
  </div>

{# ── Écran : Erreur ── #}
{% elseif error %}
  <div class="bg-rose-50 border border-rose-200 rounded-3xl p-6 shadow-sm space-y-3">
    <div class="flex items-center gap-2 text-rose-700 font-bold text-base">
      <span>⚠️</span> Erreur de connexion GA4
    </div>
    <p class="text-xs text-rose-800 leading-relaxed font-medium">{{ error }}</p>
    <div class="pt-2">
      <a href="{{ url('admin/site-config') }}" class="text-xs font-bold text-rose-700 underline">
        Vérifier les paramètres de configuration
      </a>
    </div>
  </div>

{# ── Écran : Dashboard ── #}
{% else %}
  <div class="space-y-8">
    {# ── KPIs ── #}
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
        <div class="flex justify-between items-start">
          <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Visiteurs uniques</span>
          <span class="text-base">👥</span>
        </div>
        <div class="text-2xl font-black text-slate-900 mt-2">{{ stats.totals.users|number_format(0, ',', ' ') }}</div>
        <p class="text-[10px] font-bold text-sky-600 mt-1">Utilisateurs actifs</p>
      </div>

      <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
        <div class="flex justify-between items-start">
          <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Sessions</span>
          <span class="text-base">🔑</span>
        </div>
        <div class="text-2xl font-black text-slate-900 mt-2">{{ stats.totals.sessions|number_format(0, ',', ' ') }}</div>
        <p class="text-[10px] font-bold text-amber-600 mt-1">Visites totales</p>
      </div>

      <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
        <div class="flex justify-between items-start">
          <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Pages vues</span>
          <span class="text-base">📄</span>
        </div>
        <div class="text-2xl font-black text-slate-900 mt-2">{{ stats.totals.views|number_format(0, ',', ' ') }}</div>
        <p class="text-[10px] font-bold text-emerald-600 mt-1">Total affichages</p>
      </div>

      <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
        <div class="flex justify-between items-start">
          <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Durée moyenne</span>
          <span class="text-base">⏱️</span>
        </div>
        <div class="text-2xl font-black text-slate-900 mt-2 font-mono text-xl">{{ stats.totals.duration }}</div>
        <p class="text-[10px] font-bold text-purple-600 mt-1">Temps par visite</p>
      </div>

      <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm col-span-2 sm:col-span-1">
        <div class="flex justify-between items-start">
          <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Taux de rebond</span>
          <span class="text-base">☄️</span>
        </div>
        <div class="text-2xl font-black text-slate-900 mt-2">{{ stats.totals.bounce_rate }} %</div>
        <p class="text-[10px] font-bold text-rose-600 mt-1">Visites d'une page</p>
      </div>
    </div>

    {# ── Graphique ── #}
    <div class="bg-white border border-slate-100 rounded-3xl p-6 md:p-8 shadow-sm">
      <h2 class="text-base font-bold text-slate-900 mb-0.5">Tendance de l'audience</h2>
      <p class="text-xs text-slate-400 font-medium mb-4">Évolution journalière des pages vues et des visiteurs uniques</p>

      <div class="h-80 w-full relative">
        <canvas id="trendChart"></canvas>
      </div>
    </div>

    <div class="grid lg:grid-cols-12 gap-8">
      {# ── Top Pages ── #}
      <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm lg:col-span-7">
        <h2 class="text-base font-bold text-slate-900 mb-0.5">Pages les plus consultées</h2>
        <p class="text-xs text-slate-400 font-medium mb-4">Top 15 des pages générant le plus d'audience</p>

        <div class="overflow-x-auto">
          <table class="w-full text-left text-xs">
            <thead>
              <tr class="border-b border-slate-100 text-slate-400 font-bold uppercase tracking-wider">
                <th class="py-2.5">Page</th>
                <th class="py-2.5 px-3 text-right">Vues</th>
                <th class="py-2.5 px-3 text-right">Visiteurs</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50 font-medium text-slate-700">
              {% for page in stats.pages %}
                <tr class="hover:bg-slate-50/70 transition">
                  <td class="py-2.5 max-w-[240px] truncate">
                    <span class="block text-slate-900 font-semibold truncate" title="{{ page.title }}">
                      {{ page.title|default('—') }}
                    </span>
                    <a href="{{ page.path }}" target="_blank" class="text-[10px] text-slate-400 font-mono hover:underline">
                      {{ page.path }}
                    </a>
                  </td>
                  <td class="py-2.5 px-3 text-right text-slate-900 font-bold">
                    {{ page.views|number_format(0, ',', ' ') }}
                  </td>
                  <td class="py-2.5 px-3 text-right text-slate-400">
                    {{ page.users|number_format(0, ',', ' ') }}
                  </td>
                </tr>
              {% else %}
                <tr><td colspan="3" class="py-4 text-center text-slate-400">Aucune donnée</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

      {# ── Canaux & Appareils ── #}
      <div class="space-y-6 lg:col-span-5">
        {# Sources #}
        <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm space-y-4">
          <div>
            <h2 class="text-base font-bold text-slate-900 mb-0.5">Sources de trafic</h2>
            <p class="text-xs text-slate-400 font-medium">Canaux d'acquisition principaux</p>
          </div>

          <div class="space-y-3 pt-1">
            {% for src in stats.sources %}
              <div class="space-y-1">
                <div class="flex justify-between text-xs font-semibold">
                  <span class="text-slate-700">
                    {{ src.name == 'Organic Search' ? 'Recherche organique' : (src.name == 'Direct' ? 'Accès direct' : (src.name == 'Organic Social' ? 'Réseaux sociaux' : (src.name == 'Referral' ? 'Sites référents' : src.name))) }}
                  </span>
                  <span class="text-slate-500">{{ src.sessions }} ({{ src.pct }}%)</span>
                </div>
                <div class="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                  <div class="bg-[#94674d] h-full rounded-full transition-all duration-500" style="width: {{ src.pct }}%"></div>
                </div>
              </div>
            {% else %}
              <p class="text-xs text-slate-400 text-center py-4">Aucune donnée</p>
            {% endfor %}
          </div>
        </div>

        {# Supports #}
        <div class="bg-white border border-slate-100 rounded-3xl p-6 shadow-sm space-y-4">
          <div>
            <h2 class="text-base font-bold text-slate-900 mb-0.5">Supports utilisés</h2>
            <p class="text-xs text-slate-400 font-medium">Répartition par type d'appareil</p>
          </div>

          <div class="space-y-3 pt-1">
            {% for dev in stats.devices %}
              <div class="space-y-1">
                <div class="flex justify-between text-xs font-semibold">
                  <span class="text-slate-700 flex items-center gap-1.5">
                    {% if dev.name == 'Ordinateur' %}💻{% elseif dev.name == 'Mobile' %}📱{% else %}📟{% endif %}
                    {{ dev.name }}
                  </span>
                  <span class="text-slate-500">{{ dev.pct }}%</span>
                </div>
                <div class="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                  <div class="bg-sky-500 h-full rounded-full transition-all duration-500" style="width: {{ dev.pct }}%"></div>
                </div>
              </div>
            {% else %}
              <p class="text-xs text-slate-400 text-center py-4">Aucune donnée</p>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
{% endif %}
{% endblock %}

{% block scripts %}
{% if stats and stats.trend %}
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const ctx = document.getElementById('trendChart').getContext('2d');
      const labels = {{ stats.trend.labels|json_encode|raw }};
      const views = {{ stats.trend.views|json_encode|raw }};
      const users = {{ stats.trend.users|json_encode|raw }};

      new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            {
              label: 'Pages vues',
              data: views,
              borderColor: '#94674d',
              backgroundColor: 'rgba(148, 103, 77, 0.08)',
              borderWidth: 3,
              fill: true,
              tension: 0.3,
              pointRadius: 3,
              pointBackgroundColor: '#94674d',
            },
            {
              label: 'Visiteurs uniques',
              data: users,
              borderColor: '#10b981',
              backgroundColor: 'rgba(16, 185, 129, 0.08)',
              borderWidth: 3,
              fill: true,
              tension: 0.3,
              pointRadius: 3,
              pointBackgroundColor: '#10b981',
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { position: 'top', labels: { boxWidth: 12, font: { size: 11, weight: 'bold' } } }
          },
          scales: {
            x: { grid: { color: 'rgba(0, 0, 0, 0.03)' }, ticks: { font: { size: 10 } } },
            y: { grid: { color: 'rgba(0, 0, 0, 0.03)' }, ticks: { beginAtZero: true, font: { size: 10 } } }
          }
        }
      });
    });
  </script>
{% endif %}
{% endblock %}
