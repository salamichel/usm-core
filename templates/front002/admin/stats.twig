{% extends 'admin/layout.twig' %}
{% block title %}Statistiques de visites{% endblock %}

{% block content %}
<div class="space-y-8">
  {# ── En-tête ── #}
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
      <h1 class="text-3xl font-black mb-1">Statistiques de visites</h1>
      {% if last_updated %}
        <p class="text-xs text-gray-500 font-semibold">
          Dernière mise à jour : {{ last_updated|date('H:i:s') }} (mise en cache pour 15 min)
        </p>
      {% endif %}
    </div>
    
    <div class="flex flex-wrap items-center gap-3">
      {% if not not_configured %}
        <a href="{{ url('admin/stats?period=' ~ current_period ~ '&force_refresh=1') }}" 
           class="border-4 border-black bg-white px-4 py-2 font-black text-sm shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-0.5 hover:translate-y-0.5 transition-all flex items-center gap-2">
          🔄 Actualiser
        </a>
      {% endif %}
      <a href="{{ url('admin/site-config') }}" 
         class="border-4 border-black bg-usm-brown text-white px-4 py-2 font-black text-sm shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-0.5 hover:translate-y-0.5 transition-all">
        ⚙️ Configurer
      </a>
    </div>
  </div>

  {# ── Sélecteur de période ── #}
  <div class="flex border-b-4 border-black bg-white shadow-[4px_4px_0_#000] overflow-x-auto">
    {% for key, p in periods %}
      <a href="{{ url('admin/stats?period=' ~ key) }}" 
         class="px-5 py-3 font-black text-sm border-r-4 border-black whitespace-nowrap transition-all duration-150
                {{ current_period == key ? 'bg-black text-white' : 'hover:bg-gray-100 text-gray-700' }}">
        {{ p.label }}
      </a>
    {% endfor %}
  </div>

  {# ── Écran : Non Configuré ── #}
  {% if not_configured %}
    <div class="border-4 border-black bg-amber-50 p-8 shadow-[8px_8px_0_#000] space-y-6">
      <div class="flex items-center gap-3">
        <span class="text-4xl">📈</span>
        <h2 class="text-2xl font-black">Google Analytics n'est pas encore configuré</h2>
      </div>
      
      <p class="text-sm text-gray-700 leading-relaxed font-semibold">
        Pour afficher les statistiques de fréquentation du site directement dans cette administration, vous devez configurer la liaison API avec Google Analytics 4 (GA4).
      </p>

      <div class="border-t-2 border-dashed border-black/20 pt-6">
        <h3 class="font-black text-lg mb-4">Étapes de configuration :</h3>
        <ol class="space-y-4 text-sm font-semibold text-gray-800 list-decimal pl-5">
          <li class="pl-2">
            Activer l'API <strong class="text-black">Google Analytics Data API (v1beta)</strong> sur votre console Google Cloud.
          </li>
          <li class="pl-2">
            Créer un <strong class="text-black">Compte de Service</strong> (Service Account) sur Google Cloud, puis générer et télécharger sa clé au format <strong class="text-black">JSON</strong>.
          </li>
          <li class="pl-2">
            Ajouter l'adresse e-mail de ce compte de service (ex: <code>votre-compte@projet.iam.gserviceaccount.com</code>) en tant que <strong class="text-black">Lecteur (Viewer)</strong> dans l'administration de votre propriété Google Analytics 4 (Propriété > Gestion des accès à la propriété).
          </li>
          <li class="pl-2">
            Récupérer votre <strong class="text-black">ID de propriété GA4</strong> (dans l'administration de GA4 > Paramètres de la propriété).
          </li>
          <li class="pl-2">
            Saisir ces informations dans la page de configuration du site.
          </li>
        </ol>
      </div>

      <div class="pt-4">
        <a href="{{ url('admin/site-config') }}" 
           class="inline-block border-4 border-black bg-usm-brown text-white px-6 py-3 font-black shadow-[6px_6px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-1 hover:translate-y-1 transition-all">
          Accéder à la configuration →
        </a>
      </div>
    </div>

  {# ── Écran : Erreur ── #}
  {% elseif error %}
    <div class="border-4 border-black bg-red-50 p-6 shadow-[8px_8px_0_#000] space-y-4">
      <div class="flex items-center gap-3 text-red-700">
        <span class="text-3xl">⚠️</span>
        <h2 class="text-xl font-black">Erreur de connexion</h2>
      </div>
      <p class="text-sm font-semibold text-gray-700 leading-relaxed">{{ error }}</p>
      
      <div class="pt-2">
        <a href="{{ url('admin/site-config') }}" class="underline font-black text-sm hover:text-red-700">
          Vérifier les paramètres de configuration
        </a>
      </div>
    </div>

  {# ── Écran : Dashboard ── #}
  {% else %}
    {# ── Indicateurs clés (KPI) ── #}
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      
      {# Visiteurs uniques #}
      <div class="border-4 border-black bg-sky-100 p-5 shadow-[6px_6px_0_#000] hover:translate-x-1 hover:translate-y-1 hover:shadow-[2px_2px_0_#000] transition-all">
        <div class="flex justify-between items-start">
          <span class="text-xs font-black uppercase text-sky-800 tracking-wider">Visiteurs uniques</span>
          <span class="text-xl">👥</span>
        </div>
        <div class="text-3xl font-black mt-2">{{ stats.totals.users|number_format(0, ',', ' ') }}</div>
        <p class="text-[10px] font-bold text-sky-700 mt-1">Utilisateurs actifs</p>
      </div>

      {# Sessions #}
      <div class="border-4 border-black bg-amber-100 p-5 shadow-[6px_6px_0_#000] hover:translate-x-1 hover:translate-y-1 hover:shadow-[2px_2px_0_#000] transition-all">
        <div class="flex justify-between items-start">
          <span class="text-xs font-black uppercase text-amber-800 tracking-wider">Sessions</span>
          <span class="text-xl">🔑</span>
        </div>
        <div class="text-3xl font-black mt-2">{{ stats.totals.sessions|number_format(0, ',', ' ') }}</div>
        <p class="text-[10px] font-bold text-amber-700 mt-1">Visites totales</p>
      </div>

      {# Pages vues #}
      <div class="border-4 border-black bg-emerald-100 p-5 shadow-[6px_6px_0_#000] hover:translate-x-1 hover:translate-y-1 hover:shadow-[2px_2px_0_#000] transition-all">
        <div class="flex justify-between items-start">
          <span class="text-xs font-black uppercase text-emerald-800 tracking-wider">Pages vues</span>
          <span class="text-xl">📄</span>
        </div>
        <div class="text-3xl font-black mt-2">{{ stats.totals.views|number_format(0, ',', ' ') }}</div>
        <p class="text-[10px] font-bold text-emerald-700 mt-1">Total affichages</p>
      </div>

      {# Durée moyenne #}
      <div class="border-4 border-black bg-purple-100 p-5 shadow-[6px_6px_0_#000] hover:translate-x-1 hover:translate-y-1 hover:shadow-[2px_2px_0_#000] transition-all">
        <div class="flex justify-between items-start">
          <span class="text-xs font-black uppercase text-purple-800 tracking-wider">Durée moyenne</span>
          <span class="text-xl">⏱️</span>
        </div>
        <div class="text-3xl font-black mt-2">{{ stats.totals.duration }}</div>
        <p class="text-[10px] font-bold text-purple-700 mt-1">Temps par visite</p>
      </div>

      {# Taux de rebond #}
      <div class="border-4 border-black bg-rose-100 p-5 shadow-[6px_6px_0_#000] hover:translate-x-1 hover:translate-y-1 hover:shadow-[2px_2px_0_#000] transition-all col-span-2 sm:col-span-1">
        <div class="flex justify-between items-start">
          <span class="text-xs font-black uppercase text-rose-800 tracking-wider">Taux de rebond</span>
          <span class="text-xl">☄️</span>
        </div>
        <div class="text-3xl font-black mt-2">{{ stats.totals.bounce_rate }} %</div>
        <p class="text-[10px] font-bold text-rose-700 mt-1">Visites d'une page</p>
      </div>

    </div>

    {# ── Graphique de tendance ── #}
    <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000]">
      <h2 class="text-lg font-black mb-1">Tendance de l'audience</h2>
      <p class="text-xs text-gray-500 font-bold mb-4">Évolution journalière des pages vues et des visiteurs uniques</p>
      
      <div class="h-80 w-full relative">
        <canvas id="trendChart"></canvas>
      </div>
    </div>

    <div class="grid lg:grid-cols-12 gap-8">
      {# ── Pages les plus visitées (Gauche) ── #}
      <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] lg:col-span-7">
        <h2 class="text-lg font-black mb-1">Pages les plus consultées</h2>
        <p class="text-xs text-gray-500 font-bold mb-4">Top 15 des pages générant le plus d'audience</p>
        
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-sm">
            <thead>
              <tr class="border-b-2 border-black font-black text-gray-500">
                <th class="py-2 px-1">Page</th>
                <th class="py-2 px-3 text-right">Vues</th>
                <th class="py-2 px-3 text-right">Visiteurs</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 font-semibold">
              {% for page in stats.pages %}
                <tr>
                  <td class="py-3 px-1 max-w-[280px] sm:max-w-xs md:max-w-md truncate">
                    <span class="block text-black font-black truncate" title="{{ page.title }}">
                      {{ page.title|default('—') }}
                    </span>
                    <a href="{{ page.path }}" target="_blank" class="text-xs text-gray-400 font-mono hover:text-usm-brown transition">
                      {{ page.path }}
                    </a>
                  </td>
                  <td class="py-3 px-3 text-right text-black font-black">
                    {{ page.views|number_format(0, ',', ' ') }}
                  </td>
                  <td class="py-3 px-3 text-right text-gray-500">
                    {{ page.users|number_format(0, ',', ' ') }}
                  </td>
                </tr>
              {% else %}
                <tr>
                  <td colspan="3" class="py-4 text-center text-gray-400">Aucune donnée disponible</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

      {# ── Canaux & Appareils (Droite) ── #}
      <div class="space-y-8 lg:col-span-5">
        {# Sources de trafic #}
        <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">
          <div>
            <h2 class="text-lg font-black mb-1">Sources de trafic</h2>
            <p class="text-xs text-gray-500 font-bold">Canaux d'acquisition d'audience principaux</p>
          </div>
          
          <div class="space-y-3 pt-2">
            {% for src in stats.sources %}
              <div class="space-y-1">
                <div class="flex justify-between text-xs font-black">
                  <span class="text-gray-700">
                    {{ src.name == 'Organic Search' ? 'Recherche organique' : (src.name == 'Direct' ? 'Accès direct' : (src.name == 'Organic Social' ? 'Réseaux sociaux' : (src.name == 'Referral' ? 'Sites référents' : src.name))) }}
                  </span>
                  <span>{{ src.sessions|number_format(0, ',', ' ') }} visites ({{ src.pct }}%)</span>
                </div>
                <div class="w-full bg-gray-100 border-2 border-black h-4 overflow-hidden">
                  <div class="bg-amber-400 h-full border-r-2 border-black transition-all duration-500" 
                       style="width: {{ src.pct }}%"></div>
                </div>
              </div>
            {% else %}
              <p class="text-sm text-gray-400 text-center py-4">Aucune donnée disponible</p>
            {% endfor %}
          </div>
        </div>

        {# Répartition par Appareil #}
        <div class="border-4 border-black bg-white p-6 shadow-[6px_6px_0_#000] space-y-4">
          <div>
            <h2 class="text-lg font-black mb-1">Supports utilisés</h2>
            <p class="text-xs text-gray-500 font-bold">Répartition de l'audience par type d'appareil</p>
          </div>
          
          <div class="space-y-3 pt-2">
            {% for dev in stats.devices %}
              <div class="space-y-1">
                <div class="flex justify-between text-xs font-black">
                  <span class="text-gray-700 flex items-center gap-1.5">
                    {% if dev.name == 'Ordinateur' %}💻{% elseif dev.name == 'Mobile' %}📱{% else %}📟{% endif %}
                    {{ dev.name }}
                  </span>
                  <span>{{ dev.pct }}%</span>
                </div>
                <div class="w-full bg-gray-100 border-2 border-black h-4 overflow-hidden">
                  <div class="bg-sky-400 h-full border-r-2 border-black transition-all duration-500" 
                       style="width: {{ dev.pct }}%"></div>
                </div>
              </div>
            {% else %}
              <p class="text-sm text-gray-400 text-center py-4">Aucune donnée disponible</p>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>
{% endblock %}

{% block scripts %}
{% if stats and stats.trend %}
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const ctx = document.getElementById('trendChart').getContext('2d');
      
      const labels = {{ stats.trend.labels|json_encode|raw }};
      const views = {{ stats.trend.views|json_encode|raw }};
      const users = {{ stats.trend.users|json_encode|raw }};

      // Création du graphique
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            {
              label: 'Pages vues',
              data: views,
              borderColor: '#94674d', // usm-brown
              backgroundColor: 'rgba(148, 103, 77, 0.08)',
              borderWidth: 4,
              fill: true,
              tension: 0.3,
              pointBackgroundColor: '#fff',
              pointBorderColor: '#94674d',
              pointBorderWidth: 2,
              pointHoverRadius: 6,
              pointHoverBackgroundColor: '#94674d',
              pointHoverBorderColor: '#fff',
              pointHoverBorderWidth: 2
            },
            {
              label: 'Visiteurs uniques',
              data: users,
              borderColor: '#10b981', // emerald
              backgroundColor: 'rgba(16, 185, 129, 0.08)',
              borderWidth: 4,
              fill: true,
              tension: 0.3,
              pointBackgroundColor: '#fff',
              pointBorderColor: '#10b981',
              pointBorderWidth: 2,
              pointHoverRadius: 6,
              pointHoverBackgroundColor: '#10b981',
              pointHoverBorderColor: '#fff',
              pointHoverBorderWidth: 2
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: {
            mode: 'index',
            intersect: false,
          },
          plugins: {
            legend: {
              position: 'top',
              labels: {
                boxWidth: 16,
                boxHeight: 16,
                font: {
                  family: 'monospace',
                  size: 11,
                  weight: 'bold'
                },
                color: '#000'
              }
            },
            tooltip: {
              padding: 10,
              backgroundColor: '#000',
              titleFont: {
                family: 'monospace',
                size: 12,
                weight: 'bold'
              },
              bodyFont: {
                family: 'monospace',
                size: 11
              },
              borderWidth: 2,
              borderColor: '#fff'
            }
          },
          scales: {
            x: {
              grid: {
                color: 'rgba(0, 0, 0, 0.05)',
                lineWidth: 1
              },
              ticks: {
                font: {
                  family: 'monospace',
                  size: 10,
                  weight: 'bold'
                },
                color: '#666'
              }
            },
            y: {
              grid: {
                color: 'rgba(0, 0, 0, 0.05)',
                lineWidth: 1
              },
              ticks: {
                beginAtZero: true,
                font: {
                  family: 'monospace',
                  size: 10,
                  weight: 'bold'
                },
                color: '#666'
              }
            }
          }
        }
      });
    });
  </script>
{% endif %}
{% endblock %}
