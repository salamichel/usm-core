{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}Menu{% endblock %}

{% block content %}

{# ── En-tête de page ── #}
{{ m.page_header('Menu de navigation', url('admin/menu/create'), '+ Ajouter un élément') }}

{% if items|length %}
  <div class="space-y-3">
    {% for item in items %}
    <div class="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
      <div class="flex items-center justify-between px-5 py-4 bg-slate-50/50">
        <div class="flex items-center gap-2.5 flex-wrap">
          <span class="font-bold text-base text-slate-900">{{ item.label }}</span>
          <span class="text-xs font-mono text-slate-400">
            {% if item.link_type == 'page' %}→ /p/{{ item.target }}
            {% elseif item.link_type == 'url' %}→ {{ item.target }}
            {% else %}(groupe parent){% endif %}
          </span>
          <span class="text-[10px] font-bold bg-slate-200 text-slate-600 px-2 py-0.5 rounded-full">Pos. {{ item.position }}</span>
        </div>
        <div class="flex gap-2">
          {{ m.action_buttons(
            url('admin/menu/' ~ item.id ~ '/edit'),
            url('admin/menu/' ~ item.id ~ '/delete'),
            'Supprimer cet élément et ses enfants ?',
            csrf_token
          ) }}
        </div>
      </div>

      {# Children (Level 2) #}
      {% if item.children|length %}
        <div class="border-t border-slate-100 divide-y divide-slate-50 bg-white pl-6">
          {% for child in item.children %}
          <div class="py-3 px-4">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-slate-400">↳</span>
                <span class="font-semibold text-sm text-slate-800">{{ child.label }}</span>
                <span class="text-xs font-mono text-slate-400">
                  {% if child.link_type == 'page' %}→ /p/{{ child.target }}
                  {% elseif child.link_type == 'url' %}→ {{ child.target }}
                  {% else %}(sous-groupe){% endif %}
                </span>
              </div>
              <div class="flex gap-2">
                {{ m.action_buttons(
                  url('admin/menu/' ~ child.id ~ '/edit'),
                  url('admin/menu/' ~ child.id ~ '/delete'),
                  'Supprimer ce sous-élément ?',
                  csrf_token
                ) }}
              </div>
            </div>

            {# Sub-children (Level 3) #}
            {% if child.children|length %}
              <div class="mt-2 ml-6 border-l-2 border-[#94674d]/30 pl-3 space-y-1.5 py-1">
                {% for subchild in child.children %}
                <div class="flex items-center justify-between p-2 bg-slate-50 rounded-xl text-xs">
                  <div class="flex items-center gap-2">
                    <span class="font-semibold text-slate-700">↳ {{ subchild.label }}</span>
                    <span class="text-slate-400 font-mono">
                      {% if subchild.link_type == 'page' %}→ /p/{{ subchild.target }}
                      {% elseif subchild.link_type == 'url' %}→ {{ subchild.target }}
                      {% endif %}
                    </span>
                  </div>
                  <div class="flex gap-1.5">
                    {{ m.action_buttons(
                      url('admin/menu/' ~ subchild.id ~ '/edit'),
                      url('admin/menu/' ~ subchild.id ~ '/delete'),
                      'Supprimer ?',
                      csrf_token
                    ) }}
                  </div>
                </div>
                {% endfor %}
              </div>
            {% endif %}
          </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    {% endfor %}
  </div>
{% else %}
  {{ m.empty_state('Aucun élément de menu.', url('admin/menu/create'), '+ Ajouter un élément') }}
{% endif %}
{% endblock %}
