{% extends 'admin/layout.twig' %}
{% import 'admin/_macros.twig' as m %}
{% block title %}{{ item ? 'Éditer' : 'Ajouter' }} un élément de menu{% endblock %}

{% block content %}

{# ── En-tête avec breadcrumb ── #}
<div class="relative overflow-hidden bg-slate-900 rounded-3xl p-6 md:p-8 text-white shadow-sm mb-8">
  <div class="relative">
    <nav class="flex items-center gap-1.5 text-xs text-slate-400 font-medium mb-2">
      <a href="{{ url('admin') }}" class="hover:text-white transition">Admin</a>
      <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      <a href="{{ url('admin/menu') }}" class="hover:text-white transition">Menu nav</a>
      <svg class="w-3 h-3 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      <span class="text-slate-200">{{ item ? 'Éditer' : 'Nouveau lien' }}</span>
    </nav>
    <h1 class="text-2xl font-black tracking-tight">
      {{ item ? 'Éditer l\'élément' : 'Nouvel élément de menu' }}
    </h1>
  </div>
</div>

{{ m.form_error(error) }}

<form method="POST" action="{{ action }}" class="space-y-6">
  <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

  <div class="bg-white border border-slate-100 rounded-3xl shadow-sm p-6 md:p-8 space-y-6 max-w-xl">
    {{ m.field_input('label', 'label', 'Libellé', item.label ?? '', 'text', true, 'Ex: Le Club') }}

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5" for="link_type">Type de lien</label>
      <select id="link_type" name="link_type"
              class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition"
              onchange="toggleTarget(this.value)">
        <option value="none" {% if (item.link_type ?? 'none') == 'none' %}selected{% endif %}>Aucun (groupe parent)</option>
        <option value="page" {% if (item.link_type ?? '') == 'page' %}selected{% endif %}>Page statique</option>
        <option value="url"  {% if (item.link_type ?? '') == 'url' %}selected{% endif %}>URL externe</option>
      </select>
    </div>

    <div id="target-page" class="{% if (item.link_type ?? 'none') != 'page' %}hidden{% endif %}">
      <label class="block text-sm font-bold text-slate-700 mb-1.5" for="target_page_sel">Page statique cible</label>
      <select name="target" id="target_page_sel"
              class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
        <option value="">— Choisir une page —</option>
        {% for page in pages %}
          <option value="{{ page.slug }}" {% if (item.target ?? '') == page.slug %}selected{% endif %}>
            {{ page.title }} (/p/{{ page.slug }})
          </option>
        {% endfor %}
      </select>
    </div>

    <div id="target-url" class="{% if (item.link_type ?? 'none') != 'url' %}hidden{% endif %}">
      {{ m.field_input('target_url', 'target_url', 'URL cible', (item.link_type ?? '') == 'url' ? (item.target ?? '') : '', 'text', false, 'https://...') }}
    </div>

    <div>
      <label class="block text-sm font-bold text-slate-700 mb-1.5" for="parent_id">Élément parent</label>
      <select id="parent_id" name="parent_id"
              class="w-full border border-slate-200 bg-white rounded-xl px-4 py-2.5 text-sm font-mono text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#94674d]/20 focus:border-[#94674d] transition">
        <option value="">— Aucun (racine niveau 1) —</option>
        {% for opt in roots %}
          {% if item is null or opt.id != item.id %}
          <option value="{{ opt.id }}" {% if (item.parent_id ?? '') == opt.id %}selected{% endif %}>
            {{ opt.prefix }}{{ opt.label }}
          </option>
          {% endif %}
        {% endfor %}
      </select>
      <p class="text-xs text-slate-400 font-medium mt-1.5">Niveau 1 → racine · Niveau 2 (— enfant) → colonne méga menu · Niveau 3 (—— enfant) → lien dans la colonne</p>
    </div>

    {{ m.field_input('position', 'position', 'Position d\'affichage', item.position ?? 0, 'number') }}
  </div>

  <div class="flex items-center gap-3 pt-2">
    {{ m.btn_submit(item ? 'Mettre à jour' : 'Enregistrer') }}
    <a href="{{ url('admin/menu') }}"
       class="inline-flex items-center gap-1.5 text-sm font-semibold text-slate-500 hover:text-slate-700 transition">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
      Annuler
    </a>
  </div>
</form>
{% endblock %}

{% block scripts %}
<script>
function toggleTarget(type) {
  document.getElementById('target-page').classList.toggle('hidden', type !== 'page');
  document.getElementById('target-url').classList.toggle('hidden', type !== 'url');
}
document.querySelector('form').addEventListener('submit', function() {
  const type = document.getElementById('link_type').value;
  if (type === 'page') {
    document.getElementById('target_url').name = '_target_url_disabled';
    document.getElementById('target_page_sel').name = 'target';
  } else if (type === 'url') {
    document.getElementById('target_page_sel').name = '_target_page_disabled';
    document.getElementById('target_url').name = 'target';
  }
});
</script>
{% endblock %}
