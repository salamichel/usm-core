{# ── Modal de confirmation (remplace les confirm() natifs) ──────────────────
   Inclure une fois dans admin/layout.twig avant </body>.
   Usage : ajouter data-confirm="Message..." sur les <form> POST destructifs.
   ─────────────────────────────────────────────────────────────────────────── #}
<dialog id="confirm-dialog"
        class="rounded-2xl border border-slate-200 shadow-2xl bg-white p-0 w-full max-w-sm backdrop:bg-slate-900/60 backdrop:backdrop-blur-sm"
        aria-labelledby="confirm-dialog-title"
        aria-describedby="confirm-dialog-message">

  <div class="bg-slate-900 rounded-t-2xl px-6 py-4 flex items-center gap-3">
    <div class="p-1.5 bg-rose-500/20 rounded-lg flex-shrink-0">
      <svg class="w-4 h-4 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
    </div>
    <h2 id="confirm-dialog-title" class="font-black text-white text-sm">Confirmation requise</h2>
  </div>

  <div class="px-6 py-5">
    <p id="confirm-dialog-message" class="text-sm text-slate-600 font-medium leading-relaxed"></p>
  </div>

  <div class="flex gap-3 px-6 pb-6 justify-end">
    <button type="button" id="confirm-dialog-cancel"
            class="bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 px-4 py-2 text-sm font-semibold rounded-xl transition focus:outline-none focus:ring-2 focus:ring-slate-300">
      Annuler
    </button>
    <button type="button" id="confirm-dialog-ok"
            class="bg-rose-600 hover:bg-rose-700 text-white px-4 py-2 text-sm font-bold rounded-xl transition focus:outline-none focus:ring-2 focus:ring-rose-400 shadow-sm">
      Confirmer la suppression
    </button>
  </div>
</dialog>

<script>
(function () {
  var dialog   = document.getElementById('confirm-dialog');
  var msgEl    = document.getElementById('confirm-dialog-message');
  var btnOk    = document.getElementById('confirm-dialog-ok');
  var btnCancel = document.getElementById('confirm-dialog-cancel');

  if (!dialog) return;

  var pendingForm = null;

  function openDialog(form) {
    msgEl.textContent = form.dataset.confirm || 'Êtes-vous sûr ?';
    pendingForm = form;
    dialog.showModal();
    btnCancel.focus();
  }

  function closeDialog(confirmed) {
    dialog.close();
    if (confirmed && pendingForm) {
      var f = pendingForm;
      pendingForm = null;
      delete f.dataset.confirm;
      f.submit();
    } else {
      pendingForm = null;
    }
  }

  btnOk.addEventListener('click', function () { closeDialog(true); });
  btnCancel.addEventListener('click', function () { closeDialog(false); });

  dialog.addEventListener('click', function (e) {
    if (e.target === dialog) closeDialog(false);
  });

  dialog.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeDialog(false);
  });

  document.addEventListener('submit', function (e) {
    var form = e.target;
    if (form.dataset.confirm) {
      e.preventDefault();
      openDialog(form);
    }
  });
})();
</script>
