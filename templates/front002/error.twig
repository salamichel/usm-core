{% extends 'base.twig' %}
{% block title %}Erreur — USM Volley{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto px-6 py-20">
  <div class="card p-10 text-center">
    <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-rose-50 text-rose-600 mb-6">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
    </div>
    <h1 class="font-serif text-2xl font-semibold text-slate-900 mb-3">Une erreur est survenue</h1>
    <p class="text-slate-600 leading-relaxed mb-8">{{ error }}</p>
    <a href="{{ url('/') }}" class="btn-primary">Retour à l'accueil</a>
  </div>
</div>
{% endblock %}
