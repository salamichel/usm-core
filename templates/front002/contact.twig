{% extends 'base.twig' %}
{% block title %}Contact — USM Volley{% endblock %}

{% block head %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<style>
  #map {
    height: 460px;
    border-radius: 12px;
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .map-mini {
    border-bottom: 1px solid var(--border);
  }
</style>
{% endblock %}

{% block content %}
<div class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">

  {# En-tête #}
  <div class="bg-slate-900 text-white pt-8 pb-20 md:pt-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <nav aria-label="Fil d'Ariane" class="text-sm text-slate-400 mb-6">
        <a href="{{ url('') }}" class="hover:text-white transition-colors">Accueil</a>
        <span class="mx-2 text-slate-600">/</span>
        <span class="text-slate-200">Contact</span>
      </nav>
      
      <div>
        <span class="inline-block text-xs uppercase tracking-[0.25em] text-[var(--primary)] font-semibold mb-2">Contact</span>
        <h1 class="font-serif text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-3">Nous contacter</h1>
        <p class="text-slate-400 text-sm md:text-base mt-1">
          Envoyez-nous un message ou venez nous rendre visite dans l'un de nos gymnases.
        </p>
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 -mt-10">

    <div class="grid gap-10 lg:grid-cols-3 mb-20">

      {# ── Infos de contact ── #}
      <aside class="lg:col-span-1">
        <div class="bg-white rounded-3xl p-7 space-y-6 border border-slate-100 shadow-sm">
          <h2 class="font-serif text-xl font-bold text-slate-900">Informations</h2>

          {% if site_config.phone %}
          <div>
            <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-1">Téléphone</p>
            <a href="tel:{{ site_config.phone|replace({' ': ''}) }}" class="text-[var(--primary)] font-bold hover:underline underline-offset-2">
              {{ site_config.phone }}
            </a>
          </div>
          {% endif %}

          {% if site_config.address %}
          <div>
            <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-1">Adresse</p>
            <address class="not-italic text-sm text-slate-700 whitespace-pre-line leading-relaxed">{{ site_config.address }}</address>
          </div>
          {% endif %}

          {% if site_config.facebook_url or site_config.instagram_url %}
          <div class="pt-5 border-t border-slate-100">
            <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-3">Suivez-nous</p>
            <div class="flex gap-2">
              {% if site_config.facebook_url %}
                <a href="{{ site_config.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook"
                   class="w-10 h-10 rounded-full border border-slate-200 flex items-center justify-center hover:bg-slate-50 hover:border-slate-300 transition-all">
                  <svg class="w-4 h-4 text-slate-700" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12.07C22 6.48 17.52 2 11.93 2 6.36 2 1.88 6.48 1.88 12.07c0 5.02 3.66 9.18 8.46 9.93v-7.03H7.83v-2.9h2.51V9.83c0-2.48 1.48-3.85 3.74-3.85 1.08 0 2.21.19 2.21.19v2.43h-1.25c-1.23 0-1.61.77-1.61 1.55v1.86h2.74l-.44 2.9h-2.3V22c4.8-.75 8.46-4.91 8.46-9.93z"/></svg>
                </a>
              {% endif %}
              {% if site_config.instagram_url %}
                <a href="{{ site_config.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram"
                   class="w-10 h-10 rounded-full border border-slate-200 flex items-center justify-center hover:bg-slate-50 hover:border-slate-300 transition-all">
                  <svg class="w-4 h-4 text-slate-700" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.07.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.07.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.43-.36-1.07-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.07-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zm0 4.86A4.97 4.97 0 1 0 12 17a4.97 4.97 0 0 0 0-9.97zm0 1.8a3.17 3.17 0 1 1 0 6.34 3.17 3.17 0 0 1 0-6.34zm5.18-2.16a1.16 1.16 0 1 1 0 2.32 1.16 1.16 0 0 1 0-2.32z"/></svg>
                </a>
              {% endif %}
            </div>
          </div>
          {% endif %}
        </div>
      </aside>

      {# ── Formulaire ── #}
      <div class="lg:col-span-2">
        <div class="bg-white rounded-3xl p-6 md:p-8 border border-slate-100 shadow-sm">
          <h2 class="font-serif text-2xl font-bold text-slate-900 mb-6">Nous envoyer un message</h2>

          {% if error %}
            <div class="rounded-xl border border-rose-200 bg-rose-50 text-rose-700 px-4 py-3 mb-6 text-sm font-semibold">
              {{ error }}
            </div>
          {% endif %}

          <form method="POST" action="{{ url('contact') }}" class="space-y-5">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">Nom *</label>
                <input type="text" id="name" name="name" required value="{{ form_data.name|default('') }}"
                       class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 focus:border-[var(--primary)] transition-all">
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-slate-700 mb-2">Email *</label>
                <input type="email" id="email" name="email" required value="{{ form_data.email|default('') }}"
                       class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 focus:border-[var(--primary)] transition-all">
              </div>
            </div>

            <div>
              <label for="phone" class="block text-sm font-semibold text-slate-700 mb-2">Téléphone *</label>
              <input type="tel" id="phone" name="phone" required value="{{ form_data.phone|default('') }}"
                     placeholder="06 12 34 56 78"
                     class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 focus:border-[var(--primary)] transition-all">
            </div>

            <div>
              <label for="subject" class="block text-sm font-semibold text-slate-700 mb-2">Sujet *</label>
              <select id="subject" name="subject" required
                      class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 focus:border-[var(--primary)] transition-all">
                <option value="" disabled {% if not form_data.subject %}selected{% endif %}>— Choisissez un sujet —</option>
                {% set subjects = [
                  'Adhésion / Inscription',
                  'Tarifs et licences',
                  'Informations sur les entraînements',
                  'Matchs et compétitions',
                  'Partenariat / Sponsor',
                  'Bénévolat',
                  'Question générale',
                  'Autre'
                ] %}
                {% for s in subjects %}
                  <option value="{{ s }}" {% if form_data.subject == s %}selected{% endif %}>{{ s }}</option>
                {% endfor %}
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold text-slate-700 mb-2">Message *</label>
              <textarea id="message" name="message" required rows="6" placeholder="Votre message..."
                        class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 focus:border-[var(--primary)] transition-all">{{ form_data.message|default('') }}</textarea>
            </div>

            <button type="submit" class="btn-primary w-full justify-center py-3.5 rounded-xl font-bold cursor-pointer">
              Envoyer le message
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
            </button>
          </form>
        </div>
      </div>
    </div>

    {# ── Gymnases ── #}
    {% if locations|length %}
    <div class="space-y-8 mt-12">
      <div>
        <span class="inline-block text-xs uppercase tracking-[0.25em] text-slate-400 font-semibold mb-2">Nos lieux</span>
        <h2 class="font-serif text-2xl md:text-3xl font-extrabold text-slate-900 mb-2">Nos gymnases</h2>
        <p class="text-slate-500 text-sm">Localisez nos lieux d'entraînement sur la carte interactive.</p>
      </div>

      <div id="map" class="shadow-sm rounded-3xl"></div>

      <div class="grid gap-6 sm:grid-cols-2">
        {% for location in locations %}
        <div class="bg-white rounded-3xl overflow-hidden flex flex-col border border-slate-100 shadow-sm">
          {% if location.latitude and location.longitude %}
            <div class="map-mini" id="map-{{ location.id }}" style="height: 240px;"></div>
          {% endif %}
          <div class="p-6 flex-1 flex flex-col">
            <h3 class="font-serif text-xl font-bold text-slate-900 mb-2">{{ location.name }}</h3>
            <address class="not-italic text-sm text-slate-600 whitespace-pre-line leading-relaxed mb-4">{{ location.address }}</address>
            {% if not (location.latitude and location.longitude) %}
              <a href="https://www.google.com/maps/search/{{ location.address|url_encode }}" target="_blank" rel="noopener"
                 class="mt-auto btn-secondary self-start text-xs rounded-xl font-semibold">
                Voir sur Google Maps →
              </a>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </div>

{% if locations|length %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script>
(function() {
  var locations = {{ locations|json_encode|raw }};
  var validLocations = locations.filter(function(loc) { return loc.latitude && loc.longitude; });
  if (validLocations.length === 0) {
    document.getElementById('map').innerHTML = '<p class="p-6 text-slate-500 text-center">Aucun emplacement géolocalisé.</p>';
    return;
  }

  var map = L.map('map').setView([validLocations[0].latitude, validLocations[0].longitude], 13);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors', maxZoom: 19
  }).addTo(map);

  var markers = [];
  validLocations.forEach(function(location) {
    var marker = L.marker([location.latitude, location.longitude])
      .bindPopup('<strong>' + location.name + '</strong><br>' + location.address.replace(/\n/g, '<br>'))
      .addTo(map);
    markers.push(marker);
  });
  if (markers.length > 1) {
    var group = new L.featureGroup(markers);
    map.fitBounds(group.getBounds().pad(0.1));
  }

  validLocations.forEach(function(location) {
    var mapId = 'map-' + location.id;
    var el = document.getElementById(mapId);
    if (!el) return;
    var miniMap = L.map(mapId).setView([location.latitude, location.longitude], 15);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap', maxZoom: 19
    }).addTo(miniMap);
    L.marker([location.latitude, location.longitude])
      .bindPopup('<strong>' + location.name + '</strong>')
      .addTo(miniMap)
      .openPopup();
  });
})();
</script>
{% endif %}
{% endblock %}
