{% extends 'base.twig' %}
{% import '_gallery.twig' as components %}
{% block title %}{{ post.title }} — USM Volley{% endblock %}

{% block head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "{{ base_url }}/"},
        {"@type": "ListItem", "position": 2, "name": "Actualités", "item": "{{ url('blog') }}"},
        {"@type": "ListItem", "position": 3, "name": "{{ post.title|replace({'"': '\\"'})|raw }}", "item": "{{ url('blog/' ~ post.slug) }}"}
      ]
    },
    {
      "@type": "NewsArticle",
      "headline": "{{ post.title|replace({'"': '\\"'})|raw }}",
      "url": "{{ url('blog/' ~ post.slug) }}",
      {% if post.published_at %}"datePublished": "{{ post.published_at|date('Y-m-d') }}",{% endif %}
      {% if post.excerpt %}"description": "{{ post.excerpt|striptags|replace({'"': '\\"'})|truncate(200)|raw }}",{% endif %}
      {% if post.cover %}"image": "{{ asset('uploads/' ~ post.cover.filename) }}",{% endif %}
      "author": {"@type": "Organization", "name": "{{ site_config.club_name|default('USM Volley')|replace({'"': '\\"'})|raw }}"},
      "publisher": {
        "@type": "Organization",
        "name": "{{ site_config.club_name|default('USM Volley')|replace({'"': '\\"'})|raw }}"
      }
    }
  ]
}
</script>
{% endblock %}

{% block content %}
<div class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">
  {# En-tête #}
  <div class="bg-slate-900 text-white pt-8 pb-20 md:pt-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <nav class="text-sm text-slate-400 mb-6">
        <a href="{{ url('/') }}" class="hover:text-white transition">Accueil</a>
        <span class="mx-2 text-slate-650">/</span>
        <a href="{{ url('blog') }}" class="hover:text-white transition">Actualités</a>
        <span class="mx-2 text-slate-650">/</span>
        <span class="text-slate-300">{{ post.title|truncate(40) }}</span>
      </nav>
      
      <div>
        {% if post.published_at %}
          <time class="block text-xs uppercase tracking-[0.2em] text-slate-400 font-semibold mb-3">
            {{ post.published_at|date_fr('d/m/Y') }}
          </time>
        {% endif %}
        <h1 class="font-serif text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-4 leading-tight">{{ post.title }}</h1>
        {% if post.excerpt %}
          <p class="text-slate-300 text-sm md:text-base mt-1 leading-relaxed max-w-3xl font-medium">{{ post.excerpt }}</p>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 -mt-10">
    <article class="bg-white rounded-3xl p-6 md:p-8 border border-slate-100 shadow-sm space-y-8">
      {# Cover #}
      {% if post.cover %}
        <figure class="overflow-hidden rounded-2xl">
          <img src="{{ image_variant(post.cover, 'large') }}" alt="{{ post.title }}"
               loading="lazy" decoding="async"
               class="w-full max-h-[500px] object-cover">
        </figure>
      {% endif %}

      {# Body #}
      <div class="prose prose-slate max-w-none
                  prose-headings:font-serif prose-headings:font-semibold prose-headings:text-slate-900
                  prose-a:text-[var(--primary)] prose-a:underline-offset-2
                  prose-img:rounded-xl prose-img:my-8
                  prose-blockquote:border-l-4 prose-blockquote:border-[var(--primary)] prose-blockquote:font-serif prose-blockquote:italic prose-blockquote:text-slate-700">
        {{ post.content|render_with_config|raw }}
      </div>

      {# Tags #}
      {% if tags|length %}
      <div class="pt-6 border-t border-slate-100">
        <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-3">Tags</p>
        <div class="flex flex-wrap gap-2">
          {% for tag in tags %}
            <a href="{{ url('blog/tag/' ~ tag.slug) }}"
               class="inline-block px-3 py-1.5 rounded-xl text-xs bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold transition">
              {{ tag.name }}
            </a>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      {{ components.gallery(photos) }}
    </article>

    {# Navigation #}
    <div class="mt-8 pt-8 border-t border-slate-200">
      <div class="grid grid-cols-3 items-center gap-4">
        <div>
          {% if prev_post %}
          <a href="{{ url('blog/' ~ prev_post.slug) }}"
             class="group flex flex-col bg-white border border-slate-200 hover:border-[var(--primary)] rounded-2xl transition overflow-hidden shadow-sm">
            {% if prev_post.cover %}
              <img src="{{ image_variant(prev_post.cover, 'thumb') }}" alt="" class="w-full h-24 object-cover">
            {% endif %}
            <div class="p-4">
              <span class="text-[10px] uppercase tracking-wider text-slate-400 font-bold inline-flex items-center gap-1">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Précédent
              </span>
              <p class="text-xs font-bold text-slate-800 group-hover:text-[var(--primary)] leading-snug transition line-clamp-2 mt-1">{{ prev_post.title }}</p>
            </div>
          </a>
          {% endif %}
        </div>
        
        <div class="text-center">
          <a href="{{ url('blog') }}" class="text-xs uppercase tracking-wider text-slate-500 hover:text-[var(--primary)] font-bold transition">
            Toutes les actualités
          </a>
        </div>
        
        <div class="text-right">
          {% if next_post %}
          <a href="{{ url('blog/' ~ next_post.slug) }}"
             class="group flex flex-col bg-white border border-slate-200 hover:border-[var(--primary)] rounded-2xl transition overflow-hidden items-end shadow-sm">
            {% if next_post.cover %}
              <img src="{{ image_variant(next_post.cover, 'thumb') }}" alt="" class="w-full h-24 object-cover">
            {% endif %}
            <div class="p-4">
              <span class="text-[10px] uppercase tracking-wider text-slate-400 font-bold inline-flex items-center gap-1">
                Suivant
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
              <p class="text-xs font-bold text-slate-800 group-hover:text-[var(--primary)] leading-snug transition line-clamp-2 mt-1 text-right">{{ next_post.title }}</p>
            </div>
          </a>
          {% endif %}
        </div>
      </div>
    </div>

  </div>
</div>
{% endblock %}

{% block scripts %}
{% if photos|length %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script>GLightbox({ selector: '.glightbox', touchNavigation: true, loop: true });</script>
{% endif %}
{% endblock %}
