{% extends 'base.twig' %}
{% import '_gallery.twig' as components %}
{% block title %}Acualités — {{ post.title }} — USM Volley{% endblock %}

{% block head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Accueil", "item": "{{ base_url }}/"},
        {"@type": "ListItem", "position": 2, "name": "Actualités", "item": "{{ url('blog') }}"},
        {"@type": "ListItem", "position": 3, "name": "{{ post.title|replace({'"': '\\"'})|raw }}", "item": "{{ url('blog/' ~ post.slug) }}"}
      ]
    },
    {
      "@type": "NewsArticle",
      "headline": "{{ post.title|replace({'"': '\\"'})|raw }}",
      "url": "{{ url('blog/' ~ post.slug) }}",
      {% if post.published_at %}"datePublished": "{{ post.published_at|date('Y-m-d') }}",{% endif %}
      {% if post.excerpt %}"description": "{{ post.excerpt|striptags|replace({'"': '\\"'})|truncate(200)|raw }}",{% endif %}
      {% if post.cover %}"image": "{{ asset('uploads/' ~ post.cover.filename) }}",{% endif %}
      "author": {"@type": "Organization", "name": "{{ site_config.club_name|default('USM Volley')|replace({'"': '\\"'})|raw }}"},
      "publisher": {
        "@type": "Organization",
        "name": "{{ site_config.club_name|default('USM Volley')|replace({'"': '\\"'})|raw }}"
      }
    }
  ]
}
</script>
{% endblock %}

{% block content %}
<div class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">
  {# En-tête #}
  <div class="bg-slate-900 text-white pt-8 pb-20 md:pt-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <nav class="text-sm text-slate-400 mb-6">
        <a href="{{ url('/') }}" class="hover:text-white transition">Accueil</a>
        <span class="mx-2 text-slate-650">/</span>
        <a href="{{ url('blog') }}" class="hover:text-white transition">Actualités</a>
        <span class="mx-2 text-slate-650">/</span>
        <span class="text-slate-300">{{ post.title|truncate(40) }}</span>
      </nav>
      
      <div>
        <div class="flex flex-wrap items-center gap-2 mb-3">
          {% if tags|length %}
            {% for tag in tags %}
              <a href="{{ url('blog/tag/' ~ tag.slug) }}" class="px-2 py-0.5 bg-[var(--primary)]/20 hover:bg-[var(--primary)]/30 text-[var(--primary)] text-[10px] font-bold rounded transition-all">
                {{ tag.name }}
              </a>
            {% endfor %}
          {% endif %}
          {% if post.published_at %}
            <time class="block text-xs uppercase tracking-[0.2em] text-slate-400 font-semibold">
              {{ post.published_at|date_fr('d/m/Y') }}
            </time>
          {% endif %}
        </div>
        <h1 class="font-serif text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-4 leading-tight">{{ post.title }}</h1>
        {% if post.excerpt %}
          <p class="text-slate-350 text-sm md:text-base mt-1 leading-relaxed max-w-3xl font-light">{{ post.excerpt }}</p>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 -mt-10">
    <article class="bg-white rounded-3xl p-6 md:p-8 border border-slate-100 shadow-sm space-y-8">
      {# Cover #}
      {% if post.cover %}
        <figure class="overflow-hidden rounded-2xl shadow-sm">
          <img src="{{ image_variant(post.cover, 'large') }}" alt="{{ post.title }}"
               loading="lazy" decoding="async"
               class="w-full max-h-[500px] object-cover">
        </figure>
      {% endif %}

      {# Body #}
      <div class="prose prose-slate max-w-none font-light
                  prose-headings:font-serif prose-headings:font-bold prose-headings:text-slate-900
                  prose-a:text-[var(--primary)] prose-a:underline-offset-2 prose-a:font-semibold
                  prose-img:rounded-xl prose-img:my-8 prose-img:shadow-sm
                  prose-blockquote:border-l-4 prose-blockquote:border-[var(--primary)] prose-blockquote:font-serif prose-blockquote:italic prose-blockquote:text-slate-700">
        {{ post.content|render_with_config|raw }}
      </div>

      {# Encart d'auteur & Bouton de partage #}
      <div class="pt-8 border-t border-slate-100 flex flex-wrap items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-[var(--primary)] text-white flex items-center justify-center font-bold font-serif text-sm shadow-sm shadow-[var(--primary)]/20">
            USM
          </div>
          <div>
            <p class="text-xs font-bold text-slate-800">Rédigé par l'USM Volley</p>
            <p class="text-[10px] text-slate-400 font-medium">Unions Salles Mios</p>
          </div>
        </div>
        
        <div class="flex items-center gap-2">
          <button onclick="navigator.clipboard.writeText(window.location.href); alert('Lien de l\'article copié dans le presse-papiers !');" 
                  class="px-3.5 py-2 bg-slate-50 hover:bg-slate-100 text-slate-500 hover:text-[var(--primary)] rounded-xl border border-slate-150/80 transition-all text-xs font-bold flex items-center gap-2"
                  title="Copier le lien de l'article">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244m6.513-2.513 2.513-2.513"></path>
            </svg>
            Partager l'article
          </button>
        </div>
      </div>

      {# Tags #}
      {% if tags|length %}
      <div class="pt-6 border-t border-slate-100">
        <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-3">Mots-clés</p>
        <div class="flex flex-wrap gap-2">
          {% for tag in tags %}
            <a href="{{ url('blog/tag/' ~ tag.slug) }}"
               class="inline-block px-3 py-1.5 rounded-xl text-xs bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold transition">
              #{{ tag.name }}
            </a>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      {{ components.gallery(photos) }}
    </article>

    {# Navigation #}
    <div class="mt-8 pt-8 border-t border-slate-200">
      <div class="grid grid-cols-1 md:grid-cols-3 items-center gap-4">
        <div>
          {% if prev_post %}
          <a href="{{ url('blog/' ~ prev_post.slug) }}"
             class="group flex flex-col bg-white border border-slate-100 hover:border-[var(--primary)] rounded-2xl transition-all duration-300 overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-0.5">
            {% if prev_post.cover %}
              <img src="{{ image_variant(prev_post.cover, 'thumb') }}" alt="" class="w-full h-24 object-cover">
            {% endif %}
            <div class="p-4">
              <span class="text-[10px] uppercase tracking-wider text-slate-400 font-bold inline-flex items-center gap-1">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Précédent
              </span>
              <p class="text-xs font-bold text-slate-800 group-hover:text-[var(--primary)] leading-snug transition line-clamp-2 mt-1">{{ prev_post.title }}</p>
            </div>
          </a>
          {% endif %}
        </div>
        
        <div class="text-center py-2">
          <a href="{{ url('blog') }}" class="inline-block btn-secondary text-xs uppercase tracking-wider px-4 py-2.5 rounded-xl font-bold transition">
            Toutes les actualités
          </a>
        </div>
        
        <div class="text-right">
          {% if next_post %}
          <a href="{{ url('blog/' ~ next_post.slug) }}"
             class="group flex flex-col bg-white border border-slate-100 hover:border-[var(--primary)] rounded-2xl transition-all duration-300 overflow-hidden items-end shadow-sm hover:shadow-md hover:-translate-y-0.5">
            {% if next_post.cover %}
              <img src="{{ image_variant(next_post.cover, 'thumb') }}" alt="" class="w-full h-24 object-cover">
            {% endif %}
            <div class="p-4 w-full">
              <span class="text-[10px] uppercase tracking-wider text-slate-400 font-bold inline-flex items-center gap-1 float-right">
                Suivant
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
              <div class="clear-both"></div>
              <p class="text-xs font-bold text-slate-800 group-hover:text-[var(--primary)] leading-snug transition line-clamp-2 mt-1 text-right">{{ next_post.title }}</p>
            </div>
          </a>
          {% endif %}
        </div>
      </div>
    </div>

  </div>
</div>
{% endblock %}

{% block scripts %}
{% if photos|length %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script>GLightbox({ selector: '.glightbox', touchNavigation: true, loop: true });</script>
{% endif %}
{% endblock %}
