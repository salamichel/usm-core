{% extends 'base.twig' %}
{% block title %}Actualités — USM Volley{% endblock %}

{% block content %}
<div class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">

  {# En-tête éditorial #}
  <div class="bg-slate-900 text-white pt-8 pb-24 md:pt-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <nav aria-label="Fil d'Ariane" class="text-sm text-slate-400 mb-6">
        <a href="{{ url('') }}" class="hover:text-white transition-colors">Accueil</a>
        <span class="mx-2 text-slate-600">/</span>
        <span class="text-slate-200">Actualités</span>
      </nav>
      
      <div class="grid md:grid-cols-3 gap-6 items-center">
        <div class="md:col-span-2">
          <span class="inline-block text-xs uppercase tracking-[0.25em] text-[var(--primary)] font-semibold mb-2">Le journal de l'USM</span>
          <h1 class="font-serif text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-3">Actualités</h1>
          <p class="text-slate-300 text-sm md:text-base max-w-xl font-light">Découvrez les compte-rendus de matchs, événements, portraits de joueurs et actualités au cœur de l'USM Volley-Ball.</p>
        </div>
        <div class="md:col-span-1">
          {# Formulaire de recherche #}
          <form method="GET" action="{{ url('blog') }}" class="relative w-full">
            {% if selected_tag %}
              <input type="hidden" name="tag" value="{{ selected_tag.slug }}">
            {% endif %}
            {% if selected_month %}
              <input type="hidden" name="month" value="{{ selected_month }}">
            {% endif %}
            <input type="text" name="q" value="{{ search_query }}" placeholder="Rechercher un article..."
                   class="w-full pl-10 pr-4 py-3 bg-slate-800/80 border border-slate-700/60 rounded-xl text-sm text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50 focus:border-[var(--primary)] transition-all">
            <span class="absolute left-3.5 top-3.5 text-slate-400">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
            </span>
          </form>
        </div>
      </div>
    </div>
  </div>

  {# Layout en double colonne #}
  <div class="max-w-6xl mx-auto px-4 sm:px-6 -mt-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      {# Colonne Principale (Articles) #}
      <div class="lg:col-span-2 space-y-8">
        
        {# Barre de filtres actifs #}
        {% if selected_tag or selected_month or search_query %}
          <div class="bg-white rounded-3xl p-5 border border-slate-100 shadow-sm flex flex-wrap items-center justify-between gap-4">
            <div class="flex flex-wrap items-center gap-2 text-xs font-semibold text-slate-600">
              {% if search_query %}
                <span class="px-3 py-1.5 bg-slate-100 rounded-xl inline-flex items-center gap-1.5">
                  Recherche : <strong class="text-slate-800">"{{ search_query }}"</strong>
                  <a href="{{ url('blog') ~ (selected_tag ? '?tag=' ~ selected_tag.slug : '') ~ (selected_month ? (selected_tag ? '&' : '?') ~ 'month=' ~ selected_month : '') }}" class="text-slate-400 hover:text-slate-600 transition" title="Supprimer la recherche">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                  </a>
                </span>
              {% endif %}
              
              {% if selected_tag %}
                <span class="px-3 py-1.5 bg-slate-100 rounded-xl inline-flex items-center gap-1.5">
                  Catégorie : <strong class="text-slate-800">{{ selected_tag.name }}</strong>
                  <a href="{{ url('blog') ~ (search_query ? '?q=' ~ search_query : '') ~ (selected_month ? (search_query ? '&' : '?') ~ 'month=' ~ selected_month : '') }}" class="text-slate-400 hover:text-slate-600 transition" title="Supprimer la catégorie">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                  </a>
                </span>
              {% endif %}
              
              {% if selected_month %}
                <span class="px-3 py-1.5 bg-slate-100 rounded-xl inline-flex items-center gap-1.5">
                  Mois : <strong class="text-slate-800">{{ selected_month|month_fr }}</strong>
                  <a href="{{ url('blog') ~ (search_query ? '?q=' ~ search_query : '') ~ (selected_tag ? (search_query ? '&' : '?') ~ 'tag=' ~ selected_tag.slug : '') }}" class="text-slate-400 hover:text-slate-600 transition" title="Supprimer le mois">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                  </a>
                </span>
              {% endif %}
            </div>
            <a href="{{ url('blog') }}" class="text-xs font-bold text-[var(--primary)] hover:underline">Réinitialiser les filtres</a>
          </div>
        {% endif %}

        {% if posts|length %}
          {# Article vedette #}
          {% if pagination.currentPage == 1 and not search_query and not selected_tag and not selected_month %}
            {% set featured = posts[0] %}
            <article class="bg-white rounded-3xl p-6 md:p-8 border border-slate-100 shadow-sm grid md:grid-cols-2 gap-8 items-center group hover:shadow-md transition-all duration-300">
              {% if featured.cover %}
                <a href="{{ url('blog/' ~ featured.slug) }}" class="block aspect-[4/3] overflow-hidden rounded-2xl bg-slate-100 shadow-sm">
                  <img src="{{ image_variant(featured.cover, 'medium') }}" alt="{{ featured.title }}"
                       loading="lazy" decoding="async"
                       class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]">
                </a>
              {% endif %}
              <div class="flex flex-col h-full justify-between py-2">
                <div>
                  <div class="flex flex-wrap items-center gap-2 mb-3">
                    {% if featured.tags|length %}
                      {% for tag in featured.tags %}
                        <a href="{{ url('blog/tag/' ~ tag.slug) }}" class="px-2.5 py-1 bg-slate-100 hover:bg-slate-200 text-slate-700 text-[10px] font-bold rounded-lg transition-colors">
                          {{ tag.name }}
                        </a>
                      {% endfor %}
                    {% endif %}
                    {% if featured.published_at %}
                      <time class="text-xs text-slate-400 font-semibold">{{ featured.published_at|date_fr }}</time>
                    {% endif %}
                  </div>
                  
                  <h2 class="font-serif text-2xl md:text-3xl font-bold leading-tight mb-4 text-slate-900 hover:text-[var(--primary)] transition">
                    <a href="{{ url('blog/' ~ featured.slug) }}">{{ featured.title }}</a>
                  </h2>
                  
                  {% if featured.excerpt %}
                    <p class="text-slate-500 leading-relaxed text-xs md:text-sm mb-6 line-clamp-4 font-light">{{ featured.excerpt }}</p>
                  {% endif %}
                </div>
                
                <a href="{{ url('blog/' ~ featured.slug) }}" class="text-xs font-bold text-[var(--primary)] hover:underline underline-offset-4 inline-flex items-center gap-1.5 self-start mt-auto">
                  Lire la suite
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
            </article>

            {# Liste des autres articles #}
            {% if posts|length > 1 %}
              <div class="grid gap-6 md:grid-cols-2">
                {% for post in posts|slice(1) %}
                  <article class="flex flex-col bg-white rounded-3xl p-5 border border-slate-100 shadow-sm hover:-translate-y-1 hover:shadow-md transition-all duration-300">
                    {% if post.cover %}
                      <a href="{{ url('blog/' ~ post.slug) }}" class="block aspect-[4/3] overflow-hidden rounded-2xl bg-slate-100 mb-4 group shadow-sm">
                        <img src="{{ image_variant(post.cover, 'medium') }}" alt="{{ post.title }}"
                             loading="lazy" decoding="async"
                             class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                      </a>
                    {% endif %}
                    <div class="flex flex-col flex-1">
                      <div class="flex flex-wrap items-center gap-2 mb-3">
                        {% if post.tags|length %}
                          {% for tag in post.tags %}
                            <a href="{{ url('blog/tag/' ~ tag.slug) }}" class="px-2 py-0.5 bg-slate-100 hover:bg-slate-200 text-slate-700 text-[10px] font-bold rounded-lg transition-colors">
                              {{ tag.name }}
                            </a>
                          {% endfor %}
                        {% endif %}
                        {% if post.published_at %}
                          <time class="text-[10px] text-slate-400 font-semibold">{{ post.published_at|date_fr }}</time>
                        {% endif %}
                      </div>
                      
                      <h3 class="font-serif text-base font-bold leading-tight mb-2 text-slate-900 hover:text-[var(--primary)] transition">
                        <a href="{{ url('blog/' ~ post.slug) }}">{{ post.title }}</a>
                      </h3>
                      
                      {% if post.excerpt %}
                        <p class="text-[11px] text-slate-500 leading-relaxed line-clamp-3 mb-4 font-light">{{ post.excerpt }}</p>
                      {% endif %}
                      
                      <a href="{{ url('blog/' ~ post.slug) }}" class="mt-auto text-xs font-bold text-[var(--primary)] hover:underline inline-flex items-center gap-1">
                        Lire l'article →
                      </a>
                    </div>
                  </article>
                {% endfor %}
              </div>
            {% endif %}

          {% else %}
            {# Grille de tous les articles si on est sur la page 2+ ou après filtre #}
            <div class="grid gap-6 md:grid-cols-2">
              {% for post in posts %}
                <article class="flex flex-col bg-white rounded-3xl p-5 border border-slate-100 shadow-sm hover:-translate-y-1 hover:shadow-md transition-all duration-300">
                  {% if post.cover %}
                    <a href="{{ url('blog/' ~ post.slug) }}" class="block aspect-[4/3] overflow-hidden rounded-2xl bg-slate-100 mb-4 group shadow-sm">
                      <img src="{{ image_variant(post.cover, 'medium') }}" alt="{{ post.title }}"
                           loading="lazy" decoding="async"
                           class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                    </a>
                  {% endif %}
                  <div class="flex flex-col flex-1">
                    <div class="flex flex-wrap items-center gap-2 mb-3">
                      {% if post.tags|length %}
                        {% for tag in post.tags %}
                          <a href="{{ url('blog/tag/' ~ tag.slug) }}" class="px-2 py-0.5 bg-slate-100 hover:bg-slate-200 text-slate-700 text-[10px] font-bold rounded-lg transition-colors">
                            {{ tag.name }}
                          </a>
                        {% endfor %}
                      {% endif %}
                      {% if post.published_at %}
                        <time class="text-[10px] text-slate-400 font-semibold">{{ post.published_at|date_fr }}</time>
                      {% endif %}
                    </div>
                    
                    <h3 class="font-serif text-base font-bold leading-tight mb-2 text-slate-900 hover:text-[var(--primary)] transition">
                      <a href="{{ url('blog/' ~ post.slug) }}">{{ post.title }}</a>
                    </h3>
                    
                    {% if post.excerpt %}
                      <p class="text-[11px] text-slate-500 leading-relaxed line-clamp-3 mb-4 font-light">{{ post.excerpt }}</p>
                    {% endif %}
                    
                    <a href="{{ url('blog/' ~ post.slug) }}" class="mt-auto text-xs font-bold text-[var(--primary)] hover:underline inline-flex items-center gap-1">
                      Lire l'article →
                    </a>
                  </div>
                </article>
              {% endfor %}
            </div>
          {% endif %}

        {% else %}
          {# Aucun résultat #}
          <div class="bg-white rounded-3xl p-12 text-center border border-slate-100 shadow-sm">
            <svg class="w-12 h-12 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"></path>
            </svg>
            <p class="text-slate-600 font-semibold mb-2">Aucun article ne correspond à votre recherche.</p>
            <p class="text-xs text-slate-400 mb-6 font-light">Essayez avec d'autres mots-clés ou explorez nos rubriques populaires dans la barre latérale.</p>
            <a href="{{ url('blog') }}" class="btn-primary text-xs py-2 px-4 rounded-xl font-bold inline-block">Voir tous les articles</a>
          </div>
        {% endif %}

        {# Pagination #}
        {% if pagination.totalPages > 1 %}
          <nav class="flex flex-wrap items-center justify-center gap-2 pt-10 border-t border-slate-200">
            {% set qs = (selected_tag ? '&tag=' ~ selected_tag.slug : '') ~ (selected_month ? '&month=' ~ selected_month : '') ~ (search_query ? '&q=' ~ search_query : '') %}

            {% if pagination.hasPrevious() %}
              <a href="{{ url('blog') ~ '?page=' ~ pagination.previousPage() ~ qs }}"
                 class="btn-secondary text-xs py-1.5 px-3 rounded-xl font-bold">← Précédent</a>
            {% else %}
              <span class="inline-flex px-3 py-1.5 rounded-xl border border-slate-200 text-xs font-bold text-slate-300">← Précédent</span>
            {% endif %}

            <div class="flex gap-1 mx-2">
              {% for page in pagination.getPageRange(7) %}
                {% if page == pagination.currentPage %}
                  <span class="px-3.5 py-1.5 rounded-xl bg-[var(--primary)] text-white text-sm font-bold">{{ page }}</span>
                {% else %}
                  <a href="{{ url('blog') ~ '?page=' ~ page ~ qs }}"
                     class="px-3.5 py-1.5 rounded-xl border border-slate-200 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:border-slate-300 transition">{{ page }}</a>
                {% endif %}
              {% endfor %}
            </div>

            {% if pagination.hasNext() %}
              <a href="{{ url('blog') ~ '?page=' ~ pagination.nextPage() ~ qs }}"
                 class="btn-secondary text-xs py-1.5 px-3 rounded-xl font-bold">Suivant →</a>
            {% else %}
              <span class="inline-flex px-3 py-1.5 rounded-xl border border-slate-200 text-xs font-bold text-slate-300">Suivant →</span>
            {% endif %}
          </nav>

          <p class="text-center text-xs text-slate-400 mt-4 font-semibold">Page {{ pagination.currentPage }} / {{ pagination.totalPages }}</p>
        {% endif %}

        <div class="pt-6">
          <a href="{{ url('') }}" class="text-sm font-semibold text-[var(--primary)] hover:underline inline-flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Retour à l'accueil
          </a>
        </div>

      </div>

      {# Colonne Latérale (Sidebar éditoriale) #}
      <div class="lg:col-span-1 space-y-6">

        {# Widget 1 : Présentation du journal #}
        <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm">
          <h3 class="font-serif text-base font-extrabold text-slate-900 mb-4 pb-2 border-b border-slate-100">Le Club</h3>
          <p class="text-xs text-slate-500 leading-relaxed mb-4 font-light">Bienvenue sur le journal officiel de l'USM Volley. Suivez au quotidien la vie de nos équipes, les résultats des matchs et la vie associative du club.</p>
          <div class="grid grid-cols-2 gap-3 text-center">
            <div class="bg-slate-50/80 p-3 rounded-2xl border border-slate-100">
              <span class="block text-xl font-black text-slate-800">{{ total_all_posts }}</span>
              <span class="text-[9px] uppercase font-bold text-slate-400">Articles</span>
            </div>
            <div class="bg-slate-50/80 p-3 rounded-2xl border border-slate-100">
              <span class="block text-xl font-black text-slate-800">{{ all_tags|length }}</span>
              <span class="text-[9px] uppercase font-bold text-slate-400">Rubriques</span>
            </div>
          </div>
        </div>

        {# Widget 2 : Catégories / Rubriques #}
        <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm">
          <h3 class="font-serif text-base font-extrabold text-slate-900 mb-4 pb-2 border-b border-slate-100">Rubriques</h3>
          <div class="flex flex-wrap gap-2">
            <a href="{{ url('blog') ~ (search_query ? '?q=' ~ search_query : '') ~ (selected_month ? (search_query ? '&' : '?') ~ 'month=' ~ selected_month : '') }}" 
               class="px-3 py-1.5 rounded-xl text-xs font-bold transition-all {{ not selected_tag ? 'bg-[var(--primary)] text-white shadow-sm shadow-[var(--primary)]/20' : 'bg-slate-100 hover:bg-slate-200 text-slate-700' }}">
              Toutes
            </a>
            {% for tag in all_tags %}
              {% set count = tag_counts[tag.id] ?? 0 %}
              {% if count > 0 %}
                <a href="{{ url('blog/tag/' ~ tag.slug) ~ (search_query ? '?q=' ~ search_query : '') ~ (selected_month ? '&month=' ~ selected_month : '') }}" 
                   class="px-3 py-1.5 rounded-xl text-xs font-bold transition-all {{ selected_tag and selected_tag.id == tag.id ? 'bg-[var(--primary)] text-white shadow-sm shadow-[var(--primary)]/20' : 'bg-slate-100 hover:bg-slate-200 text-slate-700' }}">
                  {{ tag.name }} <span class="opacity-60 ml-0.5 text-[10px]">({{ count }})</span>
                </a>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {# Widget 3 : Archives chronologiques #}
        {% if months|length %}
          <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm">
            <h3 class="font-serif text-base font-extrabold text-slate-900 mb-4 pb-2 border-b border-slate-100">Archives</h3>
            <div class="space-y-1 max-h-48 overflow-y-auto pr-1">
              <a href="{{ url('blog') ~ (search_query ? '?q=' ~ search_query : '') ~ (selected_tag ? (search_query ? '&' : '?') ~ 'tag=' ~ selected_tag.slug : '') }}" 
                 class="block px-3 py-2 rounded-xl text-xs font-semibold transition {{ not selected_month ? 'bg-slate-50 text-[var(--primary)] font-bold' : 'text-slate-600 hover:bg-slate-50' }}">
                Tous les mois
              </a>
              {% for month in months %}
                <a href="{{ url('blog') ~ '?month=' ~ month ~ (search_query ? '&q=' ~ search_query : '') ~ (selected_tag ? '&tag=' ~ selected_tag.slug : '') }}"
                   class="block px-3 py-2 rounded-xl text-xs font-semibold transition {{ selected_month == month ? 'bg-slate-50 text-[var(--primary)] font-bold' : 'text-slate-600 hover:bg-slate-50' }}">
                  {{ month|month_fr }}
                </a>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {# Widget 4 : Prochains Matchs #}
        {% if upcoming_matches|length %}
          <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm">
            <h3 class="font-serif text-base font-extrabold text-slate-900 mb-4 pb-2 border-b border-slate-100">Prochains Matchs</h3>
            <div class="space-y-4">
              {% for match in upcoming_matches %}
                <div class="border-b border-slate-50 pb-3 last:border-0 last:pb-0">
                  <div class="flex items-center justify-between gap-2 mb-1">
                    <span class="text-[9px] uppercase font-extrabold text-[var(--primary)] bg-[var(--primary)]/10 px-1.5 py-0.5 rounded">{{ match.location }}</span>
                    <span class="text-[10px] text-slate-400 font-semibold">{{ match.date_display }}</span>
                  </div>
                  <p class="text-xs font-bold text-slate-800 line-clamp-1 mt-1">{{ match.title }}</p>
                  <p class="text-[9px] text-slate-400 font-light mt-0.5">{{ saison_active }}</p>
                </div>
              {% endfor %}
            </div>
            <a href="{{ url('agenda') }}" class="block text-center text-xs font-bold text-[var(--primary)] hover:underline mt-4 pt-3 border-t border-slate-50">
              Voir l'agenda complet →
            </a>
          </div>
        {% endif %}

        {# Widget 5 : Réseaux Sociaux #}
        {% if site_config.facebook_url or site_config.instagram_url %}
          <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm">
            <h3 class="font-serif text-base font-extrabold text-slate-900 mb-3 pb-2 border-b border-slate-100">Suivez-nous</h3>
            <p class="text-xs text-slate-500 leading-relaxed mb-4 font-light">Retrouvez toutes les photos et les actualités en direct sur nos réseaux.</p>
            
            <div class="flex items-center justify-center gap-3">
              {% if site_config.facebook_url %}
                <a href="{{ site_config.facebook_url }}" target="_blank" class="p-2.5 bg-slate-50 hover:bg-slate-100 text-slate-600 hover:text-[var(--primary)] rounded-xl border border-slate-100 transition-all text-xs font-bold flex items-center justify-center gap-2 flex-1" title="Facebook">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/></svg>
                  Facebook
                </a>
              {% endif %}
              {% if site_config.instagram_url %}
                <a href="{{ site_config.instagram_url }}" target="_blank" class="p-2.5 bg-slate-50 hover:bg-slate-100 text-slate-600 hover:text-[var(--primary)] rounded-xl border border-slate-100 transition-all text-xs font-bold flex items-center justify-center gap-2 flex-1" title="Instagram">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                  Instagram
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}

      </div>

    </div>
  </div>

</div>
{% endblock %}
