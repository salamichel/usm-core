{% extends 'base.twig' %}
{% block title %}Actualités — USM Volley{% endblock %}

{% block content %}
<div class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">

  {# En-tête #}
  <div class="bg-slate-900 text-white pt-8 pb-20 md:pt-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <nav aria-label="Fil d'Ariane" class="text-sm text-slate-400 mb-6">
        <a href="{{ url('') }}" class="hover:text-white transition-colors">Accueil</a>
        <span class="mx-2 text-slate-600">/</span>
        <span class="text-slate-200">Actualités</span>
      </nav>
      
      <div>
        <span class="inline-block text-xs uppercase tracking-[0.25em] text-[var(--primary)] font-semibold mb-2">Le journal</span>
        <h1 class="font-serif text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-3">Actualités</h1>
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 -mt-10">

  {# Filtres #}
  {% if all_tags|length or months|length %}
  <form method="GET" action="{{ url('blog') }}" class="bg-white rounded-3xl p-5 mb-8 flex flex-wrap items-center gap-4 border border-slate-100 shadow-sm">
    {% if all_tags|length %}
    <div class="flex items-center gap-2">
      <label class="text-xs uppercase tracking-wider text-slate-400 font-semibold">Catégorie</label>
      <select name="tag" onchange="this.form.submit()"
              class="rounded-xl border border-slate-200 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 focus:border-[var(--primary)] transition-all">
        <option value="">Toutes</option>
        {% for tag in all_tags %}
          {% set count = tag_counts[tag.id] ?? 0 %}
          {% if count > 0 %}
            <option value="{{ tag.slug }}" {{ selected_tag and selected_tag.id == tag.id ? 'selected' : '' }}>
              {{ tag.name }} ({{ count }})
            </option>
          {% endif %}
        {% endfor %}
      </select>
    </div>
    {% endif %}

    {% if months|length %}
    <div class="flex items-center gap-2">
      <label class="text-xs uppercase tracking-wider text-slate-400 font-semibold">Mois</label>
      <select name="month" onchange="this.form.submit()"
              class="rounded-xl border border-slate-200 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 focus:border-[var(--primary)] transition-all">
        <option value="">Tous</option>
        {% for month in months %}
          <option value="{{ month }}" {{ selected_month == month ? 'selected' : '' }}>{{ month|month_fr }}</option>
        {% endfor %}
      </select>
    </div>
    {% endif %}

    <noscript><button type="submit" class="btn-primary text-xs py-1.5 rounded-xl font-bold">Filtrer</button></noscript>

    {% if selected_tag or selected_month %}
      <a href="{{ url('blog') }}" class="ml-auto text-sm text-slate-555 hover:text-[var(--primary)] underline underline-offset-2 font-semibold">Réinitialiser</a>
    {% endif %}
  </form>
  {% endif %}

  {# Articles #}
  {% if posts|length %}

    {# Article vedette #}
    {% set featured = posts[0] %}
    <article class="bg-white rounded-3xl p-6 md:p-8 border border-slate-100 shadow-sm mb-12 grid md:grid-cols-2 gap-10 items-center group">
      {% if featured.cover %}
        <a href="{{ url('blog/' ~ featured.slug) }}" class="block aspect-[4/3] overflow-hidden rounded-2xl bg-slate-100">
          <img src="{{ image_variant(featured.cover, 'medium') }}" alt="{{ featured.title }}"
               loading="lazy" decoding="async"
               class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]">
        </a>
      {% endif %}
      <div>
        {% if featured.published_at %}
          <time class="text-xs uppercase tracking-wider text-slate-400 font-semibold block mb-3">{{ featured.published_at|date_fr }}</time>
        {% endif %}
        <h2 class="font-serif text-3xl md:text-4xl font-semibold leading-tight mb-4 text-slate-900 hover:text-[var(--primary)] transition">
          <a href="{{ url('blog/' ~ featured.slug) }}">{{ featured.title }}</a>
        </h2>
        {% if featured.excerpt %}
          <p class="text-slate-655 leading-relaxed text-sm md:text-base mb-6 line-clamp-4">{{ featured.excerpt }}</p>
        {% endif %}
        <a href="{{ url('blog/' ~ featured.slug) }}" class="text-sm font-bold text-[var(--primary)] hover:underline underline-offset-4 inline-flex items-center gap-1">
          Lire la suite
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </article>

    {# Grille #}
    {% if posts|length > 1 %}
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {% for post in posts|slice(1) %}
      <article class="flex flex-col bg-white rounded-3xl p-5 border border-slate-100 shadow-sm hover:-translate-y-1 hover:shadow-md transition-all duration-200">
        {% if post.cover %}
          <a href="{{ url('blog/' ~ post.slug) }}" class="block aspect-[4/3] overflow-hidden rounded-2xl bg-slate-100 mb-5 group">
            <img src="{{ image_variant(post.cover, 'medium') }}" alt="{{ post.title }}"
                 loading="lazy" decoding="async"
                 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
          </a>
        {% endif %}
        <div class="flex flex-col flex-1">
          {% if post.published_at %}
            <time class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-2">{{ post.published_at|date_fr }}</time>
          {% endif %}
          <h3 class="font-serif text-lg font-bold leading-tight mb-3 text-slate-900 hover:text-[var(--primary)] transition">
            <a href="{{ url('blog/' ~ post.slug) }}">{{ post.title }}</a>
          </h3>
          {% if post.excerpt %}
            <p class="text-xs text-slate-500 leading-relaxed line-clamp-3 mb-4">{{ post.excerpt }}</p>
          {% endif %}
          <a href="{{ url('blog/' ~ post.slug) }}" class="mt-auto text-xs font-bold text-[var(--primary)] hover:underline underline-offset-4">Lire →</a>
        </div>
      </article>
      {% endfor %}
    </div>
    {% endif %}

  {% else %}
    <p class="text-slate-500 italic text-center py-20 bg-white rounded-3xl border border-slate-100 shadow-sm">Aucun article pour ces filtres.</p>
  {% endif %}

  {# Pagination #}
  {% if pagination.totalPages > 1 %}
  <nav class="flex flex-wrap items-center justify-center gap-2 mt-16 pt-10 border-t border-slate-250">
    {% set qs = (selected_tag ? '&tag=' ~ selected_tag.slug : '') ~ (selected_month ? '&month=' ~ selected_month : '') %}

    {% if pagination.hasPrevious() %}
      <a href="{{ url('blog') ~ '?page=' ~ pagination.previousPage() ~ qs }}"
         class="btn-secondary text-xs py-1.5 px-3 rounded-xl font-bold">← Précédent</a>
    {% else %}
      <span class="inline-flex px-3 py-1.5 rounded-xl border border-slate-200 text-xs font-bold text-slate-300">← Précédent</span>
    {% endif %}

    <div class="flex gap-1 mx-2">
      {% for page in pagination.getPageRange(7) %}
        {% if page == pagination.currentPage %}
          <span class="px-3.5 py-1.5 rounded-xl bg-[var(--primary)] text-white text-sm font-bold">{{ page }}</span>
        {% else %}
          <a href="{{ url('blog') ~ '?page=' ~ page ~ qs }}"
             class="px-3.5 py-1.5 rounded-xl border border-slate-200 text-sm font-bold text-slate-700 hover:bg-slate-50 hover:border-slate-300 transition">{{ page }}</a>
        {% endif %}
      {% endfor %}
    </div>

    {% if pagination.hasNext() %}
      <a href="{{ url('blog') ~ '?page=' ~ pagination.nextPage() ~ qs }}"
         class="btn-secondary text-xs py-1.5 px-3 rounded-xl font-bold">Suivant →</a>
    {% else %}
      <span class="inline-flex px-3 py-1.5 rounded-xl border border-slate-200 text-xs font-bold text-slate-300">Suivant →</span>
    {% endif %}
  </nav>

  <p class="text-center text-xs text-slate-400 mt-4 font-semibold">Page {{ pagination.currentPage }} / {{ pagination.totalPages }}</p>
  {% endif %}

  <div class="mt-12 pb-6">
    <a href="/" class="text-sm font-medium text-[var(--primary)] hover:underline underline-offset-4">← Retour à l'accueil</a>
  </div>
</div>
</div>
{% endblock %}
