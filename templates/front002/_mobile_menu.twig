{# ── Menu mobile ───────────────────────────────────────────────────────────── #}
<nav id="mobile-menu" class="hidden md:hidden bg-white border-b border-slate-200" aria-label="Navigation mobile" aria-hidden="true">
  <div class="px-6 py-4 space-y-1">
    {% for item in menu_items %}
      {% if item.children|length %}
        <button type="button"
                data-submenu-toggle="mob-sub-{{ loop.index }}"
                aria-expanded="false"
                aria-controls="mob-sub-{{ loop.index }}"
                class="w-full text-left px-3 py-2.5 rounded-md hover:bg-slate-50 transition flex items-center justify-between text-sm font-medium text-slate-900 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]">
          {{ item.label }}
          <svg class="caret w-4 h-4 transition-transform flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div id="mob-sub-{{ loop.index }}" class="hidden pl-4 border-l border-slate-200 ml-3 space-y-0.5">
          {% for child in item.children %}
            {% if child.children|length %}
              <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 pt-3 pb-1 px-3">{{ child.label }}</p>
              {% for sub in child.children %}
                <a href="{{ item_url(sub) }}" class="block px-3 py-2 text-sm text-slate-700 hover:bg-slate-50 rounded-md transition">{{ sub.label }}</a>
              {% endfor %}
            {% else %}
              <a href="{{ item_url(child) }}" class="block px-3 py-2 text-sm text-slate-700 hover:bg-slate-50 rounded-md transition">{{ child.label }}</a>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <a href="{{ item_url(item) }}" class="block px-3 py-2.5 rounded-md hover:bg-slate-50 transition text-sm font-medium text-slate-900">{{ item.label }}</a>
      {% endif %}
    {% endfor %}
  </div>
</nav>
