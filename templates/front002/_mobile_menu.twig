{# ── Menu mobile ───────────────────────────────────────────────────────────── #}
<nav id="mobile-menu" class="hidden md:hidden bg-white border-b border-slate-200" aria-label="Navigation mobile" aria-hidden="true">
  <div class="px-6 py-4 space-y-1">
    {% for item in menu_items %}
      {% if item.children|length %}
        <button type="button"
                data-submenu-toggle="mob-sub-{{ loop.index }}"
                aria-expanded="false"
                aria-controls="mob-sub-{{ loop.index }}"
                class="w-full text-left px-3 py-2.5 rounded-md hover:bg-slate-50 transition flex items-center justify-between text-sm font-medium text-slate-900 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]">
          {{ item.label }}
          <svg class="caret w-4 h-4 transition-transform flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div id="mob-sub-{{ loop.index }}" class="hidden pl-4 border-l border-slate-200 ml-3 space-y-0.5">
          {% for child in item.children %}
            {% if child.children|length %}
              <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 pt-3 pb-1 px-3">{{ child.label }}</p>
              {% for sub in child.children %}
                <a href="{{ item_url(sub) }}" class="block px-3 py-2 text-sm text-slate-700 hover:bg-slate-50 rounded-md transition">{{ sub.label }}</a>
              {% endfor %}
            {% else %}
              <a href="{{ item_url(child) }}" class="block px-3 py-2 text-sm text-slate-700 hover:bg-slate-50 rounded-md transition">{{ child.label }}</a>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <a href="{{ item_url(item) }}" class="block px-3 py-2.5 rounded-md hover:bg-slate-50 transition text-sm font-medium text-slate-900">{{ item.label }}</a>
      {% endif %}
    {% endfor %}
  </div>

  {# ── Connexion / Compte en bas du menu mobile ─────────────────────────── #}
  <div class="mobile-menu-auth">
    {% if app.session.user_name is defined %}
      <a href="{{ url('member/dashboard') }}" class="mobile-menu-auth-link">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        <span>Mon espace — <strong>{{ app.session.user_name }}</strong></span>
      </a>
      <form action="{{ url('member/logout') }}" method="POST">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
        <button type="submit" class="mobile-menu-auth-link mobile-menu-auth-danger">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Se déconnecter
        </button>
      </form>
    {% else %}
      <a href="{{ url('member/login') }}" class="mobile-menu-login-btn">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
        </svg>
        Se connecter à votre espace membre
      </a>
    {% endif %}
  </div>
</nav>
