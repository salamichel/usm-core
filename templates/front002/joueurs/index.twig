{% extends "base.twig" %}

{% block title %}Gestion des Joueurs - Back-Office{% endblock %}

{% block content %}
<div class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">
    {# En-tête #}
    <div class="bg-slate-900 text-white pt-8 pb-20 md:pt-12">
        <div class="max-w-6xl mx-auto px-4 sm:px-6">
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
                <div>
                    <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight flex items-center gap-2">
                        👥 Base de données des Joueurs
                    </h1>
                    <p class="text-slate-400 text-sm md:text-base mt-1">Ajout et suppression des membres dans la base de données principale.</p>
                </div>
                
                <div class="flex flex-wrap gap-3">
                    <a href="{{ url('dashboard') }}" class="bg-white/10 hover:bg-white/20 text-white px-4 py-2 rounded-lg font-medium transition flex items-center gap-2 text-sm shadow-sm">
                        ← Retour au Dashboard Webmaster
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 -mt-10">

    {# FORMULAIRE D'AJOUT #}
    <div class="bg-white rounded-3xl mb-10 overflow-hidden border border-slate-100 shadow-sm">
        <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50">
            <h3 class="text-lg leading-6 font-bold text-slate-900">Ajouter un nouveau joueur</h3>
        </div>
        <div class="p-6 md:p-8">
            <form action="{{ url('joueurs/store') }}" method="POST" class="sm:flex sm:items-end gap-4">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                
                <div class="w-full sm:max-w-xs">
                    <label for="Nom" class="block text-sm font-semibold text-slate-700 mb-1">Nom</label>
                    <input type="text" name="Nom" id="Nom" required class="w-full rounded-xl border border-slate-200 bg-white py-2.5 px-3.5 focus:border-[var(--primary)] focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 text-sm font-semibold transition-all text-slate-800">
                </div>
                
                <div class="w-full sm:max-w-xs mt-4 sm:mt-0">
                    <label for="Prenom" class="block text-sm font-semibold text-slate-700 mb-1">Prénom</label>
                    <input type="text" name="Prenom" id="Prenom" required class="w-full rounded-xl border border-slate-200 bg-white py-2.5 px-3.5 focus:border-[var(--primary)] focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 text-sm font-semibold transition-all text-slate-800">
                </div>

                <div class="mt-4 sm:mt-0">
                    <button type="submit" class="inline-flex justify-center rounded-xl bg-[var(--primary)] py-3 px-5 text-sm font-bold text-white shadow-sm hover:bg-opacity-95 cursor-pointer transition-all">
                        Ajouter
                    </button>
                </div>
            </form>
            <p class="text-xs text-slate-400 mt-4 font-semibold">💡 Un mot de passe aléatoire sera généré automatiquement lors de la création.</p>
        </div>
    </div>

    {# LISTE DES JOUEURS #}
    <div class="bg-white rounded-3xl overflow-hidden border border-slate-100 shadow-sm">
        <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
            <h3 class="text-lg leading-6 font-bold text-slate-900">Liste des adhérents ({{ joueurs|length }})</h3>
        </div>
        
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100">
                <thead class="bg-slate-50/50">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Identité</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Équipes / Catégories</th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-bold text-slate-400 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-100">
                    {% for joueur in joueurs %}
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm font-bold text-slate-800">{{ joueur.Nom|upper }} {{ joueur.Prénom }}</div>
                                {% if joueur.Mel %}
                                    <div class="text-xs text-slate-400 font-semibold">{{ joueur.Mel }}</div>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-wrap gap-1">
                                    
                                    {% set has_equipe = false %}
                                    {% for equipe in categories %}
                                        {% if joueur[equipe] and joueur[equipe] != '0' and joueur[equipe] != '' %}
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-xl text-xs font-bold bg-blue-50 text-blue-700 border border-blue-100">
                                                {{ equipe }}
                                            </span>
                                            {% set has_equipe = true %}
                                        {% endif %}
                                    {% endfor %}

                                    {% if not has_equipe %}
                                        <span class="text-xs text-slate-400 italic font-semibold">Aucune affectation</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-semibold">
                                <form action="{{ url('joueurs/delete/' ~ joueur.id_joueur) }}" method="POST" class="inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer {{ joueur.Prénom }} {{ joueur.Nom }} de la base de données ? Cette action est irréversible.');">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                                    <button type="submit" class="text-red-650 hover:text-red-700 font-bold text-xs cursor-pointer">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="px-6 py-8 text-center text-sm text-slate-400 italic">
                                Aucun joueur dans la base de données.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>
</div>
{% endblock %}