{% extends "base.twig" %}

{% block title %}Agenda - Filtres{% endblock %}

{% block content %}
{# --- MACRO DE CONSTRUCTION D'URL (Inchangée) --- #}
{% macro buildUrl(currentFilters, keyToRemove, keyToAdd, valueToAdd) %}
    {%- set queryParams = [] -%}
    {%- for k, v in currentFilters -%}
        {%- if k != keyToRemove -%}
            {%- set enc_val = v is same as(true) ? '1' : v|url_encode -%}
            {%- set queryParams = queryParams|merge([k ~ '=' ~ enc_val]) -%}
        {%- endif -%}
    {%- endfor -%}
    {%- if keyToAdd is not null and valueToAdd is not null -%}
        {%- set queryParams = queryParams|merge([keyToAdd ~ '=' ~ valueToAdd|url_encode]) -%}
    {%- endif -%}
    {%- if queryParams is not empty -%}
        /agenda?{{ queryParams|join('&') }}
    {%- else -%}
        /agenda
    {%- endif -%}
{% endmacro %}

<div class="max-w-6xl mx-auto px-6 py-16">

    {# Bouton d'ouverture du Sidebar sur Mobile (Masqué sur Desktop) #}
    <div class="mb-6 md:hidden">
        <button id="filters-open-btn" class="w-full px-4 py-2.5 bg-white hover:bg-slate-50 border border-slate-300 shadow-sm rounded-lg text-sm font-medium text-slate-700 flex items-center justify-center gap-2 transition-colors">
            <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
            Afficher les filtres
        </button>
    </div>

    {# Overlay sombre pour mobile (Cliquable pour fermer) #}
    <div id="filter-backdrop" class="fixed inset-0 bg-slate-900/50 z-40 hidden md:hidden transition-opacity backdrop-blur-sm"></div>

    {# Panneau de filtres : Sidebar sur Mobile / Boîte sur Desktop #}
    <div id="filter-sidebar" class="
        fixed inset-y-0 left-0 z-50 w-[85%] max-w-sm h-full overflow-y-auto bg-white shadow-2xl transform -translate-x-full transition-transform duration-300 ease-in-out
        md:relative md:w-full md:max-w-none md:h-auto md:overflow-visible md:transform-none md:shadow-sm md:rounded-xl md:border md:border-slate-200 md:z-0 md:mb-8 md:block
    ">
        <div class="p-6">
            
            {# En-tête du panneau #}
            <div class="flex justify-between items-center mb-6">
                <h2 class="font-serif text-xl md:text-lg font-semibold text-slate-900">Filtres</h2>
                
                <div class="flex items-center gap-4">
                    {% if filters is not empty %}
                        <a href="/agenda" class="text-sm text-slate-600 hover:text-blue-600 underline underline-offset-4 transition-colors">Réinitialiser</a>
                    {% endif %}
                    
                    {# Bouton de fermeture (Uniquement sur Mobile) #}
                    <button id="filters-close-btn" class="md:hidden p-2 -mr-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-full transition-colors">
                        <span class="sr-only">Fermer les filtres</span>
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </div>
            </div>

            <div class="space-y-8 md:space-y-6">

                {# Type d'évènement #}
                <div>
                    <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-3">Type d'évènement</p>
                    <div class="flex flex-wrap gap-2">
                        <a href="{{ _self.buildUrl(filters, 'type', null, null) }}" 
                           class="px-4 py-2 md:px-3 md:py-1.5 text-sm md:text-xs rounded-full font-medium transition-colors {% if not filters.type %}bg-blue-600 text-white shadow-sm{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
                            Tous
                        </a>
                        <a href="{{ _self.buildUrl(filters, 'type', 'type', 'Match') }}" 
                           class="px-4 py-2 md:px-3 md:py-1.5 text-sm md:text-xs rounded-full font-medium transition-colors {% if filters.type == 'Match' %}bg-blue-600 text-white shadow-sm{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
                            Matchs
                        </a>
                        <a href="{{ _self.buildUrl(filters, 'type', 'type', 'Présences - Entrainement') }}" 
                           class="px-4 py-2 md:px-3 md:py-1.5 text-sm md:text-xs rounded-full font-medium transition-colors {% if filters.type == 'Présences - Entrainement' %}bg-blue-600 text-white shadow-sm{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
                            Entraînements
                        </a>
                    </div>
                </div>

                {# Menus déroulants (Manifestation, Équipe, Lieu) #}
                <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                    
                    {% if filterOptions.manifestationNames %}
                    <div>
                        <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-2">Manifestation</p>
                        {% set url_without_manif = _self.buildUrl(filters, 'manifestation', null, null) %}
                        {% set sep_manif = url_without_manif ends with '/agenda' ? '?' : '&' %}
                        <select onchange="window.location.href = this.value ? '{{ url_without_manif ~ sep_manif }}manifestation=' + encodeURIComponent(this.value) : '{{ url_without_manif }}';"
                                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 md:py-2 text-sm font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 appearance-none bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23475569%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E')] bg-[length:0.7rem_0.7rem] bg-[right_0.75rem_center] bg-no-repeat pr-8">
                            <option value="">Tous les événements</option>
                            {% for name in filterOptions.manifestationNames %}
                                <option value="{{ name }}" {% if filters.manifestation == name %}selected{% endif %}>{{ name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    {% endif %}

                    {% if filterOptions.teams %}
                    <div>
                        <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-2">Équipe</p>
                        {% set url_without_team = _self.buildUrl(filters, 'team', null, null) %}
                        {% set sep_team = url_without_team ends with '/agenda' ? '?' : '&' %}
                        <select onchange="window.location.href = this.value ? '{{ url_without_team ~ sep_team }}team=' + encodeURIComponent(this.value) : '{{ url_without_team }}';"
                                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 md:py-2 text-sm font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 appearance-none bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23475569%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E')] bg-[length:0.7rem_0.7rem] bg-[right_0.75rem_center] bg-no-repeat pr-8">
                            <option value="">Toutes les équipes</option>
                            {% for team in filterOptions.teams %}
                                <option value="{{ team }}" {% if filters.team == team %}selected{% endif %}>{{ team }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    {% endif %}

                    {% if filterOptions.locations %}
                    <div>
                        <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-2">Lieu</p>
                        {% set url_without_location = _self.buildUrl(filters, 'location', null, null) %}
                        {% set sep_location = url_without_location ends with '/agenda' ? '?' : '&' %}
                        <select onchange="window.location.href = this.value ? '{{ url_without_location ~ sep_location }}location=' + encodeURIComponent(this.value) : '{{ url_without_location }}';"
                                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 md:py-2 text-sm font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 appearance-none bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23475569%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E')] bg-[length:0.7rem_0.7rem] bg-[right_0.75rem_center] bg-no-repeat pr-8">
                            <option value="">Tous les lieux</option>
                            {% for location in filterOptions.locations %}
                                <option value="{{ location }}" {% if filters.location == location %}selected{% endif %}>{{ location }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    {% endif %}
                </div>

                {# Affichage #}
                <div class="pt-6 md:pt-5 border-t border-slate-200">
                    <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-3">Affichage</p>
                    <div class="flex flex-wrap gap-2">
                        <a href="{{ _self.buildUrl(filters, 'hide_empty_players', null, null) }}" 
                           class="px-4 py-2 md:px-3 md:py-1.5 text-sm md:text-xs rounded-full font-medium transition-colors {% if not filters.hide_empty_players %}bg-blue-600 text-white shadow-sm{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
                            Liste complète
                        </a>
                        <a href="{{ _self.buildUrl(filters, 'hide_empty_players', 'hide_empty_players', '1') }}" 
                           class="px-4 py-2 md:px-3 md:py-1.5 text-sm md:text-xs rounded-full font-medium transition-colors {% if filters.hide_empty_players %}bg-blue-600 text-white shadow-sm{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
                            Ayant répondu
                        </a>
                    </div>
                </div>

                {# Période #}
                <div class="pt-6 md:pt-5 border-t border-slate-200">
                    <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-3">Période</p>
                    <div class="flex flex-wrap gap-2">
                        <a href="{{ _self.buildUrl(filters, 'this_week', null, null) }}" 
                           class="px-4 py-2 md:px-3 md:py-1.5 text-sm md:text-xs rounded-full font-medium transition-colors {% if not filters.this_week %}bg-blue-600 text-white shadow-sm{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
                            Tous les événements
                        </a>
                        <a href="{{ _self.buildUrl(filters, 'this_week', 'this_week', '1') }}" 
                           class="px-4 py-2 md:px-3 md:py-1.5 text-sm md:text-xs rounded-full font-medium transition-colors {% if filters.this_week %}bg-blue-600 text-white shadow-sm{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
                            Semaine courante
                        </a>
                    </div>
                </div>
                
            </div>
        </div>
    </div>

    {# --- LISTE DES MANIFESTATIONS (Exemple d'espace de contenu) --- #}
    {# <div class="bg-white shadow overflow-hidden sm:rounded-md"> ... </div> #}

</div>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const openBtn = document.getElementById('filters-open-btn');
    const closeBtn = document.getElementById('filters-close-btn');
    const sidebar = document.getElementById('filter-sidebar');
    const backdrop = document.getElementById('filter-backdrop');

    // Ouvre le menu latéral
    function openFilters() {
        backdrop.classList.remove('hidden');
        // Un très léger délai pour permettre à Tailwind de gérer la transition après avoir retiré "hidden"
        setTimeout(() => {
            sidebar.classList.remove('-translate-x-full');
            document.body.style.overflow = 'hidden'; // Empêche de scroller la page derrière le menu
        }, 10);
    }

    // Ferme le menu latéral
    function closeFilters() {
        sidebar.classList.add('-translate-x-full');
        document.body.style.overflow = ''; // Restaure le scroll
        
        // Attend la fin de l'animation pour cacher le fond sombre
        setTimeout(() => {
            backdrop.classList.add('hidden');
        }, 300);
    }

    if (openBtn && closeBtn && sidebar && backdrop) {
        openBtn.addEventListener('click', openFilters);
        closeBtn.addEventListener('click', closeFilters);
        // Fermer le menu si on clique sur le fond sombre
        backdrop.addEventListener('click', closeFilters);
    }
});
</script>
{% endblock %}