{# Agenda filter panel - editorial style #}
<div class="bg-white rounded-3xl p-6 mb-6 border border-slate-100 shadow-sm" id="filters">
  <div class="flex justify-between items-center mb-5">
    <h2 class="font-serif text-lg font-bold text-slate-900">Filtres</h2>
    {% if filters is not empty %}
      <button type="button" onclick="resetAgendaFilters()" class="text-sm text-slate-500 hover:text-[var(--primary)] underline underline-offset-4 transition cursor-pointer font-semibold">
        Réinitialiser
      </button>
    {% endif %}
  </div>

  {# Mobile toggle #}
  <button id="filters-toggle" class="md:hidden w-full mb-4 px-4 py-2.5 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-xl text-sm font-bold text-slate-700 flex items-center justify-between transition">
    <span>Filtres</span>
    <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
  </button>

  <div id="filters-content" class="hidden md:block space-y-6">

    {# Type d'évènement Dynamique #}
    <div>
      <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-3">Type d'évènement</p>
      
      {# Extraction des types uniques existants depuis manifestations #}
      {% set event_types = [] %}
      {% for m in manifestations %}
          {% set type = m.type|default('Événement') %}
          {% if type not in event_types %}
              {% set event_types = event_types|merge([type]) %}
          {% endif %}         
      {% endfor %}

      <div class="flex flex-wrap gap-2">
        <button type="button" onclick="updateAgendaFilter('type', '')" class="px-3.5 py-1.5 text-xs rounded-xl font-bold transition {% if not filters.type %}bg-[var(--primary)] text-white{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
          Tous
        </button>
        
        {% for type in event_types %}
            <button type="button" onclick="updateAgendaFilter('type', '{{ type }}')" class="px-3.5 py-1.5 text-xs rounded-xl font-bold transition {% if filters.type == type %}bg-[var(--primary)] text-white{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
              {{ type }}
            </button>
        {% endfor %}
      </div>
    </div>

    {# Dropdowns #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {% if filterOptions.manifestationNames %}
        <div>
          <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-2">Manifestation</p>
          <select onchange="updateAgendaFilter('manifestation', this.value)" class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-2.5 text-sm font-semibold text-slate-800 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 focus:border-[var(--primary)] transition-all">
            <option value="">Tous les événements</option>
            {% for name in filterOptions.manifestationNames %}
              <option value="{{ name }}" {% if filters.manifestation == name %}selected{% endif %}>{{ name }}</option>
            {% endfor %}
          </select>
        </div>
      {% endif %}

      {% if filterOptions.teams %}
        <div>
          <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-2">Équipe</p>
          <select onchange="updateAgendaFilter('team', this.value)" class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-2.5 text-sm font-semibold text-slate-800 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 focus:border-[var(--primary)] transition-all">
            <option value="">Toutes les équipes</option>
            {% for team in filterOptions.teams %}
              <option value="{{ team }}" {% if filters.team == team %}selected{% endif %}>{{ team }}</option>
            {% endfor %}
          </select>
        </div>
      {% endif %}

      {% if filterOptions.lieux %}
        <div>
          <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-2">Lieu</p>
          <select onchange="updateAgendaFilter('lieu', this.value)" class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-2.5 text-sm font-semibold text-slate-800 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 focus:border-[var(--primary)] transition-all">
            <option value="">Tous les lieux</option>
            {% for lieu in filterOptions.lieux %}
              <option value="{{ lieu }}" {% if filters.lieu == lieu %}selected{% endif %}>{{ lieu }}</option>
            {% endfor %}
          </select>
        </div>
      {% endif %}
    </div>

    {# Affichage #}
    <div class="pt-5 border-t border-slate-100">
      <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-3">Affichage</p>
      <div class="flex flex-wrap gap-2">
        <button type="button" onclick="updateAgendaFilter('hide_empty_players', '')" class="px-3.5 py-1.5 text-xs rounded-xl font-bold transition {% if not filters.hide_empty_players %}bg-[var(--primary)] text-white{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
          Liste complète
        </button>
        <button type="button" onclick="updateAgendaFilter('hide_empty_players', '1')" class="px-3.5 py-1.5 text-xs rounded-xl font-bold transition {% if filters.hide_empty_players %}bg-[var(--primary)] text-white{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
          Ayant répondu
        </button>
      </div>
    </div>

    {# Période #}
    <div class="pt-5 border-t border-slate-100">
      <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-3">Période</p>
      <div class="flex flex-wrap gap-2">
        <button type="button" onclick="updateAgendaFilterPeriod('all')" class="px-3.5 py-1.5 text-xs rounded-xl font-bold transition {% if not filters.this_week and not filters.next_week %}bg-[var(--primary)] text-white{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
          Tous les événements
        </button>
        <button type="button" onclick="updateAgendaFilterPeriod('this_week')" class="px-3.5 py-1.5 text-xs rounded-xl font-bold transition {% if filters.this_week %}bg-[var(--primary)] text-white{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
          Semaine courante
        </button>
        <button type="button" onclick="updateAgendaFilterPeriod('next_week')" class="px-3.5 py-1.5 text-xs rounded-xl font-bold transition {% if filters.next_week %}bg-[var(--primary)] text-white{% else %}bg-slate-100 text-slate-700 hover:bg-slate-200{% endif %}">
          Semaine suivante
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  // Gère de manière exclusive les filtres de période
  function updateAgendaFilterPeriod(period) {
    var url = new URL(window.location.href);
    if (period === 'this_week') {
        url.searchParams.set('this_week', '1');
        url.searchParams.delete('next_week');
    } else if (period === 'next_week') {
        url.searchParams.set('next_week', '1');
        url.searchParams.delete('this_week');
    } else {
        url.searchParams.delete('this_week');
        url.searchParams.delete('next_week');
    }
    window.location.href = url.toString();
  }

  // Cette fonction s'occupe de mettre à jour un paramètre tout en conservant les autres (y compris view)
  function updateAgendaFilter(filterKey, filterValue) {
    var url = new URL(window.location.href);
    if (filterValue) {
        url.searchParams.set(filterKey, filterValue);
    } else {
        url.searchParams.delete(filterKey);
    }
    window.location.href = url.toString();
  }

  // Cette fonction efface tous les filtres MAIS préserve explicitement la vue actuelle
  function resetAgendaFilters() {
    var url = new URL(window.location.href);
    var currentView = url.searchParams.get('view');
    
    url.search = ''; // Vide tous les paramètres
    
    if (currentView) {
        url.searchParams.set('view', currentView); // Remet uniquement la vue
    }
    
    url.pathname = '/agenda'; // Assure de pointer au bon endroit
    window.location.href = url.toString();
  }

  document.addEventListener('DOMContentLoaded', function() {
    var toggle = document.getElementById('filters-toggle');
    var content = document.getElementById('filters-content');
    if (toggle && content) {
      toggle.addEventListener('click', function() {
        var hidden = content.classList.toggle('hidden');
        var svg = toggle.querySelector('svg');
        if (svg) svg.style.transform = hidden ? 'rotate(0deg)' : 'rotate(180deg)';
      });
    }
  });
</script>