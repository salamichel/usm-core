{% extends "base.twig" %}
{% block title %}{{ event.title }} — Agenda — USM Volley{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-6 py-16">

  {# Breadcrumb #}
  <nav aria-label="Fil d'Ariane" class="text-sm text-slate-500 mb-10">
    <a href="{{ url('') }}" class="hover:text-[var(--primary)] transition-colors">Accueil</a>
    <span class="mx-2 text-slate-300">/</span>
    <a href="{{ url('agenda') }}" class="hover:text-[var(--primary)] transition-colors">Agenda</a>
    <span class="mx-2 text-slate-300">/</span>
    <span class="text-slate-900">{{ event.title }}</span>
  </nav>

  <article class="card overflow-hidden">

    {# Header #}
    <header class="bg-slate-900 text-white p-8 md:p-10">
      <span class="inline-block text-xs uppercase tracking-[0.2em] text-white/60 font-medium mb-3">{{ event.type|default('Événement') }}</span>
      <h1 class="font-serif text-3xl md:text-4xl font-semibold leading-tight mb-6">{{ event.title }}</h1>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-6 border-t border-white/10">
        <div>
          <div class="text-xs uppercase tracking-wider text-white/60 mb-1 font-medium">Date</div>
          <div class="font-medium">{{ event.date_display }}</div>
        </div>
        {% if event.time_display %}
          <div>
            <div class="text-xs uppercase tracking-wider text-white/60 mb-1 font-medium">Heure</div>
            <div class="font-medium">{{ event.time_display }}</div>
          </div>
        {% endif %}
        {% if event.duration %}
          <div>
            <div class="text-xs uppercase tracking-wider text-white/60 mb-1 font-medium">Durée</div>
            <div class="font-medium">{{ event.duration }}</div>
          </div>
        {% endif %}
        {% if event.nb_courts %}
          <div>
            <div class="text-xs uppercase tracking-wider text-white/60 mb-1 font-medium">Terrains</div>
            <div class="font-medium">{{ event.nb_courts }}</div>
          </div>
        {% endif %}
      </div>
    </header>

    <div class="p-8 md:p-10 space-y-8">

      {# Status #}
      {% if event.status == 'Annulé' %}
        <div class="rounded-md border border-rose-200 bg-rose-50 text-rose-800 px-4 py-3 font-medium text-sm">
          ⚠️ Cet événement a été annulé.
        </div>
      {% elseif event.status == 'Provisoire' %}
        <div class="rounded-md border border-amber-200 bg-amber-50 text-amber-800 px-4 py-3 font-medium text-sm">
          ⚠️ Cet événement est provisoire.
        </div>
      {% else %}
        <div class="rounded-md border border-emerald-200 bg-emerald-50 text-emerald-800 px-4 py-3 font-medium text-sm">
          ✓ Cet événement est confirmé.
        </div>
      {% endif %}

      {# Lieu #}
      {% if event.location %}
        <div class="pb-6 border-b border-slate-200">
          <h2 class="font-serif text-xl font-semibold text-slate-900 mb-2">Lieu</h2>
          <p class="text-slate-700">{{ event.location }}</p>
        </div>
      {% endif %}

      {# Comment #}
      {% if event.comment %}
        <div class="pb-6 border-b border-slate-200">
          <h2 class="font-serif text-xl font-semibold text-slate-900 mb-2">Informations</h2>
          <p class="text-slate-700 whitespace-pre-wrap leading-relaxed">{{ event.comment }}</p>
        </div>
      {% endif %}

      {# Badges #}
      <div class="flex gap-2 flex-wrap">
        {% if event.is_soon %}
          <span class="inline-block bg-amber-100 text-amber-800 px-3 py-1.5 rounded-full text-xs font-medium">Événement imminent</span>
        {% endif %}
        <span class="inline-block bg-slate-100 text-slate-700 px-3 py-1.5 rounded-full text-xs font-medium">Statut : {{ event.status }}</span>
      </div>

      {# Stats des Participations #}
      {% set part = event.participation_stats %}
      <div class="pt-2">
        <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Disponibilités des joueurs</h2>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
          <div class="rounded-md border border-emerald-200 bg-emerald-50 p-4">
            <div class="font-serif text-3xl font-semibold text-emerald-700">{{ part.present }}</div>
            <div class="text-xs uppercase tracking-wider text-emerald-700 font-medium mt-1">Présents</div>
          </div>
          <div class="rounded-md border border-sky-200 bg-sky-50 p-4">
            <div class="font-serif text-3xl font-semibold text-sky-700">{{ part.available }}</div>
            <div class="text-xs uppercase tracking-wider text-sky-700 font-medium mt-1">Disponibles</div>
          </div>
          <div class="rounded-md border border-amber-200 bg-amber-50 p-4">
            <div class="font-serif text-3xl font-semibold text-amber-700">{{ part.selected }}</div>
            <div class="text-xs uppercase tracking-wider text-amber-700 font-medium mt-1">Sélectionnés</div>
          </div>
          <div class="rounded-md border border-rose-200 bg-rose-50 p-4">
            <div class="font-serif text-3xl font-semibold text-rose-700">{{ part.unavailable }}</div>
            <div class="text-xs uppercase tracking-wider text-rose-700 font-medium mt-1">Indisponibles</div>
          </div>
        </div>

        {% set total_committed = part.present + part.available + part.selected %}
        {% if part.enough_players %}
          <div class="rounded-md border border-emerald-200 bg-emerald-50 text-emerald-800 px-4 py-3 font-medium mb-6">
            ✓ Équipe complète — {{ total_committed }} joueurs engagés (≥ 6 requis)
          </div>
        {% else %}
          <div class="rounded-md border border-rose-200 bg-rose-50 text-rose-800 px-4 py-3 font-medium mb-6">
            ⚠ Sous-effectif — {{ total_committed }} joueurs engagés (6 requis)
          </div>
        {% endif %}

        <div class="overflow-x-auto">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200">
                <th class="px-4 py-3 text-left text-xs uppercase tracking-wider font-semibold text-slate-600">Statut</th>
                <th class="px-4 py-3 text-right text-xs uppercase tracking-wider font-semibold text-slate-600">Nombre</th>
                <th class="px-4 py-3 text-center text-xs uppercase tracking-wider font-semibold text-slate-600">Pourcentage</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-slate-100">
                <td class="px-4 py-3 text-slate-700">✓ Présents</td>
                <td class="px-4 py-3 text-right font-semibold text-slate-900">{{ part.present }}</td>
                <td class="px-4 py-3 text-center text-slate-600">{% if part.total_responses > 0 %}{{ (part.present / part.total_responses * 100)|round(0) }}{% else %}0{% endif %}%</td>
              </tr>
              <tr class="border-b border-slate-100 bg-sky-50/50">
                <td class="px-4 py-3 text-slate-700">◐ Disponibles</td>
                <td class="px-4 py-3 text-right font-semibold text-slate-900">{{ part.available }}</td>
                <td class="px-4 py-3 text-center text-slate-600">{% if part.total_responses > 0 %}{{ (part.available / part.total_responses * 100)|round(0) }}{% else %}0{% endif %}%</td>
              </tr>
              <tr class="border-b border-slate-100 bg-amber-50/50">
                <td class="px-4 py-3 text-slate-700">★ Sélectionnés</td>
                <td class="px-4 py-3 text-right font-semibold text-slate-900">{{ part.selected }}</td>
                <td class="px-4 py-3 text-center text-slate-600">{% if part.total_responses > 0 %}{{ (part.selected / part.total_responses * 100)|round(0) }}{% else %}0{% endif %}%</td>
              </tr>
              <tr class="border-b border-slate-100 bg-rose-50/50">
                <td class="px-4 py-3 text-slate-700">✗ Indisponibles</td>
                <td class="px-4 py-3 text-right font-semibold text-slate-900">{{ part.unavailable }}</td>
                <td class="px-4 py-3 text-center text-slate-600">{% if part.total_responses > 0 %}{{ (part.unavailable / part.total_responses * 100)|round(0) }}{% else %}0{% endif %}%</td>
              </tr>
              <tr class="border-b border-slate-100">
                <td class="px-4 py-3 text-slate-700">✘ Absents</td>
                <td class="px-4 py-3 text-right font-semibold text-slate-900">{{ part.absent }}</td>
                <td class="px-4 py-3 text-center text-slate-600">{% if part.total_responses > 0 %}{{ (part.absent / part.total_responses * 100)|round(0) }}{% else %}0{% endif %}%</td>
              </tr>
              <tr class="bg-slate-50 font-semibold">
                <td class="px-4 py-3 text-slate-900">Total avec réponse</td>
                <td class="px-4 py-3 text-right text-slate-900">{{ part.total_responses }}</td>
                <td class="px-4 py-3 text-center text-slate-700">100%</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </article>

  <div class="mt-10 grid sm:grid-cols-2 gap-3">
    <a href="/agenda" class="btn-primary justify-center">← Retour à l'agenda</a>
    <a href="/" class="btn-secondary justify-center">Retour à l'accueil</a>
  </div>
</div>
{% endblock %}
