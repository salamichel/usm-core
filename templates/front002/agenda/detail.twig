{% extends "base.twig" %}
{% block title %}{{ event.title }} — Agenda — USM Volley{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-6 py-16">

  {# Breadcrumb #}
  <nav aria-label="Fil d'Ariane" class="text-sm text-slate-500 mb-10">
    <a href="{{ url('') }}" class="hover:text-[var(--primary)] transition-colors">Accueil</a>
    <span class="mx-2 text-slate-300">/</span>
    <a href="{{ url('agenda') }}" class="hover:text-[var(--primary)] transition-colors">Agenda</a>
    <span class="mx-2 text-slate-300">/</span>
    <span class="text-slate-900">{{ event.title }}</span>
  </nav>

  <article class="card overflow-hidden">

    {# Header #}
    <header class="bg-slate-900 text-white p-8 md:p-10">
      <span class="inline-block text-xs uppercase tracking-[0.2em] text-white/60 font-medium mb-3">{{ event.type|default('Événement') }}</span>
      <h1 class="font-serif text-3xl md:text-4xl font-semibold leading-tight mb-6">{{ event.title }}</h1>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-6 border-t border-white/10">
        <div>
          <div class="text-xs uppercase tracking-wider text-white/60 mb-1 font-medium">Date</div>
          <div class="font-medium">{{ event.date_display }}</div>
        </div>
        {% if event.time_display %}
          <div>
            <div class="text-xs uppercase tracking-wider text-white/60 mb-1 font-medium">Heure</div>
            <div class="font-medium">{{ event.time_display }}</div>
          </div>
        {% endif %}
        {% if event.duration %}
          <div>
            <div class="text-xs uppercase tracking-wider text-white/60 mb-1 font-medium">Durée</div>
            <div class="font-medium">{{ event.duration }}</div>
          </div>
        {% endif %}
        {% if event.nb_courts %}
          <div>
            <div class="text-xs uppercase tracking-wider text-white/60 mb-1 font-medium">Terrains</div>
            <div class="font-medium">{{ event.nb_courts }}</div>
          </div>
        {% endif %}
      </div>
    </header>

    <div class="p-8 md:p-10 space-y-8">

      {# Status #}
      {% if event.status == 'Annulé' %}
        <div class="rounded-md border border-rose-200 bg-rose-50 text-rose-800 px-4 py-3 font-medium text-sm">
          ⚠️ Cet événement a été annulé.
        </div>
      {% elseif event.status == 'Provisoire' %}
        <div class="rounded-md border border-amber-200 bg-amber-50 text-amber-800 px-4 py-3 font-medium text-sm">
          ⚠️ Cet événement est provisoire.
        </div>
      {% else %}
        <div class="rounded-md border border-emerald-200 bg-emerald-50 text-emerald-800 px-4 py-3 font-medium text-sm">
          ✓ Cet événement est confirmé.
        </div>
      {% endif %}

      {# Lieu #}
      {% if event.location %}
        <div class="pb-6 border-b border-slate-200">
          <h2 class="font-serif text-xl font-semibold text-slate-900 mb-2">Lieu</h2>
          <p class="text-slate-700">{{ event.location }}</p>
        </div>
      {% endif %}

      {# Comment #}
      {% if event.comment %}
        <div class="pb-6 border-b border-slate-200">
          <h2 class="font-serif text-xl font-semibold text-slate-900 mb-2">Informations</h2>
          <p class="text-slate-700 whitespace-pre-wrap leading-relaxed">{{ event.comment }}</p>
        </div>
      {% endif %}

      {# Badges #}
      <div class="flex gap-2 flex-wrap">
        {% if event.is_soon %}
          <span class="inline-block bg-amber-100 text-amber-800 px-3 py-1.5 rounded-full text-xs font-medium">Événement imminent</span>
        {% endif %}
        <span class="inline-block bg-slate-100 text-slate-700 px-3 py-1.5 rounded-full text-xs font-medium">Statut : {{ event.status }}</span>
      </div>

      {# Stats des Participations #}
      <div class="pt-2">
        <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Disponibilités des joueurs</h2>

        <div class="grid grid-cols-2 {% if event.is_match %}md:grid-cols-4{% else %}md:grid-cols-3{% endif %} gap-4 mb-6">
          {% if event.is_match %}
            {# Match metrics #}
            <div class="rounded-md border border-amber-200 bg-amber-50 p-4">
              <div class="font-serif text-3xl font-semibold text-amber-700">{{ event.nb_selection }}</div>
              <div class="text-xs uppercase tracking-wider text-amber-700 font-medium mt-1">Sélectionnés</div>
            </div>
            <div class="rounded-md border border-emerald-200 bg-emerald-50 p-4">
              <div class="font-serif text-3xl font-semibold text-emerald-700">{{ event.nb_disponible }}</div>
              <div class="text-xs uppercase tracking-wider text-emerald-700 font-medium mt-1">Disponibles</div>
            </div>
            <div class="rounded-md border border-sky-200 bg-sky-50 p-4">
              <div class="font-serif text-3xl font-semibold text-sky-700">{{ event.nb_disponible_si_necessaire }}</div>
              <div class="text-xs uppercase tracking-wider text-sky-700 font-medium mt-1">Si besoin</div>
            </div>
            <div class="rounded-md border border-rose-200 bg-rose-50 p-4">
              <div class="font-serif text-3xl font-semibold text-rose-700">{{ event.nb_indisponible }}</div>
              <div class="text-xs uppercase tracking-wider text-rose-700 font-medium mt-1">Indisponibles</div>
            </div>
          {% else %}
            {# Training / Other metrics #}
            <div class="rounded-md border border-emerald-200 bg-emerald-50 p-4">
              <div class="font-serif text-3xl font-semibold text-emerald-700">{{ event.nb_present }}</div>
              <div class="text-xs uppercase tracking-wider text-emerald-700 font-medium mt-1">Présents</div>
            </div>
            <div class="rounded-md border border-rose-200 bg-rose-50 p-4">
              <div class="font-serif text-3xl font-semibold text-rose-700">{{ event.nb_absent }}</div>
              <div class="text-xs uppercase tracking-wider text-rose-700 font-medium mt-1">Absents</div>
            </div>
            <div class="rounded-md border border-slate-200 bg-slate-50 p-4">
              <div class="font-serif text-3xl font-semibold text-slate-700">{{ event.nb_pas_de_reponse }}</div>
              <div class="text-xs uppercase tracking-wider text-slate-700 font-medium mt-1">Sans réponse</div>
            </div>
          {% endif %}
        </div>

        {% if event.is_match %}
          {% set total_committed = event.nb_present + event.nb_disponible + event.nb_selection %}
          {% if total_committed >= 6 %}
            <div class="rounded-md border border-emerald-200 bg-emerald-50 text-emerald-800 px-4 py-3 font-medium mb-6">
              ✓ Équipe complète — {{ total_committed }} joueurs engagés (≥ 6 requis)
            </div>
          {% else %}
            <div class="rounded-md border border-rose-200 bg-rose-50 text-rose-800 px-4 py-3 font-medium mb-6">
              ⚠ Sous-effectif — {{ total_committed }} joueurs engagés (6 requis)
            </div>
          {% endif %}
        {% else %}
          {% set total_presents = event.nb_present %}
          {% if total_presents >= 12 %}
            <div class="rounded-md border border-emerald-200 bg-emerald-50 text-emerald-800 px-4 py-3 font-medium mb-6">
              ✓ Effectif suffisant — {{ total_presents }} joueurs présents (≥ 12 requis)
            </div>
          {% else %}
            <div class="rounded-md border border-rose-200 bg-rose-50 text-rose-800 px-4 py-3 font-medium mb-6">
              ⚠ Effectif insuffisant — {{ total_presents }} joueurs présents (12 requis pour un bon entraînement)
            </div>
          {% endif %}
        {% endif %}

        <h3 class="font-serif text-xl font-semibold text-slate-900 mb-4 mt-8">Répartition des joueurs</h3>
        <div class="grid grid-cols-1 {% if event.is_match %}md:grid-cols-2 lg:grid-cols-3{% else %}md:grid-cols-3{% endif %} gap-6">
          {% if event.is_match %}
            {# 1. Sélectionnés #}
            {{ _self.render_status_list('Sélectionnés', event.selectionnes, 'border-amber-200 text-amber-800', 'bg-amber-500', event.nb_selection) }}
            {# 2. Disponibles #}
            {{ _self.render_status_list('Disponibles', event.disponibles, 'border-emerald-200 text-emerald-800', 'bg-emerald-500', event.nb_disponible) }}
            {# 3. Disponible si besoin #}
            {{ _self.render_status_list('Si besoin', event.disponibles_si_necessaire, 'border-sky-200 text-sky-800', 'bg-sky-500', event.nb_disponible_si_necessaire) }}
            {# 4. Indisponibles #}
            {{ _self.render_status_list('Indisponibles', event.indisponibles, 'border-rose-200 text-rose-800', 'bg-rose-500', event.nb_indisponible) }}
            {# 5. Sans réponse #}
            {{ _self.render_status_list('Sans réponse', event.pas_de_reponse, 'border-slate-200 text-slate-800', 'bg-slate-400', event.nb_pas_de_reponse) }}
          {% else %}
            {# 1. Présents #}
            {{ _self.render_status_list('Présents', event.presents, 'border-emerald-200 text-emerald-800', 'bg-emerald-500', event.nb_present) }}
            {# 2. Absents #}
            {{ _self.render_status_list('Absents', event.absents, 'border-rose-200 text-rose-800', 'bg-rose-500', event.nb_absent) }}
            {# 3. Sans réponse #}
            {{ _self.render_status_list('Sans réponse', event.pas_de_reponse, 'border-slate-200 text-slate-800', 'bg-slate-400', event.nb_pas_de_reponse) }}
          {% endif %}
        </div>
      </div>
    </div>
  </article>

  <div class="mt-10 grid sm:grid-cols-2 gap-3">
    <a href="/agenda" class="btn-primary justify-center">← Retour à l'agenda</a>
    <a href="/" class="btn-secondary justify-center">Retour à l'accueil</a>
  </div>
</div>
{% endblock %}

{% macro render_status_list(label, players, card_classes, dot_color, count) %}
  <div class="rounded-2xl border p-5 flex flex-col h-full bg-white shadow-sm {{ card_classes|default('border-slate-100') }}">
    <div class="flex items-center justify-between pb-3 mb-4 border-b border-slate-100">
      <h4 class="font-bold text-sm uppercase tracking-wider text-slate-700 flex items-center gap-2">
        <span class="w-2.5 h-2.5 rounded-full {{ dot_color }}"></span>
        {{ label }}
      </h4>
      <span class="px-2 py-0.5 rounded-full text-xs font-black bg-slate-50 border border-slate-100 text-slate-600">{{ count|default(0) }}</span>
    </div>
    <div class="flex-grow">
      {% if players is empty %}
        <p class="text-xs text-slate-400 italic py-2">Aucun joueur</p>
      {% else %}
        <div class="flex flex-wrap gap-2">
          {% for p in players %}
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-slate-50 hover:bg-slate-100 transition-colors border border-slate-200 text-slate-700" title="{{ p.nom }}">
              <span class="w-1.5 h-1.5 rounded-full {{ dot_color }}"></span>
              {{ p.nom }}
            </span>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
{% endmacro %}
