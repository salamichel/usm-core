{% extends "base.twig" %}
{% block title %}{{ event.title }} — Agenda — USM Volley{% endblock %}

{% block content %}
<div class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">
  {# En-tête #}
  <div class="bg-slate-900 text-white pt-8 pb-20 md:pt-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <nav aria-label="Fil d'Ariane" class="text-sm text-slate-400 mb-6">
        <a href="{{ url('') }}" class="hover:text-white transition-colors">Accueil</a>
        <span class="mx-2 text-slate-600">/</span>
        <a href="{{ url('agenda') }}" class="hover:text-white transition-colors">Agenda</a>
        <span class="mx-2 text-slate-600">/</span>
        <span class="text-slate-200">{{ event.title }}</span>
      </nav>
      
      <div>
        <span class="inline-block text-xs uppercase tracking-[0.2em] text-[var(--primary)] font-bold mb-2">{{ event.type|default('Événement') }}</span>
        <h1 class="font-serif text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-6 leading-tight">{{ event.title }}</h1>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-6 border-t border-white/10">
          <div>
            <div class="text-[10px] uppercase tracking-wider text-slate-400 mb-1 font-bold">Date</div>
            <div class="font-bold text-sm text-slate-200">{{ event.date_display }}</div>
          </div>
          {% if event.time_display %}
            <div>
              <div class="text-[10px] uppercase tracking-wider text-slate-400 mb-1 font-bold">Heure</div>
              <div class="font-bold text-sm text-slate-200">{{ event.time_display }}</div>
            </div>
          {% endif %}
          {% if event.duration %}
            <div>
              <div class="text-[10px] uppercase tracking-wider text-slate-400 mb-1 font-bold">Durée</div>
              <div class="font-bold text-sm text-slate-200">{{ event.duration }}</div>
            </div>
          {% endif %}
          {% if event.nb_courts %}
            <div>
              <div class="text-[10px] uppercase tracking-wider text-slate-400 mb-1 font-bold">Terrains</div>
              <div class="font-bold text-sm text-slate-200">{{ event.nb_courts }}</div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 -mt-10">
    <article class="bg-white rounded-3xl p-6 md:p-8 border border-slate-100 shadow-sm space-y-8">

      {# Status #}
      {% if event.status == 'Annulé' %}
        <div class="rounded-xl border border-rose-200 bg-rose-50 text-rose-700 px-4 py-3 text-sm font-bold">
          ⚠️ Cet événement a été annulé.
        </div>
      {% elseif event.status == 'Provisoire' %}
        <div class="rounded-xl border border-amber-200 bg-amber-50 text-amber-800 px-4 py-3 text-sm font-bold">
          ⚠️ Cet événement est provisoire.
        </div>
      {% else %}
        <div class="rounded-xl border border-emerald-105 bg-emerald-50/50 text-emerald-800 px-4 py-3 text-sm font-bold">
          ✓ Cet événement est confirmé.
        </div>
      {% endif %}

      {# Lieu #}
      {% if event.location %}
        <div class="pb-6 border-b border-slate-100">
          <h2 class="font-serif text-xl font-bold text-slate-900 mb-2">Lieu</h2>
          <p class="text-slate-600 text-sm font-semibold">{{ event.location }}</p>
        </div>
      {% endif %}

      {# Comment #}
      {% if event.comment %}
        <div class="pb-6 border-b border-slate-100">
          <h2 class="font-serif text-xl font-bold text-slate-900 mb-2">Informations</h2>
          <p class="text-slate-600 text-sm whitespace-pre-wrap leading-relaxed font-semibold">{{ event.comment }}</p>
        </div>
      {% endif %}

      {# Badges #}
      <div class="flex gap-2 flex-wrap pb-6 border-b border-slate-100">
        {% if event.is_soon %}
          <span class="inline-block bg-amber-50 border border-amber-100 text-amber-800 px-3.5 py-1.5 rounded-xl text-xs font-bold">Événement imminent</span>
        {% endif %}
        <span class="inline-block bg-slate-50 border border-slate-150 text-slate-700 px-3.5 py-1.5 rounded-xl text-xs font-bold">Statut : {{ event.status }}</span>
      </div>

      {# Stats des Participations #}
      <div class="pt-2">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
          <h2 class="font-serif text-2xl font-bold text-slate-900">Disponibilités des joueurs</h2>
          {% if is_captain and event.is_match %}
            <div class="flex flex-wrap gap-2">
              <a href="{{ url('member/captain/matches/' ~ event.id ~ '/edit') }}" class="inline-flex items-center gap-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 text-xs font-bold px-3.5 py-2.5 rounded-xl border border-slate-200 transition-all hover:scale-105">
                ✏️ Modifier le match
              </a>
              <a href="{{ url('member/captain/matches/' ~ event.id ~ '/select-players') }}" class="inline-flex items-center gap-1.5 bg-amber-500 hover:bg-amber-600 text-slate-900 text-xs font-bold px-4 py-2.5 rounded-xl shadow-sm hover:scale-105 transition-all">
                📋 Gérer les convocations
              </a>
            </div>
          {% endif %}
        </div>

        <div class="grid grid-cols-2 {% if event.is_match %}md:grid-cols-4{% else %}md:grid-cols-3{% endif %} gap-4 mb-6">
          {% if event.is_match %}
            {# Match metrics #}
            <div class="rounded-2xl border border-amber-100 bg-amber-50/50 p-4">
              <div class="font-serif text-3xl font-extrabold text-amber-700">{{ event.nb_selection }}</div>
              <div class="text-[10px] uppercase tracking-wider text-amber-600 font-bold mt-1">Sélectionnés</div>
            </div>
            <div class="rounded-2xl border border-emerald-100 bg-emerald-50/50 p-4">
              <div class="font-serif text-3xl font-extrabold text-emerald-700">{{ event.nb_disponible }}</div>
              <div class="text-[10px] uppercase tracking-wider text-emerald-600 font-bold mt-1">Disponibles</div>
            </div>
            <div class="rounded-2xl border border-sky-100 bg-sky-50/50 p-4">
              <div class="font-serif text-3xl font-extrabold text-sky-700">{{ event.nb_disponible_si_necessaire }}</div>
              <div class="text-[10px] uppercase tracking-wider text-sky-600 font-bold mt-1">Si besoin</div>
            </div>
            <div class="rounded-2xl border border-rose-100 bg-rose-50/50 p-4">
              <div class="font-serif text-3xl font-extrabold text-rose-700">{{ event.nb_indisponible }}</div>
              <div class="text-[10px] uppercase tracking-wider text-rose-600 font-bold mt-1">Indisponibles</div>
            </div>
          {% else %}
            {# Training / Other metrics #}
            <div class="rounded-2xl border border-emerald-100 bg-emerald-50/50 p-4">
              <div class="font-serif text-3xl font-extrabold text-emerald-700">{{ event.nb_present }}</div>
              <div class="text-[10px] uppercase tracking-wider text-emerald-600 font-bold mt-1">Présents</div>
            </div>
            <div class="rounded-2xl border border-rose-100 bg-rose-50/50 p-4">
              <div class="font-serif text-3xl font-extrabold text-rose-700">{{ event.nb_absent }}</div>
              <div class="text-[10px] uppercase tracking-wider text-rose-600 font-bold mt-1">Absents</div>
            </div>
            <div class="rounded-2xl border border-slate-150 bg-slate-50/50 p-4">
              <div class="font-serif text-3xl font-extrabold text-slate-700">{{ event.nb_pas_de_reponse }}</div>
              <div class="text-[10px] uppercase tracking-wider text-slate-500 font-bold mt-1">Sans réponse</div>
            </div>
          {% endif %}
        </div>

        {% if event.is_match %}
          {% set min_required = event.participation_stats.min_required|default(6) %}
          {% set total_committed = event.nb_present + event.nb_disponible + event.nb_selection %}
          {% if total_committed >= min_required %}
            <div class="rounded-xl border border-emerald-100 bg-emerald-50/50 text-emerald-800 px-4 py-3 text-sm font-bold mb-6">
              ✓ Équipe complète — {{ total_committed }} joueurs engagés (≥ {{ min_required }} requis)
            </div>
          {% else %}
            <div class="rounded-xl border border-rose-100 bg-rose-50/50 text-rose-800 px-4 py-3 text-sm font-bold mb-6">
              ⚠️ Sous-effectif — {{ total_committed }} joueurs engagés ({{ min_required }} requis)
            </div>
          {% endif %}
        {% else %}
          {% set total_presents = event.nb_present %}
          {% if total_presents >= 12 %}
            <div class="rounded-xl border border-emerald-100 bg-emerald-50/50 text-emerald-800 px-4 py-3 text-sm font-bold mb-6">
              ✓ Effectif suffisant — {{ total_presents }} joueurs présents (≥ 12 requis)
            </div>
          {% else %}
            <div class="rounded-xl border border-rose-100 bg-rose-50/50 text-rose-800 px-4 py-3 text-sm font-bold mb-6">
              ⚠️ Effectif insuffisant — {{ total_presents }} joueurs présents (12 requis pour un bon entraînement)
            </div>
          {% endif %}
        {% endif %}

        <h3 class="font-serif text-xl font-bold text-slate-900 mb-4 mt-8">Répartition des joueurs</h3>
        <div class="grid grid-cols-1 {% if event.is_match %}md:grid-cols-2 lg:grid-cols-3{% else %}md:grid-cols-2{% endif %} gap-6">
          {% if event.is_match %}
            {# 1. Sélectionnés #}
            {{ _self.render_status_list('Sélectionnés', event.selectionnes, 'border-amber-100 text-amber-800 bg-amber-50/10', 'bg-amber-500', event.nb_selection) }}
            {# 2. Disponibles #}
            {{ _self.render_status_list('Disponibles', event.disponibles, 'border-emerald-100 text-emerald-800 bg-emerald-50/10', 'bg-emerald-500', event.nb_disponible) }}
            {# 3. Disponible si besoin #}
            {{ _self.render_status_list('Si besoin', event.disponibles_si_necessaire, 'border-sky-100 text-sky-800 bg-sky-50/10', 'bg-sky-500', event.nb_disponible_si_necessaire) }}
            {# 4. Indisponibles #}
            {{ _self.render_status_list('Indisponibles', event.indisponibles, 'border-rose-100 text-rose-850 bg-rose-50/10', 'bg-rose-500', event.nb_indisponible) }}
          {% else %}
            {# 1. Présents #}
            {{ _self.render_status_list('Présents', event.presents, 'border-emerald-100 text-emerald-800 bg-emerald-50/10', 'bg-emerald-500', event.nb_present) }}
            {# 2. Absents #}
            {{ _self.render_status_list('Absents', event.absents, 'border-rose-100 text-rose-800 bg-rose-50/10', 'bg-rose-500', event.nb_absent) }}
          {% endif %}
        </div>
      </div>
    </article>

    <div class="mt-10 grid sm:grid-cols-2 gap-3 pb-6">
      <a href="{{ url('agenda') }}" class="btn-primary justify-center py-3.5 rounded-xl font-bold">← Retour à l'agenda</a>
      <a href="{{ url('/') }}" class="btn-secondary justify-center py-3.5 rounded-xl font-bold bg-white text-slate-700 border border-slate-200 hover:bg-slate-50">Retour à l'accueil</a>
    </div>
  </div>
</div>
{% endblock %}

{% macro render_status_list(label, players, card_classes, dot_color, count) %}
  <div class="rounded-3xl border p-5 flex flex-col h-full bg-white shadow-sm {{ card_classes|default('border-slate-100') }}">
    <div class="flex items-center justify-between pb-3 mb-4 border-b border-slate-100">
      <h4 class="font-bold text-xs uppercase tracking-wider text-slate-700 flex items-center gap-2">
        <span class="w-2.5 h-2.5 rounded-full {{ dot_color }}"></span>
        {{ label }}
      </h4>
      <span class="px-2 py-0.5 rounded-full text-xs font-black bg-slate-50 border border-slate-100 text-slate-600">{{ count|default(0) }}</span>
    </div>
    <div class="flex-grow">
      {% if players is empty %}
        <p class="text-xs text-slate-400 italic py-2">Aucun joueur</p>
      {% else %}
        <div class="flex flex-wrap gap-2">
          {% for p in players %}
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-bold bg-slate-50 hover:bg-slate-100 transition-colors border border-slate-200 text-slate-700" title="{{ p.nom }}">
              <span class="w-1.5 h-1.5 rounded-full {{ dot_color }}"></span>
              {{ p.nom }}
            </span>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
{% endmacro %}
