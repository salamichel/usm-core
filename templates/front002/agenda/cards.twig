{% extends "base.twig" %}
{% block title %}Agenda USM Volley — Mode Cartes{% endblock %}

{% block content %}
<div class="min-h-screen bg-slate-50/50">
    <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">

        {# En-tête de page #}
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10 pb-6 border-b border-slate-200">
            <div>
                <span class="text-sm font-bold text-[var(--primary)] uppercase tracking-widest">Saison {{ saison_active }}</span>
                <div class="flex items-baseline gap-3 mt-1">
                    <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">Agenda</h1>
                    <span class="text-2xl font-medium text-slate-400">/ Événements</span>
                </div>
            </div>
            
            {# Toolbar / Sélecteur de vue (Boutons Pilules) #}
            <div class="flex items-center bg-slate-100/80 p-1.5 rounded-full border border-slate-200 shadow-inner">
                <a href="{{ url('agenda?view=table') }}" class="px-5 py-2 text-sm rounded-full font-semibold text-slate-500 hover:text-slate-800 transition flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                    Liste
                </a>
                <a href="{{ url('agenda?view=cards') }}" class="px-5 py-2 text-sm rounded-full bg-white text-slate-900 font-bold shadow-sm border border-slate-200 transition flex items-center gap-2">
                    <svg class="w-4 h-4 text-[var(--primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                    Cartes
                </a>
            </div>
        </div>

        {# ZONE DE FILTRES #}
        {% include 'agenda/filters.twig' %}

        {% if manifestations is empty %}
            <div class="text-center py-20 bg-white rounded-[32px] border border-slate-100 shadow-sm my-8">
                <svg class="w-16 h-16 text-slate-200 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                <p class="text-xl font-bold text-slate-700">Aucun événement à venir</p>
                <p class="text-sm text-slate-500 mt-2">Revenez plus tard ou modifiez vos filtres.</p>
            </div>
        {% else %}
            
            {# Grille de cartes aérée #}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12" id="event-grid">
                {% for m in manifestations %}
                    {% include "agenda/_event_card.twig" with {
                        'm': m, 
                        'allow_actions': app.session.LogIn is defined and app.session.LogIn, 
                        'show_link': true
                    } %}
                {% endfor %}
            </div>

        {% endif %}

        <div class="mt-16 pt-8 text-center">
            <a href="/" class="group inline-flex items-center gap-2.5 px-6 py-3 rounded-full bg-white border border-slate-200 shadow-sm text-sm font-bold text-slate-700 hover:text-[var(--primary)] hover:border-slate-300 transition-all">
                <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Retour à l'accueil
            </a>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
{% if app.session.LogIn is defined and app.session.LogIn %}
    <script src="{{ asset('/front002/js/agenda-cards.js') }}"></script>
{% endif %}
{% endblock %}