{% extends "base.twig" %}
{% block title %}Agenda — USM Volley
{% endblock %}

{% block head %}

	{% include '_pwa_tags.twig' %}

	{# JSON-LD : EventSeries pour l'ensemble des manifestations à venir #}
	{% if manifestations is defined and manifestations|length %}
		<script type="application/ld+json">
			{
						  "@context": "https://schema.org",
						  "@type": "ItemList",
						  "name": "Agenda USM Volley",
						  "description": "Calendrier des matchs et entraînements de l'Unions Salles Mios Volley-Ball",
						  "itemListElement": [
			{% for mid, m in manifestations %}
				{% if loop.index <= 10 %}
					{
										      "@type": "ListItem",
										      "position":
					{{ loop.index }},
										      "item": {
										        "@type": "SportsEvent",
										        "name": "{{ m.titre|replace({'"': '\\"'})|raw }}",
										        "startDate": "{{ m.date_display }}",
										        "eventStatus": "
					{% if m.annule %}https://schema.org/EventCancelled{% else %}https://schema.org/EventScheduled
					{% endif %}",
										        "organizer": {
										          "@type": "SportsOrganization",
										          "name": "{{ site_config.club_name|default('USM Volley')|replace({'"': '\\"'})|raw }}"
										        }
					{% if m.lieu %},
												        "location": {
												          "@type": "Place",
												          "name": "{{ m.lieu|replace({'"': '\\"'})|raw }}"
												        }
					{% endif %}
					}
										    }{{ not loop.last and loop.index < 10 ? ',' : '' }}
				{% endif %}
			{% endfor %}
			]
						}
		</script>
	{% endif %}
{% endblock %}

{% block content %}
	<div
		class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">
		{# En-tête de page #}
		<div class="bg-slate-900 text-white pt-8 pb-20 md:pt-12">
			<div class="max-w-7xl mx-auto px-4 sm:px-6">
				<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
					<div>
						<span class="text-sm font-semibold text-[var(--primary)] uppercase tracking-wider">Saison
							{{ saison_active }}</span>
						<h1 class="text-2xl md:text-3xl font-extrabold tracking-tight text-white mt-1">Agenda du club</h1>
					</div>

					{# Toolbar / Sélecteur de vue épuré #}
					<div class="flex items-center gap-1 bg-white/10 p-1 rounded-full border border-white/10 shadow-sm">
						<a href="{{ url('agenda?view=table&hide_empty_players=1') }}" class="px-4 py-2 text-xs rounded-full bg-[var(--primary)] text-white font-bold shadow transition flex items-center gap-2">
							<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
							Liste
							{% if not can_view_player_details %}🔒
							{% endif %}
						</a>
						<a href="{{ url('agenda?view=cards') }}" class="px-4 py-2 text-xs rounded-full font-medium text-slate-350 hover:text-white transition flex items-center gap-2">
							<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
							Cartes
						</a>
					</div>
				</div>
			</div>
		</div>

		<div class="max-w-7xl mx-auto px-4 sm:px-6 -mt-10">

			{% include 'agenda/filters.twig' %}

			{# Toolbar #}
			<div class="bg-white rounded-3xl p-4 mb-6 flex flex-wrap items-center justify-between gap-4 border border-slate-100 shadow-sm">
				<div class="flex items-center gap-3">
					<span class="text-xs uppercase tracking-wider text-slate-400 font-semibold">Zoom</span>
					<div class="flex gap-1">
						<button type="button" data-zoom="1" class="zoom-btn px-3 py-1.5 text-xs rounded-xl border border-slate-205 bg-white hover:bg-slate-50 font-bold text-slate-700 transition cursor-pointer">100%</button>
						<button type="button" data-zoom="0.8" class="zoom-btn px-3 py-1.5 text-xs rounded-xl border border-slate-205 bg-white hover:bg-slate-50 font-bold text-slate-700 transition cursor-pointer">80%</button>
						<button type="button" data-zoom="0.65" class="zoom-btn px-3 py-1.5 text-xs rounded-xl border border-slate-205 bg-white hover:bg-slate-50 font-bold text-slate-700 transition cursor-pointer">65%</button>
						<button type="button" data-zoom="0.5" class="zoom-btn px-3 py-1.5 text-xs rounded-xl border border-slate-205 bg-white hover:bg-slate-50 font-bold text-slate-700 transition cursor-pointer">50%</button>
					</div>
				</div>

				{% if currentUserId %}
					<div class="flex items-center gap-2 text-xs font-semibold text-indigo-700 bg-indigo-50 border border-indigo-100 rounded-xl px-3 py-2">
						<span class="text-indigo-500">💡</span>
						<span>Cliquez sur les cases de votre ligne pour modifier vos présences en direct.</span>
					</div>
				{% endif %}
			</div>

			{% if manifestations is empty %}
				<p class="text-slate-600 italic text-center py-16 bg-white rounded-3xl border border-slate-100 shadow-sm">Aucun événement à venir.</p>
			{% else %}

				{# Crosstable #}
				<div class="agenda-table-container bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden" style="max-height:80vh; overflow-y:auto; overflow-x:auto;">
					<table class="border-collapse text-sm whitespace-nowrap agenda-table">

						<thead class="sticky top-0 z-20 bg-slate-50">
							<tr>
								<th class="sticky-left z-30 bg-slate-100 border-b border-r border-slate-200 px-3 py-3 text-left font-semibold min-w-[160px] text-slate-700">
									<div class="text-xs uppercase tracking-wider">Joueurs</div>
								</th>

								{% for mid, m in manifestations %}

									{# Couleur par type d'événement #}
									{% if 'Match' in m.type %}
										{% set type_icon       = '🏆' %}
										{% set type_text_color = 'text-indigo-600' %}
										{% set icon_color      = 'text-indigo-400' %}
										{% set type_border     = 'border-t-2 border-t-indigo-500' %}
										{% set type_bg         = 'bg-indigo-50/40' %}
									{% elseif 'Entraînement' in m.type %}
										{% set type_icon       = '🏐' %}
										{% set type_text_color = 'text-teal-600' %}
										{% set icon_color      = 'text-teal-400' %}
										{% set type_border     = 'border-t-2 border-t-teal-500' %}
										{% set type_bg         = 'bg-teal-50/40' %}
									{% else %}
										{% set type_icon       = '📅' %}
										{% set type_text_color = 'text-slate-500' %}
										{% set icon_color      = 'text-slate-400' %}
										{% set type_border     = 'border-t-2 border-t-[var(--primary)]' %}
										{% set type_bg         = 'bg-white' %}
									{% endif %}

									{# Surcharge statut (annulé/provisoire écrase la couleur de type) #}
									{% if m.annule %}
										{% set col_top = 'border-t-2 border-t-rose-400' %}
										{% set col_bg  = 'bg-rose-50/50' %}
									{% elseif m.provisoire %}
										{% set col_top = 'border-t-2 border-t-amber-400' %}
										{% set col_bg  = 'bg-amber-50/40' %}
									{% else %}
										{% set col_top = type_border %}
										{% set col_bg  = type_bg %}
									{% endif %}

									{% set ok = (m.nb_present + m.nb_disponible + m.nb_selection) >= 6 %}
									{% set terrain_alert = (m.nb_terrains != 0) and (m.nb_terrains != 1) and (m.nb_terrains != '.') %}

									<th class="border-b border-r border-slate-200 {{ col_top }} {{ col_bg }} px-3 py-3 text-left font-normal min-w-[180px] align-top" data-manifestation-header="{{ mid }}">

										<div class="flex items-center justify-between gap-1 mb-2">
											<span class="flex items-center gap-1 text-[10px] font-semibold uppercase tracking-widest {{ type_text_color }}">
												<span>{{ type_icon }}</span>
												<span>{{ m.type }}</span>
											</span>
											{% if m.annule %}
												<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-rose-100 text-rose-700">Annulé</span>
											{% elseif m.provisoire %}
												<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-amber-100 text-amber-700">Provisoire</span>
											{% else %}
												<span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700">Confirmé</span>
											{% endif %}
										</div>

										<div class="font-serif font-semibold text-base text-slate-900 leading-snug mb-2">{{ m.titre }}</div>

										<div class="space-y-1 text-xs text-slate-600 mb-2">
											<div class="flex items-center gap-1.5">
												<svg class="w-3.5 h-3.5 shrink-0 {{ icon_color }}" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
												<span>{{ m.date_display }}</span>
												{% if m.google_calendar_url %}
													<a href="{{ m.google_calendar_url }}" target="_blank" rel="noopener noreferrer" class="ml-1 inline-flex items-center text-slate-400 hover:text-emerald-600 transition-colors" title="Ajouter à Google Agenda">
														<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
															<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
														</svg>
													</a>
												{% endif %}
											</div>
											{% if m.time_range %}
												<div class="flex items-center gap-1.5">
													<svg class="w-3.5 h-3.5 shrink-0 {{ icon_color }}" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
													<span>{{ m.time_range }}</span>
												</div>
											{% endif %}
											<div class="flex items-center gap-1.5">
												<svg class="w-3.5 h-3.5 shrink-0 {{ icon_color }}" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
												<span>{{ m.lieu }}</span>
											</div>
											{% if terrain_alert %}
												<div class="flex items-center gap-1.5 text-rose-600 font-medium">
													<span>⚠</span>
													<span>{{ m.nb_terrains }}
														terrains</span>
												</div>
											{% endif %}
											{% if m.commentaire %}
												<div class="italic text-slate-500 text-xs">{{ m.commentaire|slice(0, 40) }}</div>
											{% endif %}
										</div>

										<div class="border-t border-slate-200 pt-2 space-y-1.5 text-[11px]" data-stats-container="{{ mid }}">
											{% if 'Match' in m.type %}
												<div class="px-2 py-1 rounded font-semibold text-xs text-center {% if ok %}text-emerald-700 bg-emerald-50{% else %}text-rose-700 bg-rose-50{% endif %}" data-team-badge="{{ mid }}">
													{% if ok %}✓ Équipe OK{% else %}⚠ Sous-effectif
													{% endif %}
												</div>
												<div class="flex flex-wrap gap-x-2 gap-y-0.5">
													<span class="text-amber-700 {% if m.nb_selection == 0 %}hidden{% endif %}" data-stat-wrap="selection-{{ mid }}">Sélection:
														<strong data-stat="selection-{{ mid }}">{{ m.nb_selection }}</strong>
													</span>
													<span class="text-emerald-700 {% if m.nb_present == 0 %}hidden{% endif %}" data-stat-wrap="present-{{ mid }}">Présents:
														<strong data-stat="present-{{ mid }}">{{ m.nb_present }}</strong>
													</span>
												</div>
												<div class="flex flex-wrap gap-x-2 gap-y-0.5">
													<span class="text-blue-700 {% if m.nb_disponible == 0 %}hidden{% endif %}" data-stat-wrap="disponible-{{ mid }}">Dispos:
														<strong data-stat="disponible-{{ mid }}">{{ m.nb_disponible }}</strong>
													</span>
													<span class="text-rose-700 {% if m.nb_indisponible == 0 %}hidden{% endif %}" data-stat-wrap="indisponible-{{ mid }}">Indispos:
														<strong data-stat="indisponible-{{ mid }}">{{ m.nb_indisponible }}</strong>
													</span>
												</div>
												<div class="flex flex-wrap gap-x-2 gap-y-0.5">
													<span class="text-rose-800 {% if m.nb_absent == 0 %}hidden{% endif %}" data-stat-wrap="absent-{{ mid }}">Absents:
														<strong data-stat="absent-{{ mid }}">{{ m.nb_absent }}</strong>
													</span>
													<span class="text-orange-600 {% if m.nb_ne_sait_pas == 0 %}hidden{% endif %}" data-stat-wrap="ne_sait_pas-{{ mid }}">Ne sait pas:
														<strong data-stat="ne_sait_pas-{{ mid }}">{{ m.nb_ne_sait_pas }}</strong>
													</span>
												</div>
											{% else %}
												<div class="flex flex-wrap gap-x-2 gap-y-0.5">
													<span class="text-emerald-700" data-stat-wrap="present-{{ mid }}">Présents:
														<strong data-stat="present-{{ mid }}">{{ m.nb_present }}</strong>
													</span>
													<span class="text-rose-700" data-stat-wrap="absent-{{ mid }}">Absents:
														<strong data-stat="absent-{{ mid }}">{{ m.nb_absent }}</strong>
													</span>
												</div>
												<div class="flex flex-wrap gap-x-2 gap-y-0.5">
													<span class="text-blue-700 {% if m.nb_disponible == 0 %}hidden{% endif %}" data-stat-wrap="disponible-{{ mid }}">Dispos:
														<strong data-stat="disponible-{{ mid }}">{{ m.nb_disponible }}</strong>
													</span>
													<span class="text-rose-700 {% if m.nb_indisponible == 0 %}hidden{% endif %}" data-stat-wrap="indisponible-{{ mid }}">Indispos:
														<strong data-stat="indisponible-{{ mid }}">{{ m.nb_indisponible }}</strong>
													</span>
												</div>
												<span class="text-orange-600 {% if m.nb_ne_sait_pas == 0 %}hidden{% endif %}" data-stat-wrap="ne_sait_pas-{{ mid }}">Ne sait pas:
													<strong data-stat="ne_sait_pas-{{ mid }}">{{ m.nb_ne_sait_pas }}</strong>
												</span>
											{% endif %}
										</div>
									</th>
								{% endfor %}
							</tr>
						</thead>

						<tbody>
							{% if can_view_player_details %}
								{% for jid, nom in joueurs %}
									{% set row = cross[jid] %}
									{% set nb_manif = manifestations|length %}
									{% set is_current_user = currentUserId is defined and currentUserId and (jid == currentUserId) %}

									<tr class="{{ loop.index is odd ? 'bg-white' : 'bg-slate-50/50' }} hover:bg-amber-50/40 {% if is_current_user %}bg-indigo-50/20{% endif %}">

										<td class="sticky-left z-10 border-b border-r border-slate-200 px-3 py-2 font-medium bg-slate-50 min-w-[160px] text-slate-800 {% if is_current_user %}ring-2 ring-indigo-500/50 bg-indigo-50/80 font-bold text-indigo-950{% endif %}">
											{% if row.nb_participation < nb_manif %}
												<img src="{{ asset('icons/pas_content_violet.png') }}" alt="Participation incomplète" title="Participation incomplète" loading="lazy" class="inline w-5 h-5">
											{% elseif row.nb_ne_sait_pas > 3 %}
												<span class="text-base" title="Trop d'hésitations">😕</span>
											{% elseif row.nb_ne_sait_pas_proche > 0 %}
												<span class="text-base" title="Réponse attendue bientôt">🤔</span>
											{% else %}
												<img src="{{ asset('icons/content.png') }}" alt="Participation complète" title="Participation complète" loading="lazy" class="inline w-5 h-5">
											{% endif %}
											{% set parts = nom|split(' ') %}
											{% set nom_famille = parts[0] %}
											{% set prenom = parts|last %}
											<span class="ml-1.5 text-xs">{{ nom_famille|upper }} {{ prenom }}</span>
											{% if is_current_user %}
												<span class="ml-1 px-1.5 py-0.5 text-[10px] font-bold rounded-full bg-[var(--primary)] text-white shadow-sm inline-block">Vous</span>
											{% endif %}
										</td>

										{% for mid, m in manifestations %}
											{% set part = row[mid] ?? null %}
											{% set is_selected = part and part.category == 'selected' %}
											{% set is_present = part and part.category == 'present' %}
											{% set is_available_if_needed = part and part.category == 'available_if_needed' %}
											{% set is_available = part and part.category == 'available' %}
											{% set is_unavailable = part and part.category == 'unavailable' %}
											{% set is_absent = part and part.category == 'absent' %}
											{% set is_unknown = part and part.category == 'unknown' %}

											{% if is_selected %}
												{% set cell_bg = 'bg-amber-100' %}
												{% set text_color = 'text-amber-800' %}
											{% elseif is_present %}
												{% set cell_bg = 'bg-emerald-100' %}
												{% set text_color = 'text-emerald-800' %}
											{% elseif is_available %}
												{% set cell_bg = 'bg-sky-100' %}
												{% set text_color = 'text-sky-800' %}
											{% elseif is_available_if_needed %}
												{% set cell_bg = 'bg-cyan-100' %}
												{% set text_color = 'text-cyan-800' %}
											{% elseif is_unavailable %}
												{% set cell_bg = 'bg-rose-100' %}
												{% set text_color = 'text-rose-800' %}
											{% elseif is_absent %}
												{% set cell_bg = 'bg-rose-100' %}
												{% set text_color = 'text-rose-800' %}
											{% elseif is_unknown %}
												{% set cell_bg = 'bg-gray-100' %}
												{% set text_color = 'text-gray-800' %}
											{% else %}
												{% set cell_bg = 'bg-white' %}
												{% set text_color = 'text-gray-400' %}
											{% endif %}

											{% if m.annule %}
												{% set cell_bg = 'bg-rose-200' %}
												{% set text_color = 'text-rose-900' %}
											{% elseif m.provisoire %}
												{% set cell_bg = 'bg-amber-100' %}
												{% set text_color = 'text-amber-800' %}
											{% endif %}

											{% if is_selected %}
												{% set icone = '★' %}{% set libelle = 'Sél.' %}
											{% elseif is_present %}
												{% set icone = '✓' %}{% set libelle = part.companion_count > 0 ? 'Prés. à ' ~ (part.companion_count + 1) : 'Prés.' %}
											{% elseif is_available_if_needed %}
												{% set icone = '○' %}{% set libelle = 'Si néc.' %}
											{% elseif is_available %}
												{% set icone = '◐' %}{% set libelle = 'Dispo' %}
											{% elseif is_unavailable %}
												{% set icone = '✗' %}{% set libelle = 'Indispo' %}
											{% elseif is_absent %}
												{% set icone = '✗' %}{% set libelle = 'Absent' %}
											{% elseif is_unknown %}
												{% set icone = '?' %}{% set libelle = '?' %}
											{% else %}
												{% set icone = '—' %}{% set libelle = 'S.R.' %}
											{% endif %}

											{% set is_user_cell = is_current_user and not m.annule %}

											<td class="border-b border-r border-slate-200 px-2 py-1.5 text-center font-medium {{ cell_bg }} {{ text_color }} {% if is_user_cell %}cursor-pointer hover:ring-2 hover:ring-[var(--primary)] hover:z-20 transition-all select-none relative group{% endif %}" 
												{% if is_user_cell %}
													data-user-cell="true"
													data-manifestation-id="{{ mid }}"
													data-player-id="{{ jid }}"
													data-current-status="{{ part ? part.text : '' }}"
													data-event-type="{{ 'Match' in m.type ? 'match' : 'other' }}"
													data-is-selected="{{ is_selected ? '1' : '0' }}"
													data-is-cancelled="{{ m.annule ? '1' : '0' }}"
													title="Cliquer pour modifier votre présence"
												{% else %}
													title="{{ part ? part.text : '' }}"
												{% endif %}>
												<span class="cell-icon text-sm">{{ icone }}</span>
												<span class="cell-label text-xs">{{ libelle }}</span>
												{% if is_user_cell %}
													<span class="absolute right-0.5 top-0.5 text-[8px] opacity-0 group-hover:opacity-100 transition-opacity text-slate-400">✏️</span>
												{% endif %}
											</td>
										{% endfor %}

									</tr>
								{% endfor %}
							{% else %}
								<tr>
									<td colspan="{{ manifestations|length + 1 }}" class="p-8 bg-slate-50/50 text-left">
										<div class="sticky left-6 max-w-md py-6 px-4">
											<div class="w-12 h-12 rounded-full bg-indigo-50 text-indigo-600 flex items-center justify-center mb-4 border border-indigo-100 shadow-sm">
												<svg class="w-6 h-6" fill="none" stroke="currentColor" viewbox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
											</div>
											<h3 class="text-base font-black text-slate-900 mb-1.5">Disponibilités des joueurs masquées</h3>
											<p class="text-xs text-slate-500 mb-6 font-semibold leading-relaxed">Les présences individuelles et la grille des joueurs sont réservées aux membres connectés de l'USM Volley.</p>
											<a href="/member/login?redirect={{ url('agenda?view=table')|url_encode }}" class="btn-primary rounded-xl font-bold py-3 px-6 inline-flex text-xs cursor-pointer shadow-sm hover:scale-105 transition-transform">
												Se connecter pour voir les présences
											</a>
										</div>
									</td>
								</tr>
							{% endif %}
						</tbody>
					</table>
				</div>

				{# Légende #}
				<div class="mt-10 space-y-6">
					<h2 class="font-serif text-xl font-semibold text-slate-900">Légende</h2>
					<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
						<div class="flex items-center gap-2.5 bg-emerald-50 rounded-md px-3 py-2.5">
							<span class="text-lg">✓</span>
							<div>
								<div class="text-xs font-semibold text-emerald-900">Présent</div>
								<div class="text-xs text-emerald-700">Confirmé</div>
							</div>
						</div>
						<div class="flex items-center gap-2.5 bg-amber-50 rounded-md px-3 py-2.5">
							<span class="text-lg">★</span>
							<div>
								<div class="text-xs font-semibold text-amber-900">Sélectionné</div>
								<div class="text-xs text-amber-700">Important</div>
							</div>
						</div>
						<div class="flex items-center gap-2.5 bg-sky-50 rounded-md px-3 py-2.5">
							<span class="text-lg">◐</span>
							<div>
								<div class="text-xs font-semibold text-sky-900">Disponible</div>
								<div class="text-xs text-sky-700">En réserve</div>
							</div>
						</div>
						<div class="flex items-center gap-2.5 bg-cyan-50 rounded-md px-3 py-2.5">
							<span class="text-lg">○</span>
							<div>
								<div class="text-xs font-semibold text-cyan-900">Si nécessaire</div>
								<div class="text-xs text-cyan-700">Recours</div>
							</div>
						</div>
						<div class="flex items-center gap-2.5 bg-rose-50 rounded-md px-3 py-2.5">
							<span class="text-lg">✗</span>
							<div>
								<div class="text-xs font-semibold text-rose-900">Indisponible</div>
								<div class="text-xs text-rose-700">Empêchement</div>
							</div>
						</div>
						<div class="flex items-center gap-2.5 bg-rose-100 rounded-md px-3 py-2.5">
							<span class="text-lg">✗</span>
							<div>
								<div class="text-xs font-semibold text-rose-900">Absent</div>
								<div class="text-xs text-rose-700">Confirmé</div>
							</div>
						</div>
						<div class="flex items-center gap-2.5 bg-orange-50 rounded-md px-3 py-2.5">
							<span class="text-lg">?</span>
							<div>
								<div class="text-xs font-semibold text-orange-900">Ne sait pas</div>
								<div class="text-xs text-orange-700">À confirmer</div>
							</div>
						</div>
						<div class="flex items-center gap-2.5 bg-slate-100 rounded-md px-3 py-2.5">
							<span class="text-lg">—</span>
							<div>
								<div class="text-xs font-semibold text-slate-700">Sans réponse</div>
								<div class="text-xs text-slate-600">À remplir</div>
							</div>
						</div>
					</div>

					<div class="pt-4 border-t border-slate-200 space-y-2 text-xs text-slate-600">
						<p>
							<strong class="text-emerald-700">✓ Équipe OK :</strong>
							effectif suffisant selon les besoins de l'équipe (Présents + Disponibles + Sélectionnés)</p>
						<p>
							<strong class="text-rose-700">⚠ Sous-effectif :</strong>
							effectif disponible inférieur au minimum requis pour l'équipe</p>
						<p>
							<strong>⚠ Alerte terrains :</strong>
							nombre de terrains anormal (pas 0, 1 ou ".")</p>
					</div>
				</div>

			{% endif %}

			<div class="mt-12 pb-6">
				<a href="/" class="text-sm font-medium text-[var(--primary)] hover:underline underline-offset-4">← Retour à l'accueil</a>
			</div>
		</div>
	</div>

	<style>
		.agenda-table-container {
			position: relative;
			touch-action: manipulation;
			scrollbar-width: thin;
			scrollbar-color: #cbd5e1 #f1f5f9;
		}
		.agenda-table thead {
			position: sticky;
			top: 0;
			z-index: 20;
		}
		.agenda-table th.sticky-left {
			position: sticky;
			left: 0;
			z-index: 30;
		}
		.agenda-table td.sticky-left {
			position: sticky;
			left: 0;
			z-index: 10;
		}
		@media(max-width: 640px) {
			.agenda-table-container {
				font-size: 0.75rem;
			}
			.agenda-table th,
			.agenda-table td {
				padding: 4px 6px;
			}
		}
		.zoom-btn.active {
			background-color: var(--primary);
			color: #fff;
			border-color: var(--primary);
		}
	</style>

	<script>
		(function () {
			// 1. Gestion du Zoom
			var table = document.querySelector('.agenda-table');
			var buttons = document.querySelectorAll('.zoom-btn');
			if (table && buttons.length) {
				function applyZoom(z) {
					table.style.zoom = z;
					buttons.forEach(function (b) {
						b.classList.toggle('active', parseFloat(b.dataset.zoom) === z);
					});
					try {
						localStorage.setItem('agendaZoom', String(z));
					} catch (e) {}
				}
				var stored = null;
				try {
					stored = localStorage.getItem('agendaZoom');
				} catch (e) {}
				var initial = stored ? parseFloat(stored) : (window.innerWidth < 768 ? 0.65 : 1);
				applyZoom(initial);
				buttons.forEach(function (b) {
					b.addEventListener('click', function () {
						applyZoom(parseFloat(b.dataset.zoom));
					});
				});
			}

			// Toast Helper
			function showToast(message, type = 'success') {
				const toast = document.createElement('div');
				toast.className = `fixed bottom-5 right-5 z-[9999] px-4 py-3 rounded-2xl text-xs font-bold shadow-xl transition-all duration-300 transform translate-y-10 opacity-0 ${type === 'success' ? 'bg-slate-900 text-white border border-slate-800' : 'bg-rose-600 text-white'}`;
				toast.textContent = message;
				document.body.appendChild(toast);
				
				setTimeout(() => {
					toast.classList.remove('translate-y-10', 'opacity-0');
				}, 10);

				setTimeout(() => {
					toast.classList.add('translate-y-10', 'opacity-0');
					setTimeout(() => {
						toast.remove();
					}, 300);
				}, 3000);
			}

			// 2. Modification directe de présence au clic sur les cellules du joueur connecté
			const userCells = document.querySelectorAll('[data-user-cell="true"]');
			if (!userCells.length) return;

			let activePopover = null;

			function closePopover() {
				if (activePopover) {
					activePopover.remove();
					activePopover = null;
				}
			}

			document.addEventListener('click', (e) => {
				if (activePopover && !activePopover.contains(e.target) && !e.target.closest('[data-user-cell="true"]')) {
					closePopover();
				}
			});

			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') closePopover();
			});

			function getCategoryForStatus(status) {
				if (!status || status === '.') return 'no_response';
				if (status.indexOf('Sélectionné') === 0 || status === 'En réserve') return 'selected';
				if (status.indexOf('Présent') === 0) return 'present';
				if (status === 'Disponible si nécessaire') return 'available_if_needed';
				if (status === 'Disponible' || status === 'Joker') return 'available';
				if (status === 'Indisponible') return 'unavailable';
				if (status === 'Absent' || status === 'Absent(e)') return 'absent';
				if (status === 'Ne sait pas' || status === '?') return 'unknown';
				return 'no_response';
			}

			function updateCellVisual(cell, newStatus) {
				cell.dataset.currentStatus = newStatus;
				const cat = getCategoryForStatus(newStatus);

				const bgClasses = ['bg-amber-100', 'bg-emerald-100', 'bg-sky-100', 'bg-cyan-100', 'bg-rose-100', 'bg-gray-100', 'bg-white', 'bg-rose-200'];
				const textClasses = ['text-amber-800', 'text-emerald-800', 'text-sky-800', 'text-cyan-800', 'text-rose-800', 'text-gray-800', 'text-gray-400', 'text-rose-900'];

				cell.classList.remove(...bgClasses, ...textClasses);

				let icon = '—', label = 'S.R.', cellBg = 'bg-white', textColor = 'text-gray-400';

				switch(cat) {
					case 'selected':
						icon = '★'; label = 'Sél.'; cellBg = 'bg-amber-100'; textColor = 'text-amber-800';
						break;
					case 'present':
						icon = '✓';
						if (newStatus.includes('à 2')) label = 'Prés. à 2';
						else if (newStatus.includes('à 3')) label = 'Prés. à 3';
						else if (newStatus.includes('à 4')) label = 'Prés. à 4';
						else if (newStatus.includes('à 5')) label = 'Prés. à 5';
						else label = 'Prés.';
						cellBg = 'bg-emerald-100'; textColor = 'text-emerald-800';
						break;
					case 'available':
						icon = '◐'; label = 'Dispo'; cellBg = 'bg-sky-100'; textColor = 'text-sky-800';
						break;
					case 'available_if_needed':
						icon = '○'; label = 'Si néc.'; cellBg = 'bg-cyan-100'; textColor = 'text-cyan-800';
						break;
					case 'unavailable':
						icon = '✗'; label = 'Indispo'; cellBg = 'bg-rose-100'; textColor = 'text-rose-800';
						break;
					case 'absent':
						icon = '✗'; label = 'Absent'; cellBg = 'bg-rose-100'; textColor = 'text-rose-800';
						break;
					case 'unknown':
						icon = '?'; label = '?'; cellBg = 'bg-gray-100'; textColor = 'text-gray-800';
						break;
					default:
						icon = '—'; label = 'S.R.'; cellBg = 'bg-white'; textColor = 'text-gray-400';
				}

				cell.classList.add(cellBg, textColor);
				const iconSpan = cell.querySelector('.cell-icon');
				const labelSpan = cell.querySelector('.cell-label');
				if (iconSpan) iconSpan.textContent = icon;
				if (labelSpan) labelSpan.textContent = label;
				cell.title = newStatus && newStatus !== '.' ? newStatus : '';
			}

			function updateHeaderStats(mid, counts) {
				if (!counts) return;

				const mapping = {
					'present': counts.present ?? 0,
					'disponible': counts.available ?? 0,
					'indisponible': counts.unavailable ?? 0,
					'absent': counts.absent ?? 0,
					'ne_sait_pas': counts.unknown ?? 0,
					'selection': counts.selected ?? 0
				};

				Object.keys(mapping).forEach(key => {
					const countVal = mapping[key];
					const el = document.querySelector(`[data-stat="${key}-${mid}"]`);
					const wrap = document.querySelector(`[data-stat-wrap="${key}-${mid}"]`);
					if (el) el.textContent = countVal;
					if (wrap) {
						if (countVal > 0) wrap.classList.remove('hidden');
						else if (key !== 'present' && key !== 'absent') wrap.classList.add('hidden');
					}
				});

				const teamBadge = document.querySelector(`[data-team-badge="${mid}"]`);
				if (teamBadge) {
					const totalOk = (mapping.present || 0) + (mapping.disponible || 0) + (mapping.selection || 0);
					const isOk = totalOk >= 6;
					if (isOk) {
						teamBadge.textContent = '✓ Équipe OK';
						teamBadge.className = 'px-2 py-1 rounded font-semibold text-xs text-center text-emerald-700 bg-emerald-50';
					} else {
						teamBadge.textContent = '⚠ Sous-effectif';
						teamBadge.className = 'px-2 py-1 rounded font-semibold text-xs text-center text-rose-700 bg-rose-50';
					}
				}
			}

			userCells.forEach(cell => {
				cell.addEventListener('click', (e) => {
					e.stopPropagation();
					closePopover();

					const isSelected = cell.dataset.isSelected === '1';
					const isCancelled = cell.dataset.isCancelled === '1';
					const mid = cell.dataset.manifestationId;
					const eventType = cell.dataset.eventType;
					const currentStatus = cell.dataset.currentStatus || '';

					if (isCancelled) {
						showToast('Événement annulé : modification impossible.', 'error');
						return;
					}

					if (isSelected) {
						showToast('Vous êtes convoqué(e) pour ce match par votre capitaine. Statut verrouillé.', 'error');
						return;
					}

					const popover = document.createElement('div');
					popover.className = 'fixed z-[9990] bg-white rounded-2xl shadow-xl border border-slate-200 p-2 space-y-1 text-xs min-w-[170px] transition-all animate-in fade-in zoom-in-95';

					const options = [];

					if (eventType === 'match') {
						options.push(
							{ label: '✓ Disponible', value: 'Disponible', class: 'text-emerald-700 bg-emerald-50 hover:bg-emerald-100' },
							{ label: '◐ Si besoin', value: 'Disponible si nécessaire', class: 'text-cyan-700 bg-cyan-50 hover:bg-cyan-100' },
							{ label: '✗ Indisponible', value: 'Indisponible', class: 'text-rose-700 bg-rose-50 hover:bg-rose-100' },
							{ label: '⊘ Sans réponse', value: '.', class: 'text-slate-500 bg-slate-50 hover:bg-slate-100' }
						);
					} else {
						options.push(
							{ label: '✓ Présent(e)', value: 'Présent(e)', class: 'text-emerald-700 bg-emerald-50 hover:bg-emerald-100' },
							{ label: '✓ Présent(e) à 2', value: 'Présent(e) à 2', class: 'text-emerald-700 bg-emerald-50 hover:bg-emerald-100' },
							{ label: '✓ Présent(e) à 3', value: 'Présent(e) à 3', class: 'text-emerald-700 bg-emerald-50 hover:bg-emerald-100' },
							{ label: '✓ Présent(e) à 4', value: 'Présent(e) à 4', class: 'text-emerald-700 bg-emerald-50 hover:bg-emerald-100' },
							{ label: '✗ Absent(e)', value: 'Absent(e)', class: 'text-rose-700 bg-rose-50 hover:bg-rose-100' },
							{ label: '? Ne sait pas', value: 'Ne sait pas', class: 'text-orange-700 bg-orange-50 hover:bg-orange-100' },
							{ label: '⊘ Sans réponse', value: '.', class: 'text-slate-500 bg-slate-50 hover:bg-slate-100' }
						);
					}

					options.forEach(opt => {
						const btn = document.createElement('button');
						btn.type = 'button';
						const isActive = (opt.value === currentStatus) || (opt.value === '.' && (!currentStatus || currentStatus === '.'));
						btn.className = `w-full text-left px-3 py-2 rounded-xl text-xs font-bold transition-all flex items-center justify-between gap-2 cursor-pointer ${opt.class} ${isActive ? 'ring-2 ring-indigo-500' : ''}`;
						btn.innerHTML = `<span>${opt.label}</span>${isActive ? '<span class="text-[10px]">●</span>' : ''}`;
						
						btn.addEventListener('click', () => {
							closePopover();
							if (opt.value === currentStatus) return;

							cell.style.opacity = '0.5';

							fetch('/api/member/participations/upsert', {
								method: 'POST',
								headers: { 'Content-Type': 'application/json' },
								body: JSON.stringify({
									manifestation_id: parseInt(mid),
									status: opt.value
								})
							})
							.then(r => {
								if (!r.ok) {
									return r.json().then(err => { throw new Error(err.message || 'Erreur serveur'); });
								}
								return r.json();
							})
							.then(data => {
								cell.style.opacity = '1';
								if (data.ok) {
									updateCellVisual(cell, data.new_status || opt.value);
									updateHeaderStats(mid, data.counts);
									showToast(data.message || 'Présence mise à jour avec succès', 'success');
								} else {
									showToast(data.message || 'Erreur lors de la mise à jour.', 'error');
								}
							})
							.catch(err => {
								cell.style.opacity = '1';
								showToast(err.message || 'Erreur réseau.', 'error');
							});
						});
						popover.appendChild(btn);
					});

					document.body.appendChild(popover);
					activePopover = popover;

					const rect = cell.getBoundingClientRect();
					let left = rect.left + window.scrollX - 20;
					if (left + 180 > window.innerWidth) {
						left = window.innerWidth - 190;
					}
					if (left < 10) left = 10;

					let top = rect.bottom + 6;
					if (top + popover.offsetHeight > window.innerHeight) {
						top = rect.top - popover.offsetHeight - 6;
					}

					popover.style.top = `${top}px`;
					popover.style.left = `${left}px`;
				});
			});
		})();
	</script>
{% endblock %}
