{# Reusable macros for the agenda module - editorial style #}

{% macro render_filter_dropdown(name, label, options, selected) %}
  <div>
    <label class="block text-xs uppercase tracking-wider font-medium text-slate-500 mb-2">{{ label }}</label>
    <select name="{{ name }}" onchange="this.form.submit()"
            class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--primary)]">
      <option value="Tous">[Tous]</option>
      {% for option in options %}
        <option value="{{ option }}" {% if selected == option %}selected{% endif %}>{{ option }}</option>
      {% endfor %}
    </select>
  </div>
{% endmacro %}

{% macro render_filter_checkbox(name, label, checked) %}
  <div class="flex items-center">
    <label class="flex items-center text-sm text-slate-700 cursor-pointer">
      <input type="checkbox" name="{{ name }}" value="1" {% if checked %}checked{% endif %} onchange="this.form.submit()"
             class="w-4 h-4 rounded border-slate-300 text-[var(--primary)] focus:ring-[var(--primary)]">
      <span class="ml-2">{{ label }}</span>
    </label>
  </div>
{% endmacro %}



{% macro render_stats_row(icon, label, count, color) %}
  <tr class="border-b border-slate-100 hover:bg-slate-50">
    <td class="px-4 py-3 text-sm">
      <span class="{{ color }} font-semibold">{{ icon }}</span>
    </td>
    <td class="px-4 py-3 text-sm text-slate-700">{{ label }}</td>
    <td class="px-4 py-3 text-sm font-semibold text-slate-900">{{ count }}</td>
  </tr>
{% endmacro %}

{% macro render_participation_badge(present, available, unavailable) %}
  {% set total = present + available + unavailable %}
  {% set viable = (present + available) >= 6 %}
  {% if viable %}
    {% set bg_class = 'bg-emerald-50 text-emerald-700' %}
    {% set status_icon = '✓' %}
  {% elseif present + available >= 3 %}
    {% set bg_class = 'bg-amber-50 text-amber-700' %}
    {% set status_icon = '◐' %}
  {% else %}
    {% set bg_class = 'bg-rose-50 text-rose-700' %}
    {% set status_icon = '✗' %}
  {% endif %}
  <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold {{ bg_class }}">
    <span>{{ status_icon }}</span>
    <span>{{ present + available }}/{{ total }}</span>
  </span>
{% endmacro %}
