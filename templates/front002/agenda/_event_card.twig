{# 
  Partial for an event card.
  Parameters:
    - m: The manifestation object
    - allow_actions: (bool) Whether to show participation action buttons
    - show_link: (bool) Whether to make the card or title link to the detail page
    - terrain_alert: (bool) Variable à passer si l'alerte terrain est active
#}

{# 1. Détermination de la couleur de la bordure gauche selon le statut utilisateur #}
{% set accent_color = 'border-l-slate-200' %}
{% if m.user_status is defined and m.user_status %}
    {% if m.user_status in ['Disponible', 'Présent'] %}
        {% set accent_color = 'border-l-emerald-500' %}
    {% elseif m.user_status == 'Disponible si nécessaire' %}
        {% set accent_color = 'border-l-amber-400' %}
    {% elseif m.user_status in ['Indisponible', 'Absent'] %}
        {% set accent_color = 'border-l-rose-500' %}
    {% elseif m.user_status == 'Ne sait pas encore' %}
        {% set accent_color = 'border-l-slate-400' %}
    {% endif %}
{% endif %}

{# 2. Détermination du code couleur (badge) selon le TYPE d'événement #}
{% set type_str = m.type_simple|default(m.type|default(''))|lower %}
{% set badge_bg = 'bg-slate-100' %}
{% set badge_text = 'text-slate-700' %}
{% set badge_border = 'border-slate-200' %}

{% if 'match' in type_str %}
    {% set badge_bg = 'bg-blue-100' %}
    {% set badge_text = 'text-blue-800' %}
    {% set badge_border = 'border-blue-200' %}
{% elseif 'entraînement' in type_str or 'entrainement' in type_str %}
    {% set badge_bg = 'bg-orange-100' %}
    {% set badge_text = 'text-orange-800' %}
    {% set badge_border = 'border-orange-200' %}
{% elseif 'tournoi' in type_str or 'plateau' in type_str %}
    {% set badge_bg = 'bg-purple-100' %}
    {% set badge_text = 'text-purple-800' %}
    {% set badge_border = 'border-purple-200' %}
{% elseif 'fête' in type_str or 'repas' in type_str or 'soirée' in type_str %}
    {% set badge_bg = 'bg-pink-100' %}
    {% set badge_text = 'text-pink-800' %}
    {% set badge_border = 'border-pink-200' %}
{% endif %}

<div class="bg-white rounded-[24px] border-y border-r border-slate-100 border-l-4 {{ accent_color }} shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden h-full flex flex-col group relative p-6" 
     data-manifestation-id="{{ m.id }}" 
     data-event-filter="{{ m.is_match ? 'match' : (m.type|lower|replace({' ': '-'})) }}"
     data-current-status="{{ m.user_status|default('.') }}">
    
    {# --- LIGNE DU HAUT : Titre & Badge --- #}
    <div class="flex items-start justify-between gap-4 mb-4">
        <div class="flex-1">
            <h3 class="text-xl font-extrabold text-slate-900 leading-tight">
                {% if show_link %}
                    <a href="{{ url('agenda/' ~ m.id) }}" class="hover:text-[var(--primary)] transition-colors after:absolute after:inset-0">
                        {{ m.titre }}
                    </a>
                {% else %}
                    {{ m.titre }}
                {% endif %}
            </h3>
        </div>
        <span class="inline-flex items-center px-3 py-1 rounded-full border {{ badge_bg }} {{ badge_text }} {{ badge_border }} text-[10px] font-black tracking-widest uppercase shadow-sm whitespace-nowrap">
            {{ m.type_simple|default(m.type|default('Événement')) }}
        </span>
    </div>

    {# --- LIGNE DU MILIEU : Date & Heure --- #}
    <div class="flex items-baseline gap-2 mb-4">
        <span class="text-sm font-bold uppercase tracking-wide {% if m.user_status in ['Présent', 'Disponible'] %}text-emerald-600{% else %}text-[var(--primary)]{% endif %}">
            {{ m.date_display }}
        </span>
        {% if m.time_range %}
            <span class="text-slate-300 font-light">/</span>
            <span class="text-sm font-medium text-slate-600">{{ m.time_range }}</span>
        {% endif %}
    </div>

    {# --- LIGNE INFOS : Lieu, Alerte, Commentaire --- #}
    <div class="space-y-2 mb-6 flex-grow text-sm text-slate-500">
        {% if m.lieu %}
            <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-slate-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span class="line-clamp-2 leading-snug">{{ m.lieu }}</span>
            </div>
        {% endif %}

        {% if terrain_alert is defined and terrain_alert %}
            <div class="flex items-center gap-2 mt-2 bg-rose-50 text-rose-700 px-3 py-1.5 rounded-lg border border-rose-100 w-fit">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                <span class="text-xs font-bold">{{ m.nb_terrains }} terrains</span>
            </div>
        {% endif %}

        {% if m.commentaire %}
            <div class="flex items-start gap-2 mt-2">
                <svg class="w-4 h-4 text-slate-300 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                <span class="text-xs italic leading-snug">{{ m.commentaire|slice(0, 50) }}{% if m.commentaire|length > 50 %}...{% endif %}</span>
            </div>
        {% endif %}
    </div>

{# --- LIGNE DU BAS : Vote, Statut et Pastilles --- #}
    <div class="mt-auto pt-4 border-t border-slate-100 flex flex-col gap-4 relative z-10">
        
        {# --- 1. LIGNE VOTE & MON STATUT --- #}
        <div class="flex items-center justify-between">
            <div class="flex flex-col">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Mon Statut</span>
                <span id="status-{{ m.id }}" class="inline-flex items-center text-xs font-bold {% if m.user_status %}{% if m.user_status in ['Disponible', 'Présent'] %}text-emerald-600{% elseif m.user_status == 'Disponible si nécessaire' %}text-amber-500{% elseif m.user_status in ['Indisponible', 'Absent'] %}text-rose-500{% else %}text-slate-600{% endif %}{% else %}text-slate-400{% endif %}">
                    {% if m.user_status %}
                        {% if m.user_status in ['Disponible', 'Présent'] %} <span class="mr-1">✓</span> {{ m.user_status }}
                        {% elseif m.user_status == 'Disponible si nécessaire' %} <span class="mr-1">◐</span> Si besoin
                        {% elseif m.user_status in ['Indisponible', 'Absent'] %} <span class="mr-1">✗</span> {{ m.user_status }}
                        {% else %} {{ m.user_status }} {% endif %}
                    {% else %}
                        Non renseigné
                    {% endif %}
                </span>
            </div>
            
            {% if allow_actions %}
                {# BOUTONS DE VOTE INDÉPENDANTS #}
                <div class="flex gap-1.5">
                    {% if m.is_match %}
                        <button type="button" class="status-btn w-8 h-8 rounded-xl border border-slate-200 bg-white text-emerald-600 hover:bg-emerald-50 hover:border-emerald-300 flex items-center justify-center transition-all shadow-sm" data-status="Disponible" title="Indiquer : Disponible">✓</button>
                        <button type="button" class="status-btn w-8 h-8 rounded-xl border border-slate-200 bg-white text-amber-500 hover:bg-amber-50 hover:border-amber-300 flex items-center justify-center transition-all shadow-sm" data-status="Disponible si nécessaire" title="Indiquer : Disponible si besoin">◐</button>
                        <button type="button" class="status-btn w-8 h-8 rounded-xl border border-slate-200 bg-white text-rose-500 hover:bg-rose-50 hover:border-rose-300 flex items-center justify-center transition-all shadow-sm" data-status="Indisponible" title="Indiquer : Indisponible">✗</button>
                    {% else %}
                        <button type="button" class="status-btn w-8 h-8 rounded-xl border border-slate-200 bg-white text-emerald-600 hover:bg-emerald-50 hover:border-emerald-300 flex items-center justify-center transition-all shadow-sm" data-status="Présent" title="Indiquer : Présent">✓</button>
                        <button type="button" class="status-btn w-8 h-8 rounded-xl border border-slate-200 bg-white text-rose-500 hover:bg-rose-50 hover:border-rose-300 flex items-center justify-center transition-all shadow-sm" data-status="Absent" title="Indiquer : Absent">✗</button>
                    {% endif %}
                    <button type="button" class="status-btn w-8 h-8 rounded-xl border border-slate-100 bg-slate-50 text-slate-400 hover:bg-slate-200 hover:text-slate-600 flex items-center justify-center transition-all shadow-sm ml-1" data-status="." title="Réinitialiser">⊘</button>
                </div>
            {% endif %}
        </div>

        {# --- 2. LIGNE PASTILLES (Statistiques & Liste des joueurs) --- #}
        <div class="flex items-center justify-between mt-1 pt-3 border-t border-slate-50">
            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Récapitulatif</span>
            
            <div class="flex items-center">
                {% if m.is_match %}
                    <div class="player-list-trigger cursor-pointer w-9 h-9 rounded-full border-[2px] border-white bg-emerald-100 text-emerald-700 flex items-center justify-center text-xs font-bold relative z-30 shadow-sm hover:z-50 hover:scale-110 transition-all" 
                         data-title="Joueurs disponibles" 
                         data-players='{{ m.disponibles|default([])|json_encode|e('html_attr') }}'>
                        {{ m.nb_disponible|default(0) }}
                    </div>
                    <div class="player-list-trigger cursor-pointer w-9 h-9 rounded-full border-[2px] border-white bg-amber-100 text-amber-700 flex items-center justify-center text-xs font-bold -ml-2.5 relative z-20 shadow-sm hover:z-50 hover:scale-110 transition-all" 
                         data-title="Joueurs (Si besoin)" 
                         data-players='{{ m.disponibles_si_necessaire|default([])|json_encode|e('html_attr') }}'>
                        {{ m.nb_disponible_si_necessaire|default(0) }}
                    </div>
                    <div class="player-list-trigger cursor-pointer w-9 h-9 rounded-full border-[2px] border-white bg-rose-100 text-rose-700 flex items-center justify-center text-xs font-bold -ml-2.5 relative z-10 shadow-sm hover:z-50 hover:scale-110 transition-all" 
                         data-title="Joueurs indisponibles" 
                         data-players='{{ m.indisponibles|default([])|json_encode|e('html_attr') }}'>
                        {{ m.nb_indisponible|default(0) }}
                    </div>
                {% else %}
                    <div class="player-list-trigger cursor-pointer w-9 h-9 rounded-full border-[2px] border-white bg-emerald-100 text-emerald-700 flex items-center justify-center text-xs font-bold relative z-30 shadow-sm hover:z-50 hover:scale-110 transition-all" 
                         data-title="Joueurs présents" 
                         data-players='{{ m.presents|default([])|json_encode|e('html_attr') }}'>
                        {{ m.nb_present|default(0) }}
                    </div>
                    <div class="player-list-trigger cursor-pointer w-9 h-9 rounded-full border-[2px] border-white bg-rose-100 text-rose-700 flex items-center justify-center text-xs font-bold -ml-2.5 relative z-10 shadow-sm hover:z-50 hover:scale-110 transition-all" 
                         data-title="Joueurs absents" 
                         data-players='{{ m.absents|default([])|json_encode|e('html_attr') }}'>
                        {{ m.nb_absent|default(0) }}
                    </div>
                {% endif %}
            </div>
        </div>
        
    </div>
</div>
</div>