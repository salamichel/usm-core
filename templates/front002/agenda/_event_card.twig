{# 
  Partial for an event card.
  Parameters:
    - m: The manifestation object
    - allow_actions: (bool) Whether to show participation action buttons
    - show_link: (bool) Whether to make the card or title link to the detail page
#}

{% set card_border_class = 'border-gray-200' %}
{% if m.user_status is defined and m.user_status %}
    {% if m.user_status == 'Disponible' or m.user_status == 'Présent' %}
        {% set card_border_class = 'border-green-400' %}
    {% elseif m.user_status == 'Disponible si nécessaire' %}
        {% set card_border_class = 'border-yellow-400' %}
    {% elseif m.user_status == 'Indisponible' or m.user_status == 'Absent' %}
        {% set card_border_class = 'border-red-400' %}
    {% elseif m.user_status == 'Ne sait pas encore' %}
        {% set card_border_class = 'border-gray-400' %}
    {% endif %}
{% elseif m.user_status is defined %}
    {% set card_border_class = 'border-gray-400' %}
{% endif %}

<div class="bg-white rounded-lg border {{ card_border_class }} shadow-sm overflow-hidden hover:shadow-md transition-shadow h-full flex flex-col" 
     data-manifestation-id="{{ m.id_manifestation }}" 
     data-event-filter="{{ m.is_match ? 'match' : (m.type_libelle is defined ? m.type_libelle|lower|replace({' ': '-'}) : 'training') }}">
    
    {# Header #}
    <div class="px-4 py-3 bg-gray-50 border-b border-gray-200">
        <div class="flex items-center justify-between mb-2">
            <span class="text-xs font-semibold text-gray-500 uppercase">{{ m.type_simple|default(m.type_libelle|default('Événement')) }}</span>
            {% if m.user_status is defined %}
            <span id="status-{{ m.id_manifestation }}" class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium 
                {% if m.user_status %}
                    {% if m.is_match and m.user_status == 'Disponible' %}
                        bg-green-100 text-green-700
                    {% elseif m.is_match and m.user_status == 'Disponible si nécessaire' %}
                        bg-yellow-100 text-yellow-700
                    {% elseif m.is_match and m.user_status == 'Indisponible' %}
                        bg-red-100 text-red-700
                    {% elseif not m.is_match and m.user_status == 'Présent' %}
                        bg-green-100 text-green-700
                    {% elseif not m.is_match and m.user_status == 'Absent' %}
                        bg-red-100 text-red-700
                    {% elseif m.user_status == 'Ne sait pas encore' %}
                        bg-gray-200 text-gray-700
                    {% else %}
                        bg-gray-100 text-gray-700
                    {% endif %}
                {% else %}
                    bg-gray-100 text-gray-700
                {% endif %}
            ">
                {% if m.user_status %}
                    {% if m.is_match and m.user_status == 'Disponible' %}
                        ✓ Disponible
                    {% elseif m.is_match and m.user_status == 'Disponible si nécessaire' %}
                        ◐ Si nécessaire
                    {% elseif m.is_match and m.user_status == 'Indisponible' %}
                        ✗ Indisponible
                    {% elseif not m.is_match and m.user_status == 'Présent' %}
                        ✓ Présent
                    {% elseif not m.is_match and m.user_status == 'Absent' %}
                        ✗ Absent
                    {% else %}
                        {{ m.user_status }}
                    {% endif %}
                {% else %}
                    ? Non renseigné
                {% endif %}
            </span>
            {% endif %}
        </div>
        <h3 class="text-sm font-semibold text-gray-900">
            {% if show_link %}
                <a href="{{ url('agenda/view', {id: m.id_manifestation}) }}" class="hover:text-[var(--primary)] transition-colors">
                    {{ m.titre }}
                </a>
            {% else %}
                {{ m.titre }}
            {% endif %}
        </h3>
    </div>

    {# Details #}
    <div class="px-4 py-3 space-y-2 text-xs text-gray-600 flex-grow">
        <div class="flex items-center gap-2">📅 <span>{{ m.Date|date('d/m/Y') }} - {{ m.Date|date('H:i') }}</span></div>
        {% if m.Durée_créneau %}<div class="flex items-center gap-2">🕐 <span>{{ m.Durée_créneau }}</span></div>{% endif %}
        <div class="flex items-center gap-2">📍 <span>{{ m.Lieu }}</span></div>
        
        {# Stats (optionnel si présentes) #}
        {% if m.nb_present is defined or m.nb_disponible is defined %}
            <div class="mt-3 pt-3 border-t border-gray-100 flex flex-wrap gap-x-4 gap-y-1">
                {% if m.is_match %}
                    <span class="text-green-600 font-medium" title="Disponibles">✓ {{ m.nb_disponible|default(0) }}</span>
                    <span class="text-yellow-600 font-medium" title="Si besoin">◐ {{ m.nb_si_besoin|default(0) }}</span>
                    <span class="text-red-600 font-medium" title="Indisponibles">✗ {{ m.nb_indisponible|default(0) }}</span>
                {% else %}
                    <span class="text-green-600 font-medium" title="Présents">✓ {{ m.nb_present|default(0) }}</span>
                    <span class="text-red-600 font-medium" title="Absents">✗ {{ m.nb_absent|default(0) }}</span>
                {% endif %}
            </div>
        {% endif %}
    </div>

    {# Buttons #}
    {% if allow_actions %}
    <div class="px-4 py-3 border-t border-gray-200 bg-gray-50 flex gap-2">
        {% if m.is_match %}
            <button type="button" class="status-btn flex-1 py-2 px-2 rounded-md text-xs font-medium transition-colors" data-status="Disponible" title="Disponible">✓</button>
            <button type="button" class="status-btn flex-1 py-2 px-2 rounded-md text-xs font-medium transition-colors" data-status="Disponible si nécessaire" title="Disponible si nécessaire">◐</button>
            <button type="button" class="status-btn flex-1 py-2 px-2 rounded-md text-xs font-medium transition-colors" data-status="Indisponible" title="Indisponible">✗</button>
            <button type="button" class="status-btn flex-1 py-2 px-2 rounded-md text-xs font-medium transition-colors" data-status="Ne sait pas encore" title="Ne sait pas encore">?</button>
        {% else %}
            <button type="button" class="status-btn flex-1 py-2 px-2 rounded-md text-xs font-medium transition-colors" data-status="Présent" title="Présent">✓</button>
            <button type="button" class="status-btn flex-1 py-2 px-2 rounded-md text-xs font-medium transition-colors" data-status="Absent" title="Absent">✗</button>
            <button type="button" class="status-btn flex-1 py-2 px-2 rounded-md text-xs font-medium transition-colors" data-status="Ne sait pas encore" title="Ne sait pas encore">?</button>
        {% endif %}
        <button type="button" class="status-btn flex-1 py-2 px-2 rounded-md text-xs font-medium transition-colors bg-gray-200 text-gray-700 hover:bg-gray-300" data-status="." title="Réinitialiser">⊘</button>
    </div>
    {% elseif show_link %}
    <div class="px-4 py-3 border-t border-gray-200 bg-gray-50">
        <a href="{{ url('agenda/view', {id: m.id_manifestation}) }}" class="block w-full text-center py-2 px-4 rounded-md bg-white border border-gray-300 text-xs font-medium text-gray-700 hover:bg-gray-50 transition-colors">
            Voir le détail
        </a>
    </div>
    {% endif %}
</div>