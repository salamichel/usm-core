{# 
  Partial for an event card.
  Parameters:
    - m: The manifestation object
    - allow_actions: (bool) Whether to show participation action buttons
    - show_link: (bool) Whether to make the card or title link to the detail page
    - is_first: (bool) Whether this is the first card in the list
#}

{# Détermination du style de fond de la carte #}
{% set is_active_bg = is_first ? 'bg-indigo-50/20 border-indigo-200/60 shadow-sm' : 'bg-white border-slate-100 hover:border-slate-200/80 shadow-sm hover:shadow-md' %}

<div class="rounded-[28px] border p-5 transition-all duration-300 flex flex-col relative {{ is_active_bg }}" 
     data-manifestation-id="{{ m.id }}" 
     data-event-date="{{ m.date|slice(0, 10) }}"
     data-event-filter="{{ m.is_match ? 'match' : (m.type|lower|replace({' ': '-'})) }}"
     data-current-status="{{ m.user_status|default('.') }}"
     data-event-location="{{ m.lieu|default('') }}">
    
    {# --- LIGNE PRINCIPALE (Date Badge + Contenu Grille) --- #}
    <div class="flex flex-col md:flex-row md:items-center gap-5 w-full">
        
        {# --- 1. Date Badge (Jour & Mois) & Title/Type row on mobile --- #}
        <div class="flex items-center gap-4 w-full md:w-auto">
            {% set date_parts = m.date_display|split(' ') %}
            <div class="flex-shrink-0 w-14 h-14 bg-slate-900 text-white rounded-2xl flex flex-col items-center justify-center shadow-sm relative z-20">
                <span class="text-xl font-black leading-none">{{ date_parts[1] }}</span>
                <span class="text-[9px] font-bold uppercase tracking-wider mt-1 text-slate-400">{{ date_parts[2]|slice(0, 3)|upper }}</span>
            </div>

            <div class="md:hidden space-y-1 z-20 flex-grow">
                <span class="text-[9px] font-black tracking-wider text-indigo-600/80 uppercase">{{ m.type_simple|default(m.type|default('Événement')) }}</span>
                <h3 class="text-base font-black text-slate-900 leading-snug">
                    {% if show_link %}
                        <a href="{{ url('agenda/' ~ m.id) }}" class="hover:text-[var(--primary)] transition-colors after:absolute after:inset-0 after:rounded-[28px] z-10">
                            {{ m.titre }}
                        </a>
                    {% else %}
                        {{ m.titre }}
                    {% endif %}
                </h3>
            </div>
        </div>

        {# --- 2. Contenu en grille de colonnes sur Desktop --- #}
        <div class="flex-grow grid grid-cols-1 {% if allow_actions %}md:grid-cols-4{% else %}md:grid-cols-3{% endif %} gap-6 items-center w-full">
            
            {# Colonne 1 : Titre, Type, Lieu #}
            <div class="space-y-1 z-20">
                <div class="hidden md:block space-y-1">
                    <span class="text-[9px] font-black tracking-wider text-indigo-600/80 uppercase">{{ m.type_simple|default(m.type|default('Événement')) }}</span>
                    <h3 class="text-base font-black text-slate-900 leading-snug">
                        {% if show_link %}
                            <a href="{{ url('agenda/' ~ m.id) }}" class="hover:text-[var(--primary)] transition-colors after:absolute after:inset-0 after:rounded-[28px] z-10">
                                {{ m.titre }}
                            </a>
                        {% else %}
                            {{ m.titre }}
                        {% endif %}
                    </h3>
                </div>
                {% if m.lieu %}
                    <span class="text-xs text-slate-500 font-semibold inline-flex items-center gap-1">
                        <svg class="w-3.5 h-3.5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        {{ m.lieu }}
                    </span>
                {% endif %}
            </div>

            {# Colonne 2 : Plage horaire & Barre de Progression (Effectif) #}
            <div class="space-y-2 z-20">
                <div class="flex items-center gap-1.5 text-xs font-bold text-slate-600 uppercase tracking-wide">
                    <svg class="w-3.5 h-3.5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span>{{ m.time_range|default('Horaire non précisé') }}</span>
                </div>

                {# Barre de progression #}
                {% if m.is_match %}
                    {% set total_count = m.nb_present + m.nb_disponible + m.nb_selection %}
                    {% set pct = (total_count >= 6) ? 100 : (total_count / 6 * 100) %}
                    <div>
                        <div class="flex items-center justify-between text-[10px] font-bold text-slate-400 mb-1">
                            <span class="progress-label flex items-center gap-1">
                                {% if total_count >= 6 %}
                                    <span class="text-emerald-600 flex items-center gap-1">✓ Équipe complète ({{ total_count }})</span>
                                {% else %}
                                    <span class="text-orange-500">⚠ Sous-effectif ({{ total_count }}/6)</span>
                                {% endif %}
                            </span>
                            <span>Durée : {{ m.duration|default('1h30') }}</span>
                        </div>
                        <div class="w-full bg-slate-100/80 h-2 rounded-full overflow-hidden relative border border-slate-50">
                            <div class="progress-bar h-full rounded-full transition-all duration-500 {% if total_count >= 6 %}bg-gradient-to-r from-emerald-400 to-teal-500{% else %}bg-gradient-to-r from-orange-400 to-amber-500{% endif %}" style="width: {{ pct }}%"></div>
                        </div>
                    </div>
                {% else %}
                    {% set total_presents = m.nb_present %}
                    {% set target_train = 12 %}
                    {% set pct_train = (total_presents >= target_train) ? 100 : (total_presents / target_train * 100) %}
                    <div>
                        <div class="flex items-center justify-between text-[10px] font-bold text-slate-400 mb-1">
                            <span class="progress-label text-indigo-500">{{ total_presents }} présent(s)</span>
                            <span>Durée : {{ m.duration|default('1h30') }}</span>
                        </div>
                        <div class="w-full bg-slate-100/80 h-2 rounded-full overflow-hidden relative border border-slate-50">
                            <div class="progress-bar h-full rounded-full transition-all duration-500 bg-gradient-to-r from-indigo-400 to-indigo-600" style="width: {{ pct_train }}%"></div>
                        </div>
                    </div>
                {% endif %}
            </div>

            {# Colonne 3 : Membres & Récapitulatif #}
            <div class="z-20 w-full">
                <div class="flex flex-row md:flex-col items-center md:items-start justify-between md:justify-start gap-4 w-full">
                    {# Membres #}
                    <div class="flex flex-col items-start">
                        <span class="text-[9px] font-black text-slate-400 tracking-wider uppercase">Membres</span>
                        <div class="flex items-center mt-1.5 avatar-stack">
                            {% set list_players = m.is_match ? (m.selectionnes|merge(m.disponibles)|merge(m.disponibles_si_necessaire)) : m.presents %}
                            {% set max_avatars = 24 %}
                            
                            {% for p in list_players|slice(0, max_avatars) %}
                                {% set parts = p.nom|split(' ') %}
                                {% set prenom = parts|last %}
                                {% set initial = prenom|slice(0, 1)|upper %}
                                {% set colors = [
                                    'bg-blue-100 text-blue-700',
                                    'bg-emerald-100 text-emerald-700',
                                    'bg-violet-100 text-violet-700',
                                    'bg-pink-100 text-pink-700',
                                    'bg-amber-100 text-amber-700',
                                    'bg-teal-100 text-teal-700'
                                ] %}
                                {% set color_class = colors[p.id % colors|length] %}
                                <div class="w-7 h-7 rounded-full border-2 border-white {{ color_class }} flex items-center justify-center text-[9px] font-black -ml-2.5 first:ml-0 shadow-sm relative z-30" title="{{ p.nom }}">
                                    {{ initial }}
                                </div>
                            {% endfor %}
                            
                            {% set total_players = list_players|length %}
                            {% if total_players > max_avatars %}
                                <div class="player-list-trigger cursor-pointer w-7 h-7 rounded-full border-2 border-white bg-slate-100 text-slate-700 flex items-center justify-center text-[9px] font-black -ml-2.5 relative z-30 shadow-sm hover:scale-110 hover:z-40 transition-all" 
                                     data-title="Joueurs inscrits" 
                                     data-players='{{ list_players|json_encode|e('html_attr') }}'>
                                    +{{ total_players - max_avatars }}
                                </div>
                            {% elseif total_players > 0 %}
                                <div class="player-list-trigger cursor-pointer w-7 h-7 rounded-full border-2 border-white bg-slate-50 text-slate-400 flex items-center justify-center text-[9px] font-bold -ml-2.5 relative z-30 shadow-sm hover:scale-110 hover:z-40 transition-all" 
                                     data-title="Joueurs inscrits" 
                                     data-players='{{ list_players|json_encode|e('html_attr') }}'>
                                    ℹ
                                </div>
                            {% else %}
                                <span class="text-[10px] text-slate-400 italic -ml-1">Aucun</span>
                            {% endif %}
                        </div>
                    </div>

                    {# Récapitulatif #}
                    <div class="flex flex-col items-end md:items-start md:border-t md:border-slate-100 md:pt-2 md:w-full">
                        <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Récapitulatif</span>
                        <div class="flex items-center gap-1.5 mt-1 flex-wrap justify-end md:justify-start">
                            {% if m.is_match %}
                                <div class="player-list-trigger cursor-pointer px-2 py-0.5 rounded-full text-[9px] font-extrabold bg-emerald-50 hover:bg-emerald-100 border border-emerald-100 text-emerald-700 hover:scale-105 transition-all flex items-center gap-0.5" 
                                     data-title="Joueurs disponibles" 
                                     data-status-key="Disponible"
                                     data-players='{{ m.disponibles|default([])|json_encode|e('html_attr') }}'>
                                    <span class="text-[9px]">✓</span> <span class="count-value">{{ m.nb_disponible|default(0) }}</span>
                                </div>
                                <div class="player-list-trigger cursor-pointer px-2 py-0.5 rounded-full text-[9px] font-extrabold bg-amber-50 hover:bg-amber-100 border border-amber-100 text-amber-600 hover:scale-105 transition-all flex items-center gap-0.5" 
                                     data-title="Joueurs (Si besoin)" 
                                     data-status-key="Disponible si nécessaire"
                                     data-players='{{ m.disponibles_si_necessaire|default([])|json_encode|e('html_attr') }}'>
                                     <span>◐</span> <span class="count-value">{{ m.nb_disponible_si_necessaire|default(0) }}</span>
                                </div>
                                <div class="player-list-trigger cursor-pointer px-2 py-0.5 rounded-full text-[9px] font-extrabold bg-rose-50 hover:bg-rose-100 border border-rose-100 text-rose-600 hover:scale-105 transition-all flex items-center gap-0.5" 
                                     data-title="Joueurs indisponibles" 
                                     data-status-key="Indisponible"
                                     data-players='{{ m.indisponibles|default([])|json_encode|e('html_attr') }}'>
                                     <span>✗</span> <span class="count-value">{{ m.nb_indisponible|default(0) }}</span>
                                </div>
                            {% else %}
                                <div class="player-list-trigger cursor-pointer px-2 py-0.5 rounded-full text-[9px] font-extrabold bg-emerald-50 hover:bg-emerald-100 border border-emerald-100 text-emerald-700 hover:scale-105 transition-all flex items-center gap-0.5" 
                                     data-title="Joueurs présents" 
                                     data-status-key="Présent"
                                     data-players='{{ m.presents|default([])|json_encode|e('html_attr') }}'>
                                    <span class="text-[9px]">✓</span> <span class="count-value">{{ m.nb_present|default(0) }}</span>
                                </div>
                                <div class="player-list-trigger cursor-pointer px-2 py-0.5 rounded-full text-[9px] font-extrabold bg-rose-50 hover:bg-rose-100 border border-rose-100 text-rose-600 hover:scale-105 transition-all flex items-center gap-0.5" 
                                     data-title="Joueurs absents" 
                                     data-status-key="Absent"
                                     data-players='{{ m.absents|default([])|json_encode|e('html_attr') }}'>
                                    <span class="text-[9px]">✗</span> <span class="count-value">{{ m.nb_absent|default(0) }}</span>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            {# Colonne 4 : Statut & Vote (Uniquement si connecté) #}
            {% if allow_actions %}
                <div class="flex flex-col gap-2.5 md:border-l md:border-slate-100 md:pl-4 z-20">
                    <div class="flex flex-col">
                        <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Mon Statut</span>
                        <span id="status-{{ m.id }}" class="inline-flex items-center text-xs font-black mt-0.5 {% if m.user_status %}{% if m.user_status in ['Disponible', 'Présent'] %}text-emerald-600{% elseif m.user_status == 'Disponible si nécessaire' %}text-amber-500{% elseif m.user_status in ['Indisponible', 'Absent'] %}text-rose-500{% else %}text-slate-600{% endif %}{% else %}text-slate-400{% endif %}">
                            {% if m.user_status %}
                                {% if m.user_status in ['Disponible', 'Présent'] %} <span class="mr-1 text-xs">✓</span> {{ m.user_status }}
                                {% elseif m.user_status == 'Disponible si nécessaire' %} <span class="mr-1 text-xs">◐</span> Si besoin
                                {% elseif m.user_status in ['Indisponible', 'Absent'] %} <span class="mr-1 text-xs">✗</span> {{ m.user_status }}
                                {% else %} {{ m.user_status }} {% endif %}
                            {% else %}
                                Non renseigné
                            {% endif %}
                        </span>
                    </div>

                    <div class="flex flex-wrap gap-1.5 w-full mt-1">
                        {% if m.is_match %}
                            {% set is_dispo = m.user_status == 'Disponible' %}
                            <button type="button" 
                                    class="status-btn flex-1 min-w-[80px] px-3 py-2 rounded-xl text-xs font-bold transition-all active:scale-95 flex items-center justify-center gap-1 {% if is_dispo %}bg-emerald-600 text-white{% else %}bg-emerald-50 text-emerald-600 hover:bg-emerald-100 border border-emerald-100{% endif %}" 
                                    data-status="Disponible"
                                    title="Disponible">
                                <span class="text-xs">✓</span> Dispo
                            </button>

                            {% set is_sib = m.user_status == 'Disponible si nécessaire' %}
                            <button type="button" 
                                    class="status-btn flex-1 min-w-[80px] px-3 py-2 rounded-xl text-xs font-bold transition-all active:scale-95 flex items-center justify-center gap-1 {% if is_sib %}bg-amber-500 text-white{% else %}bg-amber-50 text-amber-600 hover:bg-amber-100 border border-amber-100{% endif %}" 
                                    data-status="Disponible si nécessaire"
                                    title="Si besoin">
                                <span class="text-xs">◐</span> Si besoin
                            </button>

                            {% set is_indispo = m.user_status == 'Indisponible' %}
                            <button type="button" 
                                    class="status-btn flex-1 min-w-[80px] px-3 py-2 rounded-xl text-xs font-bold transition-all active:scale-95 flex items-center justify-center gap-1 {% if is_indispo %}bg-rose-600 text-white{% else %}bg-rose-50 text-rose-600 hover:bg-rose-100 border border-rose-100{% endif %}" 
                                    data-status="Indisponible"
                                    title="Indisponible">
                                <span class="text-xs">✗</span> Indispo
                            </button>
                        {% else %}
                            {% set is_present = m.user_status == 'Présent' %}
                            <button type="button" 
                                    class="status-btn flex-1 min-w-[80px] px-3 py-2 rounded-xl text-xs font-bold transition-all active:scale-95 flex items-center justify-center gap-1 {% if is_present %}bg-emerald-600 text-white{% else %}bg-emerald-50 text-emerald-600 hover:bg-emerald-100 border border-emerald-100{% endif %}" 
                                    data-status="Présent"
                                    title="Présent">
                                <span class="text-xs">✓</span> Présent
                            </button>

                            {% set is_absent = m.user_status == 'Absent' %}
                            <button type="button" 
                                    class="status-btn flex-1 min-w-[80px] px-3 py-2 rounded-xl text-xs font-bold transition-all active:scale-95 flex items-center justify-center gap-1 {% if is_absent %}bg-rose-600 text-white{% else %}bg-rose-50 text-rose-600 hover:bg-rose-100 border border-rose-100{% endif %}" 
                                    data-status="Absent"
                                    title="Absent">
                                <span class="text-xs">✗</span> Absent
                            </button>
                        {% endif %}
                        
                        {% set is_reset = not m.user_status or m.user_status == '.' %}
                        <button type="button" 
                                class="status-btn px-2.5 py-2 rounded-xl text-xs font-medium transition-all active:scale-95 flex items-center justify-center gap-1 {% if is_reset %}bg-slate-400 text-white{% else %}bg-slate-100 text-slate-400 hover:bg-slate-200{% endif %}" 
                                data-status="." 
                                title="Réinitialiser">
                            ⊘
                        </button>
                    </div>
                </div>
            {% endif %}

        </div>

    </div>

    {# --- LIGNE INFÉRIEURE : ALERTES / COMMENTAIRES (Pleine largeur sous les infos) --- #}
    {% if m.commentaire or (m.nb_terrains != 0 and m.nb_terrains != 1 and m.nb_terrains != '.') %}
        <div class="mt-4 pt-3 border-t border-slate-100/60 flex flex-wrap gap-3 w-full md:pl-20">
            {% if m.commentaire %}
                <div class="text-xs italic text-slate-500 bg-slate-50/50 rounded-2xl p-3 border border-slate-100/60 leading-snug flex-grow min-w-[200px]">
                    {{ m.commentaire }}
                </div>
            {% endif %}

            {% set terrain_alert = (m.nb_terrains != 0) and (m.nb_terrains != 1) and (m.nb_terrains != '.') %}
            {% if terrain_alert %}
                <div class="flex items-center gap-1.5 text-xs font-bold text-rose-600 bg-rose-50 border border-rose-100/60 rounded-xl px-2.5 py-1.5 h-fit shrink-0">
                    <span>⚠</span> {{ m.nb_terrains }} terrains alloués
                </div>
            {% endif %}
        </div>
    {% endif %}

</div>