{% extends "base.twig" %}

{% block title %}Mon Profil{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 pb-4 border-b border-gray-200">
        <div class="mb-4 sm:mb-0">
            <h1 class="text-3xl font-bold text-gray-900">Mon Profil</h1>
            <p class="text-sm text-gray-500 mt-1">Gérez vos informations personnelles</p>
        </div>
        <a href="{{ url('member/dashboard') }}" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 transition-colors">
            &larr; Retour
        </a>
    </div>

    {% if flash.error %}
        <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6"><p class="text-sm text-red-700">{{ flash.error }}</p></div>
    {% endif %}
    {% if flash.success %}
        <div class="bg-green-50 border-l-4 border-green-400 p-4 mb-6"><p class="text-sm text-green-700">{{ flash.success }}</p></div>
    {% endif %}

    <div class="bg-white shadow-sm rounded-lg overflow-hidden border border-gray-200">
        <div class="px-4 py-5 border-b border-gray-200 bg-gray-50">
            <h2 class="text-lg leading-6 font-medium text-gray-900">Informations Personnelles</h2>
        </div>

        <form action="{{ url('member/profile') }}" method="POST" class="p-6">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                
                <div>
                    <label for="prenom" class="block text-sm font-medium text-gray-700 mb-2">Prénom</label>
                    <input type="text" id="prenom" name="Prenom" value="{{ joueur.Prénom|default('') }}" required 
                           class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500">
                </div>

                <div>
                    <label for="nom" class="block text-sm font-medium text-gray-700 mb-2">Nom</label>
                    <input type="text" id="nom" name="Nom" value="{{ joueur.Nom|default('') }}" required 
                           class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500">
                </div>

                <div class="md:col-span-2">
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
                    <input type="email" id="email" name="Mel" value="{{ joueur.Mel|default('') }}" required 
                           class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500">
                </div>

            </div>

            {# Champs en lecture seule #}
            <div class="mt-8 pt-8 border-t border-gray-200">
                <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Informations du Compte</h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">ID Joueur</label>
                        <div class="px-3 py-2 bg-gray-100 border border-gray-200 rounded-md text-gray-700">
                            {{ joueur.id_joueur|default('N/A') }}
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Licencié n°</label>
                        <div class="px-3 py-2 bg-gray-100 border border-gray-200 rounded-md text-gray-700">
                            {{ joueur.Nlicence|default('Non renseigné') }}
                        </div>
                    </div>
                </div>
            </div>

            {# Équipes et Saison #}
            {% if saison_active %}
                <div class="mt-8 pt-8 border-t border-gray-200">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Saison {{ saison_active.libelle }}</h3>
                    
                    {% if equipes|length > 0 %}
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            {% for equipe in equipes %}
                                <div class="p-4 border rounded-md bg-blue-50 border-blue-200">
                                    <h4 class="font-semibold text-blue-900">{{ equipe.libelle }}</h4>
                                    {% if equipe.categorie %}
                                        <p class="text-sm text-blue-700 mt-1">Catégorie : <strong>{{ equipe.categorie }}</strong></p>
                                    {% endif %}
                                    {% if equipe.description_courte %}
                                        <p class="text-sm text-gray-600 mt-2">{{ equipe.description_courte }}</p>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-md">
                            <p class="text-sm text-yellow-700">Vous n'êtes affecté à aucune équipe pour cette saison.</p>
                        </div>
                    {% endif %}
                </div>
            {% endif %}

            <div class="mt-6 flex justify-end gap-3">
                <a href="{{ url('member/dashboard') }}" class="px-4 py-2 rounded-md border border-gray-300 bg-white text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 transition-colors">
                    Annuler
                </a>
                <button type="submit" class="px-4 py-2 rounded-md bg-blue-600 text-sm font-medium text-white shadow-sm hover:bg-blue-700 transition-colors">
                    Enregistrer les modifications
                </button>
            </div>
        </form>
    </div>

</div>
{% endblock %}
