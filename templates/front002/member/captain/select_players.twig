{% extends "base.twig" %}
{% block title %}Sélection de l'effectif — USM Volley{% endblock %}

{% block content %}
<div class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">
    
    {# En-tête #}
    <div class="bg-slate-900 text-white pt-8 pb-20 md:pt-12">
        <div class="max-w-5xl mx-auto px-4 sm:px-6">
            <div class="flex items-center gap-4">
                <a href="{{ url('member/captain') }}" class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                </a>
                <div>
                    <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">Sélection de l'effectif</h1>
                    <p class="text-slate-400 text-sm mt-1">Convoquez vos joueuses pour le match <strong>{{ event.titre }}</strong>.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 -mt-10">
        
        {# Détails match #}
        <div class="bg-white rounded-3xl p-5 border border-slate-100 shadow-sm mb-6 flex flex-col sm:flex-row justify-between sm:items-center gap-4">
            <div class="space-y-1 text-sm text-slate-600">
                <p class="flex items-center gap-2"><span class="text-slate-400 w-4 text-center">📅</span> <strong>Date :</strong> {{ event.date_display }} {% if event.time_range %}({{ event.time_range }}){% endif %}</p>
                <p class="flex items-center gap-2"><span class="text-slate-400 w-4 text-center">📍</span> <strong>Lieu :</strong> {{ event.lieu }}</p>
                {% if event.commentaire %}<p class="flex items-center gap-2 italic text-xs text-slate-400"><span class="text-slate-400 w-4 text-center">💬</span> {{ event.commentaire }}</p>{% endif %}
            </div>
            
            <div class="flex-shrink-0 bg-slate-50 border border-slate-100 rounded-2xl px-4 py-3 text-center sm:text-right">
                <p class="text-xs text-slate-400 uppercase tracking-wider font-bold">Équipe concernée</p>
                <p class="text-sm font-extrabold text-slate-800 mt-0.5">{{ team.libelle }}</p>
            </div>
        </div>

        {# Formulaire de convocation #}
        <div class="bg-white rounded-3xl p-6 md:p-8 border border-slate-100 shadow-sm">
            <form method="POST" action="{{ url('member/captain/matches/' ~ event.id ~ '/select-players') }}" class="space-y-6">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                <div class="border-b border-slate-100 pb-3 flex justify-between items-center">
                    <h3 class="text-sm font-bold text-slate-400 uppercase tracking-wider">Effectif de l'équipe</h3>
                    <button type="button" onclick="selectAllAvailable()" class="text-xs font-semibold text-[var(--primary)] hover:underline">
                        Sélectionner tous les disponibles/présents
                    </button>
                </div>

                {% if femmes|length > 0 and hommes|length > 0 %}
                    {# Équipe mixte : Grille 2 colonnes sur tablette/ordinateur, 1 colonne sur mobile #}
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                        
                        {# Colonne Féminine #}
                        <div class="space-y-3">
                            <h4 class="text-xs font-black text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-1.5 flex items-center gap-1.5">
                                ♀ Effectif Féminin ({{ femmes|length }})
                            </h4>
                            {% for j in femmes %}
                            <div class="player-row flex items-center justify-between p-3.5 border border-slate-150 rounded-2xl hover:bg-slate-50 transition-all cursor-pointer" onclick="togglePlayerCheckbox('player-{{ j.id_joueur }}')">
                                <div class="flex items-center gap-4 min-w-0">
                                    <input type="checkbox" id="player-{{ j.id_joueur }}" name="selected_players[]" value="{{ j.id_joueur }}"
                                           {% if j.is_selected %}checked{% endif %}
                                           onclick="event.stopPropagation();"
                                           class="w-5 h-5 text-amber-500 border-slate-350 rounded focus:ring-amber-400 focus:outline-none">
                                    <div>
                                        <span class="text-sm font-bold text-slate-900">{{ j.prenom }} {{ j.nom }}</span>
                                        {% if j.is_captain %}
                                        <span class="ml-1 text-[10px] bg-amber-100 text-amber-800 px-1.5 py-0.5 rounded font-extrabold">Capitaine</span>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    <span class="text-xs font-bold px-2.5 py-1 rounded-full {{ j.status_bg }} {{ j.status_text }}" data-status-category="{{ j.status_category }}">
                                        {{ j.status_label }}
                                    </span>
                                </div>
                            </div>
                            {% endfor %}
                        </div>

                        {# Colonne Masculine #}
                        <div class="space-y-3">
                            <h4 class="text-xs font-black text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-1.5 flex items-center gap-1.5">
                                ♂ Effectif Masculin ({{ hommes|length }})
                            </h4>
                            {% for j in hommes %}
                            <div class="player-row flex items-center justify-between p-3.5 border border-slate-150 rounded-2xl hover:bg-slate-50 transition-all cursor-pointer" onclick="togglePlayerCheckbox('player-{{ j.id_joueur }}')">
                                <div class="flex items-center gap-4 min-w-0">
                                    <input type="checkbox" id="player-{{ j.id_joueur }}" name="selected_players[]" value="{{ j.id_joueur }}"
                                           {% if j.is_selected %}checked{% endif %}
                                           onclick="event.stopPropagation();"
                                           class="w-5 h-5 text-amber-500 border-slate-350 rounded focus:ring-amber-400 focus:outline-none">
                                    <div>
                                        <span class="text-sm font-bold text-slate-900">{{ j.prenom }} {{ j.nom }}</span>
                                        {% if j.is_captain %}
                                        <span class="ml-1 text-[10px] bg-amber-100 text-amber-800 px-1.5 py-0.5 rounded font-extrabold">Capitaine</span>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    <span class="text-xs font-bold px-2.5 py-1 rounded-full {{ j.status_bg }} {{ j.status_text }}" data-status-category="{{ j.status_category }}">
                                        {{ j.status_label }}
                                    </span>
                                </div>
                            </div>
                            {% endfor %}
                        </div>

                    </div>
                {% else %}
                    {# Équipe non-mixte (seulement filles ou seulement garçons) : Simple liste #}
                    <div class="space-y-3">
                        {% if femmes|length > 0 %}
                            <h4 class="text-xs font-black text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-1.5 flex items-center gap-1.5">
                                ♀ Effectif Féminin ({{ femmes|length }})
                            </h4>
                            {% for j in femmes %}
                            <div class="player-row flex items-center justify-between p-3.5 border border-slate-150 rounded-2xl hover:bg-slate-50 transition-all cursor-pointer" onclick="togglePlayerCheckbox('player-{{ j.id_joueur }}')">
                                <div class="flex items-center gap-4 min-w-0">
                                    <input type="checkbox" id="player-{{ j.id_joueur }}" name="selected_players[]" value="{{ j.id_joueur }}"
                                           {% if j.is_selected %}checked{% endif %}
                                           onclick="event.stopPropagation();"
                                           class="w-5 h-5 text-amber-500 border-slate-350 rounded focus:ring-amber-400 focus:outline-none">
                                    <div>
                                        <span class="text-sm font-bold text-slate-900">{{ j.prenom }} {{ j.nom }}</span>
                                        {% if j.is_captain %}
                                        <span class="ml-1 text-[10px] bg-amber-100 text-amber-800 px-1.5 py-0.5 rounded font-extrabold">Capitaine</span>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    <span class="text-xs font-bold px-2.5 py-1 rounded-full {{ j.status_bg }} {{ j.status_text }}" data-status-category="{{ j.status_category }}">
                                        {{ j.status_label }}
                                    </span>
                                </div>
                            </div>
                            {% endfor %}
                        {% elseif hommes|length > 0 %}
                            <h4 class="text-xs font-black text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-1.5 flex items-center gap-1.5">
                                ♂ Effectif Masculin ({{ hommes|length }})
                            </h4>
                            {% for j in hommes %}
                            <div class="player-row flex items-center justify-between p-3.5 border border-slate-150 rounded-2xl hover:bg-slate-50 transition-all cursor-pointer" onclick="togglePlayerCheckbox('player-{{ j.id_joueur }}')">
                                <div class="flex items-center gap-4 min-w-0">
                                    <input type="checkbox" id="player-{{ j.id_joueur }}" name="selected_players[]" value="{{ j.id_joueur }}"
                                           {% if j.is_selected %}checked{% endif %}
                                           onclick="event.stopPropagation();"
                                           class="w-5 h-5 text-amber-500 border-slate-350 rounded focus:ring-amber-400 focus:outline-none">
                                    <div>
                                        <span class="text-sm font-bold text-slate-900">{{ j.prenom }} {{ j.nom }}</span>
                                        {% if j.is_captain %}
                                        <span class="ml-1 text-[10px] bg-amber-100 text-amber-800 px-1.5 py-0.5 rounded font-extrabold">Capitaine</span>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    <span class="text-xs font-bold px-2.5 py-1 rounded-full {{ j.status_bg }} {{ j.status_text }}" data-status-category="{{ j.status_category }}">
                                        {{ j.status_label }}
                                    </span>
                                </div>
                            </div>
                            {% endfor %}
                        {% else %}
                            <p class="text-slate-400 text-sm text-center py-6 italic">Aucun joueur trouvé dans l'effectif.</p>
                        {% endif %}
                    </div>
                {% endif %}

                {# Actions #}
                <div class="pt-6 border-t border-slate-100 flex flex-col sm:flex-row justify-between gap-3">
                    <div class="text-xs text-slate-400 max-w-md">
                        💡 Sélectionner un joueur l'ajoutera à ce match et <strong>retirera</strong> automatiquement sa participation de tout autre événement concurrent se déroulant sur le même créneau.
                    </div>
                    <div class="flex justify-end gap-3 flex-shrink-0">
                        <a href="{{ url('member/captain') }}"
                           class="text-sm font-bold bg-slate-100 hover:bg-slate-200 text-slate-700 px-5 py-3 rounded-xl transition text-center">
                            Annuler
                        </a>
                        <button type="submit"
                                class="text-sm font-bold bg-amber-500 hover:bg-amber-600 text-slate-900 px-5 py-3 rounded-xl transition text-center shadow-sm">
                            Enregistrer la sélection
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function togglePlayerCheckbox(id) {
        const checkbox = document.getElementById(id);
        if (checkbox) {
            checkbox.checked = !checkbox.checked;
        }
    }

    function selectAllAvailable() {
        const players = document.querySelectorAll('[data-status-category]');
        players.forEach(el => {
            const cat = el.getAttribute('data-status-category');
            if (cat === 'present' || cat === 'available' || cat === 'selected') {
                // Find parent container checkbox
                const row = el.closest('.player-row');
                if (row) {
                    const checkbox = row.querySelector('input[type="checkbox"]');
                    if (checkbox) {
                        checkbox.checked = true;
                    }
                }
            }
        });
    }
</script>
{% endblock %}
