{% extends "base.twig" %}
{% block title %}Planifier un Match — USM Volley{% endblock %}

{% block content %}
<div class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">
    
    {# En-tête #}
    <div class="bg-slate-900 text-white pt-8 pb-20 md:pt-12">
        <div class="max-w-3xl mx-auto px-4 sm:px-6">
            <div class="flex items-center gap-4">
                <a href="{{ url('member/captain') }}" class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                </a>
                <div>
                    <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">Planifier un Match</h1>
                    <p class="text-slate-400 text-sm mt-1">Créez une nouvelle rencontre dans l'agenda et commencez les convocations.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 -mt-10">
        <div class="bg-white rounded-3xl p-6 md:p-8 border border-slate-100 shadow-sm">
            <form method="POST" action="{{ url('member/captain/matches/create') }}" class="space-y-6">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

                {# Sélection équipe #}
                <div>
                    <label for="team_id" class="block text-sm font-semibold text-slate-700 mb-2">Pour quelle équipe ? *</label>
                    <select id="team_id" name="team_id" required
                            class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-3 text-sm text-slate-800 font-semibold focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/20">
                        {% for team in teams %}
                        <option value="{{ team.id }}">{{ team.libelle }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                    {# Date & Heure #}
                    <div>
                        <label for="date" class="block text-sm font-semibold text-slate-700 mb-2">Date et Heure *</label>
                        <input type="datetime-local" id="date" name="date" required
                               class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-3 text-sm text-slate-800 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/20">
                    </div>

                    {# Durée #}
                    <div>
                        <label for="duration" class="block text-sm font-semibold text-slate-700 mb-2">Durée estimée *</label>
                        <select id="duration" name="duration" required
                                class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-3 text-sm text-slate-800 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/20">
                            {% for dur in durations %}
                                <option value="{{ dur }}" {% if dur == '2h' %}selected{% endif %}>{{ dur }}</option>
                            {% else %}
                                <option value="2h" selected>2h</option>
                            {% endfor %}
                        </select>
                    </div>

                    {# Statut #}
                    <div>
                        <label for="statut" class="block text-sm font-semibold text-slate-700 mb-2">Statut *</label>
                        <select id="statut" name="statut" required
                                class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-3 text-sm text-slate-800 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/20">
                            {% for st in statuses %}
                                <option value="{{ st }}" {% if st == 'Confirmé' %}selected{% endif %}>{{ st }}</option>
                            {% else %}
                                <option value="Confirmé" selected>Confirmé</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                {# Lieu #}
                <div>
                    <label for="location" class="block text-sm font-semibold text-slate-700 mb-2">Lieu / Gymnase *</label>
                    <select id="location" name="location" required
                            class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-3 text-sm text-slate-800 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/20">
                        <option value="" disabled selected>Choisir un lieu...</option>
                        {% for loc in locations %}
                            <option value="{{ loc }}">{{ loc }}</option>
                        {% endfor %}
                    </select>
                </div>

                {# Commentaire #}
                <div>
                    <label for="comment" class="block text-sm font-semibold text-slate-700 mb-2">Commentaires / Consignes</label>
                    <textarea id="comment" name="comment" rows="4" placeholder="Ex: Rendez-vous à 19h30 pour l'échauffement. Maillot bleu."
                              class="w-full rounded-xl border border-slate-200 bg-white px-3.5 py-3 text-sm text-slate-800 placeholder-slate-400 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/20"></textarea>
                </div>

                {# Actions #}
                <div class="pt-4 border-t border-slate-100 flex flex-col sm:flex-row justify-end gap-3">
                    <a href="{{ url('member/captain') }}"
                       class="text-sm font-bold bg-slate-100 hover:bg-slate-200 text-slate-700 px-5 py-3 rounded-xl transition text-center">
                        Annuler
                    </a>
                    <button type="submit"
                            class="text-sm font-bold bg-amber-500 hover:bg-amber-600 text-slate-900 px-5 py-3 rounded-xl transition text-center shadow-sm">
                        Planifier et publier
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
