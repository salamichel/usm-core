{% extends "base.twig" %}
{% block title %}Mon Tableau de Bord — USM Volley{% endblock %}

{% block content %}
{# pb-24 sur mobile pour laisser de l'espace à la barre fixe du bas, md:pb-12 sur ordinateur #}
<div class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">
    
    {# 1. EN-TÊTE ET ACCUEIL #}
    <div class="bg-slate-900 text-white pt-8 pb-20 md:pt-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
                <div>
                    <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">Bonjour, {{ app.session.user_name }} 👋</h1>
                    <p class="text-slate-400 text-sm md:text-base mt-1">Voici le résumé de votre activité et des événements à venir.</p>
                </div>
                
                <div class="hidden md:flex flex-wrap gap-3">
                    <a href="{{ url('member/profile') }}" class="bg-white/10 hover:bg-white/20 text-white px-4 py-2 rounded-lg font-medium transition flex items-center gap-2 text-sm shadow-sm">
                        <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        Mon profil
                    </a>
                    <a href="{{ url('agenda') }}" class="bg-[var(--primary)] hover:bg-[var(--primary)]/90 text-white px-4 py-2 rounded-lg font-medium transition flex items-center gap-2 text-sm shadow-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        Voir tout l'agenda
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 -mt-10">
        
        {% if is_capitaine %}
        <div class="bg-gradient-to-r from-amber-500 to-amber-600 rounded-3xl p-5 mb-8 text-slate-900 shadow-md flex flex-col sm:flex-row sm:items-center justify-between gap-4 border border-amber-400">
            <div>
                <h2 class="text-lg font-black flex items-center gap-2">
                    👑 Espace Capitaine
                </h2>
                <p class="text-sm font-medium text-slate-900/80 mt-1">Vous êtes capitaine pour cette saison. Gérez les convocations de vos joueurs et créez des matchs.</p>
                <div class="mt-2.5 bg-white/20 border border-white/10 rounded-xl px-3 py-1.5 inline-flex items-center gap-2 text-xs font-semibold text-slate-900">
                    <span>🏐 Saisie des RÉSULTATS sur le site FFVB (Code : <strong class="select-all">USM024</strong>)</span>
                    <a href="https://www.ffvbbeach.org/ffvbapp/resu/saisie_resu.php" target="_blank" rel="noopener noreferrer" class="underline hover:text-black transition-colors flex items-center gap-0.5">
                        y accéder
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                </div>
            </div>
            <a href="{{ url('member/captain') }}" class="bg-slate-900 hover:bg-slate-800 text-white font-bold px-4 py-2.5 rounded-xl transition text-center text-sm shadow-sm flex-shrink-0">
                Accéder à l'espace
            </a>
        </div>
        {% endif %}
        
        {# 2. KPI MÉTRIQUES RAPIDES #}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 flex items-center gap-4 hover:-translate-y-1 transition-all cursor-pointer hover:shadow-md hover:border-slate-200 duration-200" data-kpi-filter="this-week">
                <div class="w-12 h-12 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Cette semaine</p>
                    <div class="flex items-baseline gap-2 mt-0.5">
                        <span class="text-2xl font-extrabold text-slate-900">{{ kpis.this_week }}</span>
                        <span class="text-xs font-medium text-slate-500">événements</span>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 flex items-center gap-4 hover:-translate-y-1 transition-all cursor-pointer hover:shadow-md hover:border-slate-200 duration-200" data-kpi-filter="next-week">
                <div class="w-12 h-12 rounded-full bg-sky-50 text-sky-600 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Sem. prochaine</p>
                    <div class="flex items-baseline gap-2 mt-0.5">
                        <span class="text-2xl font-extrabold text-slate-900">{{ kpis.next_week }}</span>
                        <span class="text-xs font-medium text-slate-500">événements</span>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl p-5 shadow-sm border {% if kpis.action_required > 0 %}border-amber-200 border-l-4 border-l-amber-500{% else %}border-slate-100{% endif %} flex items-center gap-4 hover:-translate-y-1 transition-all cursor-pointer hover:shadow-md hover:border-amber-300 duration-200" data-kpi-filter="action-required">
                <div class="w-12 h-12 rounded-full bg-amber-50 text-amber-500 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                </div>
                <div>
                    <p class="text-xs font-semibold {% if kpis.action_required > 0 %}text-amber-700{% else %}text-slate-400{% endif %} uppercase tracking-wider">À répondre</p>
                    <div class="flex items-baseline gap-2 mt-0.5">
                        <span class="text-2xl font-extrabold text-slate-900">{{ kpis.action_required }}</span>
                        <span class="text-xs font-medium text-slate-500">événements</span>
                    </div>
                </div>
            </div>
        </div>

        {# 3. CONTENU PRINCIPAL (Grille) #}
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            {# COLONNE GAUCHE : Prochains événements #}
            <div id="imminent-section" class="lg:col-span-2 space-y-4">
                <div class="flex items-center justify-between">
                    <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
                        <svg class="w-5 h-5 text-[var(--primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Événements à venir<span id="active-filter-label" class="text-sm font-normal text-slate-500 italic ml-2"></span>
                    </h2>
                    <button id="reset-dashboard-filters" class="hidden text-xs font-semibold text-slate-500 hover:text-slate-900 bg-slate-100 hover:bg-slate-200 px-2.5 py-1.5 rounded-lg transition flex items-center gap-1">
                        ✕ Effacer les filtres
                    </button>
                </div>

                {# Panneau Actions groupées #}
                <div class="bg-white rounded-3xl p-5 border border-slate-100 shadow-sm mb-6">
                    <div class="mb-4">
                        <h3 class="text-sm font-bold text-slate-800 flex items-center gap-2">
                            <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                            Actions groupées
                        </h3>
                        <p class="text-xs text-slate-400 mt-1">Déclarez rapidement votre statut sur une sélection de créneaux.</p>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 items-end">
                        {# 1. Sélectionner le Type #}
                        <div>
                            <label for="bulk-type-select" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1.5">1. Type d'événement</label>
                            <select id="bulk-type-select" class="w-full text-xs rounded-xl border border-slate-200 bg-white px-3.5 py-2.5 text-slate-700 font-semibold focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-all">
                                <option value="">Tous les types</option>
                                <option value="match">Matchs</option>
                                <option value="entrainement">Entraînements</option>
                                <option value="tournois">Tournois / Plateaux</option>
                                <option value="forum">Forums</option>
                                <option value="club">Club</option>
                                <option value="beach">Beach Volley</option>
                            </select>
                        </div>

                        {# 2. Sélectionner le Lieu (optionnel) #}
                        <div>
                            <label for="bulk-location-select" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1.5">2. Lieu (Optionnel)</label>
                            <select id="bulk-location-select" class="w-full text-xs rounded-xl border border-slate-200 bg-white px-3.5 py-2.5 text-slate-700 font-semibold focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-all">
                                <option value="">Tous les lieux</option>
                                {% for lieu in stats.top_lieux_all|default([]) %}
                                    <option value="{{ lieu }}">{{ lieu }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        {# 3. Choisir le Statut #}
                        <div>
                            <label for="bulk-status-select" class="block text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1.5">3. Statut à appliquer</label>
                            <select id="bulk-status-select" class="w-full text-xs rounded-xl border border-slate-200 bg-white px-3.5 py-2.5 text-slate-700 font-semibold focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-all">
                                <option value="">Choisir un statut...</option>
                                <option value="Disponible">Disponible / Présent</option>
                                <option value="Disponible si nécessaire">Si besoin (Matchs uniquement)</option>
                                <option value="Indisponible">Indisponible / Absent</option>
                                <option value=".">Réinitialiser (Sans réponse)</option>
                            </select>
                        </div>

                        {# 4. Bouton Appliquer #}
                        <div>
                            <button type="button" id="bulk-apply-btn" class="w-full text-xs font-bold bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-3 rounded-xl transition-all shadow-sm active:scale-98">
                                Appliquer
                            </button>
                        </div>
                    </div>
                </div>

                {# Liste des prochains événements #}
                <div class="space-y-4" id="event-grid" 
                     data-logged-in-user-id="{{ app.session.LogInId|default(0) }}" 
                     data-logged-in-user-name="{{ app.session.user_name|default('') }}">
                    {% for m in imminent_events %}
                        {% include "agenda/_event_card.twig" with {
                            'm': m, 
                            'allow_actions': true, 
                            'show_link': true,
                            'is_first': loop.first
                        } %}
                    {% else %}
                        <div class="p-8 text-center bg-white rounded-2xl border border-slate-100 text-slate-400 text-sm">
                            Aucun événement imminent.
                        </div>
                    {% endfor %}
                </div>
            </div>

            {# COLONNE DROITE : Analytiques & Répartitions #}
            <div class="space-y-6">
                <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
                    <svg class="w-5 h-5 text-[var(--primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    Statistiques: {{ saison_active }}
                </h2>

                {# Bloc : Ma présence #}
                <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100">
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4">Mon Taux de Présence</h3>
                    
                    <div class="cursor-pointer hover:bg-slate-50 p-1.5 rounded-xl transition-all" data-type-filter="match">
                        <div class="mb-1.5 flex justify-between text-sm font-medium">
                            <span class="text-slate-600">Matchs</span>
                            <span class="text-slate-900 font-bold">{{ stats.presence_match }}%</span>
                        </div>
                        <div class="w-full bg-slate-100 rounded-full h-2 mb-2">
                            <div class="bg-blue-500 h-2 rounded-full" style="width: {{ stats.presence_match }}%"></div>
                        </div>
                    </div>

                    <div class="cursor-pointer hover:bg-slate-50 p-1.5 rounded-xl transition-all" data-type-filter="entrainement">
                        <div class="mb-1.5 flex justify-between text-sm font-medium">
                            <span class="text-slate-600">Entraînements</span>
                            <span class="text-slate-900 font-bold">{{ stats.presence_training }}%</span>
                        </div>
                        <div class="w-full bg-slate-100 rounded-full h-2 mb-2">
                            <div class="bg-orange-400 h-2 rounded-full" style="width: {{ stats.presence_training }}%"></div>
                        </div>
                    </div>

                    <div class="cursor-pointer hover:bg-slate-50 p-1.5 rounded-xl transition-all" data-type-filter="tournois">
                        <div class="mb-1.5 flex justify-between text-sm font-medium">
                            <span class="text-slate-600">Tournois</span>
                            <span class="text-slate-900 font-bold">{{ stats.presence_tournament }}%</span>
                        </div>
                        <div class="w-full bg-slate-100 rounded-full h-2">
                            <div class="bg-purple-500 h-2 rounded-full" style="width: {{ stats.presence_tournament }}%"></div>
                        </div>
                    </div>
                </div>

                {# Bloc : Par Type #}
                <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100">
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4">Événements par type</h3>
                    <div class="space-y-1">
                        <div class="flex items-center justify-between cursor-pointer hover:bg-slate-50 p-1.5 rounded-lg transition-colors" data-type-filter="entrainement">
                            <div class="flex items-center gap-2">
                                <span class="w-2.5 h-2.5 rounded-full bg-orange-400"></span>
                                <span class="text-sm font-medium text-slate-600">Entraînements</span>
                            </div>
                            <span class="text-xs font-bold text-slate-900 bg-slate-100 px-2 py-0.5 rounded-md">{{ stats.events_by_type.training }}</span>
                        </div>
                        <div class="flex items-center justify-between cursor-pointer hover:bg-slate-50 p-1.5 rounded-lg transition-colors" data-type-filter="match">
                            <div class="flex items-center gap-2">
                                <span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span>
                                <span class="text-sm font-medium text-slate-600">Matchs</span>
                            </div>
                            <span class="text-xs font-bold text-slate-900 bg-slate-100 px-2 py-0.5 rounded-md">{{ stats.events_by_type.match }}</span>
                        </div>
                        <div class="flex items-center justify-between cursor-pointer hover:bg-slate-50 p-1.5 rounded-lg transition-colors" data-type-filter="tournois">
                            <div class="flex items-center gap-2">
                                <span class="w-2.5 h-2.5 rounded-full bg-purple-500"></span>
                                <span class="text-sm font-medium text-slate-600">Tournois / Plateaux</span>
                            </div>
                            <span class="text-xs font-bold text-slate-900 bg-slate-100 px-2 py-0.5 rounded-md">{{ stats.events_by_type.tournois }}</span>
                        </div>
                        <div class="flex items-center justify-between cursor-pointer hover:bg-slate-50 p-1.5 rounded-lg transition-colors" data-type-filter="forum">
                            <div class="flex items-center gap-2">
                                <span class="w-2.5 h-2.5 rounded-full bg-teal-500"></span>
                                <span class="text-sm font-medium text-slate-600">Forums</span>
                            </div>
                            <span class="text-xs font-bold text-slate-900 bg-slate-100 px-2 py-0.5 rounded-md">{{ stats.events_by_type.forum }}</span>
                        </div>
                        <div class="flex items-center justify-between cursor-pointer hover:bg-slate-50 p-1.5 rounded-lg transition-colors" data-type-filter="others">
                            <div class="flex items-center gap-2">
                                <span class="w-2.5 h-2.5 rounded-full bg-slate-400"></span>
                                <span class="text-sm font-medium text-slate-600">Autres</span>
                            </div>
                            <span class="text-xs font-bold text-slate-900 bg-slate-100 px-2 py-0.5 rounded-md">{{ stats.events_by_type.others }}</span>
                        </div>
                    </div>
                </div>

                {# Bloc : Lieux #}
                <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100">
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4">Top Lieux (À venir)</h3>
                    <ul class="space-y-1">
                        {% for lieu in stats.top_lieux %}
                            <li class="flex items-center justify-between cursor-pointer hover:bg-slate-50 p-1.5 rounded-lg transition-colors" data-lieu-filter="{{ lieu.nom }}">
                                <span class="text-sm text-slate-600 truncate max-w-[200px]">{{ lieu.nom }}</span>
                                <span class="text-xs font-bold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full">{{ lieu.count }}</span>
                            </li>
                        {% else %}
                            <li class="text-xs text-slate-400 p-1.5">Aucun lieu recensé.</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>

    {% include "agenda/_player_modal.twig" %}
</div>
{% endblock %}

{% block scripts %}
    <script src="{{ url('assets/front002/js/agenda-cards.js') }}"></script>
{% endblock %}