{% extends "base.twig" %}
{% block title %}Mon Tableau de Bord — USM Volley{% endblock %}

{% block content %}
{# pb-24 sur mobile pour laisser de l'espace à la barre fixe du bas, md:pb-12 sur ordinateur #}
<div class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">
    
    {# 1. EN-TÊTE ET ACCUEIL #}
    <div class="bg-slate-900 text-white pt-8 pb-20 md:pt-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
                <div>
                    <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">Bonjour, {{ app.session.user_name }} 👋</h1>
                    <p class="text-slate-400 text-sm md:text-base mt-1">Voici le résumé de votre activité et des événements à venir.</p>
                </div>
                
                {# Masqué sur mobile car déporté dans la barre de navigation du bas (évite la duplication inutile) #}
                <div class="hidden md:flex flex-wrap gap-3">
                    <a href="{{ url('member/profile') }}" class="bg-white/10 hover:bg-white/20 text-white px-4 py-2 rounded-lg font-medium transition flex items-center gap-2 text-sm shadow-sm">
                        <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        Mon profil
                    </a>
                    <a href="{{ url('agenda') }}" class="bg-[var(--primary)] hover:bg-[var(--primary)]/90 text-white px-4 py-2 rounded-lg font-medium transition flex items-center gap-2 text-sm shadow-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        Voir tout l'agenda
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 -mt-10">
        
        {# 2. KPI MÉTRIQUES RAPIDES #}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 flex items-center gap-4 hover:-translate-y-1 transition-transform">
                <div class="w-12 h-12 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Cette semaine</p>
                    <div class="flex items-baseline gap-2 mt-0.5">
                        <span class="text-2xl font-extrabold text-slate-900">{{ kpis.this_week }}</span>
                        <span class="text-xs font-medium text-slate-500">événements</span>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100 flex items-center gap-4 hover:-translate-y-1 transition-transform">
                <div class="w-12 h-12 rounded-full bg-sky-50 text-sky-600 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Sem. prochaine</p>
                    <div class="flex items-baseline gap-2 mt-0.5">
                        <span class="text-2xl font-extrabold text-slate-900">{{ kpis.next_week }}</span>
                        <span class="text-xs font-medium text-slate-500">événements</span>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl p-5 shadow-sm border {% if kpis.action_required > 0 %}border-amber-200 border-l-4 border-l-amber-500{% else %}border-slate-100{% endif %} flex items-center gap-4 hover:-translate-y-1 transition-transform">
                <div class="w-12 h-12 rounded-full bg-amber-50 text-amber-500 flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                </div>
                <div>
                    <p class="text-xs font-semibold {% if kpis.action_required > 0 %}text-amber-700{% else %}text-slate-400{% endif %} uppercase tracking-wider">À répondre</p>
                    <div class="flex items-baseline gap-2 mt-0.5">
                        <span class="text-2xl font-extrabold text-slate-900">{{ kpis.action_required }}</span>
                        <span class="text-xs font-medium text-slate-500">événements</span>
                    </div>
                </div>
            </div>
        </div>

        {# 3. CONTENU PRINCIPAL (Grille) #}
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            {# COLONNE GAUCHE : Prochains événements #}
            <div id="imminent-section" class="lg:col-span-2 space-y-4">
                <div class="flex items-center justify-between">
                    <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
                        <svg class="w-5 h-5 text-[var(--primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Imminent
                    </h2>
                    <a href="{{ url('agenda') }}" class="text-sm font-medium text-[var(--primary)] hover:underline hidden sm:inline">Gérer mes présences &rarr;</a>
                </div>

                {# Liste des prochains événements #}
                <div class="space-y-3">
                    {% for m in imminent_events %}
                        {% set isActionRequired = (m.user_status ) %}
                        
                        <div class="bg-white rounded-2xl p-4 md:p-5 shadow-sm border border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4 {% if isActionRequired %}bg-amber-50/20 relative border-l-4 border-l-amber-400{% endif %} hover:shadow-md transition-all">
                            
                            <div class="flex items-center gap-4">
                                {# Date Badge #}
                                <div class="flex-shrink-0 w-14 h-14 bg-slate-900 text-white rounded-xl flex flex-col items-center justify-center shadow-sm">
                                    <span class="text-xl font-black leading-none">{{ m.Date|date("d") }}</span>
                                    <span class="text-[10px] font-bold uppercase tracking-wider mt-1 text-slate-400">{{ m.Date|date("M") }}</span>
                                </div>
                                {# Métadonnées textuelles #}
                                <div>
                                    <div class="flex flex-wrap items-center gap-1.5 mb-1">
                                        <span class="px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-widest {% if is_match %}bg-blue-100 text-blue-800{% else %}bg-orange-100 text-orange-800{% endif %}">
                                            {% if is_match %}Match{% else %}Entraînement{% endif %}
                                        </span>
                                        {% if not isActionRequired %}
                                            <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-100 text-emerald-800">
                                                ✓ {{ m.user_status }}
                                            </span>
                                        {% endif %}
                                    </div>
                                    <h3 class="text-base font-bold text-slate-900 leading-tight">{{ m.ManifestationTypée }}</h3>
                                    <p class="text-xs text-slate-500 mt-1 flex items-center gap-1">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                                        <span class="truncate max-w-[180px] sm:max-w-[250px]">{{ m.Lieu }}</span>
                                        • {{ m.Date|date("H\\hi") }}
                                    </p>
                                </div>
                            </div>

                            {# Actions UI tactiles : 100% de largeur sur mobile pour clic au pouce #}
                            <div class="w-full sm:w-auto flex gap-2 pt-2 sm:pt-0 border-t border-slate-100 sm:border-0">
                                {% if is_match %}
                                    {# Actions MATCH #}
                                    <button type="button" class="status-btn flex-1 sm:flex-none justify-center px-3 py-2.5 sm:py-1.5 rounded-xl text-xs font-bold transition-all flex items-center gap-1 border {% if m.user_status == 'Disponible' %}bg-emerald-600 text-white border-emerald-600 shadow-sm{% else %}bg-emerald-50 text-emerald-700 border-emerald-200 hover:bg-emerald-100{% endif %}" data-manifestation-id="{{ m.id }}" data-status="Disponible">
                                        <span>✓</span> Dispo
                                    </button>
                                    <button type="button" class="status-btn flex-1 sm:flex-none justify-center px-3 py-2.5 sm:py-1.5 rounded-xl text-xs font-bold transition-all flex items-center gap-1 border {% if m.user_status == 'Disponible si nécessaire' %}bg-amber-500 text-white border-amber-500 shadow-sm{% else %}bg-amber-50 text-amber-600 border-amber-200 hover:bg-amber-100{% endif %}" data-manifestation-id="{{ m.id }}" data-status="Disponible si nécessaire">
                                        <span>◐</span> Besoin
                                    </button>
                                    <button type="button" class="status-btn flex-1 sm:flex-none justify-center px-3 py-2.5 sm:py-1.5 rounded-xl text-xs font-bold transition-all flex items-center gap-1 border {% if m.user_status == 'Indisponible' %}bg-rose-600 text-white border-rose-600 shadow-sm{% else %}bg-rose-50 text-rose-700 border-rose-200 hover:bg-rose-100{% endif %}" data-manifestation-id="{{ m.id }}" data-status="Indisponible">
                                        <span>✗</span> Non
                                    </button>
                                {% else %}
                                    {# Actions ENTRAÎNEMENT #}
                                    <button type="button" class="status-btn flex-1 sm:flex-none justify-center px-4 py-2.5 sm:py-1.5 rounded-xl text-xs font-bold transition-all flex items-center gap-1 border {% if m.user_status == 'Présent' %}bg-emerald-600 text-white border-emerald-600 shadow-sm{% else %}bg-emerald-50 text-emerald-700 border-emerald-200 hover:bg-emerald-100{% endif %}" data-manifestation-id="{{ m.id }}" data-status="Présent">
                                        <span>✓</span> Présent
                                    </button>
                                    <button type="button" class="status-btn flex-1 sm:flex-none justify-center px-4 py-2.5 sm:py-1.5 rounded-xl text-xs font-bold transition-all flex items-center gap-1 border {% if m.user_status == 'Absent' %}bg-rose-600 text-white border-rose-600 shadow-sm{% else %}bg-rose-50 text-rose-700 border-rose-200 hover:bg-rose-100{% endif %}" data-manifestation-id="{{ m.id }}" data-status="Absent">
                                        <span>✗</span> Absent
                                    </button>
                                {% endif %}
                            </div>

                        </div>
                    {% else %}
                        <div class="p-8 text-center bg-white rounded-2xl border border-slate-100 text-slate-400 text-sm">
                            Aucun événement imminent.
                        </div>
                    {% endfor %}
                </div>
            </div>

            {# COLONNE DROITE : Analytiques & Répartitions #}
            <div class="space-y-6">
                <h2 class="text-xl font-bold text-slate-900 flex items-center gap-2">
                    <svg class="w-5 h-5 text-[var(--primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    Statistiques de la saison
                </h2>

                {# Bloc : Ma présence #}
                <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100">
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4">Mon Taux de Présence</h3>
                    
                    <div class="mb-1.5 flex justify-between text-sm font-medium">
                        <span class="text-slate-600">Matchs</span>
                        <span class="text-slate-900 font-bold">{{ stats.presence_match }}%</span>
                    </div>
                    <div class="w-full bg-slate-100 rounded-full h-2 mb-4">
                        <div class="bg-blue-500 h-2 rounded-full" style="width: {{ stats.presence_match }}%"></div>
                    </div>

                    <div class="mb-1.5 flex justify-between text-sm font-medium">
                        <span class="text-slate-600">Entraînements</span>
                        <span class="text-slate-900 font-bold">{{ stats.presence_training }}%</span>
                    </div>
                    <div class="w-full bg-slate-100 rounded-full h-2 mb-1">
                        <div class="bg-orange-400 h-2 rounded-full" style="width: {{ stats.presence_training }}%"></div>
                    </div>

                    <div class="mb-1.5 flex justify-between text-sm font-medium">
                        <span class="text-slate-600">Tournois</span>
                        <span class="text-slate-900 font-bold">{{ stats.presence_tournament }}%</span>
                    </div>
                    <div class="w-full bg-slate-100 rounded-full h-2 mb-1">
                        <div class="bg-purple-500 h-2 rounded-full" style="width: {{ stats.presence_tournament }}%"></div>
                    </div>
                </div>

                {# Bloc : Par Type #}
                <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100">
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4">Événements par type</h3>
                    <div class="space-y-3">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <span class="w-2.5 h-2.5 rounded-full bg-orange-400"></span>
                                <span class="text-sm font-medium text-slate-600">Entraînements</span>
                            </div>
                            <span class="text-xs font-bold text-slate-900 bg-slate-100 px-2 py-0.5 rounded-md">{{ stats.events_by_type.training }}</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span>
                                <span class="text-sm font-medium text-slate-600">Matchs</span>
                            </div>
                            <span class="text-xs font-bold text-slate-900 bg-slate-100 px-2 py-0.5 rounded-md">{{ stats.events_by_type.match }}</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <span class="w-2.5 h-2.5 rounded-full bg-purple-500"></span>
                                <span class="text-sm font-medium text-slate-600">Tournois / Plateaux</span>
                            </div>
                            <span class="text-xs font-bold text-slate-900 bg-slate-100 px-2 py-0.5 rounded-md">{{ stats.events_by_type.tournois }}</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2">
                                <span class="w-2.5 h-2.5 rounded-full bg-purple-500"></span>
                                <span class="text-sm font-medium text-slate-600">Autres</span>
                            </div>
                            <span class="text-xs font-bold text-slate-900 bg-slate-100 px-2 py-0.5 rounded-md">{{ stats.events_by_type.others }}</span>
                        </div>
                    </div>
                </div>

                {# Bloc : Lieux #}
                <div class="bg-white rounded-2xl p-5 shadow-sm border border-slate-100">
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-4">Top Lieux (À venir)</h3>
                    <ul class="space-y-3">
                        {% for lieu in stats.top_lieux %}
                            <li class="flex items-center justify-between">
                                <span class="text-sm text-slate-600 truncate max-w-[200px]">{{ lieu.nom }}</span>
                                <span class="text-xs font-bold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full">{{ lieu.count }}</span>
                            </li>
                        {% else %}
                            <li class="text-xs text-slate-400">Aucun lieu recensé.</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% block scripts %}
    <script src="{{ url('assets/front002/js/agenda-cards.js') }}"></script>
{% endblock %}