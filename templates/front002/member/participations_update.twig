{% extends "base.twig" %}

{% block title %}Mise à jour de mes participations{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto px-6 py-16">
    
    <div class="sm:flex sm:items-center justify-between mb-8 border-b border-gray-200 pb-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Ma participation</h1>
            <p class="mt-2 text-sm text-gray-700">Déclarez vos disponibilités pour les prochains événements du club.</p>
        </div>
        <div class="mt-4 sm:mt-0">
                <a href="{{ url('member/dashboard') }}" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 transition-colors">
                &larr; Retour à mon espace
            </a>
        </div>
    </div>

    {% if flash.error %}
        <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6"><p class="text-sm text-red-700">{{ flash.error }}</p></div>
    {% endif %}
    {% if flash.success %}
        <div class="bg-green-50 border-l-4 border-green-400 p-4 mb-6"><p class="text-sm text-green-700">{{ flash.success }}</p></div>
    {% endif %}

    <form action="{{ url('member/participations/update') }}" method="POST">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

        {# Boutons de filtre dynamiques #}
        {% set event_types = [] %}
        {% for m in manifestations %}
            {% set type = '' %}
            {% if m.is_match %}
                {% set type = 'Match' %}
            {% elseif m.type_libelle is defined %}
                {# Assuming 'type_libelle' holds other specific types like 'Beach Volley' #}
                {% set type = m.type_libelle %}
            {% else %}
                {% set type = 'Entraînement' %} {# Fallback if not match and no specific type_libelle #}
            {% endif %}

            {% if type and type not in event_types %}
                {% set event_types = event_types|merge([type]) %}
            {% endif %}
        {% endfor %}
        
        {% if event_types|length > 1 %}
            <div class="mb-6 flex flex-wrap gap-2">
                <button type="button" class="filter-button px-3 py-1.5 text-xs rounded-full font-medium transition bg-[var(--primary)] text-white" data-filter="all">Tous</button>
                {% for type in event_types %}
                    <button type="button" class="filter-button filter-button px-3 py-1.5 text-xs rounded-full font-medium transition bg-slate-100 text-slate-700 hover:bg-slate-200]" data-filter="{{ type|lower|replace({' ': '-'}) }}">{{ type }}</button>
                {% endfor %}
            </div>
        {% endif %}

        <div class="mb-6 rounded-lg border border-gray-200 bg-gray-50 p-4">
            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                <div>
                    <h2 class="text-base font-semibold text-gray-900">Actions groupées</h2>
                    <p class="text-sm text-gray-600">Appliquez rapidement un statut à tous les matchs ou à tous les entraînements.</p>
                </div>
                <div class="grid gap-2 sm:grid-cols-2 md:grid-cols-3 w-full md:w-auto">
                    <div class="flex items-center gap-2">
                        <select id="bulk-match-status" 
                            class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500">
                            <option value="">Matchs : choisir</option>
                            <option value="Disponible">Disponible</option>
                            <option value="Disponible si nécessaire">Disponible si nécessaire</option>
                            <option value="Indisponible">Indisponible</option>
                            <option value="Ne sait pas encore">Ne sait pas encore</option>
                            {% if is_capitaine %}
                                <option value="Sélectionné(e)">Sélectionné(e)</option>
                            {% endif %}
                        </select>
                        <button type="button" id="bulk-match-apply" class="inline-flex items-center justify-center rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors shadow-sm">Appliquer</button>
                    </div>
                    <div class="flex items-center gap-2">
                        <select id="bulk-training-status" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500">
                            <option value="">Entraînements : choisir</option>
                            <option value="Présent">Présent</option>
                            <option value="Absent">Absent</option>
                            <option value="Ne sait pas encore">Ne sait pas encore</option>
                        </select>
                        <button type="button" id="bulk-training-apply" class="inline-flex items-center justify-center rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors shadow-sm">Appliquer</button>
                    </div>
                    <button type="button" id="bulk-reset-all" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 transition-colors shadow-sm">Tout effacer</button>
                </div>
            </div>
        </div>

        <div class="bg-white shadow overflow-hidden sm:rounded-md mb-8">
            <ul role="list" class="divide-y divide-gray-200" id="event-list">
                {% for m in manifestations %}
                    {% set item_type = '' %}
                    {% if m.is_match %}
                        {% set item_type = 'Match' %}
                    {% elseif m.type_libelle is defined %}
                        {% set item_type = m.type_libelle %}
                    {% else %}
                        {% set item_type = 'Entraînement' %}
                    {% endif %}
                    <li class="p-4 sm:px-6 hover:bg-gray-50 transition-colors" data-event-filter="{{ item_type|lower|replace({' ': '-'}) }}">
                        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between">
                            <div class="flex-1 min-w-0 mb-4 sm:mb-0">
                                <div class="flex items-center text-sm font-medium text-blue-600 truncate">
                                    {% if m.is_match %}
                                        <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800 mr-2">Match</span>
                                    {% else %}
                                        <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800 mr-2">Entraînement</span>
                                    {% endif %}
                                    {{ m.ManifestationTypée|split(' - ')|last }}
                                </div>
                                <div class="mt-1 flex items-center text-sm text-gray-500">
                                    <span class="truncate mr-4">📅 {{ m.Date|date('d/m/Y à H:i') }}</span>
                                    <span class="truncate">📍 {{ m.Lieu }}</span>
                                </div>
                            </div>
                            
                            <div class="mt-2 sm:mt-0 w-full sm:w-auto">
                                <label for="part_{{ m.id_manifestation }}" class="sr-only">Statut</label>
                                <select 
                                    id="part_{{ m.id_manifestation }}" 
                                    name="participations[{{ m.id_manifestation }}]"
                                    data-event-type="{{ m.is_match ? 'match' : 'training' }}"
                                    class="w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]"
                                >
                                    <option value=".">--- Non renseigné ---</option>
                                    
                                    {% if m.is_match %}
                                        {# Options spécifiques aux matchs #}
                                        <option value="Disponible" {% if m.user_status == 'Disponible' %}selected{% endif %}>Disponible</option>
                                        <option value="Disponible si nécessaire" {% if m.user_status == 'Disponible si nécessaire' %}selected{% endif %}>Disponible si nécessaire</option>
                                        <option value="Indisponible" {% if m.user_status == 'Indisponible' %}selected{% endif %}>Indisponible</option>
                                        <option value="Ne sait pas encore" {% if m.user_status == 'Ne sait pas encore' %}selected{% endif %}>Ne sait pas encore</option>
                                        {% if is_capitaine or m.user_status == 'Sélectionné(e)' %}
                                            <option value="Sélectionné(e)" {% if m.user_status == 'Sélectionné(e)' %}selected{% endif %}>Sélectionné(e)</option>
                                        {% endif %}
                                    {% else %}
                                        {# Options spécifiques aux entraînements / autres #}
                                        <option value="Présent" {% if m.user_status == 'Présent' %}selected{% endif %}>Présent</option>
                                        <option value="Absent" {% if m.user_status == 'Absent' %}selected{% endif %}>Absent</option>
                                        <option value="Ne sait pas encore" {% if m.user_status == 'Ne sait pas encore' %}selected{% endif %}>Ne sait pas encore</option>
                                    {% endif %}
                                </select>
                            </div>
                        </div>
                    </li>
                {% else %}
                    <li class="p-6 text-center text-gray-500">
                        Aucun événement à venir dans l'agenda.
                    </li>
                {% endfor %}
            </ul>
        </div>

        {% if manifestations|length > 0 %}
            <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 p-4 shadow-lg flex justify-end">
                <button type="submit" class="inline-flex justify-center py-3 px-6 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    Enregistrer mes disponibilités
                </button>
            </div>
            <div class="pb-20"></div> {# Ajoute un padding pour que le contenu ne soit pas masqué par le bouton fixe #}
        {% endif %}
    </form>

    {# SECTION LÉGENDE / AIDE (Issue de l'ancien fichier) #}
    <div class="bg-blue-50 border-l-4 border-blue-400 p-6 rounded-r-lg mt-8">
        <h3 class="text-lg font-bold text-blue-900 mb-4">💡 Comment remplir sa disponibilité pour un match ?</h3>
        <p class="text-sm text-blue-800 mb-4 text-justify">
            Une sélection se passe "à peu près" comme ça : les personnes <strong>"Disponible"</strong> sont sélectionnées en priorité, puis le capitaine pioche parmi les <strong>"Disponible si nécessaire"</strong> pour compléter au besoin. 
            Dans tous les cas, le capitaine a plein pouvoir sur sa sélection (cohérence de l'équipe, nombre de matchs déjà joués par joueur, présence aux matchs à l'extérieur, etc.).
        </p>
        <p class="text-sm text-blue-800 font-medium mb-6">
            Si vous <u>pouvez</u> et <u>voulez</u> jouer le match, mettez "Disponible" et non "Disponible si nécessaire". Ne vous "auto-excluez" pas, le capitaine s'en chargera ! :-)
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <h4 class="font-semibold text-gray-900 border-b pb-2 mb-3">Cas d'un match</h4>
                <ul class="space-y-3 text-sm text-gray-700">
                    <li><span class="inline-block w-6 text-center font-bold text-green-600">✓</span> <strong>Disponible :</strong> Je peux et je veux faire le match.</li>
                    <li><span class="inline-block w-6 text-center font-bold text-yellow-500">◐</span> <strong>Disponible si nécessaire :</strong> Je veux bien venir en cas de sous-effectif pour éviter un forfait.</li>
                    <li><span class="inline-block w-6 text-center font-bold text-red-600">✗</span> <strong>Indisponible :</strong> Ne peut pas se libérer.</li>
                    <li><span class="inline-block w-6 text-center font-bold text-gray-500">?</span> <strong>Ne sait pas encore :</strong> Répondra dès que possible.</li>
                </ul>
            </div>
            <div>
                <h4 class="font-semibold text-gray-900 border-b pb-2 mb-3">Entraînement & Autres</h4>
                <ul class="space-y-3 text-sm text-gray-700">
                    <li><span class="inline-block w-6 text-center font-bold text-green-600">✓</span> <strong>Présent :</strong> Sera présent à l'événement.</li>
                    <li><span class="inline-block w-6 text-center font-bold text-red-600">✗</span> <strong>Absent :</strong> Ne sera pas présent.</li>
                    <li><span class="inline-block w-6 text-center font-bold text-gray-500">?</span> <strong>Ne sait pas encore :</strong> Répondra dès que possible.</li>
                </ul>
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% block scripts %}
<script>
  (function() {
    const setBulkStatus = (scope, value) => {
      document.querySelectorAll(`select[data-event-type="${scope}"]`).forEach(select => {
        if (!value) {
          select.value = '.';
          return;
        }
        const option = Array.from(select.options).find(opt => opt.value === value);
        if (option) {
          select.value = value;
        }
      });
    };

    document.getElementById('bulk-match-apply')?.addEventListener('click', function() {
      const value = document.getElementById('bulk-match-status')?.value;
      if (value) {
        setBulkStatus('match', value);
      }
    });

    document.getElementById('bulk-training-apply')?.addEventListener('click', function() {
      const value = document.getElementById('bulk-training-status')?.value;
      if (value) {
        setBulkStatus('training', value);
      }
    });

    document.getElementById('bulk-reset-all')?.addEventListener('click', function() {
      document.querySelectorAll('select[data-event-type]').forEach(select => select.value = '.');
    });

    // Logique de filtrage des événements
    const filterButtons = document.querySelectorAll('.filter-button');
    const eventListItems = document.querySelectorAll('#event-list li');

    // Définition des classes Tailwind pour l'état actif et inactif
    const activeClasses = ['bg-[var(--primary)]', 'text-white'];
    const inactiveClasses = ['bg-slate-100','text-slate-700', 'hover:bg-slate-200'];

px-3 py-1.5 text-xs rounded-full font-medium transition bg-[var(--primary)] text-white

    filterButtons.forEach(button => {
        button.addEventListener('click', function() {
            const filterType = this.dataset.filter;

            // 1. Réinitialiser tous les boutons à l'état "inactif"
            filterButtons.forEach(btn => {
                btn.classList.remove(...activeClasses);
                btn.classList.add(...inactiveClasses);
            });

            // 2. Mettre le bouton cliqué à l'état "actif"
            this.classList.remove(...inactiveClasses);
            this.classList.add(...activeClasses);

            // 3. Filtrer les événements (inchangé)
            eventListItems.forEach(item => {
                if (filterType === 'all' || item.dataset.eventFilter === filterType) {
                    item.style.display = ''; 
                } else {
                    item.style.display = 'none'; 
                }
            });
        });
    });
  })();
</script>
{% endblock %}
