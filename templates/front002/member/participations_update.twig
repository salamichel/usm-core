{% extends "base.twig" %}

{% block title %}Ma participation{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto px-6 py-16">
    
    <div class="sm:flex sm:items-center justify-between mb-8 border-b border-gray-200 pb-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Ma participation</h1>
            <p class="mt-2 text-sm text-gray-700">Déclarez votre statut pour chaque créneau en cliquant sur l'icône correspondant. La sauvegarde est automatique.</p>
        </div>
        <div class="mt-4 sm:mt-0">
            <a href="{{ url('member/dashboard') }}" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 transition-colors">
                ← Retour à mon espace
            </a>
        </div>
    </div>

    {% if flash.error %}
        <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6"><p class="text-sm text-red-700">{{ flash.error }}</p></div>
    {% endif %}
    {% if flash.success %}
        <div class="bg-green-50 border-l-4 border-green-400 p-4 mb-6"><p class="text-sm text-green-700">{{ flash.success }}</p></div>
    {% endif %}

    {% if manifestations|length > 0 %}
        {# Calcul des types d'événements pour les filtres #}
        {% set event_types = [] %}
        {% for m in manifestations %}
            {% set type = m.type|default('Événement') %}
            {% if type not in event_types %}
                {% set event_types = event_types|merge([type]) %}
            {% endif %}         
        {% endfor %}

        {# Boutons de filtre dynamiques #}
        {% if event_types|length > 1 %}
            <div class="mb-6 flex flex-wrap gap-2">
                <button type="button" class="filter-button px-3 py-1.5 text-xs rounded-full font-medium transition bg-[var(--primary)] text-white" data-filter="all">Tous</button>
                {% for type in event_types %}
                    <button type="button" class="filter-button filter-button px-3 py-1.5 text-xs rounded-full font-medium transition bg-slate-100 text-slate-700 hover:bg-slate-200]" data-filter="{{ type|lower|replace({' ': '-'}) }}">{{ type }}</button>
                {% endfor %}
            </div>
        {% endif %}

        {# Section Actions groupées #}
        <div class="mb-6 rounded-lg border border-gray-200 bg-gray-50 p-4">
            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                <div>
                    <h2 class="text-base font-semibold text-gray-900">Actions groupées</h2>
                    <p class="text-sm text-gray-600">Appliquez rapidement un statut à tous les matchs ou entraînements.</p>
                </div>
                <div class="flex flex-wrap gap-2 w-full md:w-auto md:justify-end md:items-center">
                    <div class="flex items-center gap-2 w-full sm:w-auto">
                        <select id="bulk-match-status" class="flex-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 min-w-[120px]">
                            <option value="">Matchs</option>
                            <option value="Disponible">Disponible</option>
                            <option value="Disponible si nécessaire">Disponible si nécessaire</option>
                            <option value="Indisponible">Indisponible</option>
                            <option value="Ne sait pas encore">Ne sait pas encore</option>
                        </select>
                        <button type="button" id="bulk-match-apply" class="inline-flex items-center justify-center rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors shadow-sm">Appliquer</button>
                    </div>
                    <div class="flex items-center gap-2 w-full sm:w-auto">
                        <select id="bulk-entrainement-status" class="flex-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 min-w-[120px]">
                            <option value="">Entraînements</option>
                            <option value="Présent">Présent</option>
                            <option value="Absent">Absent</option>
                            <option value="Ne sait pas encore">Ne sait pas encore</option>
                        </select>
                        <button type="button" id="bulk-entrainement-apply" class="inline-flex items-center justify-center rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors shadow-sm">Appliquer</button>
                    </div>
                    <div class="flex items-center gap-2 w-full sm:w-auto">
                        <select id="bulk-club-status" class="flex-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 min-w-[120px]">
                            <option value="">Club</option>
                            <option value="Présent">Présent</option>
                            <option value="Absent">Absent</option>
                            <option value="Ne sait pas encore">Ne sait pas encore</option>
                        </select>
                        <button type="button" id="bulk-club-apply" class="inline-flex items-center justify-center rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors shadow-sm">Appliquer</button>
                    </div>
                    <div class="flex items-center gap-2 w-full sm:w-auto">
                        <select id="bulk-beach-status" class="flex-1 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 min-w-[120px]">
                            <option value="">Beach Volley</option>
                            <option value="Présent">Présent</option>
                            <option value="Absent">Absent</option>
                            <option value="Ne sait pas encore">Ne sait pas encore</option>
                        </select>
                        <button type="button" id="bulk-beach-apply" class="inline-flex items-center justify-center rounded-md bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors shadow-sm">Appliquer</button>
                    </div>
                    {# Reset All Button #}
                    {# <button type="button" id="bulk-reset-all" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 transition-colors shadow-sm w-full sm:w-auto">Tout effacer</button> #}
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-8" id="event-grid">
            {% for m in manifestations %}
                {% include "agenda/_event_card.twig" with {'m': m, 'allow_actions': true, 'show_link': false} %}
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-12">
            <h3 class="text-sm font-medium text-gray-900">Aucun créneau disponible</h3>
            <p class="mt-1 text-sm text-gray-500">Aucun événement ne correspond à votre profil actuellement.</p>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block scripts %}
<script src="{{ asset('front002/js/agenda-cards.js') }}"></script>
{% endblock %}
