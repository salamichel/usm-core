{% extends 'base.twig' %}
{% block title %}{{ categorie.nom }}{% if saison %} — {{ saison.libelle }}{% endif %} — USM Volley{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto px-6 py-16">
  <nav aria-label="Fil d'Ariane" class="text-sm text-slate-500 mb-10">
    <a href="{{ url('') }}" class="hover:text-[var(--primary)] transition-colors">Accueil</a>
    <span class="mx-2 text-slate-300">/</span>
    <a href="{{ url('equipes') }}" class="hover:text-[var(--primary)] transition-colors">Équipes</a>
    <span class="mx-2 text-slate-300">/</span>
    <span class="text-slate-900">{{ categorie.nom }}</span>
  </nav>

  <header class="mb-14 pb-10 border-b border-slate-200">
    <span class="inline-block text-xs uppercase tracking-[0.25em] text-[var(--primary)] font-medium mb-3">Catégorie d'équipes</span>
    <h1 class="font-serif text-4xl md:text-5xl font-semibold text-slate-900 leading-tight">{{ categorie.nom }}</h1>
    {% if saison %}
      <p class="text-slate-600 mt-3">Saison <span class="font-medium">{{ saison.libelle }}</span></p>
    {% endif %}
  </header>

  {% if categorie.description %}
  <section class="prose prose-slate mb-12 text-slate-700">
    {{ categorie.description|render_with_config|raw }}
  </section>
  {% endif %}

  {% if equipes|length %}
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {% for eq in equipes %}
    <a href="{{ url('equipes/' ~ categorie.slug ~ '/' ~ eq.slug) }}" class="group block">
      <div class="aspect-[4/3] overflow-hidden rounded-lg bg-slate-100 mb-5">
        {% if eq.cover %}
          <img src="{{ image_variant(eq.cover, 'medium') }}" alt="{{ eq.libelle }}"
               loading="lazy" decoding="async"
               class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
        {% else %}
          <div class="w-full h-full bg-gradient-to-br from-slate-200 to-slate-300 flex items-center justify-center text-5xl text-slate-400">🏐</div>
        {% endif %}
      </div>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-3 group-hover:text-[var(--primary)] transition">{{ eq.libelle }}</h2>
      {% if eq.description_courte %}
        <p class="text-sm text-slate-600 leading-relaxed italic">{{ eq.description_courte }}</p>
      {% endif %}
    </a>
    {% endfor %}
  </div>
  {% else %}
  <div class="card p-10 text-center">
    <p class="text-slate-600 text-lg">Aucune équipe disponible dans cette catégorie pour la saison sélectionnée.</p>
  </div>
  {% endif %}
</div>
{% endblock %}
