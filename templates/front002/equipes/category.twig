{% extends 'base.twig' %}
{% block title %}{{ categorie.nom }}{% if saison %} — {{ saison.libelle }}{% endif %} — USM Volley{% endblock %}

{% block content %}
<div class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">
  {# En-tête #}
  <div class="bg-slate-900 text-white pt-8 pb-20 md:pt-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <nav aria-label="Fil d'Ariane" class="text-sm text-slate-400 mb-6">
        <a href="{{ url('') }}" class="hover:text-white transition-colors">Accueil</a>
        <span class="mx-2 text-slate-600">/</span>
        <a href="{{ url('equipes') }}" class="hover:text-white transition-colors">Équipes</a>
        <span class="mx-2 text-slate-600">/</span>
        <span class="text-slate-200">{{ categorie.nom }}</span>
      </nav>
      
      <div>
        <span class="inline-block text-xs uppercase tracking-[0.25em] text-[var(--primary)] font-semibold mb-2">Catégorie d'équipes</span>
        <h1 class="font-serif text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-3">{{ categorie.nom }}</h1>
        {% if saison %}
          <p class="text-slate-400 text-sm md:text-base mt-1">Saison <span class="font-bold text-white">{{ saison.libelle }}</span></p>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 -mt-10">

  {% if categorie.description %}
  <section class="bg-white rounded-3xl p-6 md:p-8 border border-slate-100 shadow-sm prose prose-slate mb-8 text-slate-700 max-w-none">
    {{ categorie.description|render_with_config|raw }}
  </section>
  {% endif %}

  {% if equipes|length %}
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {% for eq in equipes %}
    <a href="{{ url('equipes/' ~ categorie.slug ~ '/' ~ eq.slug) }}" class="group block bg-white rounded-3xl p-5 border border-slate-100 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md">
      <div class="aspect-[4/3] overflow-hidden rounded-2xl bg-slate-50 mb-5">
        {% if eq.cover %}
          <img src="{{ image_variant(eq.cover, 'medium') }}" alt="{{ eq.libelle }}"
               loading="lazy" decoding="async"
               class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
        {% else %}
          <div class="w-full h-full bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center text-5xl text-slate-400">🏐</div>
        {% endif %}
      </div>
      <h2 class="font-serif text-xl font-bold text-slate-900 mb-2 group-hover:text-[var(--primary)] transition">{{ eq.libelle }}</h2>
      {% if eq.description_courte %}
        <p class="text-xs text-slate-500 leading-relaxed italic">{{ eq.description_courte }}</p>
      {% endif %}
    </a>
    {% endfor %}
  </div>
  {% else %}
  <div class="bg-white rounded-3xl p-10 text-center border border-slate-100 shadow-sm">
    <p class="text-slate-600 text-lg font-bold">Aucune équipe disponible dans cette catégorie pour la saison sélectionnée.</p>
  </div>
  {% endif %}
</div>
</div>
{% endblock %}
