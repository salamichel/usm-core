{% extends 'base.twig' %}
{% block title %}{{ equipe.libelle }}{% if saison %} — {{ saison.libelle }}{% endif %} — USM Volley{% endblock %}

{% import '_gallery.twig' as components %}
{% import 'agenda/_macros.twig' as agendaMacros %}

{% block head %}
{% if photos|length or cover %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
{% endif %}
{% endblock %}

{% block content %}
<div class="min-h-screen bg-slate-50/50 pb-24 md:pb-12">
  {# En-tête #}
  <div class="bg-slate-900 text-white pt-8 pb-20 md:pt-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <nav class="text-sm text-slate-400 mb-6">
        <a href="{{ url('/') }}" class="hover:text-white transition">Accueil</a>
        <span class="mx-2 text-slate-650">/</span>
        <a href="{{ url('equipes') }}" class="hover:text-white transition">Équipes</a>
        <span class="mx-2 text-slate-650">/</span>
        <a href="{{ url('equipes/' ~ categorie_slug) }}" class="hover:text-white transition">{{ equipe.categorie }}</a>
        <span class="mx-2 text-slate-650">/</span>
        <span class="text-slate-300">{{ equipe.libelle }}</span>
      </nav>

      <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
          <span class="inline-block text-xs uppercase tracking-[0.2em] text-[var(--primary)] font-semibold mb-2">{{ equipe.categorie }}</span>
          <h1 class="font-serif text-3xl md:text-5xl font-extrabold tracking-tight text-white leading-tight mb-2">{{ equipe.libelle }}</h1>
        </div>

        <div class="flex flex-wrap gap-4 items-center">
          {% if saison %}
            <div class="relative inline-block text-left group">
              <button type="button" class="inline-flex items-center gap-x-1.5 rounded-xl bg-white/10 px-3 py-2 text-xs font-bold text-white hover:bg-white/20 transition shadow-sm" id="menu-button" aria-expanded="false" aria-haspopup="true">
                <span class="text-slate-400 font-semibold">Saison</span>
                <span class="font-bold">{{ saison.libelle }}</span>
                <svg class="-mr-1 h-4 w-4 text-slate-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                </svg>
              </button>

              <div class="absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-xl bg-white shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-205" role="menu" aria-orientation="vertical" aria-labelledby="menu-button" tabindex="-1">
                <div class="py-1" role="none">
                  {% for s in allSaisons %}
                    <a href="{{ url('equipes/' ~ categorie_slug ~ '/' ~ equipe.slug ~ '?saison=' ~ s.id ~ '&slug=' ~ s.libelle ) }}" class="block px-4 py-2 text-xs font-bold {{ s.id == saison.id ? 'bg-slate-100 text-slate-900 font-extrabold' : 'text-slate-700 hover:bg-slate-50' }}" role="menuitem" tabindex="-1" id="menu-item-{{ loop.index0 }}">{{ s.libelle }}</a>
                  {% endfor %}
                </div>
              </div>
            </div>
          {% endif %}
          {% if joueurs|length %}
            <span class="bg-white/10 px-3 py-2 rounded-xl text-xs font-bold text-slate-350">Effectif: <strong class="text-white">{{ joueurs|length }}</strong></span>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 -mt-10">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      {# Main Content #}
      <div class="lg:col-span-2 space-y-8">
        
        {# Team Cover and Description card #}
        <div class="bg-white rounded-3xl p-6 md:p-8 border border-slate-100 shadow-sm space-y-6">
          {% if cover %}
          <a href="{{ asset('uploads/' ~ cover.filename) }}"
             class="glightbox block overflow-hidden rounded-2xl bg-slate-50 group"
             {% if cover.caption %}data-glightbox="description: {{ cover.caption }}"{% endif %}
             data-gallery="gallery-equipe_saison-cover">
            <img src="{{ image_variant(cover, 'large') }}"
                 alt="{{ cover.caption ? cover.caption|truncate(125) : 'Photo de couverture' }}"
                 loading="eager" decoding="async"
                 class="w-full max-h-[460px] object-cover transition-transform duration-500 group-hover:scale-[1.02]">
          </a>
          {% endif %}
          
          {% if equipe.description %}
            <div class="prose prose-slate max-w-none text-slate-655">
              {{ equipe.description|raw }}
            </div>
          {% endif %}
        </div>

        {# Gallery #}
        {{ components.gallery(photos) }}

        {# Upcoming matches #}
        {% if mini_agenda_events|length %}
        <div class="space-y-4">
          <div class="flex items-baseline justify-between flex-wrap gap-3">
            <div>
              <span class="inline-block text-xs uppercase tracking-[0.25em] text-slate-400 font-semibold mb-1">Calendrier</span>
              <h2 class="font-serif text-2xl font-bold text-slate-900">Prochains matchs</h2>
            </div>
            {% if agenda_filter_url %}
            <a href="{{ agenda_filter_url }}" class="text-xs font-bold text-[var(--primary)] hover:underline underline-offset-4">Agenda complet →</a>
            {% endif %}
          </div>
      
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {% for event in mini_agenda_events %}
            <div class="bg-white rounded-3xl p-5 border border-slate-100 shadow-sm hover:-translate-y-1 hover:shadow-md transition-all duration-205">
              <div class="flex justify-between items-start gap-4">
                <div class="flex-1 min-w-0">
                  <h3 class="font-serif font-bold text-base text-slate-900 leading-tight mb-3">{{ event.titre }}</h3>
                  <div class="space-y-1 text-xs text-slate-500">
                    <p class="flex items-center gap-1.5"><span class="text-slate-400">📅</span> {{ event.date_display }}</p>
                    {% if event.time_range %}<p class="flex items-center gap-1.5"><span class="text-slate-400">🕐</span> {{ event.time_range }}</p>{% endif %}
                    <p class="flex items-center gap-1.5"><span class="text-slate-400">📍</span> {{ event.lieu }}</p>
                  </div>
                </div>
                <div class="flex-shrink-0">
                  {{ agendaMacros.render_participation_badge(event.nb_present, event.nb_disponible, event.nb_indisponible) }}
                </div>
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
        {% endif %}
        
      </div>

      {# Sidebar #}
      <div class="space-y-8">
        
        {# FFVB Results card #}
        {% if ffvb_links|length %}
        <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm space-y-4">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
              </svg>
            </div>
            <div>
              <h3 class="font-serif text-lg font-bold text-slate-900 mb-1">
                Résultats FFVB
              </h3>
              <p class="text-xs text-slate-500 leading-normal">
                Suivez le classement et les résultats officiels de l'équipe pour cette saison.
              </p>
            </div>
          </div>
          
          <div class="flex flex-col gap-2 pt-2">
            {% for link in ffvb_links %}
            <a href="{{ link.url }}" target="_blank" rel="noopener noreferrer"
               class="w-full inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm px-5 py-3 rounded-xl shadow-sm transition cursor-pointer">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              {{ link.label }}
            </a>
            {% endfor %}
          </div>
        </div>
        {% endif %}

        {# Capitaines card #}
        {% if capitaines|length %}
        <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-amber-50 text-amber-500 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.907c.961 0 1.36 1.243.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-serif text-lg font-bold text-slate-900 mb-1">
                Capitaine{{ capitaines|length > 1 ? 's' : '' }}
              </h3>
              <p class="text-xs text-slate-500">
                {% for cap in capitaines %}
                  <strong class="text-slate-800">{{ cap.prenom }} {{ cap.nom }}</strong>{% if not loop.last %}, {% endif %}
                {% endfor %}
              </p>
            </div>
          </div>
          
          <button type="button" onclick="openContactModal()"
                  class="w-full inline-flex items-center justify-center gap-2 bg-[var(--primary)] text-white font-bold text-sm px-5 py-3 rounded-xl shadow-sm hover:bg-opacity-95 transition cursor-pointer">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Contacter le{{ capitaines|length > 1 ? 's' : '' }} capitaine{{ capitaines|length > 1 ? 's' : '' }}
          </button>
        </div>
        {% endif %}

        {# Roster list #}
        {% if joueurs|length %}
        <div class="space-y-4">
          <h2 class="font-serif text-xl font-bold text-slate-900">Effectif de l'équipe</h2>
          <div class="bg-white rounded-3xl p-5 border border-slate-100 shadow-sm divide-y divide-slate-100">
            {% for j in joueurs %}
            {%- set isFemale = j.data.Sexe|default('F') == 'F' -%}
            <div class="py-3 flex items-center justify-between gap-3 {% if loop.first %}pt-0{% endif %} {% if loop.last %}pb-0{% endif %}">
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 text-xs font-bold {{ isFemale ? 'bg-pink-50 text-pink-700' : 'bg-blue-50 text-blue-700' }}">
                  {{ j.prenom|first }}{{ j.nom|first }}
                </div>
                <p class="font-semibold text-xs text-slate-800 truncate">{{ j.prenom }} {{ j.nom }}</p>
              </div>
              {% if j.is_captain %}
                <span title="Capitaine" class="flex-shrink-0 bg-amber-100 text-amber-800 p-1 rounded-full">
                  <svg class="w-3.5 h-3.5 text-amber-600" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                </span>
              {% endif %}
            </div>
            {% endfor %}
          </div>
        </div>
        {% endif %}

      </div>

    </div>

    {# Other teams #}
    {% if otherEquipes|length %}
    <section class="mt-20 pt-10 border-t border-slate-205">
      <h2 class="font-serif text-2xl font-bold text-slate-900 mb-8">Autres équipes — {{ equipe.categorie }}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {% for eq in otherEquipes %}
        <a href="{{ url('equipes/' ~ categorie_slug ~ '/' ~ eq.slug) }}" class="group block bg-white rounded-3xl p-5 border border-slate-100 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md">
          <div class="aspect-[4/3] overflow-hidden rounded-2xl bg-slate-50 mb-4">
            {% if eq.cover %}
              <img src="{{ image_variant(eq.cover, 'medium') }}" alt="{{ eq.libelle }}"
                   loading="lazy" decoding="async"
                   class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
            {% else %}
              <div class="w-full h-full bg-slate-50 flex items-center justify-center text-slate-400">Pas de photo</div>
            {% endif %}
          </div>
          <h3 class="font-serif text-lg font-bold text-slate-900 leading-tight group-hover:text-[var(--primary)] transition">{{ eq.libelle }}</h3>
        </a>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {# Contact Modal #}
    {% if capitaines|length %}
    <div id="contact-modal" class="fixed inset-0 z-50 overflow-y-auto hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
      <!-- Background backdrop -->
      <div class="fixed inset-0 bg-slate-900/60 transition-opacity animate-fade-in" onclick="closeContactModal()"></div>

      <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
        <div class="relative transform overflow-hidden rounded-3xl bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg border border-slate-200">
          <form method="POST" action="{{ url('equipes/' ~ categorie_slug ~ '/' ~ equipe.slug ~ '/contact-capitaine' ~ (saison ? '?saison=' ~ saison.id : '')) }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">

            <div class="bg-white px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
              <div class="sm:flex sm:items-start">
                <div class="mx-auto flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-amber-50 sm:mx-0 sm:h-10 sm:w-10">
                  <svg class="h-6 w-6 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left w-full">
                  <h3 class="font-serif text-lg font-bold leading-6 text-slate-900" id="modal-title">
                    Message pour le{{ capitaines|length > 1 ? 's' : '' }} capitaine{{ capitaines|length > 1 ? 's' : '' }}
                  </h3>
                  <p class="text-xs text-slate-400 mt-1 font-semibold">
                    Ce formulaire sera envoyé de manière sécurisée sans révéler l'adresse e-mail.
                  </p>

                  {% if contact_error %}
                    <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 text-rose-700 px-3 py-2 text-xs font-semibold">
                      {{ contact_error }}
                    </div>
                  {% endif %}

                  <div class="mt-4 space-y-4">
                    <div>
                      <label for="visitor_name" class="block text-xs font-semibold text-slate-700 mb-1">Votre nom *</label>
                      <input type="text" id="visitor_name" name="name" required value="{{ contact_form_data.name|default('') }}"
                             class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm shadow-sm focus:border-[var(--primary)] focus:ring-2 focus:ring-[var(--primary)]/20 focus:outline-none transition-all">
                    </div>
                    <div>
                      <label for="visitor_email" class="block text-xs font-semibold text-slate-700 mb-1">Votre adresse email *</label>
                      <input type="email" id="visitor_email" name="email" required value="{{ contact_form_data.email|default('') }}"
                             class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm shadow-sm focus:border-[var(--primary)] focus:ring-2 focus:ring-[var(--primary)]/20 focus:outline-none transition-all">
                    </div>
                    <div>
                      <label for="visitor_subject" class="block text-xs font-semibold text-slate-700 mb-1">Sujet *</label>
                      <input type="text" id="visitor_subject" name="subject" required value="{{ contact_form_data.subject|default('') }}"
                             class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm shadow-sm focus:border-[var(--primary)] focus:ring-2 focus:ring-[var(--primary)]/20 focus:outline-none transition-all">
                    </div>
                    <div>
                      <label for="visitor_message" class="block text-xs font-semibold text-slate-700 mb-1">Message *</label>
                      <textarea id="visitor_message" name="message" rows="4" required
                                class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm shadow-sm focus:border-[var(--primary)] focus:ring-2 focus:ring-[var(--primary)]/20 focus:outline-none transition-all">{{ contact_form_data.message|default('') }}</textarea>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="bg-slate-50 px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6 gap-2 rounded-b-3xl">
              <button type="submit"
                      class="inline-flex w-full justify-center rounded-xl bg-[var(--primary)] px-4 py-2.5 text-sm font-bold text-white shadow-sm hover:bg-opacity-95 sm:w-auto transition cursor-pointer">
                Envoyer
              </button>
              <button type="button" onclick="closeContactModal()"
                      class="mt-3 inline-flex w-full justify-center rounded-xl bg-white px-4 py-2.5 text-sm font-bold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-200 hover:bg-slate-50 sm:mt-0 sm:w-auto transition cursor-pointer">
                Annuler
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
    {% endif %}

  </div>
</div>
{% endblock %}

{% block scripts %}
{% if photos|length or cover %}
<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script>GLightbox({ selector: '.glightbox' });</script>
{% endif %}
{% if capitaines|length %}
  <script>
    function openContactModal() {
      const modal = document.getElementById('contact-modal');
      modal.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
    }

    function closeContactModal() {
      const modal = document.getElementById('contact-modal');
      modal.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
    }

    // Auto-open if validation failed
    {% if open_contact_modal %}
      document.addEventListener('DOMContentLoaded', function() {
        openContactModal();
      });
    {% endif %}
  </script>
{% endif %}
{% endblock %}
