{% extends 'base.twig' %}
{% block title %}Nos équipes{% if saison %} — {{ saison.libelle }}{% endif %} — USM Volley{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto px-6 py-16">

  {# Header #}
  <header class="mb-14 pb-10 border-b border-slate-200">
    <span class="inline-block text-xs uppercase tracking-[0.25em] text-slate-500 font-medium mb-3">Le club</span>
    <h1 class="font-serif text-4xl md:text-6xl font-semibold text-slate-900 leading-tight">Nos équipes</h1>
    {% if saison %}
      <p class="text-slate-600 mt-3">Saison <span class="font-medium">{{ saison.libelle }}</span></p>
    {% endif %}
  </header>

  {% if grouped|length %}
    {% for cat, equipes in grouped %}
    <section class="mb-20">
      <div class="flex items-baseline justify-between flex-wrap gap-4 mb-8">
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-slate-900">{{ cat }}</h2>
      </div>

      {% if categorie_descriptions[cat] is defined and categorie_descriptions[cat].description %}
        <div class="prose prose-slate mb-8 text-slate-700">
          {{ categorie_descriptions[cat].description|raw }}
        </div>
      {% endif %}

      {% if categorie_descriptions[cat] is defined and (categorie_descriptions[cat].type or categorie_descriptions[cat].hauteur_filet) %}
        <div class="card p-6 mb-10 max-w-2xl">
          <div class="grid sm:grid-cols-2 gap-6">
            {% if categorie_descriptions[cat].type %}
              <div>
                <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-1">Type</p>
                <p class="font-serif text-lg font-semibold text-slate-900">{{ categorie_descriptions[cat].type }}</p>
              </div>
            {% endif %}
            {% if categorie_descriptions[cat].hauteur_filet %}
              <div>
                <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-1">Hauteur du filet</p>
                <p class="font-serif text-lg font-semibold text-slate-900">{{ categorie_descriptions[cat].hauteur_filet }}</p>
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {% for eq in equipes %}
        <a href="{{ url('equipes/' ~ eq.slug) }}" class="group block">
          <div class="aspect-[4/3] overflow-hidden rounded-lg bg-slate-100 mb-5">
            {% if eq.cover %}
              <img src="{{ image_variant(eq.cover, 'medium') }}" alt="{{ eq.libelle }}"
                   loading="lazy" decoding="async"
                   class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
            {% else %}
              <div class="w-full h-full bg-gradient-to-br from-slate-200 to-slate-300 flex items-center justify-center text-5xl text-slate-400">🏐</div>
            {% endif %}
          </div>
          <h3 class="font-serif text-xl font-semibold text-slate-900 leading-tight mb-2 group-hover:text-[var(--primary)] transition">
            {{ eq.libelle }}
          </h3>

          {% if eq.type or eq.hauteur_filet %}
          <div class="flex gap-4 text-xs text-slate-500 mb-3">
            {% if eq.type %}<span><span class="text-slate-400">Type</span> · {{ eq.type }}</span>{% endif %}
            {% if eq.hauteur_filet %}<span><span class="text-slate-400">Filet</span> · {{ eq.hauteur_filet }}</span>{% endif %}
          </div>
          {% endif %}

          {% if eq.description_courte %}
            <p class="text-sm text-slate-600 leading-relaxed italic">{{ eq.description_courte }}</p>
          {% endif %}
        </a>
        {% endfor %}
      </div>
    </section>
    {% endfor %}
  {% else %}
    <div class="card p-10 text-center">
      <p class="text-slate-600 text-lg">Aucune équipe disponible pour cette saison.</p>
      <p class="text-slate-500 text-sm mt-2">Les équipes apparaissent après le flashage d'une saison active.</p>
    </div>
  {% endif %}
</div>
{% endblock %}
