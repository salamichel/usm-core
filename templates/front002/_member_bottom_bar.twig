{# templates/front002/_member_bottom_bar.twig #}
<nav class="fixed bottom-0 left-0 w-full bg-white/95 backdrop-blur-md border-t border-slate-200 z-50 md:hidden shadow-[0_-4px_12px_rgba(0,0,0,0.08)] pb-[env(safe-area-inset-bottom,0px)]">
    <div class="flex justify-between items-center h-16 px-4 relative">
        
        {# Onglet 1 : Accueil (Dashboard) #}
        {% set m_url_1 = site_config.member_bottom_url_1|default('member/dashboard') %}
        {% set m_href_1 = (m_url_1 starts with 'http://' or m_url_1 starts with 'https://' or m_url_1 starts with '#' or m_url_1 starts with '/') ? m_url_1 : url(m_url_1) %}
        {% set is_dashboard = m_url_1 != '' and m_url_1 in app.server.REQUEST_URI|default('') and 'filter=this-week' not in app.server.REQUEST_URI|default('') %}
        <a href="{{ m_href_1 }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_dashboard %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            <div class="relative">
                {% include '_icon.twig' with {name: site_config.member_bottom_icon_1|default('home'), class: 'w-6 h-6 mb-0.5'} %}
                {% if member_events_this_week > 0 %}
                    <span class="absolute -top-1.5 -right-1.5 flex h-4 min-w-[1rem] items-center justify-center rounded-full bg-[var(--primary)] px-1 text-[9px] font-extrabold text-white ring-2 ring-white">
                        {{ member_events_this_week }}
                    </span>
                {% endif %}
            </div>
            <span class="text-[10px] font-bold tracking-tight">{{ site_config.member_bottom_label_1|default('Accueil') }}</span>
        </a>

        {# Onglet 2 : Ma Semaine #}
        {% set m_url_2 = site_config.member_bottom_url_2|default('member/dashboard?filter=this-week&scroll=1') %}
        {% set m_href_2 = (m_url_2 starts with 'http://' or m_url_2 starts with 'https://' or m_url_2 starts with '#' or m_url_2 starts with '/') ? m_url_2 : url(m_url_2) %}
        {% set is_ma_semaine = m_url_2 != '' and m_url_2 in app.server.REQUEST_URI|default('') and 'filter=this-week' in app.server.REQUEST_URI|default('') %}
        <a href="{{ m_href_2 }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_ma_semaine %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            {% include '_icon.twig' with {name: site_config.member_bottom_icon_2|default('clipboard-check'), class: 'w-6 h-6 mb-0.5'} %}
            <span class="text-[10px] font-medium tracking-tight">{{ site_config.member_bottom_label_2|default('Ma Sem.') }}</span>
        </a>

        {# --- FLOATING ACTION BUTTON CENTRAL : AGENDA --- #}
        {% set m_url_3 = site_config.member_bottom_url_3|default('agenda?view=cards#filters') %}
        {% set m_href_3 = (m_url_3 starts with 'http://' or m_url_3 starts with 'https://' or m_url_3 starts with '#' or m_url_3 starts with '/') ? m_url_3 : url(m_url_3) %}
        <div class="relative -top-5 z-50 flex justify-center w-16 flex-shrink-0">
            <a href="{{ m_href_3 }}" class="w-14 h-14 rounded-full bg-[var(--primary)] text-white flex items-center justify-center shadow-[0_4px_10px_rgba(239,68,68,0.4)] hover:bg-[var(--primary)]/90 active:scale-90 active:rotate-45 transition-all duration-200 border-4 border-white" title="{{ site_config.member_bottom_label_3|default('Ouvrir l\'agenda complet') }}">
                {% include '_icon.twig' with {name: site_config.member_bottom_icon_3|default('calendar'), class: 'w-6 h-6'} %}
            </a>
        </div>

        {# Onglet 4 : Semaine Club #}
        {% set m_url_4 = site_config.member_bottom_url_4|default('agenda?this_week=1&view=cards&scroll=1') %}
        {% set m_href_4 = (m_url_4 starts with 'http://' or m_url_4 starts with 'https://' or m_url_4 starts with '#' or m_url_4 starts with '/') ? m_url_4 : url(m_url_4) %}
        {% set is_semaine_club = m_url_4 != '' and m_url_4 in app.server.REQUEST_URI|default('') and 'this_week' in app.server.REQUEST_URI|default('') %}
        <a href="{{ m_href_4 }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_semaine_club %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            {% include '_icon.twig' with {name: site_config.member_bottom_icon_4|default('calendar'), class: 'w-6 h-6 mb-0.5'} %}
            <span class="text-[10px] font-medium tracking-tight">{{ site_config.member_bottom_label_4|default('Sem. Club') }}</span>
        </a>

        {# Onglet 5 : Profil #}
        {% set m_url_5 = site_config.member_bottom_url_5|default('member/profile') %}
        {% set m_href_5 = (m_url_5 starts with 'http://' or m_url_5 starts with 'https://' or m_url_5 starts with '#' or m_url_5 starts with '/') ? m_url_5 : url(m_url_5) %}
        {% set is_profile = m_url_5 != '' and m_url_5 in app.server.REQUEST_URI|default('') %}
        <a href="{{ m_href_5 }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_profile %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            {% include '_icon.twig' with {name: site_config.member_bottom_icon_5|default('user'), class: 'w-6 h-6 mb-0.5'} %}
            <span class="text-[10px] font-medium tracking-tight">{{ site_config.member_bottom_label_5|default('Profil') }}</span>
        </a>
        
    </div>
</nav>

{# FAB Capitaine pour ajouter un match (visible uniquement sur mobile pour les capitaines) #}
{% if app.session.IsCaptainSaison %}
<a href="{{ url('member/captain/matches/create') }}" class="fixed bottom-[calc(5rem+env(safe-area-inset-bottom,0px))] right-4 z-50 w-12 h-12 rounded-full bg-amber-500 hover:bg-amber-600 text-slate-900 shadow-[0_4px_10px_rgba(245,158,11,0.4)] flex items-center justify-center active:scale-95 hover:scale-105 transition-all duration-200 md:hidden border border-amber-600" title="Ajouter un match">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
    </svg>
</a>
{% endif %}