{# templates/front002/_member_bottom_bar.twig #}
<nav class="fixed bottom-0 left-0 w-full bg-white/95 backdrop-blur-md border-t border-slate-200 z-50 md:hidden shadow-[0_-4px_12px_rgba(0,0,0,0.08)] pb-[env(safe-area-inset-bottom,0px)]">
    <div class="flex justify-between items-center h-16 px-4 relative">
        
        {# Onglet 1 : Accueil (Dashboard) #}
        {% set is_dashboard = 'dashboard' in app.server.REQUEST_URI|default('') %}
        <a href="{{ url('member/dashboard') }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_dashboard %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            <div class="relative">
                <svg class="w-6 h-6 mb-0.5" fill="{% if is_dashboard %}currentColor{% else %}none{% endif %}" stroke="currentColor" viewBox="0 0 20 20">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
                </svg>
                {% if member_events_this_week > 0 %}
                    <span class="absolute -top-1.5 -right-1.5 flex h-4 min-w-[1rem] items-center justify-center rounded-full bg-[var(--primary)] px-1 text-[9px] font-extrabold text-white ring-2 ring-white">
                        {{ member_events_this_week }}
                    </span>
                {% endif %}
            </div>
            <span class="text-[10px] font-bold tracking-tight">Accueil</span>
        </a>

        {# Onglet 2 : Équipes #}
        {% set is_equipes = 'equipes' in app.server.REQUEST_URI|default('') %}
        <a href="{{ url('equipes') }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_equipes %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            <span class="text-[10px] font-medium tracking-tight">Équipes</span>
        </a>

        {# --- FLOATING ACTION BUTTON CENTRAL : AGENDA --- #}
        <div class="relative -top-5 z-50 flex justify-center w-16 flex-shrink-0">
            <a href="{{ url('agenda?view=cards#filters') }}" class="w-14 h-14 rounded-full bg-[var(--primary)] text-white flex items-center justify-center shadow-[0_4px_10px_rgba(239,68,68,0.4)] hover:bg-[var(--primary)]/90 active:scale-90 active:rotate-45 transition-all duration-200 border-4 border-white" title="Ouvrir l'agenda complet">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </a>
        </div>

        {# Onglet 4 : Actualités / Blog #}
        {% set is_blog = 'blog' in app.server.REQUEST_URI|default('') %}
        <a href="{{ url('blog') }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_blog %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
            <span class="text-[10px] font-medium tracking-tight">Actus</span>
        </a>

        {# Onglet 5 : Profil #}
        {% set is_profile = 'profile' in app.server.REQUEST_URI|default('') %}
        <a href="{{ url('member/profile') }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_profile %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span class="text-[10px] font-medium tracking-tight">Profil</span>
        </a>
        
    </div>
</nav>

{# FAB Capitaine pour ajouter un match (visible uniquement sur mobile pour les capitaines) #}
{% if app.session.IsCaptainSaison %}
<a href="{{ url('member/captain/matches/create') }}" class="fixed bottom-[calc(5rem+env(safe-area-inset-bottom,0px))] right-4 z-50 w-12 h-12 rounded-full bg-amber-500 hover:bg-amber-600 text-slate-900 shadow-[0_4px_10px_rgba(245,158,11,0.4)] flex items-center justify-center active:scale-95 hover:scale-105 transition-all duration-200 md:hidden border border-amber-600" title="Ajouter un match">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
    </svg>
</a>
{% endif %}