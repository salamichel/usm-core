{# ── Header éditorial ──────────────────────────────────────────────────────── #}
<header class="header-classic">
  <div class="header-inner">
    {% set _logo_mode = site_config.logo_url ? (site_config.logo_display_mode|default('image_only')) : 'text_only' %}
    {% set _logo_h    = site_config.logo_height|default('40') %}
    <a href="{{ url('/') }}" class="logo-classic flex items-center gap-2.5">
      {% if site_config.logo_url and _logo_mode != 'text_only' %}
        <img src="{{ asset('uploads/' ~ site_config.logo_url) }}"
             alt="{{ site_config.club_name|default('USM Volley') }}"
             style="height:{{ _logo_h }}px; width:auto; max-width:280px; display:block;"
             class="{% if _logo_mode == 'image_desktop_text_mobile' %}hidden md:block{% endif %}">
      {% endif %}
      {% if _logo_mode == 'text_only' or _logo_mode == 'image_and_text' %}
        <span>{{ site_config.club_name|default('USM Volley') }}</span>
      {% elseif _logo_mode == 'image_desktop_text_mobile' %}
        <span class="md:hidden">{{ site_config.club_name|default('USM Volley') }}</span>
      {% endif %}
    </a>

    <nav class="nav-classic hidden md:flex" aria-label="Navigation principale">
      <ul class="nav-list-classic">
        {% for item in menu_items %}
          {% if item.children|length %}
            <li class="nav-item-classic has-mega-classic">
              <a href="#" class="nav-link-classic" aria-haspopup="true" aria-expanded="false">
                {{ item.label }}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </a>
              <div class="mega-menu-classic" role="menu">
                {% set has_columns = false %}
                {% for child in item.children %}
                  {% if child.children|length %}{% set has_columns = true %}{% endif %}
                {% endfor %}

                {% if has_columns %}
                  {% for col in item.children %}
                    <div class="mega-column-classic">
                      <h3>{{ col.label }}</h3>
                      <ul class="mega-links-classic">
                        {% if col.children|length %}
                          {% for sub in col.children %}
                            <li><a href="{{ item_url(sub) }}" role="menuitem">{{ sub.label }}</a></li>
                          {% endfor %}
                        {% else %}
                          <li><a href="{{ item_url(col) }}" role="menuitem">{{ col.label }}</a></li>
                        {% endif %}
                      </ul>
                    </div>
                  {% endfor %}
                {% else %}
                  <div class="mega-column-classic" style="grid-column: 1 / -1;">
                    <ul class="mega-links-classic" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.125rem 1rem;">
                      {% for child in item.children %}
                        <li><a href="{{ item_url(child) }}" role="menuitem">{{ child.label }}</a></li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              </div>
            </li>
          {% else %}
            {% set item_href = item_url(item) %}
            <li class="nav-item-classic">
              <a href="{{ item_href }}" class="nav-link-classic {{ is_active(item_href) ? 'active' : '' }}">{{ item.label }}</a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </nav>

    {# ── Actions desktop (connexion / compte) ─────────────────────────── #}
    <div class="header-actions">
      {% if app.session.user_name is defined %}
        <div class="header-user-dropdown" id="header-user-wrapper">
          <button class="btn-secondary header-user-btn" id="member-menu-toggle"
                  aria-haspopup="true" aria-expanded="false" aria-controls="member-menu">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M5.121 17.804A13.937 13.937 0 0112 15c2.5 0 4.847.59 6.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="hidden sm:inline">{{ app.session.user_name }}</span>
            <svg class="w-3.5 h-3.5 header-user-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="header-user-menu" id="member-menu" role="menu" aria-hidden="true">
            <a href="{{ url('member/dashboard') }}" class="header-user-menu-item" role="menuitem">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              Mon espace
            </a>
            <div class="header-user-divider" role="separator"></div>
            <form action="{{ url('member/logout') }}" method="POST">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
              <button type="submit" class="header-user-menu-item header-user-menu-danger" role="menuitem">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                Se déconnecter
              </button>
            </form>
          </div>
        </div>
      {% else %}
        <a href="{{ url('member/login') }}" class="btn-login-header">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
          </svg>
          <span class="hidden sm:inline">Se connecter</span>
          <span class="sm:hidden" aria-label="Se connecter"></span>
        </a>
      {% endif %}
    </div>

    {# ── Burger mobile ────────────────────────────────────────────────── #}
    <button id="mobile-menu-toggle"
            class="md:hidden burger-btn"
            aria-label="Ouvrir le menu"
            aria-expanded="false"
            aria-controls="mobile-menu">
      <svg class="icon-burger" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg class="icon-close" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
</header>
