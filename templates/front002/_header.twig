{# ── Header éditorial ──────────────────────────────────────────────────────── #}
<header class="header-classic">
  <div class="header-inner">
    {% set _logo_mode = site_config.logo_url ? (site_config.logo_display_mode|default('image_only')) : 'text_only' %}
    {% set _logo_h    = site_config.logo_height|default('40') %}
    <a href="{{ url('/') }}" class="logo-classic flex items-center gap-2.5">
      {% if site_config.logo_url and _logo_mode != 'text_only' %}
        <img src="{{ asset('uploads/' ~ site_config.logo_url) }}"
             alt="{{ site_config.club_name|default('USM Volley') }}"
             style="height:{{ _logo_h }}px; width:auto; max-width:280px; display:block;"
             class="{% if _logo_mode == 'image_desktop_text_mobile' %}hidden md:block{% endif %}">
      {% endif %}
      {% if _logo_mode == 'text_only' or _logo_mode == 'image_and_text' %}
        <span>{{ site_config.club_name|default('USM Volley') }}</span>
      {% elseif _logo_mode == 'image_desktop_text_mobile' %}
        <span class="md:hidden">{{ site_config.club_name|default('USM Volley') }}</span>
      {% endif %}
    </a>

    <nav class="nav-classic hidden md:flex" aria-label="Navigation principale">
      <ul class="nav-list-classic">
        {% for item in menu_items %}
          {% if item.children|length %}
            <li class="nav-item-classic has-mega-classic">
              <a href="#" class="nav-link-classic" aria-haspopup="true" aria-expanded="false">
                {{ item.label }}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </a>
              <div class="mega-menu-classic" role="menu">
                {% set has_columns = false %}
                {% for child in item.children %}
                  {% if child.children|length %}{% set has_columns = true %}{% endif %}
                {% endfor %}

                {% if has_columns %}
                  {% for col in item.children %}
                    <div class="mega-column-classic">
                      <h3>{{ col.label }}</h3>
                      <ul class="mega-links-classic">
                        {% if col.children|length %}
                          {% for sub in col.children %}
                            <li><a href="{{ item_url(sub) }}" role="menuitem">{{ sub.label }}</a></li>
                          {% endfor %}
                        {% else %}
                          <li><a href="{{ item_url(col) }}" role="menuitem">{{ col.label }}</a></li>
                        {% endif %}
                      </ul>
                    </div>
                  {% endfor %}
                {% else %}
                  <div class="mega-column-classic" style="grid-column: 1 / -1;">
                    <ul class="mega-links-classic" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.125rem 1rem;">
                      {% for child in item.children %}
                        <li><a href="{{ item_url(child) }}" role="menuitem">{{ child.label }}</a></li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              </div>
            </li>
          {% else %}
            {% set item_href = item_url(item) %}
            <li class="nav-item-classic">
              <a href="{{ item_href }}" class="nav-link-classic {{ is_active(item_href) ? 'active' : '' }}">{{ item.label }}</a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </nav>

    <div class="ml-auto flex items-center gap-3">
      {% if user_name is defined %}
        <div class="relative">
          <button class="px-3 py-2 rounded-md border text-sm font-medium flex items-center gap-2" id="member-menu-toggle">
            <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 15c2.5 0 4.847.59 6.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="hidden sm:inline">{{ user_name }}</span>
          </button>
          <div class="absolute right-0 mt-2 w-48 bg-white border rounded-md shadow-lg hidden" id="member-menu">
            <a href="{{ url('member/dashboard') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Mon espace</a>
            <form action="{{ url('member/logout') }}" method="POST" class="px-4 py-2">
              <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
              <button type="submit" class="w-full text-left text-sm text-red-600">Se déconnecter</button>
            </form>
          </div>
        </div>
      {% else %}
        <a href="{{ url('member/login') }}" class="px-4 py-2 rounded-md border text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">Se connecter</a>
      {% endif %}
    </div>

    <button id="mobile-menu-toggle"
            class="md:hidden ml-auto p-2 rounded-md border transition focus:outline-none focus:ring-2 focus:ring-[var(--primary)]"
            aria-label="Ouvrir le menu"
            aria-expanded="false"
            aria-controls="mobile-menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>
</header>
