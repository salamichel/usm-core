{% extends "base.twig" %}

{% block title %}Connexion - Espace Adhérent{% endblock %}

{% block content %}
<div class="min-h-[70vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-3xl shadow-sm border border-slate-100">
        <div>
            <h2 class="mt-2 text-center text-3xl font-extrabold text-slate-900 font-serif">
                Espace Adhérent
            </h2>
            <p class="mt-2 text-center text-sm text-slate-500">
                Connectez-vous pour gérer votre agenda et accéder à l'intranet.
            </p>
        </div>

        {% if flash.error %}
            <div class="bg-rose-50 border-l-4 border-rose-500 p-4 mb-4 rounded-r-xl">
                <p class="text-sm text-rose-700 font-semibold">{{ flash.error }}</p>
            </div>
        {% endif %}
        {% if flash.success %}
            <div class="bg-emerald-50 border-l-4 border-emerald-500 p-4 mb-4 rounded-r-xl">
                <p class="text-sm text-emerald-700 font-semibold">{{ flash.success }}</p>
            </div>
        {% endif %}

        <form class="mt-8 space-y-6" action="{{ url('member/login') }}" method="POST">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            
            <div class="space-y-4">
                <div>
                    <label for="id_email" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Adresse email</label>
                    <input id="id_email" name="Id" type="email" required 
                           class="w-full px-3.5 py-3 border border-slate-200 rounded-xl text-slate-800 focus:border-[var(--primary)] focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 transition-all text-sm" 
                           placeholder="nom@exemple.com">
                </div>
                <div>
                    <label for="id_password" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Mot de passe</label>
                    <input id="id_password" name="IdPassword" type="password" required 
                           class="w-full px-3.5 py-3 border border-slate-200 rounded-xl text-slate-800 focus:border-[var(--primary)] focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 transition-all text-sm" 
                           placeholder="••••••••">
                </div>
            </div>

            <div>
                <button type="submit" class="group relative w-full flex justify-center py-3.5 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-[var(--primary)] hover:bg-[var(--primary)]/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 transition-all">
                    Se connecter
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}