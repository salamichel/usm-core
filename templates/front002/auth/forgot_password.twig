{% extends "base.twig" %}

{% block title %}Mot de passe oublié - Espace Adhérent{% endblock %}

{% block content %}
<div class="min-h-[70vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-3xl shadow-sm border border-slate-100">
        <div>
            <h2 class="mt-2 text-center text-3xl font-extrabold text-slate-900 font-serif">
                Récupération
            </h2>
            <p class="mt-2 text-center text-sm text-slate-500">
                Saisissez votre adresse email pour recevoir vos identifiants actuels.
            </p>
        </div>

        <form class="mt-8 space-y-6" action="{{ url('member/forgot-password') }}" method="POST">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
            
            <div class="space-y-4">
                <div>
                    <label for="id_email" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Adresse email</label>
                    <input id="id_email" name="email" type="email" required 
                           class="w-full px-3.5 py-3 border border-slate-200 rounded-xl text-slate-800 focus:border-[var(--primary)] focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 transition-all text-sm" 
                           placeholder="nom@exemple.com">
                </div>
            </div>

            <div class="space-y-4">
                <button type="submit" class="group relative w-full flex justify-center py-3.5 px-4 border border-transparent text-sm font-bold rounded-xl text-white bg-[var(--primary)] hover:bg-[var(--primary)]/90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/20 transition-all shadow-sm">
                    Envoyer mes identifiants
                </button>
                
                <div class="text-center">
                    <a href="{{ url('member/login') }}" class="text-sm font-bold text-[var(--primary)] hover:text-[var(--primary)]/80 transition-colors">
                        Retour à la connexion
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}
