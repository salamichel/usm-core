{# templates/front002/_visitor_bottom_bar.twig #}
<nav class="fixed bottom-0 left-0 w-full bg-white/95 backdrop-blur-md border-t border-slate-200 z-50 md:hidden shadow-[0_-4px_12px_rgba(0,0,0,0.08)] pb-[env(safe-area-inset-bottom,0px)]">
    <div class="flex justify-between items-center h-16 px-4 relative">
        
        {# Onglet 1 : Accueil Public #}
        {% set v_url_1 = site_config.visitor_bottom_url_1|default('') %}
        {% set v_href_1 = (v_url_1 starts with 'http://' or v_url_1 starts with 'https://' or v_url_1 starts with '#' or v_url_1 starts with '/') ? v_url_1 : url(v_url_1) %}
        {% set is_active_1 = app.request.uri == '/' or (v_url_1 != '' and v_url_1 in app.request.uri) %}
        <a href="{{ v_href_1 }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_active_1 %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            {% include '_icon.twig' with {name: site_config.visitor_bottom_icon_1|default('home'), class: 'w-6 h-6 mb-0.5'} %}
            <span class="text-[10px] font-medium tracking-tight">{{ site_config.visitor_bottom_label_1|default('Accueil') }}</span>
        </a>

        {# Onglet 2 : Les Équipes #}
        {% set v_url_2 = site_config.visitor_bottom_url_2|default('equipes') %}
        {% set v_href_2 = (v_url_2 starts with 'http://' or v_url_2 starts with 'https://' or v_url_2 starts with '#' or v_url_2 starts with '/') ? v_url_2 : url(v_url_2) %}
        {% set is_equipes = v_url_2 != '' and v_url_2 in app.request.uri|default('') %}
        <a href="{{ v_href_2 }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_equipes %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            {% include '_icon.twig' with {name: site_config.visitor_bottom_icon_2|default('users'), class: 'w-6 h-6 mb-0.5'} %}
            <span class="text-[10px] font-medium tracking-tight">{{ site_config.visitor_bottom_label_2|default('Équipes') }}</span>
        </a>

        {# --- FLOATING ACTION BUTTON CENTRAL : CONNEXION --- #}
        {% set v_url_3 = site_config.visitor_bottom_url_3|default('member/login') %}
        {% set v_href_3 = (v_url_3 starts with 'http://' or v_url_3 starts with 'https://' or v_url_3 starts with '#' or v_url_3 starts with '/') ? v_url_3 : url(v_url_3) %}
        <div class="relative -top-5 z-50 flex justify-center w-16 flex-shrink-0">
            <a href="{{ v_href_3 }}" class="w-14 h-14 rounded-full bg-slate-900 text-white flex items-center justify-center shadow-[0_4px_10px_rgba(15,23,42,0.4)] hover:bg-slate-800 active:scale-90 transition-all duration-200 border-4 border-white" title="{{ site_config.visitor_bottom_label_3|default('Se connecter') }}">
                {% include '_icon.twig' with {name: site_config.visitor_bottom_icon_3|default('lock'), class: 'w-6 h-6'} %}
            </a>
        </div>

        {# Onglet 3 : Actualités / Blog #}
        {% set v_url_4 = site_config.visitor_bottom_url_4|default('blog') %}
        {% set v_href_4 = (v_url_4 starts with 'http://' or v_url_4 starts with 'https://' or v_url_4 starts with '#' or v_url_4 starts with '/') ? v_url_4 : url(v_url_4) %}
        {% set is_blog = v_url_4 != '' and v_url_4 in app.request.uri|default('') %}
        <a href="{{ v_href_4 }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_blog %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            {% include '_icon.twig' with {name: site_config.visitor_bottom_icon_4|default('newspaper'), class: 'w-6 h-6 mb-0.5'} %}
            <span class="text-[10px] font-medium tracking-tight">{{ site_config.visitor_bottom_label_4|default('Actus') }}</span>
        </a>

        {# Onglet 4 : Contact #}
        {% set v_url_5 = site_config.visitor_bottom_url_5|default('contact') %}
        {% set v_href_5 = (v_url_5 starts with 'http://' or v_url_5 starts with 'https://' or v_url_5 starts with '#' or v_url_5 starts with '/') ? v_url_5 : url(v_url_5) %}
        {% set is_contact = v_url_5 != '' and v_url_5 in app.request.uri|default('') %}
        <a href="{{ v_href_5 }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_contact %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            {% include '_icon.twig' with {name: site_config.visitor_bottom_icon_5|default('mail'), class: 'w-6 h-6 mb-0.5'} %}
            <span class="text-[10px] font-medium tracking-tight">{{ site_config.visitor_bottom_label_5|default('Contact') }}</span>
        </a>
        
    </div>
</nav>