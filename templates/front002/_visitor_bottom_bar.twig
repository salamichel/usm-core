{# templates/front002/_visitor_bottom_bar.twig #}
<nav class="fixed bottom-0 left-0 w-full bg-white/95 backdrop-blur-md border-t border-slate-200 z-50 md:hidden shadow-[0_-4px_12px_rgba(0,0,0,0.08)] pb-[env(safe-area-inset-bottom,0px)]">
    <div class="flex justify-between items-center h-16 px-4 relative">
        
        {# Onglet 1 : Accueil Public #}
        <a href="{{ url('') }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if app.request.uri == '/' %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            <svg class="w-6 h-6 mb-0.5" fill="{% if app.request.uri == '/' %}currentColor{% else %}none{% endif %}" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            <span class="text-[10px] font-medium tracking-tight">Accueil</span>
        </a>

        {# Onglet 2 : Les Équipes #}
        {% set is_equipes = 'equipes' in app.request.uri|default('') %}
        <a href="{{ url('equipes') }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_equipes %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            <span class="text-[10px] font-medium tracking-tight">Équipes</span>
        </a>

        {# --- FLOATING ACTION BUTTON CENTRAL : CONNEXION --- #}
        <div class="relative -top-5 z-50 flex justify-center w-16 flex-shrink-0">
            <a href="{{ url('member/login') }}" class="w-14 h-14 rounded-full bg-slate-900 text-white flex items-center justify-center shadow-[0_4px_10px_rgba(15,23,42,0.4)] hover:bg-slate-800 active:scale-90 transition-all duration-200 border-4 border-white" title="Se connecter">
                {# Icône Utilisateur / Cadenas #}
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
            </a>
        </div>

        {# Onglet 3 : Actualités / Blog #}
        {% set is_blog = 'blog' in app.request.uri|default('') %}
        <a href="{{ url('blog') }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_blog %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
            <span class="text-[10px] font-medium tracking-tight">Actus</span>
        </a>

        {# Onglet 4 : Contact #}
        {% set is_contact = 'contact' in app.request.uri|default('') %}
        <a href="{{ url('contact') }}" class="flex flex-col items-center justify-center w-14 py-1 active:scale-95 transition-all {% if is_contact %}text-[var(--primary)]{% else %}text-slate-400{% endif %}">
            <svg class="w-6 h-6 mb-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <span class="text-[10px] font-medium tracking-tight">Contact</span>
        </a>
        
    </div>
</nav>