<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=yes, maximum-scale=5">
  {% block pwa_meta %}{% endblock %}

  {# ── Google Analytics ── #}
  {% if site_config.google_analytics_id %}
    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ site_config.google_analytics_id }}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '{{ site_config.google_analytics_id }}');

      // Suivi de tous les clics
      document.addEventListener('click', function(event) {
        var target = event.target;
        var element = target.closest('a, button, [role="button"], input[type="submit"], input[type="button"]');
        var trackingTarget = element || target;

        var text = (trackingTarget.innerText || trackingTarget.value || trackingTarget.alt || '').trim().substring(0, 100);
        var tag = trackingTarget.tagName.toLowerCase();

        var params = {
          'element_text': text,
          'element_tag': tag,
          'element_id': trackingTarget.id || undefined,
          'element_class': trackingTarget.className || undefined,
          'page_location': window.location.href
        };

        if (tag === 'a' && trackingTarget.href) {
          params['link_url'] = trackingTarget.href;
        }

        gtag('event', 'click_tracking', params);
      });
    </script>
  {% endif %}

  {% set page_title = block('title')|trim %}
  <title>{{ page_title ?: 'USM Volley' }}</title>

  {# ── SEO ── #}
  {% if meta %}
    <meta name="description" content="{{ meta.description|truncate(160) }}">
    <meta name="robots" content="{{ meta.robots }}">
    {% if meta.canonical %}
      <link rel="canonical" href="{{ meta.canonical }}">
    {% else %}
      <link rel="canonical" href="{{ base_url ~ current_path }}">
    {% endif %}
  {% else %}
    <meta name="description" content="{{ 'Unions Salles Mios Volley-Ball — actualités, agenda et équipes.'|truncate(160) }}">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ base_url ~ current_path }}">
  {% endif %}

  {# ── Open Graph ── #}
  {% if meta %}
    <meta property="og:title" content="{{ meta.title }}">
    <meta property="og:description" content="{{ meta.description|truncate(160) }}">
    <meta property="og:type" content="{{ meta.ogType|default('website') }}">
    <meta property="og:url" content="{{ meta.canonical|default(base_url ~ current_path) }}">
    {% if meta.ogImage %}
      <meta property="og:image" content="{{ meta.ogImage }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="630">
      <meta property="og:image:type" content="image/jpeg">
    {% endif %}
    {% if meta.articlePublishedAt %}
      <meta property="article:published_time" content="{{ meta.articlePublishedAt }}">
    {% endif %}
    {% if meta.articleModifiedAt %}
      <meta property="article:modified_time" content="{{ meta.articleModifiedAt }}">
    {% endif %}
  {% else %}
    <meta property="og:title" content="{{ page_title ?: 'USM Volley' }}">
    <meta property="og:description" content="{{ 'Unions Salles Mios Volley-Ball — actualités, agenda et équipes.'|truncate(160) }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ base_url ~ current_path }}">
  {% endif %}

  <meta name="twitter:card" content="summary_large_image">
  {% if meta %}
    <meta name="twitter:title" content="{{ meta.title }}">
    <meta name="twitter:description" content="{{ meta.description|truncate(160) }}">
    {% if meta.ogImage %}
      <meta name="twitter:image" content="{{ meta.ogImage }}">
    {% endif %}
  {% else %}
    <meta name="twitter:title" content="{{ page_title ?: 'USM Volley' }}">
    <meta name="twitter:description" content="{{ 'Unions Salles Mios Volley-Ball — actualités, agenda et équipes.'|truncate(160) }}">
  {% endif %}

  {# ── JSON-LD ── #}
  {% if meta and meta.jsonLd %}
    {% for schema in meta.jsonLd %}
    <script type="application/ld+json">
      {{ json_encode_pretty(schema) }}
    </script>
    {% endfor %}
  {% endif %}

  {# ── Fonts ── #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&display=swap">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&display=swap">
  {% if site_config.font_family %}
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family={{ site_config.font_family|replace({' ': '+'}) }}:wght@300;400;500;600;700&display=swap">
  {% else %}
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap">
  {% endif %}

  {# ── Tailwind CDN + config (variables dynamiques via site_config) ── #}
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest" defer></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'usm-brown':   '{{ site_config.primary_color|default('#1d4ed8') }}',
            'brutal-gold': '{{ site_config.primary_color|default('#1d4ed8') }}'
          },
          fontFamily: {
            sans:  ['{{ site_config.font_family|default('Inter') }}', 'ui-sans-serif', 'system-ui', 'sans-serif'],
            serif: ['Playfair Display', 'Georgia', 'serif'],
          }
        }
      }
    }
  </script>

  <link rel="stylesheet" href="{{ asset('content-styles.css') }}?v={{ "now"|date("U") }}">
  <link rel="stylesheet" href="{{ asset(theme ~ '/frames.css') }}?v={{ "now"|date("U") }}">

  {# CSS vars dynamiques (dépendent de site_config, doivent rester inline) #}
  <style>
    :root {
      --primary:            {{ site_config.primary_color|default('#1d4ed8') }};
      --header-bg:          {{ site_config.header_bg_color|default('#ffffff') }};
      --header-text:        {{ site_config.header_text_color|default('#0f172a') }};
      --header-hover-bg:    {{ site_config.header_hover_bg_color|default(site_config.primary_color|default('#1d4ed8')) }};
      --header-hover-text:  {{ site_config.header_hover_text_color|default('#ffffff') }};
      --header-active-bg:   {{ site_config.header_active_bg_color|default(site_config.header_hover_bg_color|default(site_config.primary_color|default('#1d4ed8'))) }};
      --header-active-text: {{ site_config.header_active_text_color|default(site_config.header_hover_text_color|default('#ffffff')) }};
      --logo-bg:            {{ site_config.logo_bg_color|default('transparent') }};
      --logo-text:          {{ site_config.logo_text_color|default('#0f172a') }};
      --surface:            #ffffff;
      --surface-alt:        #f8fafc;
      --text:               #0f172a;
      --text-muted:         #64748b;
      --border:             #e2e8f0;
      --transition:         all 0.2s ease;
      --footer-bg:          {{ site_config.footer_bg_color|default('#0f172a') }};
      --footer-text:        {{ site_config.footer_text_color|default('#cbd5e1') }};
      --footer-heading:     {{ site_config.footer_heading_color|default('#ffffff') }};
      --header-h:           max(76px, calc({{ site_config.logo_height|default('40') }}px + 36px));
      --frame-dark-bg:      {{ site_config.frame_dark_bg_color|default('#0f172a') }};
    }
    body {
      color: var(--text);
      background: var(--surface);
      font-family: '{{ site_config.font_family|default('Inter') }}', ui-sans-serif, system-ui, sans-serif;
    }
    .header-inner { height: var(--header-h); }
    #mobile-menu:not(.hidden) { top: var(--header-h); max-height: calc(100vh - var(--header-h)); }
  </style>

  {% block head %}{% endblock %}

  <script src="{{ asset(theme ~ '/base.js') }}?v={{ "now"|date("U") }}" defer></script>
</head>
<body class="min-h-screen flex flex-col">

  {% include '_header.twig' %}
  {% include '_mobile_menu.twig' %}
  {% if app.session.LogIn %}
      {# Utilisateur connecté : Barre avec Dashboard, Stats, Agenda complet... #}
      {% include '_member_bottom_bar.twig' %}
  {% else %}
      {# Visiteur : Barre avec Infos du club et gros bouton de Connexion #}
      {% include '_visitor_bottom_bar.twig' %}
  {% endif %}
{% include '_flash.twig' %}

  {# ── Main ── #}
  <main class="flex-1 pb-24 md:pb-0">
    {% block content %}{% endblock %}
  </main>

  {% include '_footer.twig' %}

  {% block pwa_scripts %}{% endblock %}
  {% block scripts %}{% endblock %}
</body>
</html>
