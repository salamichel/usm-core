{% extends 'base.twig' %}
{% block title %}Documents — USM Volley{% endblock %}

{% block content %}
<div class="max-w-3xl mx-auto px-4 py-10">
  <h1 class="text-3xl font-black mb-6 border-b-4 border-black pb-3">Documents</h1>

  {% if documents|length %}
    {# Group by doc_type #}
    {% set types = [] %}
    {% for doc in documents %}
      {% if doc.doc_type not in types %}
        {% set types = types|merge([doc.doc_type]) %}
      {% endif %}
    {% endfor %}

    {% for type in types %}
      <section class="mb-8">
        <h2 class="text-xl font-bold mb-3 border-b-2 border-black pb-1">{{ type ?: 'Divers' }}</h2>
        <ul class="space-y-2">
          {% for doc in documents if doc.doc_type == type %}
          <li class="border-2 border-black bg-white p-3 shadow-[3px_3px_0_#000] flex items-center justify-between">
            <span class="font-semibold">{{ doc.title }}</span>
            <a href="{{ asset('uploads/' ~ doc.filename) }}"
               target="_blank"
               class="text-sm font-bold border-2 border-black px-3 py-1 hover:bg-black hover:text-white transition">
              Télécharger
            </a>
          </li>
          {% endfor %}
        </ul>
      </section>
    {% endfor %}
  {% else %}
    <p class="text-gray-500 italic">Aucun document disponible.</p>
  {% endif %}
</div>
{% endblock %}
