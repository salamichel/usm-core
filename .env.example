# Copier en .env et adapter

# ── Base locale ────────────────────────────────────────────────────────────────
DB_HOST=db
DB_NAME=usm_volley
DB_USER=usm
DB_PASS=usm_password

# ── Base externe (production : mettre les vraies valeurs IF0) ──────────────────
EXT_DB_HOST=db_external
EXT_DB_NAME=usm_external
EXT_DB_USER=usm_ext
EXT_DB_PASS=usm_ext_password

# ── Docker ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root_password

# ── Application ────────────────────────────────────────────────────────────────
# URL publique (sans slash final)
BASE_URL=http://localhost:8080

# Thème actif (dossier sous templates/)
THEME=front001

# Mode debug (false en production)
APP_DEBUG=true

# Admin — générer le hash : php -r "echo password_hash('MonMotDePasse', PASSWORD_BCRYPT);"
ADMIN_EMAIL=admin@usm-volley.fr
ADMIN_PASSWORD_HASH=$2y$12$...changez_ce_hash...

# ── Brevo (Service d'email) ────────────────────────────────────────────────────
# Clé API Brevo pour l'intégration du formulaire de contact
BREVO_API_KEY=your_brevo_api_key_here
BREVO_FROM_EMAIL=noreply@usm-volley.fr
BREVO_FROM_NAME=USM Volley
