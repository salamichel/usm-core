DJANGO_SECRET_KEY=change-me-with-python-secrets-token-hex-32
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,usm.moka-web.net
DJANGO_CSRF_TRUSTED_ORIGINS=https://usm.moka-web.net

# Laisser vide pour SQLite (mode dev rapide) ou :
# DATABASE_URL=postgresql://usm:usm_password@localhost:5432/usm_volley

DEFAULT_FROM_EMAIL=noreply@usmvolley.fr
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# HelloAsso — Credentials depuis le dashboard HelloAsso
#   PRODUCTION : https://api.helloasso.com (client_id/secret à générer là-bas)
#   SANDBOX (dev/test) : https://api.helloasso-sandbox.com (credentials sandbox séparées)
# Génération de tokens :
#   Production : https://api.helloasso.com/oauth2
#   Sandbox : https://api.helloasso-sandbox.com/oauth2
# Notifications (webhook) :
#   Onglet "Notifications" → créer endpoint → copier le secret généré
HELLOASSO_API_HOST=https://api.helloasso.com/v5
# Pour sandbox, remplacer par : HELLOASSO_API_HOST=https://api.helloasso-sandbox.com/v5
HELLOASSO_CLIENT_ID=
HELLOASSO_CLIENT_SECRET=
HELLOASSO_WEBHOOK_SECRET=
HELLOASSO_ORGANIZATION_SLUG=usm-volley

# Brevo — Emails transactionnels
# Clé API depuis https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
# ID des templates transactionnels à créer dans Brevo
BREVO_TEMPLATE_ADHESION_CREATED=1
BREVO_TEMPLATE_PAYMENT_CONFIRMED=2
