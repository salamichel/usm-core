// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Énumérations
enum Role {
  ADHERENT
  ENTRAINEUR
  BUREAU
}

enum Gender {
  MASCULIN
  FEMININ
  AUTRE
}

enum CategorieAdhesion {
  SANS_COMPETITION
  COMPETITION_VOLLEY
  COMPETLIB
  COMPETITION_DEP
}

enum StatutPaiement {
  EN_ATTENTE
  VALIDÉ
  REMBOURSÉ
}

enum TypeDocument {
  FACTURE
  CERTIFICAT
  REGLEMENTAIRE
  AUTRE
}

enum PermissionDocument {
  PUBLIC
  GROUPE_RESTREINT
  ADHERENTS_ONLY
  BUREAU_ONLY
}

// Modèle User (Adhérent, Entraîneur, Bureau)
model User {
  id                    Int       @id @default(autoincrement())
  email                 String    @unique
  firstName             String
  lastName              String
  dateOfBirth           DateTime
  gender                Gender    @default(AUTRE)
  phone                 String?
  address               String
  city                  String
  zipCode               String
  emergencyContact      String?
  emergencyPhone        String?
  hashedPassword        String
  role                  Role      @default(ADHERENT)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  adhesions             Adhesion[]
  equipes               Equipe_Groupe[]
}

// Modèle Saison
model Saison {
  id                    Int       @id @default(autoincrement())
  label                 String    @unique
  isActive              Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  adhesions             Adhesion[]
  equipes               Equipe_Groupe[]
}

// Modèle Adhesion (Junction table User + Saison avec données supplémentaires)
model Adhesion {
  id                    Int       @id @default(autoincrement())
  userId                Int
  saisonId              Int
  categorieAdhesion     CategorieAdhesion
  montant               Decimal   @db.Decimal(10, 2)
  statutPaiement        StatutPaiement @default(EN_ATTENTE)
  transactionId         String?
  preferences           Json?     // JSONB: indisponibilités, souhaits équipes, choix coupes
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  saison                Saison    @relation(fields: [saisonId], references: [id], onDelete: Cascade)

  @@unique([userId, saisonId])
  @@index([userId])
  @@index([saisonId])
}

// Modèle Equipe_Groupe
model Equipe_Groupe {
  id                    Int       @id @default(autoincrement())
  nom                   String
  slug                  String    @unique
  categorie             CategorieAdhesion
  saisonId              Int
  description           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  saison                Saison    @relation(fields: [saisonId], references: [id], onDelete: Cascade)
  joueurs               User[]
  documents             Document[]

  @@index([saisonId])
  @@index([slug])
}

// Modèle Document (Fichiers sécurisés)
model Document {
  id                    Int       @id @default(autoincrement())
  titre                 String
  cheminServeur         String
  type                  TypeDocument
  permission            PermissionDocument @default(BUREAU_ONLY)
  equipeGroupeId        Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  equipeGroupe          Equipe_Groupe? @relation(fields: [equipeGroupeId], references: [id], onDelete: SetNull)

  @@index([equipeGroupeId])
  @@index([permission])
}

// Modèle Post (Articles blog)
model Post {
  id                    Int       @id @default(autoincrement())
  titre                 String
  slug                  String    @unique
  contenu               String    @db.Text
  categorie             String
  datePublication       DateTime
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([slug])
  @@index([categorie])
  @@index([datePublication])
}

// Modèle Event (Événements & Galeries)
model Event {
  id                    Int       @id @default(autoincrement())
  titre                 String
  description           String?
  dateEvenement         DateTime
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  photos                Photo[]

  @@index([dateEvenement])
}

// Modèle Photo (Galerie d'images)
model Photo {
  id                    Int       @id @default(autoincrement())
  chemin                String
  alt                   String?
  eventId               Int
  tags_equipes          String[]  @default([])
  createdAt             DateTime  @default(now())

  // Relations
  event                 Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}
